# =============================================================================
# LOCAL: copy to .env in project root
# RENDER: Dashboard → Web Service → Environment → "Add from .env" or add each row
# =============================================================================

# --- Required for login / MongoDB ---
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/cliant_db?retryWrites=true&w=majority

# --- App (optional on Render — Render sets PORT automatically) ---
NODE_ENV=production
PORT=3000

# --- Session (not wired in server.js yet; safe to set for future use) ---
SESSION_SECRET=change-this-to-a-long-random-string
SECRET_KEY=change-this-secret

# --- MongoDB parts (optional — app uses MONGODB_URI only) ---
DB_USER=your_atlas_user
DB_PASSWORD=your_atlas_password
DB_NAME=cliant_db
DB_HOST=cluster0.xxxxx.mongodb.net
DB_PORT=27017

# --- M-Pesa (only if you use payments on production) ---
# MPESA_CONSUMER_KEY=
# MPESA_CONSUMER_SECRET=
# MPESA_SHORTCODE=
# MPESA_PASSKEY=
# MPESA_CALLBACK_URL=https://YOUR-SERVICE.onrender.com/api/mpesa/callback

# --- Pesapal (sandbox / production) ---
PESAPAL_ENVIRONMENT=sandbox
PESAPAL_CONSUMER_KEY=YOUR_PESAPAL_CONSUMER_KEY
PESAPAL_CONSUMER_SECRET=YOUR_PESAPAL_CONSUMER_SECRET
