<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Membership - <%= group ? group.groupName : 'Group' %></title>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    :root {
      --bg:        #f1f5f9;
      --surface:   #ffffff;
      --card:      #f8fafc;
      --border:    #e2e8f0;
      --primary:   #0f9d58;
      --primary-dk:#0b7d46;
      --accent:    #f59e0b;
      --text:      #1e293b;
      --muted:     #64748b;
      --faint:     #94a3b8;
      --radius:    14px;
      --radius-sm: 8px;
      --shadow:    0 4px 20px rgba(0,0,0,0.1);
      --focus-ring:rgba(15,157,88,0.15);
      --danger:    #ef4444;
    }
 
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
 
    body {
      font-family: 'DM Sans', sans-serif;
      background: linear-gradient(160deg, #0f2027, #203a43, #2c5364);
      min-height: 100vh;
      font-size: 15px;
      display: flex;
      justify-content: center;
      align-items: flex-start;
      padding: 2px;
      color: var(--text);
    }
 
    /* ── OUTER WRAPPER ── */
    .page-wrapper {
      width: calc(100% - 4px);
      max-width: 640px;
      background: var(--surface);
      border-radius: 5px;
      box-shadow: 0 25px 60px rgba(0,0,0,0.35);
      overflow: hidden;
      animation: slideUp .5s ease-out;
      min-height: calc(100vh - 4px);
      display: flex;
      flex-direction: column;
    }
    @keyframes slideUp {
      from { opacity: 0; transform: translateY(30px); }
      to   { opacity: 1; transform: translateY(0); }
    }
 
    /* ── HEADER ── */
    .header {
      background: linear-gradient(135deg, #0f9d58, #34d399);
      padding: 16px 20px;
      display: flex;
      align-items: center;
      gap: 14px;
      position: sticky;
      top: 0;
      z-index: 200;
      overflow: hidden;
    }
    .header::before {
      content: '';
      position: absolute;
      top: -50%; right: -20%;
      width: 200px; height: 200px;
      background: rgba(255,255,255,.08);
      border-radius: 50%;
      pointer-events: none;
    }
    .header-back {
      width: 36px; height: 36px;
      border-radius: 50%;
      background: rgba(255,255,255,.18);
      border: 1px solid rgba(255,255,255,.3);
      display: flex; align-items: center; justify-content: center;
      color: #fff;
      text-decoration: none;
      font-size: 14px;
      flex-shrink: 0;
      transition: background .2s;
      position: relative;
    }
    .header-back:hover { background: rgba(255,255,255,.28); }
    .header-title {
      font-family: 'Syne', sans-serif;
      font-size: 17px;
      font-weight: 700;
      color: #fff;
      letter-spacing: -0.3px;
      position: relative;
    }
    .header-subtitle {
      font-size: 12px;
      color: rgba(255,255,255,.85);
      font-weight: 500;
      margin-top: 1px;
      position: relative;
    }
    .header-badge {
      margin-left: auto;
      background: rgba(255,255,255,.2);
      border: 1px solid rgba(255,255,255,.35);
      color: #fff;
      border-radius: 20px;
      padding: 4px 10px;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: .3px;
      position: relative;
      white-space: nowrap;
    }
 
    /* ── CONTENT ── */
    .content { padding: 20px; flex: 1; background: var(--bg); }
 
    /* ── IDENTITY CARD ── */
    .id-card {
      background: linear-gradient(135deg, #f0fdf4, #eff6ff);
      border-radius: var(--radius);
      padding: 20px;
      margin-bottom: 18px;
      position: relative;
      overflow: hidden;
      box-shadow: var(--shadow);
      border: 1px solid #bbf7d0;
    }
    .id-card::before {
      content: '';
      position: absolute;
      top: -30px; right: -30px;
      width: 120px; height: 120px;
      border-radius: 50%;
      background: rgba(15,157,88,.08);
      pointer-events: none;
    }
    .id-card::after {
      content: '';
      position: absolute;
      bottom: -40px; right: 20px;
      width: 80px; height: 80px;
      border-radius: 50%;
      background: rgba(245,158,11,.06);
      pointer-events: none;
    }
    .id-card-top {
      display: flex;
      align-items: center;
      gap: 14px;
      margin-bottom: 16px;
    }
    .id-avatar {
      width: 52px; height: 52px;
      border-radius: 50%;
      background: linear-gradient(135deg, #0f9d58, #34d399);
      display: flex; align-items: center; justify-content: center;
      font-family: 'Syne', sans-serif;
      font-size: 18px;
      font-weight: 800;
      color: #fff;
      flex-shrink: 0;
      box-shadow: 0 0 0 3px rgba(15,157,88,.2);
    }
    .id-info { flex: 1; min-width: 0; }
    .id-name {
      font-family: 'Syne', sans-serif;
      font-size: 16px;
      font-weight: 700;
      color: var(--text);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .id-phone { font-size: 12px; color: var(--muted); margin-top: 2px; }
    .id-status-chip {
      background: #dcfce7;
      border: 1px solid #86efac;
      color: #15803d;
      border-radius: 20px;
      padding: 4px 12px;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: .3px;
      white-space: nowrap;
    }
    .id-stats {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 10px;
    }
    .id-stat {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      padding: 10px 12px;
    }
    .id-stat-label {
      font-size: 9px;
      font-weight: 600;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: .7px;
      margin-bottom: 4px;
    }
    .id-stat-value {
      font-family: 'Syne', sans-serif;
      font-size: 14px;
      font-weight: 700;
      color: var(--text);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
 
    /* ── SECTION LABEL ── */
    .section-label {
      font-size: 10px;
      font-weight: 700;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 10px;
      margin-top: 22px;
    }
 
    /* ── ACTION GRID ── */
    .action-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
    }
    .action-grid.single { grid-template-columns: 1fr; }
 
    .action-btn {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 14px 16px;
      background: #fff;
      border: 1.5px solid var(--border);
      border-radius: var(--radius);
      color: var(--text);
      cursor: pointer;
      text-align: left;
      transition: background .2s, border-color .2s, box-shadow .2s, transform .1s;
      font-family: 'DM Sans', sans-serif;
      font-size: 13px;
      font-weight: 600;
      text-decoration: none;
    }
    .action-btn:active { transform: scale(.98); }
    .action-btn:hover {
      background: #f0fdf4;
      border-color: var(--primary);
      box-shadow: 0 2px 8px rgba(15,157,88,.12);
    }
    .action-btn.accent:hover {
      background: #fffbeb;
      border-color: var(--accent);
      box-shadow: 0 2px 8px rgba(245,158,11,.12);
    }
    .btn-icon {
      width: 34px; height: 34px;
      border-radius: var(--radius-sm);
      display: flex; align-items: center; justify-content: center;
      font-size: 14px;
      flex-shrink: 0;
    }
    .btn-icon.green  { background: #dcfce7; color: #15803d; }
    .btn-icon.blue   { background: #dbeafe; color: #1d4ed8; }
    .btn-icon.amber  { background: #fef3c7; color: #b45309; }
    .btn-icon.red    { background: #fee2e2; color: #b91c1c; }
    .btn-icon.violet { background: #ede9fe; color: #6d28d9; }
 
    .btn-text { flex: 1; min-width: 0; }
    .btn-label { display: block; }
    .btn-hint  { display: block; font-size: 10px; font-weight: 400; color: var(--muted); margin-top: 1px; }
    .btn-arrow { color: var(--faint); font-size: 11px; }
 
    /* ── MODALS ── */
    .overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,.55);
      z-index: 1000;
      overflow-y: auto;
      padding: 20px;
      backdrop-filter: blur(3px);
    }
    .overlay.open { 
      display: flex !important; 
      align-items: flex-start; 
      justify-content: center; 
    }
 
    .modal {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 12px;
      overflow: hidden;
      width: 100%;
      max-width: 460px;
      box-shadow: 0 20px 60px rgba(0,0,0,.25);
      animation: slideUp .25s ease;
      margin: auto;
    }
    @keyframes slideUp {
      from { opacity: 0; transform: translateY(24px); }
      to   { opacity: 1; transform: translateY(0); }
    }
 
    .modal-header {
      background: linear-gradient(135deg, #0f9d58, #34d399);
      padding: 14px 18px;
      display: flex;
      align-items: center;
      gap: 10px;
      position: sticky;
      top: 0;
      overflow: hidden;
    }
    .modal-header::before {
      content: '';
      position: absolute;
      top: -40%; right: -10%;
      width: 100px; height: 100px;
      background: rgba(255,255,255,.08);
      border-radius: 50%;
      pointer-events: none;
    }
    .modal-header-icon {
      width: 30px; height: 30px;
      border-radius: var(--radius-sm);
      display: flex; align-items: center; justify-content: center;
      font-size: 13px;
      background: rgba(255,255,255,.2);
      color: #fff;
      position: relative;
    }
    .modal-title {
      font-family: 'Syne', sans-serif;
      font-size: 15px;
      font-weight: 700;
      flex: 1;
      color: #fff;
      position: relative;
    }
    .modal-close {
      background: rgba(255,255,255,.2);
      border: none;
      color: #fff;
      width: 28px; height: 28px;
      border-radius: 50%;
      cursor: pointer;
      font-size: 15px;
      display: flex; align-items: center; justify-content: center;
      transition: background .2s;
      position: relative;
    }
    .modal-close:hover { background: rgba(255,255,255,.35); }
 
    .modal-body {
      padding: 18px;
      max-height: 70vh;
      overflow-y: auto;
      background: #fff;
    }
    .modal-body::-webkit-scrollbar { width: 4px; }
    .modal-body::-webkit-scrollbar-track { background: transparent; }
    .modal-body::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; }
 
    /* ── MEMBER LIST ── */
    .member-item {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px 14px;
      background: #f8fafc;
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      margin-bottom: 8px;
      transition: border-color .2s, background .2s;
    }
    .member-item:hover { background: #f0fdf4; border-color: #86efac; }
    .member-num {
      width: 28px; height: 28px;
      border-radius: 50%;
      background: #dcfce7;
      border: 1px solid #86efac;
      display: flex; align-items: center; justify-content: center;
      font-size: 11px;
      font-weight: 700;
      color: #15803d;
      flex-shrink: 0;
    }
    .member-details { flex: 1; min-width: 0; }
    .member-name {
      font-size: 13px;
      font-weight: 600;
      color: var(--text);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .member-phone { font-size: 11px; color: var(--muted); margin-top: 1px; }
    .role-chip {
      font-size: 10px;
      font-weight: 700;
      padding: 3px 9px;
      border-radius: 20px;
      letter-spacing: .3px;
      white-space: nowrap;
    }
    .chip-green  { background: #dcfce7; color: #15803d;  border: 1px solid #86efac; }
    .chip-blue   { background: #dbeafe; color: #1d4ed8;  border: 1px solid #93c5fd; }
    .chip-amber  { background: #fef3c7; color: #b45309;  border: 1px solid #fcd34d; }
 
/* ── FORM FIELDS ── */
    .field { margin-bottom: 14px; }
    .field label {
      display: block;
      font-size: 11px;
      font-weight: 700;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: .5px;
      margin-bottom: 6px;
    }
    .field input,
    .field textarea {
      width: 100%;
      padding: 12px 14px;
      background: #fff;
      border: 1.5px solid var(--border);
      border-radius: var(--radius-sm);
      color: var(--text);
      font-family: 'DM Sans', sans-serif;
      font-size: 14px;
      outline: none;
      transition: border-color .2s, box-shadow .2s;
    }
    .field input:focus,
    .field textarea:focus {
      border-color: var(--primary);
      box-shadow: 0 0 0 4px var(--focus-ring);
    }
    .field textarea { resize: none; }
    ::placeholder { color: var(--faint); }
 
    .submit-btn {
      width: 100%;
      padding: 13px;
      background: linear-gradient(135deg, #0f9d58, #34d399);
      color: #fff;
      border: none;
      border-radius: var(--radius-sm);
      font-family: 'Syne', sans-serif;
      font-size: 14px;
      font-weight: 700;
      cursor: pointer;
      transition: opacity .2s, transform .1s;
      letter-spacing: .3px;
    }
    .submit-btn:hover { opacity: .9; }
    .submit-btn:active { transform: scale(.98); }
 
    /* ── EMPTY / LOADING ── */
    .empty-state {
      text-align: center;
      padding: 36px 20px;
      color: var(--faint);
    }
    .empty-state i { font-size: 32px; margin-bottom: 10px; display: block; color: #cbd5e1; }
    .empty-state p { font-size: 13px; }
 
    /* ── DIVIDER ── */
    .divider { height: 1px; background: var(--border); margin: 18px 0; }
 
    /* Mobile tweaks */
    @media (max-width: 380px) {
      .id-stats { grid-template-columns: 1fr 1fr; }
      .action-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
<div class="page-wrapper">
 
  <!-- ── HEADER ── -->
  <div class="header">
    <a href="/general/group/<%= encodeURIComponent(group.groupName) %>" class="header-back">
      <i class="fas fa-arrow-left"></i>
    </a>
    <div>
      <div class="header-title">Membership</div>
      <div class="header-subtitle"><%= group.groupName || 'Group' %></div>
    </div>
    <div class="header-badge"><i class="fas fa-circle" style="font-size:7px; margin-right:4px;"></i>Active</div>
  </div>
   
  <div class="content">
   
    <!-- ── IDENTITY CARD ── -->
    <div class="id-card">
      <div class="id-card-top">
        <div class="id-avatar" id="avatarInitial">?</div>
        <div class="id-info">
          <div class="id-name"><%= member ? (member.name || member.memberId) : memberPhone %></div>
          <div class="id-phone"><%= memberPhone %></div>
        </div>
        <div class="id-status-chip">Active</div>
      </div>
      <div class="id-stats">
        <div class="id-stat">
          <div class="id-stat-label">Index</div>
          <div class="id-stat-value"><%= memberIndex || '—' %></div>
        </div>
        <div class="id-stat">
          <div class="id-stat-label">Role</div>
          <div class="id-stat-value">Member</div>
        </div>
        <div class="id-stat">
          <div class="id-stat-label">Account</div>
            <div class="id-stat-value" title="<%= accountNumber || '' %>"><%= accountNumber || '—' %></div>
          </div>
        </div>
      </div>
  
      <!-- ── QUICK ACTIONS ── -->
      <div class="section-label">Quick Actions</div>
      <div class="action-grid">
  
        <button class="action-btn" onclick="showOfficials()">
          <div class="btn-icon blue"><i class="fas fa-user-tie"></i></div>
          <div class="btn-text">
            <span class="btn-label">Officials</span>
            <span class="btn-hint">View group leaders</span>
          </div>
          <i class="fas fa-chevron-right btn-arrow"></i>
        </button>
  
        <button class="action-btn" onclick="showTrustrees()">
          <div class="btn-icon green"><i class="fas fa-users"></i></div>
          <div class="btn-text">
            <span class="btn-label">Trustees</span>
            <span class="btn-hint">Legal representatives</span>
          </div>
          <i class="fas fa-chevron-right btn-arrow"></i>
        </button>
  
      </div>
  
      <div class="divider"></div>
  
      <div class="action-grid single">
  
<button class="action-btn accent" onclick="showAddMemberRequest()">
          <div class="btn-icon violet"><i class="fas fa-user-plus"></i></div>
          <div class="btn-text">
            <span class="btn-label">Request to Add Member</span>
            <span class="btn-hint">Submit a membership request</span>
          </div>
          <i class="fas fa-chevron-right btn-arrow"></i>
        </button>

        <button type="button" class="action-btn accent" onclick="showRoleChangeRequestModal()" style="margin-top:10px; background:#ede9fe; border-color:#c4b5fd;">
          <div class="btn-icon violet"><i class="fas fa-user-tie"></i></div>
          <div class="btn-text">
            <span class="btn-label">Request Role Change</span>
            <span class="btn-hint">Request official or trustee appointment</span>
          </div>
          <i class="fas fa-chevron-right btn-arrow"></i>
        </button>
   
        <button type="button" class="action-btn accent" onclick="var el = document.getElementById('terminationOverlay'); if(el){el.classList.add('open');el.style.display='flex';}" style="margin-top:10px; background:#fef2f2; border-color:#fecaca;">
          <div class="btn-icon red"><i class="fas fa-user-slash"></i></div>
          <div class="btn-text">
            <span class="btn-label">Request Termination</span>
            <span class="btn-hint">Terminate membership contract</span>
          </div>
          <i class="fas fa-chevron-right btn-arrow"></i>
        </button>

        <button type="button" class="action-btn accent" onclick="showConstitutionDetails()" style="margin-top:10px; background:#f0fdf4; border-color:#86efac;">
          <div class="btn-icon green"><i class="fas fa-file-contract"></i></div>
          <div class="btn-text">
            <span class="btn-label">Group Constitution</span>
            <span class="btn-hint">View group principles</span>
          </div>
          <i class="fas fa-chevron-right btn-arrow"></i>
        </button>
  
      </div>
  
    </div>
  
    <!-- ══════════════════════════════════
         OFFICIALS MODAL
    ══════════════════════════════════ -->
    <div id="officialsOverlay" class="overlay">
      <div class="modal">
        <div class="modal-header">
          <div class="modal-header-icon btn-icon blue"><i class="fas fa-user-tie"></i></div>
          <div class="modal-title">Group Officials</div>
          <button class="modal-close" onclick="closeModal('officialsOverlay')">
            <i class="fas fa-times"></i>
          </button>
        </div>
        <div class="modal-body">
          <div id="officialsList">
            <div class="empty-state"><i class="fas fa-spinner fa-spin"></i><p>Loading officials…</p></div>
          </div>
        </div>
      </div>
    </div>
  
    <!-- ══════════════════════════════════
         TRUSTEES MODAL
    ══════════════════════════════════ -->
    <div id="trustreesOverlay" class="overlay">
      <div class="modal">
        <div class="modal-header">
          <div class="modal-header-icon btn-icon green"><i class="fas fa-users"></i></div>
          <div class="modal-title">Group Trustees</div>
          <button class="modal-close" onclick="closeModal('trustreesOverlay')">
            <i class="fas fa-times"></i>
          </button>
        </div>
        <div class="modal-body">
          <div id="trustreesList">
            <div class="empty-state"><i class="fas fa-spinner fa-spin"></i><p>Loading trustees…</p></div>
          </div>
        </div>
      </div>
    </div>
  
    <!-- ══════════════════════════════════
         ADD MEMBER MODAL
    ══════════════════════════════════ -->
    <div id="addMemberOverlay" class="overlay">
      <div class="modal">
        <div class="modal-header">
          <div class="modal-header-icon btn-icon violet"><i class="fas fa-user-plus"></i></div>
          <div class="modal-title">Request to Add Member</div>
          <button class="modal-close" onclick="closeModal('addMemberOverlay')">
            <i class="fas fa-times"></i>
          </button>
        </div>
        <div class="modal-body">
          <div class="field">
            <label>Full Name</label>
            <input type="text" id="newMemberName" placeholder="Enter full name">
          </div>
          <div class="field">
            <label>Phone Number</label>
            <input type="tel" id="newMemberPhone" placeholder="Enter phone number">
          </div>
          <div class="field">
            <label>Reason for Request</label>
            <textarea id="memberReason" rows="3" placeholder="Explain why this member should be added"></textarea>
          </div>
          <button class="submit-btn" onclick="submitAddMemberRequest()">
            <i class="fas fa-paper-plane" style="margin-right:6px;"></i>Submit Request
          </button>
        </div>
      </div>
    </div>
  
    <!-- ══════════════════════════════════
         TERMINATION REQUEST MODAL
    ══════════════════════════════════ -->
    <div id="terminationOverlay" class="overlay">
      <div class="modal">
        <div class="modal-header" style="background: linear-gradient(135deg, #0f9d58, #34d399);">
          <div class="modal-header-icon btn-icon green"><i class="fas fa-user-slash"></i></div>
          <div class="modal-title">Request Membership Termination</div>
          <button class="modal-close" onclick="closeModal('terminationOverlay')">
            <i class="fas fa-times"></i>
          </button>
        </div>
        <div class="modal-body">
          <div style="background:#fef3c7; border:1px solid #fde68a; border-radius:8px; padding:12px; margin-bottom:14px;">
            <p style="font-size:12px; color:#92400e; margin:0;">
              <i class="fas fa-exclamation-triangle" style="margin-right:6px;"></i>
              This action will request the group officials/trustees to terminate your membership contract. This action cannot be undone.
            </p>
          </div>
          <div class="field">
            <label>Reason for Termination</label>
            <textarea id="terminationReason" rows="4" placeholder="Explain your reason for leaving the group..."></textarea>
          </div>
          <div class="field">
            <label>Final Settlement Preference</label>
            <select id="settlementPreference" class="form-input" style="padding:12px;">
              <option value="">-- Select Option --</option>
              <option value="withdraw">Withdraw all savings & shares</option>
              <option value="transfer">Transfer to another group</option>
              <option value="hold">Hold account until future date</option>
            </select>
          </div>
          <button class="submit-btn" style="background:linear-gradient(135deg, #0f9d58, #34d399);" onclick="submitTerminationRequest()">
            <i class="fas fa-paper-plane" style="margin-right:6px;"></i>Submit Termination Request
          </button>
        </div>
      </div>
    </div>

    <!-- ══════════════════════════════════
         CONSTITUTION DETAILS MODAL
    ══════════════════════════════════ -->
    <div id="constitutionOverlay" class="overlay">
      <div class="modal">
        <div class="modal-header" style="background: linear-gradient(135deg, #0f9d58, #34d399);">
          <div class="modal-header-icon btn-icon green"><i class="fas fa-file-contract"></i></div>
          <div class="modal-title">Group Constitution</div>
          <button type="button" class="modal-close" onclick="closeModal('constitutionOverlay')">
            <i class="fas fa-times"></i>
          </button>
        </div>
        <div class="modal-body" id="constitutionBody">
          <div class="empty-state"><i class="fas fa-spinner fa-spin"></i><p>Loading constitution...</p></div>
        </div>
      </div>
    </div>

  <script>
    /* ── SERVER DATA (EJS-injected; safe fallbacks for static preview) ── */
    const groupName       = (function(){ try{ return '<%= group ? group.groupName : "" %>'; } catch(e){ return ''; } })();
    const memberPhone     = (function(){ try{ return '<%= memberPhone %>'; } catch(e){ return ''; } })();
 
    /* ── AVATAR INITIAL ── */
    (function() {
      try {
        const name = '<%= member ? (member.name || member.memberId) : memberPhone %>';
        const initial = (name && name.trim().length) ? name.trim()[0].toUpperCase() : '?';
        document.getElementById('avatarInitial').textContent = initial;
      } catch(e) {}
    })();
 
/* ── MODAL HELPERS ── */
    function closeModal(id) {
      var el = document.getElementById(id);
      if (el) {
        el.classList.remove('open');
        el.style.display = 'none';
      }
    }
    document.querySelectorAll('.overlay').forEach(el => {
      el.addEventListener('click', e => { if (e.target === el) el.classList.remove('open'); });
    });
    
    /* ── OFFICIALS / TRUSTREES ── */
    function showOfficials() {
      document.getElementById('officialsOverlay').classList.add('open');
      loadGroupData('officialsList', 'official');
    }
    function showTrustrees() {
      document.getElementById('trustreesOverlay').classList.add('open');
      loadGroupData('trustreesList', 'trustree');
    }
 
    function loadGroupData(containerId, filterRole) {
      const container = document.getElementById(containerId);
      fetch('/member/group-by-name', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ groupName })
      })
      .then(r => r.json())
      .then(data => {
        if (!data || !data.members) {
          container.innerHTML = '<div class="empty-state"><i class="fas fa-exclamation-circle"></i><p>No data available</p></div>';
          return;
        }
        const filtered = Object.entries(data.members).filter(([, m]) =>
          (m.role || '').toLowerCase().includes(filterRole)
        );
        if (!filtered.length) {
          container.innerHTML = '<div class="empty-state"><i class="fas fa-user-slash"></i><p>No ' + filterRole + 's found</p></div>';
          return;
        }
        container.innerHTML = filtered.map(([phone, m], i) => {
          const name = m.name || m.memberId || phone;
          const role = m.role || 'Member';
          const chipClass = filterRole === 'official' ? 'chip-blue' : 'chip-green';
          return '<div class="member-item">' +
            '<div class="member-num">' + (i + 1) + '</div>' +
            '<div class="member-details">' +
              '<div class="member-name">' + name + '</div>' +
              '<div class="member-phone">' + phone + '</div>' +
            '</div>' +
            '<span class="role-chip ' + chipClass + '">' + role + '</span>' +
          '</div>';
        }).join('');
      })
      .catch(() => {
        container.innerHTML = '<div class="empty-state"><i class="fas fa-exclamation-circle"></i><p>Error loading data</p></div>';
      });
    }
 
    /* ── ADD MEMBER ── */
    function showAddMemberRequest() {
      document.getElementById('addMemberOverlay').classList.add('open');
    }
    async function submitAddMemberRequest() {
      const name   = document.getElementById('newMemberName').value.trim();
      const phone  = document.getElementById('newMemberPhone').value.trim();
      const reason = document.getElementById('memberReason').value.trim();
      if (!name)  { alert('Please enter member name'); return; }
      if (!phone) { alert('Please enter phone number'); return; }
      
      try {
        const res = await fetch('/member/request-add-member', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ 
            groupName: groupName, 
            requesterPhone: memberPhone,
            newMemberName: name, 
            newMemberPhone: phone, 
            reason: reason 
          })
        });
        const data = await res.json();
        if (data.success) {
          alert('Request submitted successfully!\n\nName: ' + name + '\nPhone: ' + phone + '\n\nPending approval from group officials.');
        } else {
          alert('Error: ' + (data.error || 'Failed to submit request'));
          return;
        }
      } catch (err) {
        alert('Error: ' + err.message);
        return;
      }
      
      closeModal('addMemberOverlay');
      ['newMemberName','newMemberPhone','memberReason'].forEach(id => document.getElementById(id).value = '');
    }
  
    /* ── TERMINATION REQUEST ── */
    function showTerminationRequest() {
      var el = document.getElementById('terminationOverlay');
      if (el) {
        el.classList.add('open');
        el.style.display = 'flex';
      } else {
        alert('Overlay not found');
      }
    }
    function submitTerminationRequest() {
      const reason = document.getElementById('terminationReason').value.trim();
      const settlement = document.getElementById('settlementPreference').value;
      
      if (!reason) {
        alert('Please provide a reason for termination');
        return;
      }
      if (!settlement) {
        alert('Please select a settlement preference');
        return;
      }
      
      if (!confirm('Are you sure you want to request membership termination? This action cannot be undone.')) {
        return;
      }
      
      const terminationData = {
        groupName: groupName,
        memberPhone: memberPhone,
        reason: reason,
        settlementPreference: settlement,
        requestDate: new Date().toISOString(),
        status: 'pending'
      };
      
      alert('Termination request submitted successfully!\n\nYour request will be reviewed by group officials. You will be notified of the outcome.');
      closeModal('terminationOverlay');
      document.getElementById('terminationReason').value = '';
      document.getElementById('settlementPreference').value = '';
    }

    /* ── CONSTITUTION DETAILS ── */
    function showConstitutionDetails() {
      var el = document.getElementById('constitutionOverlay');
      if (el) {
        el.classList.add('open');
        el.style.display = 'flex';
        loadConstitutionDetails();
      } else {
        alert('Error: Modal element not found');
      }
    }

    function loadConstitutionDetails() {
      const body = document.getElementById('constitutionBody');
      body.innerHTML = '<div class="empty-state"><i class="fas fa-spinner fa-spin"></i><p>Loading constitution...</p></div>';
      
      fetch('/member/group-by-name', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ groupName })
      })
      .then(r => {
        if (!r.ok) throw new Error('Network error: ' + r.status);
        return r.json();
      })
      .then(data => {
        if (!data || !data.principles) {
          body.innerHTML = '<div class="empty-state"><i class="fas fa-exclamation-circle"></i><p>No constitution data found. The group may not have completed constitution setup.</p></div>';
          return;
        }
        
        const p = data.principles;
        const intervals = p.intervals || {};
        const loans = p.loans || {};
        const governance = p.governance || {};
        const distribution = p.distribution || {};
        const contributions = p.otherContributions || [];
        
        let html = '';
        
        // Duration & Frequency
        html += '<div style="background:#f0fdf4; border:1px solid #bbf7d0; border-radius:8px; padding:12px; margin-bottom:12px;">';
        html += '<div style="font-size:11px; font-weight:700; color:#15803d; text-transform:uppercase; margin-bottom:8px;">Duration & Frequency</div>';
        html += '<div style="display:grid; grid-template-columns:1fr 1fr; gap:8px;">';
        html += '<div style="font-size:12px;"><span style="color:#64748b;">End Saving:</span> <span style="font-weight:600;">' + (intervals.endSavingPeriod || '—') + '</span></div>';
        html += '<div style="font-size:12px;"><span style="color:#64748b;">Frequency:</span> <span style="font-weight:600;">' + (intervals.frequency || '—') + '</span></div>';
        html += '<div style="font-size:12px;"><span style="color:#64748b;">Meeting Day:</span> <span style="font-weight:600;">' + (intervals.period || '—') + '</span></div>';
        html += '</div></div>';
        
        // Governance
        html += '<div style="background:#f8fafc; border:1px solid #e2e8f0; border-radius:8px; padding:12px; margin-bottom:12px;">';
        html += '<div style="font-size:11px; font-weight:700; color:#475569; text-transform:uppercase; margin-bottom:8px;">Governance</div>';
        html += '<div style="display:grid; grid-template-columns:1fr 1fr; gap:8px;">';
        html += '<div style="font-size:12px;"><span style="color:#64748b;">Fast Notify:</span> <span style="font-weight:600;">' + (governance.fastNotificationThreshold || '0') + '%</span></div>';
        html += '<div style="font-size:12px;"><span style="color:#64748b;">Edit Acct:</span> <span style="font-weight:600;">' + (governance.editAccountThreshold || '0') + '%</span></div>';
        html += '<div style="font-size:12px;"><span style="color:#64748b;">Remove Member:</span> <span style="font-weight:600;">' + (governance.memberRemovalThreshold || '0') + '%</span></div>';
        html += '</div></div>';
        
        // Loans
        const interest = loans.interestAndLimits || {};
        html += '<div style="background:#fef3c7; border:1px solid #fde68a; border-radius:8px; padding:12px; margin-bottom:12px;">';
        html += '<div style="font-size:11px; font-weight:700; color:#b45309; text-transform:uppercase; margin-bottom:8px;">Loan Policy</div>';
        html += '<div style="display:grid; grid-template-columns:1fr 1fr; gap:8px;">';
        html += '<div style="font-size:12px;"><span style="color:#64748b;">Interest:</span> <span style="font-weight:600;">' + (interest.interestRate || '0') + '%</span></div>';
        html += '<div style="font-size:12px;"><span style="color:#64748b;">Limit:</span> <span style="font-weight:600;">x' + (interest.limitMultiplier || '0') + '</span></div>';
        html += '<div style="font-size:12px;"><span style="color:#64748b;">Max Loans:</span> <span style="font-weight:600;">' + (interest.maxActiveLoans || '1') + '</span></div>';
        const repayment = loans.repayment || {};
        html += '<div style="font-size:12px;"><span style="color:#64748b;">Repay Days:</span> <span style="font-weight:600;">' + (repayment.durationDays || '0') + '</span></div>';
        html += '</div></div>';
        
        // Benefits
        html += '<div style="background:#fdf2f8; border:1px solid #fbcfe8; border-radius:8px; padding:12px; margin-bottom:12px;">';
        html += '<div style="font-size:11px; font-weight:700; color:#be185d; text-transform:uppercase; margin-bottom:8px;">Benefits Distribution</div>';
        html += '<div style="display:grid; grid-template-columns:1fr 1fr; gap:8px;">';
        html += '<div style="font-size:12px;"><span style="color:#64748b;">Model:</span> <span style="font-weight:600;">' + (distribution.model || '—') + '</span></div>';
        html += '<div style="font-size:12px;"><span style="color:#64748b;">Performance:</span> <span style="font-weight:600;">' + (distribution.performancePct || '0') + '%</span></div>';
        html += '<div style="font-size:12px;"><span style="color:#64748b;">Official %:</span> <span style="font-weight:600;">' + (distribution.officialPct || '0') + '%</span></div>';
        html += '<div style="font-size:12px;"><span style="color:#64748b;">Target Acct:</span> <span style="font-weight:600;">' + (distribution.targetAccountName || '—') + '</span></div>';
        html += '</div></div>';
        
        // Contributions
        if (contributions && contributions.length > 0) {
          html += '<div style="background:#eff6ff; border:1px solid #bfdbfe; border-radius:8px; padding:12px; margin-bottom:12px;">';
          html += '<div style="font-size:11px; font-weight:700; color:#1d4ed8; text-transform:uppercase; margin-bottom:8px;">Contributions</div>';
          contributions.forEach(c => {
            html += '<div style="display:flex; justify-content:space-between; font-size:12px; padding:4px 0; border-bottom:1px solid #e2e8f0;">';
            html += '<span style="font-weight:600;">' + (c.accountName || '—') + '</span>';
            html += '<span style="color:#15803d;">KES ' + (parseFloat(c.expectedAmount) || 0).toLocaleString() + '</span>';
            html += '</div>';
          });
          html += '</div>';
        }
        
        body.innerHTML = html;
      })
      .catch(err => {
        console.error('Constitution load error:', err);
        body.innerHTML = '<div class="empty-state"><i class="fas fa-exclamation-circle"></i><p>Error loading constitution: ' + err.message + '</p></div>';
      });
    }

    /* ── ROLE CHANGE REQUEST MODAL ── */
    async function showRoleChangeRequestModal() {
      const membersData = await fetch('/member/group-by-name', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ groupName })
      }).then(r => r.json()).catch(() => ({ members: {} }));
      
      const select = document.getElementById('roleChangeSelect');
      if (membersData && membersData.members) {
        let options = '<option value="">-- Select Member --</option>';
        Object.entries(membersData.members).forEach(([phone, m]) => {
          const role = m.role || 'member';
          options += '<option value="' + phone + '">' + (m.name || phone) + ' (' + role + ')</option>';
        });
        select.innerHTML = options;
      }
      document.getElementById('roleChangeOverlay').classList.add('open');
    }

    async function submitRoleChangeRequest() {
      const targetPhone = document.getElementById('roleChangeSelect').value;
      const newRole = document.getElementById('newRoleSelect').value;
      const reason = document.getElementById('roleChangeReason').value.trim();
      
      if (!targetPhone) { alert('Please select a member'); return; }
      if (!newRole) { alert('Please select a role'); return; }
      
      try {
        const res = await fetch('/member/request-role-change', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ 
            groupName, 
            requesterPhone: memberPhone,
            targetMemberPhone: targetPhone, 
            newRole: newRole, 
            reason: reason 
          })
        });
        const data = await res.json();
        if (data.success) {
          alert('Request submitted!');
        } else {
          alert('Error: ' + (data.error || 'Failed to submit request'));
        }
      } catch (err) {
        alert('Error: ' + err.message);
      }
      
      closeModal('roleChangeOverlay');
    }
  </script>

<!-- ROLE CHANGE REQUEST MODAL -->
<div id="roleChangeOverlay" class="overlay">
  <div class="modal">
    <div class="modal-header" style="background: linear-gradient(135deg, #7c3aed, #a78bfa);">
      <div class="modal-header-icon btn-icon violet"><i class="fas fa-user-tie"></i></div>
      <div class="modal-title">Request Role Change</div>
      <button class="modal-close" onclick="closeModal('roleChangeOverlay')">
        <i class="fas fa-times"></i>
      </button>
    </div>
    <div class="modal-body">
      <div class="field">
        <label>Select Member</label>
        <select id="roleChangeSelect">
          <option value="">-- Loading members --</option>
        </select>
      </div>
      <div class="field">
        <label>New Role</label>
        <select id="newRoleSelect">
          <option value="">-- Select Role --</option>
          <option value="official">Official</option>
          <option value="trustee">Trustee</option>
          <option value="secretary">Secretary</option>
          <option value="member">Member (Remove Role)</option>
        </select>
      </div>
      <div class="field">
        <label>Reason</label>
        <textarea id="roleChangeReason" rows="3" placeholder="Explain reason for role change..."></textarea>
      </div>
      <button class="submit-btn" style="background: linear-gradient(135deg, #7c3aed, #a78bfa);" onclick="submitRoleChangeRequest()">
        <i class="fas fa-paper-plane" style="margin-right:8px;"></i>Submit Request
      </button>
    </div>
  </div>
</div>
</div><!-- /page-wrapper -->
</body>
</html>