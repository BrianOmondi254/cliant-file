<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Member Verification</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <style>
        body {
            font-family: Arial, sans-serif;
            background: #f4f6f8;
            margin: 0;
            padding: 20px;
        }

        .container {
            max-width: 600px;
            margin: auto;
        }

        .card {
            background: #fff;
            padding: 20px;
            border-radius: 10px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        }

        .header-box {
            background: #eef2f7;
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 20px;
        }

        .header-box h3 {
            margin: 0 0 10px 0;
        }

        .row {
            display: flex;
            justify-content: space-between;
            margin-bottom: 8px;
        }

        .label {
            font-weight: bold;
            color: #555;
        }

        .value {
            color: #222;
        }

        .success {
            text-align: center;
            color: green;
            font-weight: bold;
            margin-top: 10px;
        }

        .member-box {
            margin-top: 15px;
        }

        .member-box h4 {
            margin-bottom: 10px;
        }

    </style>
</head>
<body>

<div class="container">
    <div class="card">

        <!-- TOP HEADER (Regional + Group Info) -->
        <div class="header-box">
            <h3>Regional Block: <%= member.regionalBlock %></h3>

            <div class="row">
                <div><span class="label">Group No:</span> <span class="value"><%= member.groupNo %></span></div>
                <div><span class="label">Group Type:</span> <span class="value"><%= member.groupType %></span></div>
            </div>

            <div class="row">
                <div><span class="label">Certificate:</span> <span class="value"><%= member.certificate %></span></div>
                <div><span class="label">Agent:</span> <span class="value"><%= member.agentName %></span></div>
            </div>

            <div class="row">
                <div><span class="label">Phone:</span> <span class="value"><%= member.phone %></span></div>
            </div>
        </div>

        <!-- MEMBER DETAILS -->
        <div class="member-box">
            <h4>Member Details</h4>

            <div class="row">
                <div><span class="label">Member No:</span> <span class="value"><%= member.mno %></span></div>
            </div>

            <!-- VERIFIED STATUS BELOW MEMBER NO -->
            <div class="success">
                Verified Successfully ✔
            </div>

            <div class="row">
                <div><span class="label">Name:</span> <span class="value"><%= member.name %></span></div>
            </div>

            <div class="row">
                <div><span class="label">ID Number:</span> <span class="value"><%= member.idNumber %></span></div>
            </div>

            <div class="row">
                <div><span class="label">Status:</span> <span class="value"><%= member.status %></span></div>
            </div>

        </div>

    </div>
</div>

</body>
</html>