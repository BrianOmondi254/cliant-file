<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>Group Performance | Agent Portal</title>
  
  <!-- Fonts & Icons -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  
  <!-- Chart.js -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

  <style>
    :root {
      /* Color Palette - Modern & Professional */
      --primary: #0f9d58;
      --primary-dark: #0b7d46;
      --primary-light: #ecfdf5;
      --secondary: #4285f4;
      --secondary-light: #e8f0fe;
      --accent: #5f9ea0;
      --dark: #1e293b;
      --slate: #64748b;
      --light: #f8fafc;
      --white: #ffffff;
      --danger: #ef4444;
      --danger-light: #fee2e2;
      --warning: #f59e0b;
      --warning-light: #fef3c7;
      --border: #e2e8f0;
      
      /* Shadows */
      --shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
      --shadow-lg: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
      
      /* Radius */
      --radius: 12px;
      --radius-sm: 8px;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }

    body {
      font-family: 'Inter', sans-serif;
      background-color: #f1f5f9;
      color: var(--dark);
      line-height: 1.5;
      min-height: 100vh;
      padding-bottom: 40px;
    }

    /* --- Layout --- */
    .app-container {
      max-width: 900px;
      margin: 0 auto;
      padding: 15px;
    }

    /* --- Header --- */
    .header {
      background: linear-gradient(135deg, var(--primary), #059669);
      color: var(--white);
      padding: 24px 20px;
      border-radius: var(--radius);
      box-shadow: var(--shadow-lg);
      margin-bottom: 24px;
      position: relative;
      overflow: hidden;
    }

    .header::before {
      content: '';
      position: absolute;
      top: -50%;
      right: -20%;
      width: 200px;
      height: 200px;
      background: rgba(255,255,255,0.1);
      border-radius: 50%;
    }

    .header-nav {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 12px;
    }

    .back-btn {
      background: rgba(255,255,255,0.2);
      border: none;
      color: white;
      width: 36px;
      height: 36px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: background 0.2s;
    }
    .back-btn:hover { background: rgba(255,255,255,0.3); }

    .header h1 {
      font-size: 24px;
      font-weight: 800;
      letter-spacing: -0.5px;
    }

    .header-subtitle {
      font-size: 12px;
      opacity: 0.9;
      text-transform: uppercase;
      letter-spacing: 1px;
      font-weight: 600;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    /* --- Cards & Containers --- */
    .card {
      background: var(--white);
      border-radius: var(--radius);
      padding: 20px;
      box-shadow: var(--shadow);
      margin-bottom: 20px;
      border: 1px solid var(--border);
      transition: transform 0.2s ease;
    }

    .card-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 16px;
      padding-bottom: 12px;
      border-bottom: 1px solid var(--border);
    }

    .card-title {
      font-size: 14px;
      font-weight: 700;
      color: var(--dark);
      text-transform: uppercase;
      letter-spacing: 0.5px;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .card-title i {
      width: 28px;
      height: 28px;
      border-radius: 6px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 12px;
    }

    /* --- Summary Grid --- */
    .summary-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
      margin-bottom: 20px;
    }

    .stat-card {
      background: var(--white);
      border-radius: var(--radius);
      padding: 16px;
      border: 1px solid var(--border);
      box-shadow: var(--shadow);
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      position: relative;
      overflow: hidden;
    }

    .stat-card::after {
      content: '';
      position: absolute;
      right: -10px;
      bottom: -10px;
      width: 60px;
      height: 60px;
      border-radius: 50%;
      opacity: 0.1;
      z-index: 0;
    }

    .stat-icon {
      width: 40px;
      height: 40px;
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 18px;
      margin-bottom: 12px;
      z-index: 1;
    }

    .stat-value {
      font-size: 20px;
      font-weight: 800;
      color: var(--dark);
      margin-bottom: 4px;
      z-index: 1;
    }

    .stat-label {
      font-size: 11px;
      color: var(--slate);
      font-weight: 600;
      text-transform: uppercase;
      z-index: 1;
    }

    /* Variants */
    .stat-green .stat-icon { background: var(--primary-light); color: var(--primary); }
    .stat-green::after { background: var(--primary); }
    
    .stat-blue .stat-icon { background: var(--secondary-light); color: var(--secondary); }
    .stat-blue::after { background: var(--secondary); }
    
    .stat-teal .stat-icon { background: #e0f2f1; color: var(--accent); }
    .stat-teal::after { background: var(--accent); }
    
    .stat-orange .stat-icon { background: var(--warning-light); color: var(--warning); }
    .stat-orange::after { background: var(--warning); }

    /* --- Tables --- */
    .table-responsive {
      overflow-x: auto;
      border-radius: var(--radius-sm);
      border: 1px solid var(--border);
    }

    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 12px;
      white-space: nowrap;
    }

    th {
      background: var(--light);
      padding: 12px 16px;
      text-align: left;
      font-weight: 700;
      color: var(--slate);
      text-transform: uppercase;
      font-size: 10px;
      letter-spacing: 0.5px;
      border-bottom: 1px solid var(--border);
    }

    td {
      padding: 12px 16px;
      border-bottom: 1px solid var(--border);
      color: var(--dark);
    }

    tr:last-child td { border-bottom: none; }
    tr:hover { background-color: #f8fafc; }

    .text-right { text-align: right; }
    .font-bold { font-weight: 700; }
    .text-green { color: var(--primary); }
    .text-red { color: var(--danger); }

    /* --- Charts --- */
    .chart-wrapper {
      position: relative;
      height: 250px;
      width: 100%;
    }

     /* --- Toast Notification --- */
    .toast {
      position: fixed;
      bottom: 20px;
      left: 50%;
      transform: translateX(-50%) translateY(100px);
      background: #333;
      color: white;
      padding: 12px 24px;
      border-radius: 30px;
      box-shadow: var(--shadow-lg);
      font-size: 14px;
      opacity: 0;
      transition: all 0.3s cubic-bezier(0.68, -0.55, 0.27, 1.55);
      z-index: 2000;
      display: flex;
      align-items: center;
      gap: 10px;
    }
    
    .toast.visible {
      transform: translateX(-50%) translateY(0);
      opacity: 1;
    }

    .toast-success { background: var(--primary); }
    .toast-error { background: var(--danger); }

    /* --- Utility --- */
    .badge {
      display: inline-block;
      padding: 4px 8px;
      border-radius: 4px;
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
    }
    .badge-green { background: var(--primary-light); color: var(--primary); }
    
    @media (max-width: 600px) {
      .summary-grid { grid-template-columns: 1fr; }
      .header h1 { font-size: 20px; }
    }
  </style>
</head>

<body>

     <div class="app-container">
     
      <!-- Header -->
<header class="header">
         <div class="header-nav" style="display: flex; align-items: center; justify-content: center; position: relative;">
           <button class="back-btn" onclick="goBack()" aria-label="Go Back" style="position: absolute; left: 0;">
             <i class="fas fa-arrow-left"></i>
           </button>
           <h1 id="groupNameDisplay" style="font-size: 24px; font-weight: 800; letter-spacing: -0.5px; margin: 0;"><%- group?.groupName || (groupData?.groupName) || 'Loading Group...' %></h1>
         </div>
      </header>

<!-- Summary Stats -->
       <div class="summary-grid">
         <div class="stat-card stat-blue">
           <div class="stat-icon"><i class="fas fa-wallet"></i></div>
           <div class="stat-value"><%= 'KES ' + Number(totalClosingBalance || 0).toLocaleString(undefined, { minimumFractionDigits: 0, maximumFractionDigits: 0 }) %></div>
           <div class="stat-label">Balance</div>
         </div>
         <div class="stat-card stat-teal">
           <div class="stat-icon"><i class="fas fa-hand-holding-usd"></i></div>
           <div class="stat-value"><%= 'KES ' + Number(totalAmountIn || 0).toLocaleString(undefined, { minimumFractionDigits: 0, maximumFractionDigits: 0 }) %></div>
           <div class="stat-label">Contributions</div>
         </div>
         <div class="stat-card stat-green">
           <div class="stat-icon"><i class="fas fa-hand-holding-heart"></i></div>
           <div class="stat-value"><%= 'KES ' + Number(benefitAccountsTotal || 0).toLocaleString(undefined, { minimumFractionDigits: 0, maximumFractionDigits: 0 }) %></div>
           <div class="stat-label">Benefit</div>
         </div>
         <div class="stat-card stat-orange">
           <div class="stat-icon"><i class="fas fa-hand-holding-usd"></i></div>
           <div class="stat-value" id="activeLoans">0</div>
           <div class="stat-label">Loans</div>
         </div>
       </div>

<!-- Group Performance Section -->
      <div class="card">
        <div class="card-header">
          <div class="card-title">
            <i class="fas fa-chart-bar" style="background: var(--primary-light); color: var(--primary);"></i>
            Performance
          </div>
          <span class="badge badge-green" id="statusBadge">Active</span>
        </div>

<!-- Account Breakdown Section -->
        <div class="card" style="margin-top: 20px;">
          <div class="card-header">
            <div class="card-title">
              <i class="fas fa-wallet" style="background: var(--primary-light); color: var(--primary);"></i>
              Accounts
            </div>
          </div>
          <div class="table-responsive">
<table id="accountBreakdownTable">
               <thead>
                 <tr>
                   <th>ID</th>
                   <th>Name</th>
                   <th class="text-right">Balance</th>
                   <th class="text-right">In</th>
                   <th class="text-right">Out</th>
                 </tr>
               </thead>
              <tbody>
                <!-- Populated by JS -->
              </tbody>
            </table>
         </div>
       </div>

<!-- Cycles Table -->
<div style="margin-bottom: 15px; display: flex; justify-content: space-between; align-items: center;">
          <h3 style="font-size: 13px; font-weight: 700; color: var(--dark);">Cycle</h3>
          <button onclick="showToast('Exporting CSV...', 'success')" style="background:none; border:none; color: var(--primary); font-size: 12px; font-weight: 600; cursor: pointer;">
            <i class="fas fa-download"></i> Export
          </button>
        </div>
      
<div class="table-responsive">
          <table id="cyclesTable">
            <thead>
              <tr>
                <th>Cycle</th>
                <th class="text-right">am in</th>
                <th class="text-right">am out</th>
                <th class="text-right">balance</th>
              </tr>
            </thead>
            <tbody>
              <!-- Populated by JS -->
            </tbody>
          </table>
        </div>
     </div>

<!-- Charts Section -->
     <div class="card">
       <div class="card-header">
         <div class="card-title">
           <i class="fas fa-chart-pie" style="background: var(--secondary-light); color: var(--secondary);"></i>
           Analytics
         </div>
       </div>
       
<div style="display: grid; gap: 20px;">
           <div>
             <h4 style="font-size: 12px; color: var(--slate); margin-bottom: 10px; font-weight: 600;">Transaction Group</h4>
             <div class="chart-wrapper">
               <canvas id="transactionChart"></canvas>
             </div>
           </div>
           
<div style="border-top: 1px solid var(--border); padding-top: 20px;">
            <h4 style="font-size: 12px; color: var(--slate); margin-bottom: 10px; font-weight: 600;">Closing Balance</h4>
            <div class="chart-wrapper">
              <canvas id="memberGrowthChart"></canvas>
            </div>
          </div>
         </div>
</div>

   <!-- Toast Container -->
  <div id="toast" class="toast">
    <i class="fas fa-info-circle"></i>
    <span id="toastMessage">Notification</span>
   </div>

   <script>
       // --- 2. LOGIC & FUNCTIONS ---

       let groupData = <%- JSON.stringify(groupData || {}) %>;
       let group = <%- JSON.stringify(group || {}) %>;

// Initialization
document.addEventListener('DOMContentLoaded', () => {
          initData();
          calculateAndRenderAll();
          renderPerformanceSection();
          initCharts();
        });

      function calculateAndRenderAll() {
        // Build account-wise totals from member accounts
        const accountWiseTotals = {};

        if (groupData?.members) {
          Object.values(groupData.members).forEach(member => {
            if (member.accounts) {
              Object.values(member.accounts).forEach(account => {
                const accountId = account.accountId;
                if (!accountWiseTotals[accountId]) {
                  accountWiseTotals[accountId] = {
                    accountId: accountId,
                    accountName: account.accountName || 'Unknown',
                    closingBalance: 0,
                    amountIn: 0,
                    amountOut: 0
                  };
                }
                accountWiseTotals[accountId].closingBalance += parseFloat(account.financials?.closingBalance || 0);
                accountWiseTotals[accountId].amountIn += parseFloat(account.financials?.amountIn || 0);
                accountWiseTotals[accountId].amountOut += parseFloat(account.financials?.amountOut || 0);
              });
            }
          });
        }

        // Sum all account balances for total savings and contributions
        let totalSavings = 0;
        let totalContributions = 0;
        Object.values(accountWiseTotals).forEach(acc => {
          totalSavings += acc.closingBalance;
          totalContributions += acc.amountIn;
        });

        const activeLoans = 2; // Hardcoded for mock visual

        // Update Summary Stats (only activeLoans is set client-side)
        document.getElementById('activeLoans').textContent = activeLoans;

        // Render Account Breakdown Table
        renderAccountBreakdown(accountWiseTotals);
      }

      function initData() {
        // Header already rendered server-side via EJS, only set JS fallback if needed
        const groupNameEl = document.getElementById('groupNameDisplay');
        const gd = groupData || {};
        const g = group || {};
        // If header elements are empty, populate them from available data
        if (groupNameEl && !groupNameEl.textContent.replace(/<[^>]*>/g, '').trim()) {
          groupNameEl.innerHTML = g.groupName || gd.groupName || 'Unknown Group';
        }
      }

    function formatCurrency(amount) {
      return 'KES ' + Number(amount || 0).toLocaleString(undefined, { minimumFractionDigits: 0, maximumFractionDigits: 0 });
    }

      // --- Account Breakdown ---
      function renderAccountBreakdown(accountWiseTotals) {
        const tableBody = document.querySelector('#accountBreakdownTable tbody');
        if (!tableBody) return;

        const accounts = Object.values(accountWiseTotals).sort((a, b) => a.accountId.localeCompare(b.accountId));

        if (accounts.length === 0) {
          tableBody.innerHTML = '<tr><td colspan="5" style="text-align:center; padding: 10px;">No account data available</td></tr>';
          return;
        }

        let html = '';
        accounts.forEach(acc => {
          html += `
            <tr>
              <td><span class="badge badge-green">${acc.accountId}</span></td>
              <td>${acc.accountName}</td>
              <td class="text-right font-bold">${formatCurrency(acc.closingBalance)}</td>
              <td class="text-right text-green">+${formatCurrency(acc.amountIn)}</td>
              <td class="text-right text-red">-${formatCurrency(acc.amountOut)}</td>
            </tr>
          `;
        });

        // Grand total row
        const grandTotals = accounts.reduce((sum, acc) => ({
          closingBalance: sum.closingBalance + acc.closingBalance,
          amountIn: sum.amountIn + acc.amountIn,
          amountOut: sum.amountOut + acc.amountOut
        }), { closingBalance: 0, amountIn: 0, amountOut: 0 });

        html += `
          <tr style="background: var(--light); font-weight: 700;">
            <td colspan="2" class="text-right">Grand Total</td>
            <td class="text-right text-green">${formatCurrency(grandTotals.closingBalance)}</td>
            <td class="text-right text-green">${formatCurrency(grandTotals.amountIn)}</td>
            <td class="text-right text-red">${formatCurrency(grandTotals.amountOut)}</td>
          </tr>
        `;

        tableBody.innerHTML = html;
      }

      // --- Performance & Cycles Logic ---
     function renderPerformanceSection() {
       const intervals = groupData?.principles?.intervals || {};
       const frequency = intervals.frequency || 'Not Set';
       
       // Calculate Dates
       const startDate = new Date(groupData?.constitutionStartKey || groupData?.createdAt || Date.now());
       const endDate = new Date(startDate);
      
      // Calculate end date based on saving period
      const duration = intervals.endSavingPeriod || '1-year';
      if (duration === '6-months') endDate.setMonth(endDate.getMonth() + 6);
      else if (duration === '1-year') endDate.setFullYear(endDate.getFullYear() + 1);
      else if (duration === '2-years') endDate.setFullYear(endDate.getFullYear() + 2);

       // Generate Cycles Table
      generateCyclesTable(startDate, endDate, frequency);
     
     const statusBadge = document.getElementById('statusBadge');
     if (statusBadge) {
       statusBadge.textContent = groupData?.status || 'Active';
     }
      }

 function generateCyclesTable(startDate, endDate, frequency) {
        const tableBody = document.querySelector('#cyclesTable tbody');
        const cycles = [];
        let current = new Date(startDate);
        let grandTotalIn = 0;
        let grandTotalOut = 0;
        let cycleCount = 0;
        let runningBalance = 0;
        // Default expected per cycle (fallback)
        const expectedPerCycle = 10000;

        while (current <= endDate) {
          // Limit to 12 cycles for display purposes to avoid massive tables in demo
          if (cycleCount >= 12) break; 

          cycles.push({ cycleNum: cycleCount + 1 });
          grandTotalIn += expectedPerCycle;
          // For demo purposes, let's assume some amount out (e.g., 20% of amount in)
          grandTotalOut += expectedPerCycle * 0.2;

          // Advance date
          if (frequency === 'daily') current.setDate(current.getDate() + 1);
          else if (frequency === 'weekly') current.setDate(current.getDate() + 7);
          else if (frequency === 'monthly') current.setMonth(current.getMonth() + 1);
          else if (frequency === 'yearly') current.setFullYear(current.getFullYear() + 1);

          cycleCount++;
        }

        let html = '';
        cycles.forEach((cycle, index) => {
          const amountIn = expectedPerCycle;
          const amountOut = expectedPerCycle * 0.2; // 20% outflow for demo
          runningBalance += (amountIn - amountOut);
          
          html += `
            <tr>
              <td><span class="badge badge-green">Cycle ${cycle.cycleNum}</span></td>
              <td class="text-right font-bold">${formatCurrency(amountIn)}</td>
              <td class="text-right font-bold">${formatCurrency(amountOut)}</td>
              <td class="text-right font-bold">${formatCurrency(runningBalance)}</td>
            </tr>
          `;
        });

        if (cycleCount === 0) {
          html = `<tr><td colspan="4" style="text-align:center; padding: 20px;">No cycles configured</td></tr>`;
        }

        tableBody.innerHTML = html;
      }
    function initCharts() {
       // 1. Transaction History (Bar Chart)
       const ctxTx = document.getElementById('transactionChart').getContext('2d');
       const txHistory = groupData?.transactionHistory || [];
       new Chart(ctxTx, {
         type: 'bar',
         data: {
           labels: txHistory.map(t => t.date),
           datasets: [{
             label: 'Inflow',
             data: txHistory.map(t => t.type === 'credit' ? t.amount : 0),
             backgroundColor: '#0f9d58',
             borderRadius: 4
           }, {
             label: 'Outflow',
             data: txHistory.map(t => t.type === 'debit' ? t.amount : 0),
             backgroundColor: '#ef4444',
             borderRadius: 4
           }]
         },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: { legend: { position: 'bottom', labels: { usePointStyle: true, boxWidth: 6 } } },
          scales: { y: { beginAtZero: true, grid: { borderDash: [2, 4] } }, x: { grid: { display: false } } }
        }
      });

      // 2. Member Growth (Line Chart) - Closing Balance per Cycle
      const ctxGrowth = document.getElementById('memberGrowthChart').getContext('2d');
      // Mocked closing balance data per cycle
      const balanceData = [0, 5000, 12000, 25000, 45000, 80000];
      const cycleNumbers = ['1', '2', '3', '4', '5', '6'];
      
      new Chart(ctxGrowth, {
        type: 'line',
        data: {
          labels: cycleNumbers,
          datasets: [{
            label: 'Closing Balance',
            data: balanceData,
            borderColor: '#4285f4',
            backgroundColor: 'rgba(66, 133, 244, 0.1)',
            fill: true,
            tension: 0.4,
            pointRadius: 4,
            pointBackgroundColor: '#fff',
            pointBorderWidth: 2
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: { 
            legend: { display: false },
            tooltip: {
              callbacks: {
                label: function(context) {
                  return 'KES ' + Number(context.parsed.y).toLocaleString();
                }
              }
            }
          },
          scales: { 
            y: { 
              beginAtZero: true, 
              ticks: { 
                stepSize: 20000,
                callback: function(value) {
                  return 'KES ' + Number(value).toLocaleString();
                }
              } 
            }, 
            x: { 
              grid: { display: false },
              title: {
                display: true,
                text: 'Cycle Number'
              }
            } 
          }
        }
});
     }

     // --- Utilities ---
    function showToast(message, type = 'success') {
      const toast = document.getElementById('toast');
      const msg = document.getElementById('toastMessage');
      
      msg.textContent = message;
      toast.className = `toast toast-${type} visible`;
      
      setTimeout(() => {
        toast.classList.remove('visible');
      }, 3000);
    }

    function goBack() {
      showToast("Navigating back...", "success");
      // In a real app: window.history.back();
    }

  </script>
</body>
</html>