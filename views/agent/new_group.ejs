    // ─── MPESA STK ────────────────────────────────────────────
    function startSTKPush() {
      const phone = document.getElementById('stkPhone').value;
      if (!isValidPhone(phone)) {
        showNotification('Invalid M-Pesa phone number. Use 254XXXXXXXXX (12 digits) or 07/01XXXXXXXX (10 digits).');
        return;
      }
      document.getElementById('mpesaPrompt').style.display = 'none';
      document.getElementById('loadingStatus').style.display = 'block';
    }

    // ─── PHONE VALIDATION HELPER ──────────────────────────────
    function isValidPhone(phone) {
      // Accepts: 254XXXXXXXXX (12 digits), 07XXXXXXXX (10 digits), 01XXXXXXXX (10 digits)
      return /^254[0-9]{9}$/.test(phone) || /^0[17][0-9]{8}$/.test(phone);
    }

    function getPhoneErrorMessage(field) {
      return `Invalid phone format for ${field}. Use 254XXXXXXXXX (12 digits) or 07/01XXXXXXXX (10 digits).`;
    }

    // ─── VERIFY MEMBERS ───────────────────────────────────────
    function verifyMembers() {
      // Collect all phone numbers to check for duplicates
      const allPhones = [];
      const phoneErrors = [];
      let hasEmptyMemberNumber = false;
      let emptyMemberName = '';

       // Validate all trustees dynamically
       for (let i = 0; i < STD_TRUSTEES; i++) {
         const idx = i + 1;
         const memberNumber = document.getElementById(`t${idx}_memberNumber`).value.trim();
         const phone = document.getElementById(`t${idx}_phone`).value.trim();
         const title = document.getElementById(`t${idx}_title`).value.trim();
         
         if (!title) {
           showNotification(`Title is required for Trustee ${idx}. Please select a title.`);
           return;
         }
         
         if (!memberNumber) {
           hasEmptyMemberNumber = true;
           emptyMemberName = title;
         }
         
         if (i === 0) {
           // Chairperson phone is pre-filled
           if (isValidPhone(phone)) {
             allPhones.push({ phone: phone, name: `Trustee ${idx} (${title})` });
           }
         } else {
           // All other trustees require valid phone
           if (!isValidPhone(phone)) { 
             showNotification(getPhoneErrorMessage(`Trustee ${idx} (${title})`)); 
             return; 
           }
           allPhones.push({ phone: phone, name: `Trustee ${idx} (${title})` });
         }
       }

      // Officials
      let hasOfficialTitle = false;
      let hasOfficialNumber = false;
      let missingOfficialInfo = '';
      for (let i = 0; i < currentOfficialsCount; i++) {
        const idx = STD_TRUSTEES + i + 1;
        const memberNumber = document.getElementById(`official_${idx}_memberNumber`).value.trim();
        const phone = document.getElementById(`official_${idx}_phone`).value.trim();
        const title = document.getElementById(`official_${idx}_title`).value.trim();
        
        if (!title) {
          hasOfficialTitle = true;
          missingOfficialInfo = `Official ${i + 1}`;
        }
        
        if (!memberNumber) {
          hasEmptyMemberNumber = true;
          hasOfficialNumber = true;
          if (!missingOfficialInfo) missingOfficialInfo = `Official ${i + 1}`;
        }
        
        if (phone && isValidPhone(phone)) {
          allPhones.push({ phone: phone, name: title || `Official ${i + 1}` });
        }
      }
      
      // Check if all officials have title
      if (currentOfficialsCount > 0 && hasOfficialTitle) {
        showNotification(`Title is required for ${missingOfficialInfo}. Please fill all titles.`);
        return;
      }

      // Regular Members
      for (let i = 0; i < regularMembersCount; i++) {
        const idx = STD_TRUSTEES + currentOfficialsCount + i + 1;
        const memberNumber = document.getElementById(`member_${idx}_memberNumber`).value.trim();
        const phone = document.getElementById(`member_${idx}_phone`).value.trim();
        
        if (!memberNumber) {
          hasEmptyMemberNumber = true;
          emptyMemberName = `Member ${i + 1}`;
        }
        
        if (!isValidPhone(phone)) {
          showNotification(getPhoneErrorMessage(`Member ${i + 1}`));
          return;
        }
        allPhones.push({ phone: phone, name: `Member ${i + 1} (Index ${idx})` });
      }

      // Check if any member number is empty
      if (hasEmptyMemberNumber) {
        showNotification(`Member number is required for ${emptyMemberName}. Please fill all member numbers before verifying.`);
        return;
      }

      // Check for duplicate phone numbers
      const phoneMap = new Map();
      for (const entry of allPhones) {
        if (phoneMap.has(entry.phone)) {
          phoneErrors.push(`${entry.phone} is used by both ${phoneMap.get(entry.phone)} and ${entry.name}`);
        } else {
          phoneMap.set(entry.phone, entry.name);
        }
      }

      // If duplicates found, show error and stop
      if (phoneErrors.length > 0) {
        showNotification('Duplicate phone numbers found:\n\n' + phoneErrors.join('\n') + '\n\nEach member must have a unique phone number.');
        return;
      }

      // All validations passed - show verification form
      showVerificationForm();
    }

    // ─── SHOW VERIFICATION FORM ──────────────────────────────
    function showVerificationForm() {
      const list = document.getElementById('verificationList');
      list.innerHTML = '<div style="text-align:center; padding:40px;"><i class="fas fa-spinner fa-spin" style="font-size:30px; color:var(--primary);"></i><p style="margin-top:15px; font-size:14px; color:var(--slate);">Verifying members...</p></div>';
      showStep('step4-verify');

      setTimeout(() => {
        verifyMembersProcess();
      }, 100);
    }

    function verifyMembersProcess() {
      const list = document.getElementById('verificationList');

      // Populate group info for verification step
      const groupType = document.getElementById('groupType').value;
      const groupCertNumber = document.getElementById('groupCertificateNumber').value.trim();

      // Update header box with group info
      document.getElementById('verifyGroupType').textContent = groupType || '-';
      document.getElementById('verifyCertNumber').textContent = groupCertNumber || 'Not provided';
      // Regional block, group no, agent info are already populated via EJS template

      // Collect all member data from form inputs
      const membersToVerify = [];

       // Add all trustees dynamically
       for (let i = 0; i < STD_TRUSTEES; i++) {
         const idx = i + 1;
         membersToVerify.push({
           key: `trustee_${idx}`,
           memberNumber: document.getElementById(`t${idx}_memberNumber`).value.trim(),
           phone: document.getElementById(`t${idx}_phone`).value.trim(),
           id: document.getElementById(`t${idx}_id`).value.trim(),
           role: 'trustee',
           title: document.getElementById(`t${idx}_title`).value.trim() || 'Trustee',
           index: String(idx)
         });
       }

     // Officials
     for (let i = 0; i < currentOfficialsCount; i++) {
       const idx = STD_TRUSTEES + i + 1;
       membersToVerify.push({
         key: `official_${idx}`,
         memberNumber: document.getElementById(`official_${idx}_memberNumber`).value.trim(),
         phone: document.getElementById(`official_${idx}_phone`).value.trim(),
         id: document.getElementById(`official_${idx}_id`).value.trim(),
         role: 'official',
         title: document.getElementById(`official_${idx}_title`).value.trim() || 'No Title',
         index: String(idx)
       });
     }

      // Regular Members
      for (let i = 0; i < regularMembersCount; i++) {
        const idx = STD_TRUSTEES + currentOfficialsCount + i + 1;
        membersToVerify.push({
          key: `member_${idx}`,
          memberNumber: document.getElementById(`member_${idx}_memberNumber`).value.trim(),
          phone: document.getElementById(`member_${idx}_phone`).value.trim(),
          id: document.getElementById(`member_${idx}_id`).value.trim(),
          role: 'member',
          title: 'Member',
          index: String(idx)
        });
      }

      console.log('Sending', membersToVerify.length, 'members for verification');

      // Verify agent phone against data.json
      let agentPhone = '<%= agent ? agent.phoneNumber : "" %>';
      // Normalize phone - remove leading 0 or +254
      if (agentPhone.startsWith('0')) agentPhone = agentPhone.substring(1);
      if (agentPhone.startsWith('+254')) agentPhone = agentPhone.substring(4);
      if (agentPhone.startsWith('254') && agentPhone.length > 9) agentPhone = agentPhone.substring(3);
      console.log('Agent phone for verification:', agentPhone);
      fetch('/general/api/verify-members', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ members: [{ key: 'agent', phone: agentPhone, id: '', role: 'agent', title: 'Agent', index: '0' }] })
      })
        .then(r => r.json())
.then(agentResponse => {
          console.log('Agent verification response:', agentResponse);
          if (agentResponse.success && agentResponse.members && agentResponse.members.length > 0) {
            const agentData = agentResponse.members[0];
            console.log('Agent data:', agentData);
            // Verify by phone match only - no ID check needed
            if (agentData.name) {
              document.getElementById('verifyAgentName').textContent = agentData.name;
              document.getElementById('verifyAgentPhoneIcon').className = 'fas fa-check-circle';
              document.getElementById('verifyAgentPhoneIcon').style.color = '#166534';
              document.getElementById('verifyAgentPhoneIcon').style.animation = 'none';
            } else {
              document.getElementById('verifyAgentName').textContent = '<%= group.agentName %>';
              document.getElementById('verifyAgentPhoneIcon').className = 'fas fa-times-circle';
              document.getElementById('verifyAgentPhoneIcon').style.color = '#991b1b';
            }
          }
        })
        .catch(() => {
          document.getElementById('verifyAgentName').textContent = '<%= group.agentName %>';
          document.getElementById('verifyAgentPhoneIcon').className = 'fas fa-times-circle';
          document.getElementById('verifyAgentPhoneIcon').style.color = '#991b1b';
        });

      // Call API to verify members against data.json
      fetch('/general/api/verify-members', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ members: membersToVerify })
      })
        .then(r => r.json())
        .then(apiResponse => {
          if (!apiResponse.success) {
            console.warn('⚠ API returned error:', apiResponse.error);
            showNotification('Failed to verify members. Please try again.', 'error');
            return;
          }

          const verifiedMembers = apiResponse.members;
          console.log('✓ Verification complete:', verifiedMembers.length, 'members verified');

          // Build verification cards with member numbers from original form inputs
          let html = '';
          verifiedMembers.forEach((member, idx) => {
            const bgColor = member.role === 'trustee' ? '#dbeafe' :
                           member.role === 'official' ? '#fef9c3' : '#dcfce7';
            const textColor = member.role === 'trustee' ? '#1d4ed8' :
                             member.role === 'official' ? '#92400e' : 'var(--primary-dark)';

            // Get member number from original form input based on role and index
            let formMemberNumber = '';
            const memberIdx = parseInt(member.index);
            if (member.role === 'trustee') {
              formMemberNumber = document.getElementById(`t${memberIdx}_memberNumber`)?.value.trim() || '';
            } else if (member.role === 'official') {
              formMemberNumber = document.getElementById(`official_${memberIdx}_memberNumber`)?.value.trim() || '';
            } else {
              formMemberNumber = document.getElementById(`member_${memberIdx}_memberNumber`)?.value.trim() || '';
            }

            html += buildVerificationCard(
              member.role === 'trustee' ? member.title : '',
              member.title,
              member.index,
              member.phone,
              bgColor,
              textColor,
              member,
              member.id,
              formMemberNumber
            );
          });

          list.innerHTML = html;

          // Check if all members are valid (both member number and verified status)
          const allValid = verifiedMembers.every((member, idx) => {
            const formMemberNumber = document.getElementById(`t${member.index}_memberNumber`)?.value.trim() ||
                              document.getElementById(`official_${member.index}_memberNumber`)?.value.trim() ||
                              document.getElementById(`member_${member.index}_memberNumber`)?.value.trim();
            return formMemberNumber && member.verified;
          });
          const submitBtn = document.getElementById('confirmSubmitBtn');
          const downloadBtn = document.getElementById('downloadRegFormBtn');
          if (submitBtn && downloadBtn) {
            if (!allValid) {
              submitBtn.style.display = 'none';
              downloadBtn.style.display = 'none';
              showNotification('All members must be verified with member numbers before submitting.', 'error');
            } else {
              submitBtn.style.display = 'flex';
              downloadBtn.style.display = 'flex';
            }
          }
})
        .catch(err => {
          console.error('Error verifying members:', err);
          showNotification('Network error. Please check your connection.', 'error');
          goBackToForm();
        });
    }

