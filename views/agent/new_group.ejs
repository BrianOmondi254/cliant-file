function disableFormElements() {
  // Disable all inputs and buttons except the Terms, Accept, and Download buttons
  const inputs = document.querySelectorAll('input, select, button');
  inputs.forEach(element => {
    const onclickStr = element.onclick ? element.onclick.toString() : '';
    if (!onclickStr.includes('showRegulationsModal') &&
        !onclickStr.includes('closeRegulationsModal') &&
        !onclickStr.includes('downloadWithWatermark')) {
      element.disabled = true;
      element.style.opacity = '0.5';
      element.style.pointerEvents = 'none';
    }
  });
}

function enableFormElements() {
  // Enable all inputs and buttons
  const inputs = document.querySelectorAll('input, select, button');
  inputs.forEach(element => {
    element.disabled = false;
    element.style.opacity = '1';
    element.style.pointerEvents = 'auto';
  });
}

