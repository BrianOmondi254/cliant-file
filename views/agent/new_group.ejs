async function downloadWithWatermark() {
  const { jsPDF } = window.jspdf;

  // Create PDF document with regulations
  const doc = new jsPDF();
  const pageHeight = doc.internal.pageSize.height || doc.internal.pageSize.getHeight();
  const pageWidth = doc.internal.pageSize.width || doc.internal.pageSize.getWidth();
  const margin = 20;
  let yPos = margin;

  // Function to add watermark to current page
  function addWatermark() {
    // Add subtle watermark in corners instead of center
    doc.setTextColor(240, 240, 240); // Very light gray
    doc.setFontSize(20);
    doc.setFont('helvetica', 'normal');

    // Top-left corner
    doc.text('TBANK', margin, margin + 10, {
      angle: 0
    });

    // Bottom-right corner
    doc.text('TBANK', pageWidth - margin - 30, pageHeight - margin - 10, {
      angle: 0
    });

    // Top-right corner
    doc.text('TBANK', pageWidth - margin - 30, margin + 10, {
      angle: 0
    });

    // Bottom-left corner
    doc.text('TBANK', margin, pageHeight - margin - 10, {
      angle: 0
    });

    // Reset text color for content
    doc.setTextColor(0, 0, 0);
  }

  // Helper function to add text with word wrap
  function addWrappedText(text, x, y, maxWidth, lineHeight = 7) {
    const lines = doc.splitTextToSize(text, maxWidth);
    doc.text(lines, x, y);
    return lines.length * lineHeight;
  }

  // Helper to check if we need a new page
  function checkPageSpace(requiredHeight) {
    if (yPos + requiredHeight > pageHeight - margin) {
      addWatermark(); // Add watermark to current page
      doc.addPage();
      yPos = margin;
      addWatermark(); // Add watermark to new page
    }
  }

  // Add watermark to first page
  addWatermark();

  // Header
  doc.setFontSize(18);
  doc.setFont('helvetica', 'bold');
  doc.text('GROUP FORMATION REGULATIONS', margin, yPos);
  yPos += 15;

  doc.setFontSize(12);
  doc.setFont('helvetica', 'normal');
  doc.text('Constitution of Kenya, 2010 - Chapter Four: The Bill of Rights', margin, yPos);
  yPos += 10;

  doc.setFontSize(10);
  doc.text(`Downloaded: ${new Date().toLocaleString('en-GB')}`, margin, yPos);
  yPos += 15;

  // Freedom of Association
