    // ─── MPESA STK ────────────────────────────────────────────
    function startSTKPush() {
      const phone = document.getElementById('stkPhone').value;
      if (!isValidPhone(phone)) {
        showNotification('Invalid M-Pesa phone number. Use 254XXXXXXXXX (12 digits) or 07/01XXXXXXXX (10 digits).');
        return;
      }
      document.getElementById('mpesaPrompt').style.display   = 'none';
      document.getElementById('loadingStatus').style.display = 'block';
    }

    // ─── PHONE VALIDATION ─────────────────────────────────────
    function isValidPhone(phone) {
      // Support 254XXXXXXXXX (12), +254XXXXXXXXX (13), 07XXXXXXXX (10) or 01XXXXXXXX (10)
      return /^\+?254[0-9]{9}$/.test(phone) || /^0[17][0-9]{8}$/.test(phone);
    }
    function getPhoneErrorMessage(field) {
      return `Invalid phone format for ${field}. Use +254XXXXXXXXX (13), 254XXXXXXXXX (12) or 07/01XXXXXXXX (10 digits).`;
    }

    // Dynamically adjust phone input maxlength
    document.addEventListener('input', function(e) {
      if (e.target.type === 'tel' && e.target.id.includes('_phone')) {
        const val = e.target.value;
        if (val.startsWith('+')) e.target.maxLength = 13;
        else if (val.startsWith('254')) e.target.maxLength = 12;
        else e.target.maxLength = 10;
      }
    });

    // ─── VERIFY MEMBERS ───────────────────────────────────────
    function verifyMembers() {
      // Start verification flow
      try {
        const list = document.getElementById('verificationList');
        if (list) {
          list.innerHTML = '<div style="text-align:center; padding:20px;"><i class="fas fa-spinner fa-spin" style="font-size:24px; color:var(--primary);"></i><p style="margin-top:10px; font-size:13px; color:var(--slate);">Preparing verification...</p></div>';
        }
      } catch(e) { console.error('Pre-verify prep error:', e); }
      
        const allPhones = [], phoneErrors = [];
        let hasEmptyMemberNumber = false, emptyMemberName = '';

         for (let i=0; i<STD_TRUSTEES; i++) {
           const idx         = i+1;
           const memberNumber= document.getElementById(`t${idx}_memberNumber`)?.value.trim() || '';
           const phone       = document.getElementById(`t${idx}_phone`)?.value.trim() || '';
           const title       = document.getElementById(`t${idx}_title`)?.value.trim() || '';
           if (!title)        { showNotification(`Title is required for Trustee ${idx}. Please select a title.`); return; }
           if (!memberNumber) { hasEmptyMemberNumber = true; emptyMemberName = `Trustee ${idx}`; }
           if (i===0) { if (isValidPhone(phone)) allPhones.push({ phone, name:`Trustee ${idx}` }); }
           else {
             if (!isValidPhone(phone)) { showNotification(getPhoneErrorMessage(`Trustee ${idx}`)); return; }
             allPhones.push({ phone, name:`Trustee ${idx}` });
           }
         }

        let hasOfficialTitle = false, hasOfficialNumber = false, missingOfficialInfo = '';
        for (let i=0; i<currentOfficialsCount; i++) {
          const idx         = STD_TRUSTEES + i + 1;
          const memberNumber= document.getElementById(`official_${idx}_memberNumber`)?.value.trim() || '';
          const phone       = document.getElementById(`official_${idx}_phone`)?.value.trim() || '';
          const title       = document.getElementById(`official_${idx}_title`)?.value.trim() || '';
          if (!title)        { hasOfficialTitle = true; missingOfficialInfo = `Official ${i+1}`; }
          if (!memberNumber) { hasEmptyMemberNumber = true; hasOfficialNumber = true; if (!missingOfficialInfo) missingOfficialInfo = `Official ${i+1}`; }
          if (phone && isValidPhone(phone)) allPhones.push({ phone, name: title || `Official ${i+1}` });
        }
        if (currentOfficialsCount > 0 && hasOfficialTitle) {
          showNotification(`Title is required for ${missingOfficialInfo}. Please fill all titles.`); return;
        }

        for (let i=0; i<regularMembersCount; i++) {
          const idx         = STD_TRUSTEES + currentOfficialsCount + i + 1;
          const memberNumber= document.getElementById(`member_${idx}_memberNumber`)?.value.trim() || '';
          const phone       = document.getElementById(`member_${idx}_phone`)?.value.trim() || '';
          if (!memberNumber) { hasEmptyMemberNumber = true; emptyMemberName = `Member ${i+1}`; }
          if (!isValidPhone(phone)) { showNotification(getPhoneErrorMessage(`Member ${i+1}`)); return; }
          allPhones.push({ phone, name:`Member ${i+1} (Index ${idx})` });
        }

        if (hasEmptyMemberNumber) {
          showNotification(`Member number is required for ${emptyMemberName}. Please fill all member numbers before verifying.`); return;
        }

        const allMemberNumbers = [], memberNumberErrors = [];
        for (let i=0; i<STD_TRUSTEES; i++) {
          const idx = i+1;
          const mn  = document.getElementById(`t${idx}_memberNumber`).value.trim();
          if (mn) allMemberNumbers.push({ value: mn, name:`Trustee ${idx}` });
        }
        for (let i=0; i<currentOfficialsCount; i++) {
          const idx = STD_TRUSTEES + i + 1;
          const mn  = document.getElementById(`official_${idx}_memberNumber`).value.trim();
          if (mn) allMemberNumbers.push({ value: mn, name:`Official ${i+1}` });
        }
        for (let i=0; i<regularMembersCount; i++) {
          const idx = STD_TRUSTEES + currentOfficialsCount + i + 1;
          const mn  = document.getElementById(`member_${idx}_memberNumber`).value.trim();
          if (mn) allMemberNumbers.push({ value: mn, name:`Member ${i+1}` });
        }

        const mnMap = new Map();
        for (const entry of allMemberNumbers) {
          if (mnMap.has(entry.value)) memberNumberErrors.push(`${entry.value} is used by both ${mnMap.get(entry.value)} and ${entry.name}`);
          else mnMap.set(entry.value, entry.name);
        }
        if (memberNumberErrors.length > 0) {
          showNotification('Duplicate membership numbers found:\n\n' + memberNumberErrors.join('\n') + '\n\nEach member must have a unique membership number.'); return;
        }

        if (allMemberNumbers.length > 1) {
          const first        = allMemberNumbers[0].value;
          const prefixMatch  = first.match(/^([a-zA-Z-]+)?/);
          const reqPrefix    = prefixMatch ? prefixMatch[0] : '';
          for (let i=1; i<allMemberNumbers.length; i++) {
            if (!allMemberNumbers[i].value.startsWith(reqPrefix)) {
              showNotification(`Membership number format inconsistency: "${allMemberNumbers[i].value}" does not match the required prefix "${reqPrefix}" from the first entry.`); return;
            }
          }
        }

        const phoneMap = new Map();
        for (const entry of allPhones) {
          if (phoneMap.has(entry.phone)) phoneErrors.push(`${entry.phone} is used by both ${phoneMap.get(entry.phone)} and ${entry.name}`);
          else phoneMap.set(entry.phone, entry.name);
        }
        if (phoneErrors.length > 0) {
          showNotification('Duplicate phone numbers found:\n\n' + phoneErrors.join('\n') + '\n\nEach member must have a unique phone number.'); return;
        }

        showVerificationForm();
    }

    // ─── SHOW VERIFICATION FORM ──────────────────────────────
    function showVerificationForm() {
      const list = document.getElementById('verificationList');
      list.innerHTML = '<div style="text-align:center; padding:40px;"><i class="fas fa-spinner fa-spin" style="font-size:30px; color:var(--primary);"></i><p style="margin-top:15px; font-size:14px; color:var(--slate);">Verifying members...</p></div>';
      showStep('step4-verify');
      setTimeout(() => { verifyMembersProcess(); }, 100);
    }

    function verifyMembersProcess() {
      const list        = document.getElementById('verificationList');
      const groupType   = document.getElementById('groupType').value;
      const groupCertNo = document.getElementById('groupCertificateNumber').value.trim();
      document.getElementById('verifyGroupType').textContent   = groupType   || '-';
      document.getElementById('verifyCertNumber').textContent  = groupCertNo || 'Not provided';

      const membersToVerify = [];
      for (let i=0; i<STD_TRUSTEES; i++) {
        const idx = i+1;
        membersToVerify.push({
          key:`trustee_${idx}`, memberNumber:document.getElementById(`t${idx}_memberNumber`)?.value.trim() || '',
          phone:document.getElementById(`t${idx}_phone`)?.value.trim() || '', id:document.getElementById(`t${idx}_id`)?.value.trim() || '',
          role:'trustee', title:document.getElementById(`t${idx}_title`)?.value.trim()||'Trustee', index:String(idx)
        });
      }
      for (let i=0; i<currentOfficialsCount; i++) {
        const idx = STD_TRUSTEES + i + 1;
        membersToVerify.push({
          key:`official_${idx}`, memberNumber:document.getElementById(`official_${idx}_memberNumber`)?.value.trim() || '',
          phone:document.getElementById(`official_${idx}_phone`)?.value.trim() || '', id:document.getElementById(`official_${idx}_id`)?.value.trim() || '',
          role:'official', title:document.getElementById(`official_${idx}_title`)?.value.trim()||'No Title', index:String(idx)
        });
      }
      for (let i=0; i<regularMembersCount; i++) {
        const idx = STD_TRUSTEES + currentOfficialsCount + i + 1;
        membersToVerify.push({
          key:`member_${idx}`, memberNumber:document.getElementById(`member_${idx}_memberNumber`)?.value.trim() || '',
          phone:document.getElementById(`member_${idx}_phone`)?.value.trim() || '', id:document.getElementById(`member_${idx}_id`)?.value.trim() || '',
          role:'member', title:'Member', index:String(idx)
        });
      }

      let agentPhone = '<%= agent ? agent.phoneNumber : "" %>';
      fetch('/general/verify-members', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ members: [{ key:'agent', phone:agentPhone, id:'', role:'agent', title:'Agent', index:'0' }] })
      }).then(r => {
        if (!r.ok) return { success: false };
        return r.json();
      }).then(agentResponse => {
        if (agentResponse.success && agentResponse.members && agentResponse.members.length > 0) {
          const agentData = agentResponse.members[0];
          if (agentData.name) {
            document.getElementById('verifyAgentName').textContent      = agentData.name;
            document.getElementById('verifyAgentPhoneIcon').className   = 'fas fa-check-circle';
            document.getElementById('verifyAgentPhoneIcon').style.color = '#166534';
            document.getElementById('verifyAgentPhoneIcon').style.animation = 'none';
          } else {
            document.getElementById('verifyAgentName').textContent      = '<%= group.agentName %>';
            document.getElementById('verifyAgentPhoneIcon').className   = 'fas fa-times-circle';
            document.getElementById('verifyAgentPhoneIcon').style.color = '#991b1b';
          }
        }
      }).catch(() => {
        document.getElementById('verifyAgentName').textContent      = '<%= group.agentName %>';
        document.getElementById('verifyAgentPhoneIcon').className   = 'fas fa-times-circle';
        document.getElementById('verifyAgentPhoneIcon').style.color = '#991b1b';
      });

      fetch('/general/verify-members', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ members: membersToVerify })
      }).then(r => {
        if (!r.ok) throw new Error('Verification failed with status ' + r.status);
        return r.json();
      }).then(apiResponse => {
        if (!apiResponse.success) { showNotification('Failed to verify members. Please try again.', 'error'); return; }
        const verifiedMembers = apiResponse.members;
        verifiedMembersData = verifiedMembers;

        let html = '';
        verifiedMembers.forEach((member) => {
          const bgColor   = member.role==='trustee' ? '#dbeafe' : member.role==='official' ? '#fef9c3' : '#dcfce7';
          const textColor = member.role==='trustee' ? '#1d4ed8' : member.role==='official' ? '#92400e' : 'var(--primary-dark)';
          let formMemberNumber = '';
          const memberIdx = parseInt(member.index);
          if      (member.role === 'trustee')  formMemberNumber = document.getElementById(`t${memberIdx}_memberNumber`)?.value.trim()       || '';
          else if (member.role === 'official') formMemberNumber = document.getElementById(`official_${memberIdx}_memberNumber`)?.value.trim()|| '';
          else                                 formMemberNumber = document.getElementById(`member_${memberIdx}_memberNumber`)?.value.trim()  || '';
          html += buildVerificationCard(
            member.role === 'trustee' ? member.title : '',
            member.title, member.index, member.phone, bgColor, textColor, member, member.id, formMemberNumber
          );
        });
        list.innerHTML = html;

        const allValid = verifiedMembers.every(member => {
          const mn = document.getElementById(`t${member.index}_memberNumber`)?.value.trim()       ||
                     document.getElementById(`official_${member.index}_memberNumber`)?.value.trim()||
                     document.getElementById(`member_${member.index}_memberNumber`)?.value.trim();
          return mn && member.verified;
        });
        const submitBtn  = document.getElementById('confirmSubmitBtn');
        if (submitBtn) {
          if (!allValid) {
            submitBtn.style.display  = 'none';
            showNotification('All members must be verified with member numbers before submitting.', 'error');
          } else {
            submitBtn.style.display  = 'flex';
          }
        }
      }).catch(err => {
        console.error('Error verifying members:', err);
        showNotification('Network error. Please check your connection.', 'error');
        goBackToForm();
      });
    }

    function buildVerificationCard(rolePrefix, title, index, phone, bgColor, textColor, matchData, formIdValue, memberNumber) {
      const isVerified   = matchData && matchData.verified;
      const displayName  = (matchData && matchData.name) ? matchData.name : 'Not Identified';
      const idValue      = (matchData && matchData.id)   ? matchData.id   : '-';
      return `
        <div class="member-card" style="margin-bottom:0; border:none; background:none; box-shadow:none;
          border-bottom:2px solid #e2e8f0; padding-bottom:10px; border-radius:0;">
          <div class="top">
            <div>
              <div class="name">${index}. ${displayName}</div>
              <div class="role-text" style="color:${textColor};">${title}</div>
            </div>
            <div class="badges">
              ${isVerified
                ? '<div class="badge verified">Verified <i class="fas fa-check-circle"></i></div>'
                : '<div class="badge error-badge">Pending <i class="fas fa-clock"></i></div>'}
            </div>
          </div>
          <div style="display:flex; gap:16px; margin-top:12px;">
            <div style="display:flex; gap:8px; align-items:center;">
              <span class="label">Phone:</span>
              <span class="value">${phone||'-'}</span>
              ${isVerified ? '<i class="fas fa-check-circle" style="color:#166534; font-size:12px;"></i>' : ''}
            </div>
            <div style="display:flex; gap:8px; align-items:center;">
              <span class="label">ID:</span>
              <span class="value">${idValue}</span>
              ${isVerified ? '<i class="fas fa-check-circle" style="color:#166634; font-size:12px;"></i>' : ''}
            </div>
          </div>
          <div style="display:flex; justify-content:flex-end; margin-top:8px;">
            <div class="badge mno">Member-${memberNumber||'N/A'}</div>
          </div>
        </div>`;
    }

    function goBackToForm() {
      showStep('step3-tbank');
      updateTrusteeTitles();
    }

      submitTbankRegistration();

    // ─── DOWNLOAD REGISTRATION FORM ────────────────────────────────────
    async function downloadRegistrationForm() {
      const { jsPDF } = window.jspdf;
      const members   = [];
      for (let i=0; i<STD_TRUSTEES; i++) {
        const idx = i+1;
        members.push({ index:idx, title:document.getElementById(`t${idx}_title`).value.trim()||'Trustee',
          name:`Trustee ${idx}`, memberNumber:document.getElementById(`t${idx}_memberNumber`).value.trim()||'',
          phone:document.getElementById(`t${idx}_phone`).value.trim()||'', id:document.getElementById(`t${idx}_id`).value.trim()||'', type:'trustee' });
      }
      for (let i=0; i<currentOfficialsCount; i++) {
        const idx = STD_TRUSTEES+i+1;
        members.push({ index:idx, title:document.getElementById(`official_${idx}_title`)?.value.trim()||'Official',
          name:`Official ${i+1}`, memberNumber:document.getElementById(`official_${idx}_memberNumber`)?.value.trim()||'',
          phone:document.getElementById(`official_${idx}_phone`)?.value.trim()||'', id:document.getElementById(`official_${idx}_id`)?.value.trim()||'', type:'official' });
      }
      for (let i=0; i<regularMembersCount; i++) {
        const idx = STD_TRUSTEES+currentOfficialsCount+i+1;
        members.push({ index:idx, title:'Member', name:`Member ${i+1}`,
          memberNumber:document.getElementById(`member_${idx}_memberNumber`)?.value.trim()||'',
          phone:document.getElementById(`member_${idx}_phone`)?.value.trim()||'',
          id:document.getElementById(`member_${idx}_id`)?.value.trim()||'', type:'member' });
      }

      const groupName = groupData.groupName||'';
      const location  = `${groupData.ward||''}, ${groupData.constituency||''}, ${groupData.county||''}`;
      const agentName = groupData.agentName||'Unknown Agent';
      const agentPhone= groupData.agentPhone||'';
      const downloadDateTime = new Date().toLocaleString('en-GB',{ day:'2-digit', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit' });

      const doc        = new jsPDF();
      const pageHeight = doc.internal.pageSize.height||doc.internal.pageSize.getHeight();
      const margin     = 15;
      let yPos         = margin;

      function addWrappedText(text, x, y, maxWidth, lineHeight=7) {
        const lines = doc.splitTextToSize(text, maxWidth);
        doc.text(lines, x, y);
        return lines.length * lineHeight;
      }
      function checkPageSpace(h) { if (yPos+h > pageHeight-margin) { doc.addPage(); yPos=margin; } }

      doc.setFontSize(16); doc.setFont('helvetica','bold');
      doc.text('GROUP REGISTRATION FORM', margin, yPos); yPos+=10;
      doc.setFontSize(12); doc.setFont('helvetica','normal');
      doc.text(`Downloaded: ${downloadDateTime}`, margin, yPos); yPos+=7;
      doc.setFont('helvetica','bold'); doc.text('Group Information:', margin, yPos); yPos+=7;
      doc.setFont('helvetica','normal');
      doc.text(`Group Name: ${groupName}`, margin+5, yPos); yPos+=6;
      doc.text(`Location: ${location}`, margin+5, yPos); yPos+=6;
      doc.text(`Agent: ${agentName} (${agentPhone})`, margin+5, yPos); yPos+=10;
      doc.setFont('helvetica','bold'); doc.text('Registered Members', margin, yPos); yPos+=7;
      doc.setFillColor(240,240,240); doc.rect(margin, yPos, 190, 8, 'F');
      doc.setFont('helvetica','bold');
      doc.text('Idx', margin+3, yPos+5); doc.text('Title', margin+15, yPos+5);
      doc.text('Name', margin+45, yPos+5); doc.text('Member No.', margin+90, yPos+5);
      doc.text('Phone', margin+135, yPos+5); doc.text('ID No.', margin+165, yPos+5); yPos+=8;
      doc.setFont('helvetica','normal'); doc.setFontSize(10);
      for (let member of members) {
        checkPageSpace(15);
        if (members.indexOf(member)%2===0) { doc.setFillColor(250,250,250); doc.rect(margin, yPos, 190, 7, 'F'); }
        doc.text(String(member.index), margin+3, yPos+5); doc.text(member.title, margin+15, yPos+5);
        doc.text(member.name, margin+45, yPos+5); doc.text(member.memberNumber||'-', margin+90, yPos+5);
        doc.text(member.phone||'-', margin+135, yPos+5); doc.text(member.id||'-', margin+165, yPos+5); yPos+=7;
      }
      yPos+=5; checkPageSpace(20);
      doc.setFontSize(11); doc.setFont('helvetica','bold');
      doc.text(`Total Members: ${members.length}`, margin, yPos); yPos+=15;
      doc.setFont('helvetica','bold'); doc.text('Prepared By:', margin, yPos); yPos+=7;
      doc.setFont('helvetica','normal'); doc.setFontSize(10);
      doc.text(`Name: ${agentName}`, margin+5, yPos); yPos+=5;
      doc.text(`Phone: ${agentPhone}`, margin+5, yPos); yPos+=5;
      doc.text('Signature: _____________________________', margin+5, yPos); yPos+=12;
      doc.setFont('helvetica','bold'); doc.text('Chairperson Confirmation:', margin, yPos); yPos+=7;
      doc.setFont('helvetica','normal'); doc.setFontSize(10);
      const chair      = members.find(m => m.type==='trustee' && m.title.toLowerCase()==='chairperson');
      const chairName  = chair ? chair.name  : '_________________';
      const chairPhone = chair ? chair.phone : '_________________';
      doc.text(`Name: ${chairName}`, margin+5, yPos); yPos+=5;
      doc.text(`Phone: ${chairPhone}`, margin+5, yPos); yPos+=5;
      doc.text('Signature: _____________________________', margin+5, yPos); yPos+=12;
      doc.setFontSize(8); doc.setFont('helvetica','italic');
      doc.text('This form was automatically generated from the registration system.', margin, yPos);
      const filename = `Group_Registration_${groupName.replace(/\s+/g,'_')}_${new Date().getTime()}.pdf`;
      doc.save(filename);
      showNotification('Registration form downloaded successfully!', 'success');
    }

    // ─── T-BANK SUBMISSION ────────────────────────────────────
    function submitTbankRegistration() {
      const trustees = [];
      for (let i=0; i<STD_TRUSTEES; i++) {
        const idx   = i+1;
        const phone = document.getElementById(`t${idx}_phone`).value.trim();
        const memberNumber = document.getElementById(`t${idx}_memberNumber`).value.trim();
        const id = document.getElementById(`t${idx}_id`).value.trim();
        
        // Get verified name if available
        const verifiedInfo = verifiedMembersData.find(m => m.index === String(idx) && m.role === 'trustee');
        const name = verifiedInfo && verifiedInfo.name ? verifiedInfo.name : null;
        
        if (!memberNumber) { showNotification(`Please enter member number for Trustee ${idx}.`); return; }
        if (i > 0 && phone && !phone.match(/^07[0-9]{8}$/)) { showNotification(`Please enter a valid phone for Trustee ${idx}.`); return; }
        trustees.push({ index:String(idx), type:'trustee',
          title:document.getElementById(`t${idx}_title`).value.trim()||'Trustee',
          memberNumber,
          phone, id, name });
      }
      const addedOfficials = []; const officialTitlesSet = new Set();
      for (let i=0; i<currentOfficialsCount; i++) {
        const idx   = STD_TRUSTEES+i+1;
        const title = document.getElementById(`official_${idx}_title`).value.trim();
        const phone = document.getElementById(`official_${idx}_phone`).value.trim();
        const memberNumber = document.getElementById(`official_${idx}_memberNumber`).value.trim();
        const id = document.getElementById(`official_${idx}_id`).value.trim();
        
        // Get verified name if available
        const verifiedInfo = verifiedMembersData.find(m => m.index === String(idx) && m.role === 'official');
        const name = verifiedInfo && verifiedInfo.name ? verifiedInfo.name : null;
        
        if (!memberNumber) { showNotification(`Please enter member number for Official ${i+1}.`); return; }
        if (title) {
          if (officialTitlesSet.has(title.toLowerCase())) { showNotification(`Duplicate title "${title}" found.`); return; }
          officialTitlesSet.add(title.toLowerCase());
        }
        if (phone && !phone.match(/^07[0-9]{8}$/)) { showNotification(`Please enter a valid phone for Official ${i+1}.`); return; }
        addedOfficials.push({ index:String(idx), type:'official', title, memberNumber, phone, id, name });
      }
      for (let i=0; i<regularMembersCount; i++) {
        const idx   = STD_TRUSTEES+currentOfficialsCount+i+1;
        const phone = document.getElementById(`member_${idx}_phone`).value.trim();
        const memberNumber = document.getElementById(`member_${idx}_memberNumber`).value.trim();
        const id = document.getElementById(`member_${idx}_id`).value.trim();
        
        // Get verified name if available
        const verifiedInfo = verifiedMembersData.find(m => m.index === String(idx) && m.role === 'member');
        const name = verifiedInfo && verifiedInfo.name ? verifiedInfo.name : null;
        
        if (!memberNumber) { showNotification(`Please enter member number for Member ${i+1}.`); return; }
        if (!phone.match(/^07[0-9]{8}$/)) { showNotification(`Please enter a valid phone for Member ${i+1}.`); return; }
      }
      const groupType            = document.getElementById('groupType').value;
      const groupCertificateNumber = document.getElementById('groupCertificateNumber').value.trim();
      
      const constitutionStartKey = String(Math.floor(1000 + Math.random() * 9000));
      
      const agentPhone = '<%= agent ? agent.phoneNumber : "" %>';
      const finalTotalCount = STD_TRUSTEES + currentOfficialsCount + regularMembersCount;
      
      const payload = {
        groupName: groupData.groupName,
        groupType,
        groupCertificateNumber,
        phone: groupData.phone,
        totalMembers: finalTotalCount,
        totalAmount: totalPayableAmount,
        paymentMethod: 'tbank',
        constitutionStartKey,
        phase: 2,
        createdAt: new Date().toISOString(),
        processorPhone: 'n/a',
        agentProcessed: agentPhone || 'n/a',
        trustees, officials: addedOfficials, members: []
      };
      for (let i=0; i<regularMembersCount; i++) {
        const idx = STD_TRUSTEES+currentOfficialsCount+i+1;
        const phone = document.getElementById(`member_${idx}_phone`).value.trim();
        const id = document.getElementById(`member_${idx}_id`).value.trim();
        const memberNumber = document.getElementById(`member_${idx}_memberNumber`).value.trim();
        
        // Get verified name if available
        const verifiedInfo = verifiedMembersData.find(m => m.index === String(idx) && m.role === 'member');
        const name = verifiedInfo && verifiedInfo.name ? verifiedInfo.name : null;
        
        payload.members.push({ index:String(idx), type:'member', memberNumber, phone, id, name });
      }
      showStep('step5');
      fetch('/agent/activate-group', {
        method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify(payload)
      }).then(r => r.json()).then(res => {
        if (res.success) {
          document.getElementById('submitStatusMsg').textContent = '✓ Group registered successfully!';
          document.getElementById('successTitle').textContent = '<%= group.groupName %> Created Successfully';
          document.getElementById('successSubtitle').innerHTML = 'Group registration completed.<br>Thank you!';
        } else {
          document.getElementById('submitStatusMsg').textContent = `Error: ${res.message || 'Something went wrong.'}`;
          document.getElementById('successTitle').textContent = 'Registration Failed';
          document.getElementById('successSubtitle').textContent = 'Please try again or contact support.';
        }
        document.getElementById('backToDashBtn').style.display = 'flex';
      }).catch(() => {
        document.getElementById('submitStatusMsg').textContent = 'Network error. Please try again.';
        document.getElementById('backToDashBtn').style.display = 'flex';
      });
    }

    // ─── DOWNLOAD GROUP REGISTRATION FORM ─────────────────────
    function downloadGroupRegistrationForm() {
      const formData = {
        groupName: groupData.groupName, groupType: document.getElementById('groupType').value,
        certificateNumber: document.getElementById('groupCertificateNumber').value.trim(),
        county: groupData.county, constituency: groupData.constituency, ward: groupData.ward,
        agentName: groupData.agentName, agentPhone: groupData.agentPhone, members: []
      };
      for (let i=0; i<STD_TRUSTEES; i++) {
        const idx = i+1;
        formData.members.push({ index:idx, type:'trustee', title:document.getElementById(`t${idx}_title`).value.trim(),
          name:`Trustee ${idx}`, memberNumber:document.getElementById(`t${idx}_memberNumber`).value.trim(),
          phone:document.getElementById(`t${idx}_phone`).value.trim(), id:document.getElementById(`t${idx}_id`).value.trim() });
      }
      for (let i=0; i<currentOfficialsCount; i++) {
        const idx = STD_TRUSTEES+i+1;
        formData.members.push({ index:idx, type:'official', title:document.getElementById(`official_${idx}_title`).value.trim(),
          name:`Official ${i+1}`, memberNumber:document.getElementById(`official_${idx}_memberNumber`).value.trim(),
          phone:document.getElementById(`official_${idx}_phone`).value.trim(), id:document.getElementById(`official_${idx}_id`).value.trim() });
      }
      for (let i=0; i<regularMembersCount; i++) {
        const idx = STD_TRUSTEES+currentOfficialsCount+i+1;
        formData.members.push({ index:idx, type:'member', title:'Member', name:`Member ${i+1}`,
          memberNumber:document.getElementById(`member_${idx}_memberNumber`).value.trim(),
          phone:document.getElementById(`member_${idx}_phone`).value.trim(),
          id:document.getElementById(`member_${idx}_id`).value.trim() });
      }
      localStorage.setItem('groupFormData', JSON.stringify(formData));
      window.location.href = `/agent/group-form/${encodeURIComponent(formData.groupName)}`;
    }

    // ─── DOWNLOAD WITH WATERMARK (REGULATIONS) ───────────────
    async function downloadWithWatermark() {
      const { jsPDF } = window.jspdf;
      const doc        = new jsPDF();
      const pageHeight = doc.internal.pageSize.height||doc.internal.pageSize.getHeight();
      const pageWidth  = doc.internal.pageSize.width ||doc.internal.pageSize.getWidth();
      const margin     = 20;
      let yPos         = margin;

      function addWatermark() {
        doc.setTextColor(240,240,240); doc.setFontSize(20); doc.setFont('helvetica','normal');
        doc.text('TBANK', margin, margin+10, {angle:0});
        doc.text('TBANK', pageWidth-margin-30, pageHeight-margin-10, {angle:0});
        doc.text('TBANK', pageWidth-margin-30, margin+10, {angle:0});
        doc.text('TBANK', margin, pageHeight-margin-10, {angle:0});
        doc.setTextColor(0,0,0);
      }
      function addWrappedText(text, x, y, maxWidth, lineHeight=7) {
        const lines = doc.splitTextToSize(text, maxWidth); doc.text(lines, x, y); return lines.length*lineHeight;
      }
      function checkPageSpace(h) {
        if (yPos+h > pageHeight-margin) { addWatermark(); doc.addPage(); yPos=margin; addWatermark(); }
      }

      addWatermark();
      doc.setFontSize(18); doc.setFont('helvetica','bold');
      doc.text('GROUP FORMATION REGULATIONS', margin, yPos); yPos+=15;
      doc.setFontSize(12); doc.setFont('helvetica','normal');
      doc.text('Constitution of Kenya, 2010 - Chapter Four: The Bill of Rights', margin, yPos); yPos+=10;
      doc.setFontSize(10); doc.text(`Downloaded: ${new Date().toLocaleString('en-GB')}`, margin, yPos); yPos+=15;

      doc.setFont('helvetica','bold'); doc.setFontSize(14);
      doc.text('FREEDOM OF ASSOCIATION (Article 36)', margin, yPos); yPos+=10;
      doc.setFont('helvetica','normal'); doc.setFontSize(11);

      checkPageSpace(60);
      ['Article 36(1): Every person has the right to freedom of association, which includes the right to form, join or participate in the activities of an association of any kind.',
       '','Article 36(2): A person shall not be compelled to join an association of any kind.',
       '','Article 36(3): Any association shall have the freedom to acquire and dispose of movable and immovable property for the promotion of its objectives.',
       '','This fundamental right is essential for democratic participation and enables citizens to collectively address common interests, promote social welfare, and engage in community development activities through organized groups and associations.'
      ].forEach(line => { if (line.trim()) { yPos += addWrappedText(line, margin, yPos, 170, 6); } else { yPos+=4; } });
      yPos+=15;

      checkPageSpace(20);
      doc.setFont('helvetica','bold'); doc.setFontSize(14);
      doc.text('REGULATORY FRAMEWORK', margin, yPos); yPos+=10;

      [
        { title:'Societies Act (Chapter 108, Laws of Kenya)',
          items:['• Minimum membership requirements for registration (typically 10+ members)','• Proper constitution and bylaws outlining organizational structure and rules','• Democratic election of office bearers and leadership positions','• Mandatory annual general meetings for accountability and decision-making','• Comprehensive record keeping including minutes, financial records, and membership lists','• Prohibition of activities contrary to public policy or national security','• Requirement for proper dissolution procedures and asset distribution'] },
        { title:'Co-operative Societies Act (Chapter 490)',
          items:['• Minimum of 10 members for primary societies, higher for secondary societies','• Democratic control by members through one-member-one-vote principle','• Economic participation of members through share capital contributions','• Autonomy and independence from external control or interference','• Education and training programs for member development','• Limited interest on share capital to prevent speculative investment','• Surplus distribution based on patronage rather than capital contribution','• Cooperative audits and regulatory oversight by Commissioner for Co-operatives'] },
        { title:'Labour Relations Act, 2007',
          items:['• Right to form and join trade unions without interference or intimidation','• Protection against discrimination based on trade union membership','• Collective bargaining rights for wages, working conditions, and grievances','• Freedom from employer interference in union activities','• Protection of union officials from unfair dismissal or victimization','• Legal framework for industrial action and dispute resolution','• Requirement for union registration and democratic governance structures'] }
      ].forEach(section => {
        checkPageSpace(30);
        doc.setFont('helvetica','bold'); doc.setFontSize(12); doc.text(section.title, margin, yPos); yPos+=8;
        doc.setFont('helvetica','normal'); doc.setFontSize(10);
        section.items.forEach(item => { checkPageSpace(8); doc.text(item, margin+5, yPos); yPos+=6; });
        yPos+=8;
      });

      checkPageSpace(50);
      doc.setFont('helvetica','bold'); doc.setFontSize(14); doc.text('REGISTRATION REQUIREMENTS', margin, yPos); yPos+=10;
      doc.setFont('helvetica','bold'); doc.setFontSize(12); doc.text('Mandatory Documentation:', margin, yPos); yPos+=8;
      doc.setFont('helvetica','normal'); doc.setFontSize(10);
      [
        "1. Constitution: Written constitution clearly stating the association's objectives, membership rules, rights and obligations.",
        '', "2. Minutes: Certified minutes of the inaugural meeting with signatures of attendees.",
        '', "3. Member List: Complete list of founding members including full names and identification numbers.",
        '', "4. Objectives: Detailed statement of the association's specific objectives and planned activities.",
        '', "5. Financial Records: Evidence of financial capability including initial capital contributions.",
        '', "6. Certificate: Official registration certificate from the relevant ministry (optional but recommended)."
      ].forEach(req => {
        if (req.trim()) { checkPageSpace(12); yPos += addWrappedText(req, margin+5, yPos, 165, 5); yPos+=2; } else { yPos+=3; }
      });

      checkPageSpace(25); yPos+=10;
      doc.setFont('helvetica','bold'); doc.setFontSize(12); doc.text('Additional Legal Requirements:', margin, yPos); yPos+=8;
      doc.setFont('helvetica','normal'); doc.setFontSize(10);
      ['• Compliance with anti-money laundering and counter-terrorism financing regulations',
       '• Data protection compliance under the Data Protection Act',
       '• Tax registration and compliance with Kenya Revenue Authority requirements',
       '• Occupational health and safety compliance for workplace associations',
       '• Environmental impact assessment for groups involved in resource utilization'
      ].forEach(req => { checkPageSpace(8); doc.text(req, margin+5, yPos); yPos+=6; });
      yPos+=10;

      checkPageSpace(35); yPos+=10;
      doc.setFillColor(255,247,237); doc.rect(margin, yPos-5, 170, 35, 'F');
      doc.setTextColor(154,52,18); doc.setFont('helvetica','bold'); doc.setFontSize(11);
      doc.text('Important Note', margin+5, yPos); yPos+=6;
      doc.setFont('helvetica','normal'); doc.setFontSize(9);
      yPos += addWrappedText("All associations must operate within the framework of the Constitution of Kenya and relevant legislation. Registration provides legal recognition and protection for the association's activities.", margin+5, yPos, 160, 4);

      checkPageSpace(20); yPos+=15;
      doc.setFont('helvetica','bold'); doc.setFontSize(11); doc.setTextColor(0,0,0);
      doc.text('For Registration Assistance:', margin, yPos); yPos+=8;
      doc.setFont('helvetica','normal'); doc.setFontSize(9);
      doc.text('• Registrar of Societies: registrar@societies.go.ke', margin+5, yPos); yPos+=5;
      doc.text('• Department of Co-operatives: cooperatives@kilimo.go.ke', margin+5, yPos); yPos+=5;
      doc.text('• Ministry of Labour: info@labour.go.ke', margin+5, yPos); yPos+=10;
      doc.setFont('helvetica','italic'); doc.setFontSize(8);
      doc.text("This document is for informational purposes only. Please consult with legal professionals for specific guidance.", margin, yPos); yPos+=8;

      const ddt = new Date().toLocaleString('en-GB',{ day:'2-digit', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit', second:'2-digit', timeZoneName:'short' });
      doc.setFont('helvetica','normal'); doc.setFontSize(7);
      doc.text(`© ${new Date().getFullYear()} TBANK. All rights reserved.`, margin, yPos); yPos+=4;
      doc.text(`Downloaded on: ${ddt}`, margin, yPos);
      addWatermark();

      doc.save(`Group_Formation_Regulations_TBANK_${new Date().getTime()}.pdf`);
      showNotification('Regulations document downloaded successfully!', 'success');
    }

    function handleGroupTypeChange() { /* Group type selected - form continues normally */ }

    function showRegulationsModal() { document.getElementById('regulationsModal').style.display = 'block'; }
    function closeRegulationsModal(){ document.getElementById('regulationsModal').style.display = 'none'; }
  </script>

