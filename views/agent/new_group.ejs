  });
  yPos += 15;

  // Regulatory Framework
  checkPageSpace(20);
  doc.setFont('helvetica', 'bold');
  doc.setFontSize(14);
  doc.text('REGULATORY FRAMEWORK', margin, yPos);
  yPos += 10;

  // Societies Act
