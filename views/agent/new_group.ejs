     // ─── DOWNLOAD REGISTRATION FORM ────────────────────────────────────
    async function downloadRegistrationForm() {
      const { jsPDF } = window.jspdf;

      // 1. COLLECT ALL MEMBER DATA
      const members = [];

      // Collect trustees
      for (let i = 0; i < STD_TRUSTEES; i++) {
        const idx = i + 1;
        const title = document.getElementById(`t${idx}_title`).value.trim() || 'Trustee';
        members.push({
          index: idx,
          title: title,
          name: `Trustee ${idx}`, // We don't have name field, so use placeholder
          memberNumber: document.getElementById(`t${idx}_memberNumber`).value.trim() || '',
          phone: document.getElementById(`t${idx}_phone`).value.trim() || '',
          id: document.getElementById(`t${idx}_id`).value.trim() || '',
          type: 'trustee'
        });
      }

      // Collect officials
      for (let i = 0; i < currentOfficialsCount; i++) {
        const idx = STD_TRUSTEES + i + 1;
        const titleInput = document.getElementById(`official_${idx}_title`);
        const memberNumberInput = document.getElementById(`official_${idx}_memberNumber`);
        const phoneInput = document.getElementById(`official_${idx}_phone`);
        const idInput = document.getElementById(`official_${idx}_id`);
        members.push({
          index: idx,
          title: titleInput ? titleInput.value.trim() || 'Official' : 'Official',
          name: `Official ${i + 1}`,
          memberNumber: memberNumberInput ? memberNumberInput.value.trim() : '',
          phone: phoneInput ? phoneInput.value.trim() : '',
          id: idInput ? idInput.value.trim() : '',
          type: 'official'
        });
      }

      // Collect regular members
      for (let i = 0; i < regularMembersCount; i++) {
        const idx = STD_TRUSTEES + currentOfficialsCount + i + 1;
        const memberNumberInput = document.getElementById(`member_${idx}_memberNumber`);
        const phoneInput = document.getElementById(`member_${idx}_phone`);
        const idInput = document.getElementById(`member_${idx}_id`);
        members.push({
          index: idx,
          title: 'Member',
          name: `Member ${i + 1}`,
          memberNumber: memberNumberInput ? memberNumberInput.value.trim() : '',
          phone: phoneInput ? phoneInput.value.trim() : '',
          id: idInput ? idInput.value.trim() : '',
          type: 'member'
        });
      }

      // Get metadata
      const groupName = groupData.groupName || '';
      const location = `${groupData.ward || ''}, ${groupData.constituency || ''}, ${groupData.county || ''}`;
      const agentName = groupData.agentName || agent?.name || 'Unknown Agent';
      const agentPhone = groupData.agentPhone || agent?.phoneNumber || '';
      const downloadDateTime = new Date().toLocaleString('en-GB', {
        day: '2-digit',
        month: 'short',
        year: 'numeric',
        hour: '2-digit',
        minute: '2-digit'
      });

      // 2. CREATE PDF
      const doc = new jsPDF();
      const pageHeight = doc.internal.pageSize.height || doc.internal.pageSize.getHeight();
      const margin = 15;
      let yPos = margin;

      // Helper function to add text with word wrap
      function addWrappedText(text, x, y, maxWidth, lineHeight = 7) {
        const lines = doc.splitTextToSize(text, maxWidth);
        doc.text(lines, x, y);
        return lines.length * lineHeight;
      }

      // Helper to check if we need a new page
      function checkPageSpace(requiredHeight) {
        if (yPos + requiredHeight > pageHeight - margin) {
          doc.addPage();
          yPos = margin;
        }
      }

      // Header - Title
      doc.setFontSize(16);
      doc.setFont('helvetica', 'bold');
      doc.text('GROUP REGISTRATION FORM', margin, yPos);
      yPos += 10;

      doc.setFontSize(12);
      doc.setFont('helvetica', 'normal');
      doc.text(`Downloaded: ${downloadDateTime}`, margin, yPos);
      yPos += 7;

      // Group Information
      doc.setFont('helvetica', 'bold');
      doc.text('Group Information:', margin, yPos);
      yPos += 7;
      doc.setFont('helvetica', 'normal');
      doc.text(`Group Name: ${groupName}`, margin + 5, yPos);
      yPos += 6;
      doc.text(`Location: ${location}`, margin + 5, yPos);
      yPos += 6;
      doc.text(`Agent: ${agentName} (${agentPhone})`, margin + 5, yPos);
      yPos += 10;

      // Member List Header
      doc.setFont('helvetica', 'bold');
      doc.text('Registered Members', margin, yPos);
      yPos += 7;

      // Table Header
      doc.setFillColor(240, 240, 240);
      doc.rect(margin, yPos, 190, 8, 'F');
      doc.setFont('helvetica', 'bold');
      doc.text('Idx', margin + 3, yPos + 5);
      doc.text('Title', margin + 15, yPos + 5);
      doc.text('Name', margin + 45, yPos + 5);
      doc.text('Member No.', margin + 90, yPos + 5);
      doc.text('Phone', margin + 135, yPos + 5);
      doc.text('ID No.', margin + 165, yPos + 5);
      yPos += 8;

      // Table Rows
      doc.setFont('helvetica', 'normal');
      doc.setFontSize(10);

      for (let member of members) {
        checkPageSpace(15);
        // Alternate row colors
        if (members.indexOf(member) % 2 === 0) {
          doc.setFillColor(250, 250, 250);
          doc.rect(margin, yPos, 190, 7, 'F');
        }

        doc.text(String(member.index), margin + 3, yPos + 5);
        doc.text(member.title, margin + 15, yPos + 5);
        doc.text(member.name, margin + 45, yPos + 5);
        doc.text(member.memberNumber || '-', margin + 90, yPos + 5);
        doc.text(member.phone || '-', margin + 135, yPos + 5);
        doc.text(member.id || '-', margin + 165, yPos + 5);
        yPos += 7;
      }

      yPos += 5;

      // Summary line
      const totalMembers = members.length;
      checkPageSpace(20);
      doc.setFontSize(11);
      doc.setFont('helvetica', 'bold');
      doc.text(`Total Members: ${totalMembers}`, margin, yPos);
      yPos += 15;

      // Prepared By Section
      doc.setFont('helvetica', 'bold');
      doc.text('Prepared By:', margin, yPos);
      yPos += 7;
      doc.setFont('helvetica', 'normal');
      doc.setFontSize(10);
      doc.text(`Name: ${agentName}`, margin + 5, yPos);
