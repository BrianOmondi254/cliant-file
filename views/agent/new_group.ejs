<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>New Group Activation | Agent Portal</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
    rel="stylesheet">
   <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
   <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
 
   <style>
    :root {
      --primary: #0f9d58;
      --primary-dark: #0b7d46;
      --primary-light: #ecfdf5;
      --secondary: #4285f4;
      --secondary-light: #e8f0fe;
      --accent: #5f9ea0;
      --dark: #1e293b;
      --slate: #64748b;
      --light: #f8fafc;
      --white: #ffffff;
      --danger: #ef4444;
      --warning: #f59e0b;
      --shadow: 0 10px 25px -5px rgba(0, 0, 0, .1), 0 8px 10px -6px rgba(0, 0, 0, .1);
      --shadow-lg: 0 20px 25px -5px rgba(0, 0, 0, .1), 0 10px 10px -5px rgba(0, 0, 0, .1);
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: 'Inter', sans-serif;
      background: linear-gradient(160deg, #0f2027, #203a43, #2c5364);
      display: flex;
      justify-content: center;
      align-items: flex-start;
      min-height: 100vh;
      padding: 20px;
      color: var(--dark);
    }

    .container {
      background: var(--white);
      width: 100%;
      max-width: 520px;
      border-radius: 28px;
      box-shadow: var(--shadow-lg);
      overflow: visible;
      position: relative;
      animation: slideIn 0.5s cubic-bezier(0.4, 0, 0.2, 1);
      margin: auto;
      z-index: 100;
    }

    @keyframes slideIn {
      from {
        opacity: 0;
        transform: translateY(30px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    /* ─── HEADER ─── */
    .header {
      background: linear-gradient(135deg, var(--primary), #34d399);
      padding: 35px 25px;
      color: var(--white);
      text-align: center;
      position: relative;
    }

    .header h1 {
      font-size: 22px;
      font-weight: 800;
      margin-bottom: 5px;
      letter-spacing: -.5px;
    }

    .header p {
      font-size: 13px;
      opacity: .9;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .back-btn {
      position: absolute;
      top: 25px;
      left: 20px;
      color: var(--white);
      text-decoration: none;
      font-size: 18px;
      opacity: .8;
      transition: opacity .2s;
    }



    /* ─── CONTENT ─── */
    .content {
      padding: 28px;
      position: relative;
      z-index: 10;
    }

    .group-info-stripe {
      background: var(--light);
      border-radius: 16px;
      padding: 14px 18px;
      margin-bottom: 24px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      border: 1px solid #e2e8f0;
    }

    .group-name-mini {
      font-weight: 800;
      font-size: 15px;
      color: var(--dark);
    }

    .group-loc-mini {
      font-size: 11px;
      color: var(--slate);
      font-weight: 600;
    }

    /* ─── FORM STEPS ─── */
    .form-step {
      display: none;
      animation: fadeIn .4s ease;
      position: relative;
      z-index: 10;
    }

    .form-step.active {
      display: block;
    }

    @keyframes fadeIn {
      from {
        opacity: 0;
        transform: translateX(10px);
      }

      to {
        opacity: 1;
        transform: translateX(0);
      }
    }

    .input-group {
      margin-bottom: 20px;
    }

    .input-group label {
      display: block;
      font-size: 11px;
      font-weight: 800;
      color: var(--slate);
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 8px;
    }

    .input-wrapper {
      position: relative;
    }

    .input-wrapper input,
    .input-wrapper select {
      width: 100%;
      padding: 14px 18px;
      border: 2px solid #e2e8f0;
      border-radius: 14px;
      font-size: 15px;
      font-weight: 600;
      color: var(--dark);
      transition: all .3s ease;
      outline: none;
      background: #fcfdfe;
      font-family: 'Inter', sans-serif;
    }

    .input-wrapper input:focus,
    .input-wrapper select:focus {
      border-color: var(--primary);
      box-shadow: 0 0 0 5px var(--primary-light);
    }

    .input-wrapper input[readonly],
    .input-wrapper input.locked {
      background: #f1f5f9;
      color: var(--slate);
      cursor: not-allowed;
    }

    .lock-icon {
      position: absolute;
      right: 16px;
      top: 50%;
      transform: translateY(-50%);
      color: var(--slate);
      font-size: 13px;
      pointer-events: none;
    }

    .compliance-note {
      font-size: 11px;
      font-weight: 600;
      color: var(--slate);
      margin-top: 7px;
      display: flex;
      align-items: center;
      gap: 6px;
    }

    /* ─── FEE CARD ─── */
    .fee-card {
      background: var(--primary-light);
      border: 1.5px dashed var(--primary);
      border-radius: 20px;
      padding: 22px;
      text-align: center;
      margin-bottom: 24px;
      position: relative;
      z-index: 5;
    }

    .fee-label {
      font-size: 11px;
      text-transform: uppercase;
      font-weight: 800;
      color: var(--primary-dark);
      letter-spacing: 1px;
      margin-bottom: 8px;
    }

    .fee-amount {
      font-size: 30px;
      font-weight: 900;
      color: var(--primary-dark);
    }

    /* ─── PAYMENT OPTIONS ─── */
    .payment-options {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 14px;
      margin-top: 16px;
    }

    .payment-option {
      border: 2px solid #e2e8f0;
      border-radius: 16px;
      padding: 20px 12px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all .3s ease;
      background: var(--white);
      position: relative;
      z-index: 1;
    }

    .payment-option:hover {
      border-color: var(--primary);
      transform: translateY(-2px);
    }

    .payment-option.active {
      border-color: var(--primary);
      background: var(--primary-light);
      box-shadow: 0 4px 12px rgba(15, 157, 88, .15);
    }

    .payment-option.active-tbank {
      border-color: var(--secondary);
      background: var(--secondary-light);
    }

    .payment-option span {
      font-size: 13px;
      font-weight: 700;
      color: var(--dark);
    }

    .mpesa-color {
      color: #40c057;
    }

    .tbank-color {
      color: var(--secondary);
    }

    /* ─── SECTION HEADER (trustee / official / member) ─── */
    .section-header {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 12px 16px;
      border-radius: 14px;
      margin-bottom: 14px;
      margin-top: 6px;
      font-size: 13px;
      font-weight: 800;
      letter-spacing: .5px;
    }

    .section-header.trustee {
      background: #eff6ff;
      color: #1d4ed8;
      border: 1px solid #bfdbfe;
    }

    .section-header.official {
      background: #fefce8;
      color: #92400e;
      border: 1px solid #fde68a;
    }

    .section-header.member {
      background: var(--primary-light);
      color: var(--primary-dark);
      border: 1px solid #a7f3d0;
    }

    /* ─── MEMBER CARD ─── */
    .member-card {
      background: var(--light);
      border-radius: 16px;
      border: 1px solid #e2e8f0;
      padding: 18px;
      margin-bottom: 14px;
      transition: box-shadow .2s;
    }

    .member-card:hover {
      box-shadow: 0 4px 16px rgba(0, 0, 0, .07);
    }

    .member-card-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 14px;
    }

    .member-card-title {
      font-size: 13px;
      font-weight: 800;
      color: var(--dark);
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .member-card-title .badge {
      font-size: 10px;
      font-weight: 700;
      padding: 3px 9px;
      border-radius: 20px;
      background: #e0e7ff;
      color: #3730a3;
    }

    .member-card-title .badge.trustee {
      background: #dbeafe;
      color: #1d4ed8;
    }

    .member-card-title .badge.official {
      background: #fef9c3;
      color: #92400e;
    }

    .member-card-title .badge.member {
      background: #dcfce7;
      color: #166534;
    }

    .row-2 {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }

    /* ─── BUTTONS ─── */
    .btn-container {
      margin-top: 28px;
      position: relative;
      z-index: 10;
    }

    button {
      width: 100%;
      padding: 15px;
      border: none;
      border-radius: 14px;
      font-size: 15px;
      font-weight: 800;
      cursor: pointer;
      transition: all .3s ease;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      font-family: 'Inter', sans-serif;
      position: relative;
      z-index: 20;
    }

    button:disabled {
      background: #94a3b8 !important;
      cursor: not-allowed;
      opacity: 0.7;
      pointer-events: auto !important;
      z-index: 100 !important;
    }

    button:disabled:hover {
      transform: none;
      box-shadow: none;
    }

    .btn-primary {
      background: var(--primary);
      color: var(--white);
      box-shadow: 0 8px 15px -3px rgba(15, 157, 88, .3);
    }

    .btn-primary:hover {
      background: var(--primary-dark);
      transform: translateY(-2px);
      box-shadow: 0 16px 20px -5px rgba(15, 157, 88, .4);
    }

    .btn-secondary {
      background: var(--light);
      color: var(--dark);
      border: 2px solid #e2e8f0;
      margin-top: 10px;
    }

    .btn-secondary:hover {
      background: #f1f5f9;
    }

    .btn-tbank {
      background: var(--secondary);
      color: var(--white);
      box-shadow: 0 8px 15px -3px rgba(66, 133, 244, .3);
    }

    .btn-tbank:hover {
      background: #3071e8;
      transform: translateY(-2px);
    }

    .waiting-note {
      background: #fff7ed;
      border: 1px solid #ffedd5;
      padding: 14px;
      border-radius: 12px;
      font-size: 12px;
      color: #9a3412;
      font-weight: 600;
      margin-top: 18px;
      display: flex;
      gap: 10px;
    }

    /* ─── PROGRESS RING ─── */
    .progress-ring-wrap {
      text-align: center;
      padding: 30px 0;
    }

    .progress-ring-wrap i {
      font-size: 40px;
      color: var(--secondary);
      margin-bottom: 16px;
      animation: spin 1s linear infinite;
    }

    @keyframes spin {
      to {
        transform: rotate(360deg);
      }
    }

    /* ─── DIVIDER ─── */
    .divider {
      border: none;
      border-top: 1px solid #e2e8f0;
      margin: 22px 0;
    }

    /* ─── MEMBERSHIP SUMMARY CARD ─── */
    .membership-summary {
      border-radius: 18px;
      border: 1.5px solid #e2e8f0;
      overflow: hidden;
      margin-bottom: 20px;
      box-shadow: 0 2px 12px rgba(0, 0, 0, .05);
    }

    .summary-rows {
      display: flex;
    }

    .summary-col {
      flex: 1;
      padding: 14px 10px;
      text-align: center;
      border-right: 1px solid #e2e8f0;
      transition: background .2s;
    }

    .summary-col:last-child {
      border-right: none;
    }

    .summary-col-val {
      font-size: 22px;
      font-weight: 900;
      line-height: 1;
    }

    .summary-col-lbl {
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .8px;
      margin-top: 4px;
      color: var(--slate);
    }

    .summary-col.c-trustee {
      background: #eff6ff;
    }

    .summary-col.c-official {
      background: #fefce8;
    }

    .summary-col.c-member {
      background: var(--primary-light);
    }

    .summary-col.c-total {
      background: #f1f5f9;
    }

    .summary-col.c-trustee .summary-col-val {
      color: #1d4ed8;
    }

    .summary-col.c-official .summary-col-val {
      color: #92400e;
    }

    .summary-col.c-member .summary-col-val {
      color: var(--primary-dark);
    }

    .summary-col.c-total .summary-col-val {
      color: var(--dark);
    }

    /* Scroll for member form */
    #step-members {
      height: auto;
      overflow-y: auto;
      padding-right: 4px;
      position: relative;
      z-index: 5;
    }

    #step-members::-webkit-scrollbar {
      width: 5px;
    }

    #step-members::-webkit-scrollbar-track {
      background: #f1f5f9;
      border-radius: 10px;
    }

    #step-members::-webkit-scrollbar-thumb {
      background: var(--primary);
      border-radius: 10px;
    }

    /* Mobile responsiveness */
    @media (max-width: 600px) {
      .container {
        max-width: 100%;
        margin: 0;
        padding: 10px;
      }

      .header {
        padding: 25px 15px;
      }

      .header h1 {
        font-size: 18px;
      }

      .content {
        padding: 20px 15px;
      }

      .row-2 {
        grid-template-columns: 1fr;
        gap: 10px;
      }

      .btn-container button {
        padding: 12px;
        font-size: 14px;
      }

      .input-wrapper input,
      .input-wrapper select {
        padding: 12px 16px;
        font-size: 14px;
      }

      .member-card {
        padding: 14px;
      }

      .member-card-head {
        flex-direction: column;
        align-items: flex-start;
        gap: 8px;
      }

      .section-header {
        padding: 10px 12px;
        font-size: 12px;
      }

      .fee-card {
        padding: 18px;
      }

      .payment-options {
        grid-template-columns: 1fr;
      }
    }

  </style>
</head>

  <body>
  <div class="container">
    <!-- HEADER -->
    <div class="header">
      <a href="/agent" class="back-btn"><i class="fas fa-arrow-left"></i></a>
      <h1>Members Payment and Registration</h1>
      <p>Group Activation Process</p>
    </div>

    <div class="content">
      <!-- GROUP INFO STRIPE -->
      <div class="group-info-stripe">
        <div>
          <div class="group-name-mini">
            <%= group.groupName %>
          </div>
          <div class="group-loc-mini">
            <%= group.ward %> · <%= group.constituency %>
          </div>
        </div>
        <div style="font-size:14px; font-weight:800; color:var(--primary);">
          <i class="fas fa-shield-halved"></i>
        </div>
      </div>

      <!-- ═══════════════════════════════════════════ -->
      <!-- STEP 1 : MEMBER COUNT                       -->
      <!-- ═══════════════════════════════════════════ -->
      <div class="form-step active" id="step1">
        <div class="input-group">
          <label>Total Membership Count</label>
          <div class="input-wrapper">
            <input type="number" id="totalMembers" placeholder="Minimum <%= registrationConfig.members %> members"
              min="<%= registrationConfig.members %>" max="<%= registrationConfig.maxMembers %>">
          </div>
          <div class="compliance-note">
            <i class="fas fa-info-circle"></i>
            Compliance: Min <%= registrationConfig.members %> – Max <%= registrationConfig.maxMembers %> Members
          </div>
        </div>
        <div id="step1Notification" style="min-height:20px; margin-bottom:8px;"></div>
        <div class="btn-container">
          <button class="btn-primary" onclick="proceedToPayment()">
            Proceed to Payment <i class="fas fa-chevron-right"></i>
          </button>
        </div>
      </div>

      <!-- ═══════════════════════════════════════════ -->
      <!-- STEP 2 : PAYMENT METHOD                     -->
      <!-- ═══════════════════════════════════════════ -->
      <div class="form-step" id="step2">
        <div class="fee-card">
          <div class="fee-label">Group Registration Fee (<span id="countDisplay">0</span> members)</div>
          <div class="fee-amount" id="totalFeeDisplay">KES 0.00</div>
          <div style="font-size:11px; font-weight:700; color:var(--primary-dark); margin-top:5px; opacity:.8;"
            id="feeRateDisplay">KES 50 per member</div>
        </div>

        <div class="input-group">
          <label>Select Payment Method</label>
          <div class="payment-options">
            <div class="payment-option" id="optTbank" onclick="selectPayment('tbank')">
              <span>Agent</span>
            </div>
            <div class="payment-option" id="optMpesa" onclick="selectPayment('mpesa')">
              <span>M-Pesa</span>
            </div>
          </div>
        </div>

        <div class="btn-container">
          <button class="btn-primary" id="continueBtn" onclick="proceedToFinal()" disabled>
            Continue <i class="fas fa-chevron-right"></i>
          </button>
        </div>
      </div>

      <!-- ═══════════════════════════════════════════ -->
      <!-- STEP 3a : MPESA STK PUSH                    -->
      <!-- ═══════════════════════════════════════════ -->
      <div class="form-step" id="step3-mpesa">
        <div id="mpesaPrompt">
          <div class="input-group">
            <label>M-Pesa Phone Number</label>
            <div class="input-wrapper">
              <input type="tel" id="stkPhone" placeholder="254XXX or 07/01XXXXXXXX" maxlength="12">
            </div>
            <div class="compliance-note">
              <i class="fas fa-shield-check"></i>
              Total: <span id="stkAmountDisplay">KES 0.00</span>
            </div>
          </div>
          <div class="btn-container">
            <button class="btn-primary" onclick="startSTKPush()">
              Process Payment <i class="fas fa-check"></i>
            </button>
            <button class="btn-secondary" onclick="goBack(0,2,'step3-mpesa')">
              <i class="fas fa-chevron-left"></i> Back
            </button>
          </div>
        </div>

        <div id="loadingStatus" style="display:none; text-align:center; padding:40px 0;">
          <i class="fas fa-spinner fa-spin" style="font-size:40px; color:var(--primary); margin-bottom:20px;"></i>
          <h3 style="font-size:18px;">Processing Request...</h3>
          <p style="font-size:13px; color:var(--slate); margin-top:10px;">Check your phone for the M-Pesa STK push.</p>
          <div class="waiting-note">
            <i class="fas fa-microchip"></i>
            <span>System Note: Awaiting full M-Pesa API integration.</span>
          </div>
          <button class="btn-primary" style="margin-top:28px;" onclick="window.location.href='/agent'">
            Back to Dashboard
          </button>
        </div>
      </div>

      <!-- ═══════════════════════════════════════════ -->
      <!-- STEP 3b : T-BANK MEMBER REGISTRATION FORM  -->
      <!-- ═══════════════════════════════════════════ -->
      <div class="form-step" id="step3-tbank">
         <div id="step-members">

          <!-- ── MEMBERSHIP BREAKDOWN SUMMARY ── -->
          <div class="membership-summary">
            <div class="summary-rows">
              <div class="summary-col c-trustee">
                <div class="summary-col-val" id="sumTrustees">3</div>
                <div class="summary-col-lbl">Trustees</div>
              </div>
              <div class="summary-col c-official">
                <div class="summary-col-val" id="sumOfficials">—</div>
                <div class="summary-col-lbl">Officials</div>
              </div>
              <div class="summary-col c-member">
                <div class="summary-col-val" id="sumMembers">—</div>
                <div class="summary-col-lbl">Members</div>
              </div>
              <div class="summary-col c-total">
                <div class="summary-col-val" id="sumTotal">—</div>
                <div class="summary-col-lbl">Total</div>
              </div>
            </div>
          </div>

           <!-- ── TRUSTEES ── -->
           <div style="display: flex; justify-content: flex-end; margin-bottom: 8px;">
             <button onclick="downloadGroupRegistrationForm()" style="background: #8b5cf6; color: white; border: none; padding: 8px 14px; border-radius: 8px; font-size: 0.85rem; cursor: pointer; font-weight: 600; box-shadow: 0 2px 4px rgba(139, 92, 246, 0.2);">
               <i class="fas fa-file-pdf" style="margin-right: 5px;"></i> Download Form
             </button>
           </div>
           <div class="section-header trustee">
             <i class="fas fa-user-shield"></i> Trustees
             <span style="background: #dbeafe; color: #1d4ed8; padding: 3px 10px; border-radius: 15px; font-size: 0.8rem; font-weight: 700; margin-left: 8px; display: inline-block; white-space: nowrap;">
               <span id="trusteesCountLabel"><%= registrationConfig.trustees %></span> Required
             </span>
           </div>
          <div id="trusteesContainer"></div>

           <hr class="divider">

          <!-- ── OFFICIALS ── -->
          <div class="section-header official">
            <i class="fas fa-user-tie"></i> Officials (<span id="officialsCountLabel">0</span> / <span id="officialsMaxLabel"><%= registrationConfig.officials %></span>)
          </div>
          <div id="officialsContainer"></div>
          <button class="btn-secondary" id="addOfficialBtn" onclick="addOfficial()" style="margin-top: 12px;">
            <i class="fas fa-plus"></i> Add Official
          </button>

          <hr class="divider">

          <!-- ── MEMBERS ── -->
          <div class="section-header member">
            <i class="fas fa-users"></i> Members (<span id="membersCountLabel">0</span>)
          </div>
          <div id="membersContainer"></div>

        </div><!-- end #step-members -->

         <div id="verifyNotification" style="min-height:20px; margin-bottom:8px;"></div>

          <div class="btn-container" style="padding-top:8px; display:none; position:relative;" id="memberButtons">
           <button class="btn-tbank" onclick="verifyMembers()">
             <i class="fas fa-clipboard-check"></i> Verify Members
           </button>
           <button class="btn-secondary" onclick="goBack(0,2,'step3-tbank')">
             <i class="fas fa-chevron-left"></i> Back
           </button>
         </div>
      </div>

      <!-- ═══════════════════════════════════════════ -->
      <!-- STEP 4 : VERIFICATION FORM                  -->
      <!-- ═══════════════════════════════════════════ -->
      <div class="form-step" id="step4-verify">
        <div style="margin-bottom:20px; text-align:center;">
          <h3 style="font-size:18px; font-weight:800; color:var(--primary-dark); margin-bottom:8px;">
            <i class="fas fa-clipboard-check"></i> Member Verification
          </h3>
          <p style="font-size:12px; color:var(--slate);">Review all member details before final submission</p>
        </div>

        <div id="verificationList" style="max-height:50vh; overflow-y:auto; padding-right:4px;"></div>

         <div class="btn-container" style="padding-top:12px;">
           <button class="btn-primary" onclick="downloadRegistrationForm()" style="background:var(--secondary);">
             <i class="fas fa-download"></i> Download Registration Form
           </button>
           <button class="btn-tbank" onclick="confirmAndSubmit()">
             <i class="fas fa-check-circle"></i> Confirm & Submit Registration
           </button>
           <button class="btn-secondary" onclick="goBackToForm()">
             <i class="fas fa-chevron-left"></i> Back to Edit
           </button>
         </div>
      </div>

      <!-- ═══════════════════════════════════════════ -->
      <!-- STEP 5 : SUBMITTING (T-BANK)                -->
      <!-- ═══════════════════════════════════════════ -->
      <div class="form-step" id="step5">
        <div style="text-align:center; padding:40px 0;">
          <i class="fas fa-circle-notch fa-spin"
            style="font-size:42px; color:var(--secondary); margin-bottom:20px;"></i>
          <h3 style="font-size:18px; font-weight:800;">Submitting Registration...</h3>
          <p style="font-size:13px; color:var(--slate); margin-top:10px;">T-Bank is processing the group
            payment.<br>Please wait.</p>
          <div class="waiting-note" style="margin-top:22px;">
            <i class="fas fa-university"></i>
            <span id="submitStatusMsg">Connecting to T-Bank and saving members...</span>
          </div>
          <button class="btn-primary" id="backToDashBtn" style="margin-top:28px; display:none;"
            onclick="window.location.href='/agent'">
            Back to Dashboard
          </button>
        </div>
      </div>

    </div><!-- .content -->
  </div><!-- .container -->

  <script>
    // ─── NOTIFICATION HELPER ──────────────────────────────────
    function showNotification(message, type = 'error') {
      // Determine the notification container based on current step
      let notificationId = 'verifyNotification'; // default for step3-tbank
      const activeStep = document.querySelector('.form-step.active');
      if (activeStep && activeStep.id === 'step1') {
        notificationId = 'step1Notification';
      }

      const inlineNotif = document.getElementById(notificationId);
      if (inlineNotif) {
        const icon = type === 'error' ? 'fa-exclamation-circle' :
                      type === 'success' ? 'fa-check-circle' : 'fa-exclamation-triangle';
        const bgColor = type === 'error' ? '#fee2e2' :
                        type === 'success' ? '#dcfce7' : '#fef3c7';
        const textColor = type === 'error' ? '#991b1b' :
                          type === 'success' ? '#166534' : '#92400e';

        inlineNotif.innerHTML = `
          <div style="background:${bgColor}; color:${textColor}; padding:12px 16px; border-radius:10px;
                      font-size:12px; font-weight:600; display:flex; align-items:center; gap:8px;
                      border-left:4px solid ${textColor}; animation:fadeIn .3s ease;">
            <i class="fas ${icon}" style="font-size:16px;"></i>
            <span>${message}</span>
          </div>
        `;

        // Clear after 5 seconds
        setTimeout(() => {
          inlineNotif.innerHTML = '';
        }, 5000);
      }
    }

    // ─── CONFIG ───────────────────────────────────────────────
    const groupData = <%- JSON.stringify(group) %>;
    const config = <%- JSON.stringify(registrationConfig) %>;
    const STD_TRUSTEES = Math.min(3, parseInt(config.trustees) || 3);
    const STD_OFFICIALS = parseInt(config.officials) || 4;
    const MIN_MEMBERS = parseInt(config.members) || 10;
    const MAX_MEMBERS = parseInt(config.maxMembers) || 40;
    const BASE_FEE = parseFloat(config.newGroupFee) || 50;

    let selectedMethod = null;
    let totalMembersCount = 0;
    let totalPayableAmount = 0;
    let regularMembersCount = 0;  // total - trustees - officials
    let currentOfficialsCount = 0;  // track how many official forms are shown



    function showStep(id) {
      document.querySelectorAll('.form-step').forEach(s => s.classList.remove('active'));
      document.getElementById(id).classList.add('active');
    }

    function showMemberForm() {
      document.getElementById('step-members').style.display = 'block';
      // Also show the buttons
      document.getElementById('memberButtons').style.display = 'flex';
    }

    // ─── STEP 1 → 2 ───────────────────────────────────────────
    function proceedToPayment() {
      totalMembersCount = parseInt(document.getElementById('totalMembers').value);
      if (isNaN(totalMembersCount) || totalMembersCount < MIN_MEMBERS || totalMembersCount > MAX_MEMBERS) {
        showNotification(`Membership count must be between ${MIN_MEMBERS} and ${MAX_MEMBERS}.`);
        return;
      }
      totalPayableAmount = totalMembersCount * BASE_FEE;
      document.getElementById('countDisplay').textContent = totalMembersCount;
      document.getElementById('totalFeeDisplay').textContent = `KES ${totalPayableAmount.toLocaleString()}.00`;
      document.getElementById('feeRateDisplay').textContent = `KES ${BASE_FEE.toLocaleString()} per member`;
       document.getElementById('stkAmountDisplay').textContent = `KES ${totalPayableAmount.toLocaleString()}.00`;
       showStep('step2');
    }

    // ─── PAYMENT SELECTION ────────────────────────────────────
    function selectPayment(method) {
      selectedMethod = method;
      document.querySelectorAll('.payment-option').forEach(o => {
        o.classList.remove('active', 'active-tbank');
      });
      if (method === 'tbank') {
        document.getElementById('optTbank').classList.add('active-tbank');
      } else {
        document.getElementById('optMpesa').classList.add('active');
      }
      // Enable continue button after selection
      document.getElementById('continueBtn').disabled = false;
    }

     // ─── STEP 2 → 3 ───────────────────────────────────────────
     function proceedToFinal() {
       if (!selectedMethod) { showNotification('Please select a payment method.'); return; }
      if (selectedMethod === 'mpesa') {
        showStep('step3-mpesa');
       } else {
         buildMemberForm();
         showMemberForm();
         showStep('step3-tbank');
       }
    }

    // ─── BACK ─────────────────────────────────────────────────
    function goBack(fromStepNum, toStepNum, fromStepId) {
      const fromId = fromStepId || `step${fromStepNum}`;
      const toId = `step${toStepNum}`;
      showStep(toId);
      // Hide member buttons when going back
      if (toId === 'step2') {
        document.getElementById('memberButtons').style.display = 'none';
      }
    }

    // ─── BUILD TRUSTEE FIELDS DYNAMICALLY ─────────────────────
    function buildTrustees() {
      const container = document.getElementById('trusteesContainer');
      container.innerHTML = '';
      
      const trusteeIcons = ['fa-crown', 'fa-coins', 'fa-pen-nib', 'fa-user-shield'];
      const defaultTitles = ['Chairperson', 'Treasurer', 'Secretary', 'Trustee'];

      for (let i = 0; i < STD_TRUSTEES; i++) {
        const idx = i + 1;
        const isChairperson = i === 0;
        const div = document.createElement('div');
        div.className = 'member-card';
        div.innerHTML = `
            <div class="member-card-head">
              <div class="member-card-title">
                <i class="fas ${trusteeIcons[i] || 'fa-user-shield'}" style="color:#1d4ed8;"></i>
                Trustee ${idx}
              </div>
              <span style="font-size:11px; color:#1d4ed8; font-weight:600; background:#dbeafe; padding:3px 9px; border-radius:20px;">Index ${idx}</span>
            </div>
            <!-- Title full-width -->
            <div class="input-group" style="margin-bottom:12px;">
              <label>Title</label>
              <div class="input-wrapper">
                <select id="t${idx}_title" ${isChairperson ? 'class="locked" disabled' : 'onchange="updateTrusteeTitles()"'}>
                  <option value="" disabled>Select Title</option>
                  <option value="Chairperson" ${isChairperson ? 'selected' : ''}>Chairperson</option>
                  <option value="Treasurer" ${idx === 2 && !isChairperson ? 'selected' : ''}>Treasurer</option>
                  <option value="Secretary" ${idx === 3 && !isChairperson ? 'selected' : ''}>Secretary</option>
                  <option value="Auditor">Auditor</option>
                  <option value="Trustee">Trustee</option>
                </select>
                ${isChairperson ? '<i class="fas fa-lock lock-icon"></i>' : ''}
              </div>
            </div>
            <!-- Phone full-width -->
            <div class="input-group" style="margin-bottom:12px;">
              <label>Phone Number</label>
              <div class="input-wrapper">
                <input type="tel" id="t${idx}_phone" ${isChairperson ? 'value="<%= group.phone %>" readonly class="locked"' : 'placeholder="Enter phone number"'} maxlength="12">
                ${isChairperson ? '<i class="fas fa-lock lock-icon"></i>' : ''}
              </div>
              ${isChairperson ? '<div class="compliance-note"><i class="fas fa-info-circle"></i> Chairperson phone pre-filled</div>' : ''}
            </div>
            <!-- ID full-width -->
            <div class="input-group">
              <label>ID Number <span
                  style="font-weight:500; text-transform:none; letter-spacing:0;">(optional)</span></label>
              <div class="input-wrapper">
                <input type="text" id="t${idx}_id" placeholder="National ID" maxlength="10">
              </div>
            </div>
        `;
        container.appendChild(div);
      }
      // Update title dropdowns to hide already selected titles
      updateTrusteeTitles();
    }

    // ─── BUILD MEMBER FORM (officials + regular members) ──────
    function buildMemberForm() {
      regularMembersCount = totalMembersCount - STD_TRUSTEES;  // don't subtract officials since they're optional
      if (regularMembersCount < 0) regularMembersCount = 0;

      // ── Populate summary card ──
      document.getElementById('sumTrustees').textContent = STD_TRUSTEES;
      document.getElementById('sumOfficials').textContent = '0';  // will update as officials are added
      document.getElementById('sumMembers').textContent = regularMembersCount;
      document.getElementById('sumTotal').textContent = totalMembersCount;

      document.getElementById('officialsMaxLabel').textContent = STD_OFFICIALS;
      document.getElementById('membersCountLabel').textContent = regularMembersCount;
      document.getElementById('trusteesCountLabel').textContent = STD_TRUSTEES;
      
      buildTrustees();
      buildOfficials();
      buildMembers();
    }

    function officialTitles() {
      return ['Auditor', 'Ass. Chairperson', 'Committee Member', 'Vice Secretary'];
    }

    function buildOfficials() {
      const container = document.getElementById('officialsContainer');
      container.innerHTML = '';
      currentOfficialsCount = 0;

      // Build datalist once
      if (!document.getElementById('officialTitleList')) {
        const dl = document.createElement('datalist');
        dl.id = 'officialTitleList';
        ['Auditor', 'Ass. Chairperson', 'Ass. Secretary', 'Committee Member', 'Advisor'].forEach(t => {
          const opt = document.createElement('option');
          opt.value = t; dl.appendChild(opt);
        });
        document.body.appendChild(dl);
      }

      // Show only 1 official form by default
      addOfficial();

      // Update the button visibility
      updateAddOfficialButton();
    }

    function addOfficial() {
      if (currentOfficialsCount >= STD_OFFICIALS) return;

      const container = document.getElementById('officialsContainer');
      const i = currentOfficialsCount;
      const idx = STD_TRUSTEES + i + 1;
      const key = `official_${idx}`;

      const div = document.createElement('div');
      div.className = 'member-card';
      div.id = `official_card_${i}`;
      div.innerHTML = `
        <div class="member-card-head">
          <div class="member-card-title">
            <i class="fas fa-user-tie" style="color:#92400e;"></i>
            Official ${i + 1}
            <span class="badge official" id="${key}_badge">${i === 0 ? 'Required' : 'Optional'}</span>
          </div>
          <div style="display:flex; align-items:center; gap:8px;">
            <span style="font-size:11px; color:#92400e; font-weight:600; background:#fef9c3; padding:3px 9px; border-radius:20px;">Index ${idx}</span>
            <button onclick="removeOfficial(${i})" style="width:auto; padding:6px 10px; font-size:11px; background:#fee2e2; color:#991b1b; border-radius:8px; border:none; cursor:pointer;${i === 0 ? ' display:none;' : ''}">
              <i class="fas fa-times"></i>
            </button>
          </div>
        </div>
        <!-- Title full-width -->
        <div class="input-group" style="margin-bottom:12px;">
          <label>Title (optional)</label>
          <div class="input-wrapper">
            <input type="text" id="${key}_title"
              placeholder="Select or type title"
              list="officialTitleList"
              autocomplete="off"
              oninput="updateOfficialBadge('${key}', this.value)">
          </div>
        </div>
        <!-- Phone full-width -->
        <div class="input-group" style="margin-bottom:12px;">
          <label>Phone (optional)</label>
          <div class="input-wrapper">
            <input type="tel" id="${key}_phone" placeholder="Enter phone number" maxlength="12">
          </div>
        </div>
        <!-- ID full-width -->
        <div class="input-group">
          <label>ID Number <span style="font-weight:500; text-transform:none; letter-spacing:0;">(optional)</span></label>
          <div class="input-wrapper">
            <input type="text" id="${key}_id" placeholder="National ID" maxlength="10">
          </div>
        </div>
      `;

      container.appendChild(div);
      currentOfficialsCount++;

      // Recalculate regular members (total - trustees - current officials)
      regularMembersCount = totalMembersCount - STD_TRUSTEES - currentOfficialsCount;
      if (regularMembersCount < 0) regularMembersCount = 0;

       // Update summary card
        document.getElementById('sumOfficials').textContent = currentOfficialsCount;
        document.getElementById('sumMembers').textContent = regularMembersCount;
        document.getElementById('officialsCountLabel').textContent = currentOfficialsCount;
        document.getElementById('membersCountLabel').textContent = regularMembersCount;

        buildMembers();

       // Show the buttons after building the member form
       document.getElementById('memberButtons').style.display = 'flex';

      // Update button visibility and remove buttons
      updateAddOfficialButton();
      updateRemoveButtons();
    }

    function removeOfficial(index) {
      // Prevent removing the last official (minimum 1 required)
      if (currentOfficialsCount <= 1) {
        showNotification('At least 1 official is required.');
        return;
      }

      const card = document.getElementById(`official_card_${index}`);
      if (card) {
        card.remove();
        currentOfficialsCount--;

        // Recalculate regular members (total - trustees - current officials)
        regularMembersCount = totalMembersCount - STD_TRUSTEES - currentOfficialsCount;
        if (regularMembersCount < 0) regularMembersCount = 0;

        // Update summary card
        document.getElementById('sumOfficials').textContent = currentOfficialsCount;
        document.getElementById('sumMembers').textContent = regularMembersCount;
        document.getElementById('membersCountLabel').textContent = regularMembersCount;

        // Re-index remaining officials
        const cards = document.querySelectorAll('#officialsContainer .member-card');
        cards.forEach((card, newIndex) => {
          const newIdx = STD_TRUSTEES + newIndex + 1;
          const newKey = `official_${newIdx}`;
          const badge = card.querySelector('.badge');
          if (badge) {
            badge.textContent = newIndex === 0 ? 'Required' : 'Optional';
            badge.id = `${newKey}_badge`;
          }
          const title = card.querySelector('.member-card-title');
          if (title) {
            const textNode = title.childNodes[2];
            if (textNode) textNode.textContent = ` Official ${newIndex + 1} `;
          }
          // Update index display
          const headDiv = card.querySelector('.member-card-head > div:last-child');
          if (headDiv) {
            const indexSpan = headDiv.querySelector('span');
            if (indexSpan) {
              indexSpan.textContent = `Index ${newIdx}`;
            }
          }
          // Update input IDs
          const inputs = card.querySelectorAll('input');
          inputs.forEach(input => {
            if (input.id.includes('_title')) {
              input.id = `${newKey}_title`;
              input.setAttribute('oninput', `updateOfficialBadge('${newKey}', this.value)`);
            } else if (input.id.includes('_id')) {
              input.id = `${newKey}_id`;
            } else if (input.id.includes('_phone')) {
              input.id = `${newKey}_phone`;
            }
          });
          // Update remove button onclick and visibility
          const removeBtn = card.querySelector('button[onclick^="removeOfficial"]');
          if (removeBtn) {
            removeBtn.setAttribute('onclick', `removeOfficial(${newIndex})`);
          }
        });

        // Rebuild members section with new count
        buildMembers();

        // Update label and buttons
        document.getElementById('officialsCountLabel').textContent = currentOfficialsCount;
        updateAddOfficialButton();
        updateRemoveButtons();
        updateOfficialTitleDatalist();
      }
    }

    function updateAddOfficialButton() {
      const btn = document.getElementById('addOfficialBtn');
      if (btn) {
        if (currentOfficialsCount >= STD_OFFICIALS) {
          btn.style.display = 'none';
        } else {
          btn.style.display = 'flex';
        }
      }
    }

    function updateRemoveButtons() {
      const cards = document.querySelectorAll('#officialsContainer .member-card');
      cards.forEach((card, index) => {
        const removeBtn = card.querySelector('button[onclick^="removeOfficial"]');
        if (removeBtn) {
          // Hide remove button if it's the only official (mandatory minimum of 1)
          if (currentOfficialsCount <= 1) {
            removeBtn.style.display = 'none';
          } else {
            removeBtn.style.display = 'block';
          }
        }
      });
    }

    function updateOfficialBadge(key, title) {
      const badge = document.getElementById(key + '_badge');
      if (badge) {
        // Don't override "Required" label for first official
        if (!badge.textContent.includes('Required')) {
          badge.textContent = title.trim() || 'Optional';
        }
      }
      // Update datalist to hide selected titles
      updateOfficialTitleDatalist();
    }

function updateTrusteeTitles() {
      const allTitles = ['Chairperson', 'Treasurer', 'Secretary', 'Auditor', 'Trustee'];
      const takenTitles = new Set();

      // Collect all currently selected titles from ALL trustees (including chairperson)
      for (let i = 1; i <= STD_TRUSTEES; i++) {
        const select = document.getElementById(`t${i}_title`);
        if (select) {
          const selectedValue = select.value;
          if (selectedValue) {
            takenTitles.add(selectedValue);
          }
        }
      }

      // Update each trustee dropdown (excluding chairperson if locked)
      for (let i = 1; i <= STD_TRUSTEES; i++) {
        const select = document.getElementById(`t${i}_title`);
        if (!select) continue;

        const isChairperson = (i === 1);
        if (isChairperson && select.disabled) {
          continue; // Skip chairperson - their title is locked
        }

        // Update options in this dropdown
        const options = select.querySelectorAll('option');
        options.forEach(option => {
          if (option.value) {
            // Hide this option if the title is already taken by someone else
            if (takenTitles.has(option.value) && option.value !== select.value) {
              option.style.display = 'none';
            } else {
              option.style.display = 'block';
            }
          }
        });
      }
    }

    function updateOfficialTitleDatalist() {
      const dl = document.getElementById('officialTitleList');
      if (!dl) return;

      // Collect all currently selected titles
      const selectedTitles = new Set();
      for (let i = 0; i < currentOfficialsCount; i++) {
        const idx = STD_TRUSTEES + i + 1;
        const titleInput = document.getElementById(`official_${idx}_title`);
        if (titleInput && titleInput.value.trim()) {
          selectedTitles.add(titleInput.value.trim().toLowerCase());
        }
      }

      // Update datalist options - hide selected ones
      const allTitles = ['Auditor', 'Ass. Chairperson', 'Ass. Secretary', 'Committee Member', 'Advisor'];
      dl.innerHTML = '';
      allTitles.forEach(title => {
        if (!selectedTitles.has(title.toLowerCase())) {
          const opt = document.createElement('option');
          opt.value = title;
          dl.appendChild(opt);
        }
      });
    }

    function buildMembers() {
      const container = document.getElementById('membersContainer');
      container.innerHTML = '';
      for (let i = 0; i < regularMembersCount; i++) {
        const idx = STD_TRUSTEES + currentOfficialsCount + i + 1;
        const key = `member_${idx}`;
        container.innerHTML += `
          <div class="member-card">
            <div class="member-card-head">
              <div class="member-card-title">
                <i class="fas fa-person" style="color:var(--primary-dark);"></i>
                Member ${i + 1}
                <span class="badge member">Member</span>
              </div>
              <span style="font-size:11px; color:var(--primary-dark); font-weight:600; background:#dcfce7; padding:3px 9px; border-radius:20px;">Index ${idx}</span>
            </div>
            <div class="row-2">
              <div class="input-group" style="margin-bottom:0;">
                <label>Phone</label>
                <div class="input-wrapper">
                  <input type="tel" id="${key}_phone" placeholder="Enter phone number" maxlength="12">
                </div>
              </div>
              <div class="input-group" style="margin-bottom:0;">
                <label>ID Number <span style="font-weight:500; text-transform:none; letter-spacing:0;">(optional)</span></label>
                <div class="input-wrapper">
                  <input type="text" id="${key}_id" placeholder="National ID" maxlength="10">
                </div>
              </div>
            </div>
          </div>
        `;
      }
    }

    // ─── MPESA STK ────────────────────────────────────────────
    function startSTKPush() {
      const phone = document.getElementById('stkPhone').value;
      if (!isValidPhone(phone)) {
        showNotification('Invalid M-Pesa phone number. Use 254XXXXXXXXX (12 digits) or 07/01XXXXXXXX (10 digits).');
        return;
      }
      document.getElementById('mpesaPrompt').style.display = 'none';
      document.getElementById('loadingStatus').style.display = 'block';
    }

    // ─── PHONE VALIDATION HELPER ──────────────────────────────
    function isValidPhone(phone) {
      // Accepts: 254XXXXXXXXX (12 digits), 07XXXXXXXX (10 digits), 01XXXXXXXX (10 digits)
      return /^254[0-9]{9}$/.test(phone) || /^0[17][0-9]{8}$/.test(phone);
    }

    function getPhoneErrorMessage(field) {
      return `Invalid phone format for ${field}. Use 254XXXXXXXXX (12 digits) or 07/01XXXXXXXX (10 digits).`;
    }

    // ─── VERIFY MEMBERS ───────────────────────────────────────
    function verifyMembers() {
      // Collect all phone numbers to check for duplicates
      const allPhones = [];
      const phoneErrors = [];

       // Validate all trustees dynamically
       for (let i = 0; i < STD_TRUSTEES; i++) {
         const idx = i + 1;
         const phone = document.getElementById(`t${idx}_phone`).value.trim();
         const title = document.getElementById(`t${idx}_title`).value.trim() || `Trustee ${idx}`;
         
         if (i === 0) {
           // Chairperson phone is pre-filled
           if (isValidPhone(phone)) {
             allPhones.push({ phone: phone, name: `Trustee ${idx} (${title})` });
           }
         } else {
           // All other trustees require valid phone
           if (!isValidPhone(phone)) { 
             showNotification(getPhoneErrorMessage(`Trustee ${idx} (${title})`)); 
             return; 
           }
           allPhones.push({ phone: phone, name: `Trustee ${idx} (${title})` });
         }
       }

      // Officials
      for (let i = 0; i < currentOfficialsCount; i++) {
        const idx = STD_TRUSTEES + i + 1;
        const phone = document.getElementById(`official_${idx}_phone`).value.trim();
        
        if (phone && isValidPhone(phone)) {
          allPhones.push({ phone: phone, name: `Official ${i + 1}` });
        }
      }

      // Regular Members
      for (let i = 0; i < regularMembersCount; i++) {
        const idx = STD_TRUSTEES + currentOfficialsCount + i + 1;
        const phone = document.getElementById(`member_${idx}_phone`).value.trim();
        if (!isValidPhone(phone)) {
          showNotification(getPhoneErrorMessage(`Member ${i + 1}`));
          return;
        }
        allPhones.push({ phone: phone, name: `Member ${i + 1} (Index ${idx})` });
      }

      // Check for duplicate phone numbers
      const phoneMap = new Map();
      for (const entry of allPhones) {
        if (phoneMap.has(entry.phone)) {
          phoneErrors.push(`${entry.phone} is used by both ${phoneMap.get(entry.phone)} and ${entry.name}`);
        } else {
          phoneMap.set(entry.phone, entry.name);
        }
      }

      // If duplicates found, show error and stop
      if (phoneErrors.length > 0) {
        showNotification('Duplicate phone numbers found:\n\n' + phoneErrors.join('\n') + '\n\nEach member must have a unique phone number.');
        return;
      }

      // All validations passed - show verification form
      showVerificationForm();
    }

    // ─── SHOW VERIFICATION FORM ──────────────────────────────
    function showVerificationForm() {
      const list = document.getElementById('verificationList');

      // Collect all member data from form inputs
      const membersToVerify = [];

       // Add all trustees dynamically
       for (let i = 0; i < STD_TRUSTEES; i++) {
         const idx = i + 1;
         membersToVerify.push({
           key: `trustee_${idx}`,
           phone: document.getElementById(`t${idx}_phone`).value.trim(),
           id: document.getElementById(`t${idx}_id`).value.trim(),
           role: 'trustee',
           title: document.getElementById(`t${idx}_title`).value.trim() || 'Trustee',
           index: String(idx)
         });
       }

      // Officials
      for (let i = 0; i < currentOfficialsCount; i++) {
        const idx = STD_TRUSTEES + i + 1;
        membersToVerify.push({
          key: `official_${idx}`,
          phone: document.getElementById(`official_${idx}_phone`).value.trim(),
          id: document.getElementById(`official_${idx}_id`).value.trim(),
          role: 'official',
          title: document.getElementById(`official_${idx}_title`).value.trim() || 'No Title',
          index: String(idx)
        });
      }

      // Regular Members
      for (let i = 0; i < regularMembersCount; i++) {
        const idx = STD_TRUSTEES + currentOfficialsCount + i + 1;
        membersToVerify.push({
          key: `member_${idx}`,
          phone: document.getElementById(`member_${idx}_phone`).value.trim(),
          id: document.getElementById(`member_${idx}_id`).value.trim(),
          role: 'member',
          title: 'Member',
          index: String(idx)
        });
      }

      console.log('Sending', membersToVerify.length, 'members for verification');

      // Call API to verify members against data.json
      fetch('/general/api/verify-members', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ members: membersToVerify })
      })
        .then(r => r.json())
        .then(apiResponse => {
          if (!apiResponse.success) {
            console.warn('⚠ API returned error:', apiResponse.error);
            showNotification('Failed to verify members. Please try again.', 'error');
            return;
          }

          const verifiedMembers = apiResponse.members;
          console.log('✓ Verification complete:', verifiedMembers.length, 'members verified');

          // Build verification cards
          let html = '';
          verifiedMembers.forEach(member => {
            const bgColor = member.role === 'trustee' ? '#dbeafe' :
                           member.role === 'official' ? '#fef9c3' : '#dcfce7';
            const textColor = member.role === 'trustee' ? '#1d4ed8' :
                             member.role === 'official' ? '#92400e' : 'var(--primary-dark)';

            html += buildVerificationCard(
              member.role === 'trustee' ? member.title : '',
              member.title,
              member.index,
              member.phone,
              bgColor,
              textColor,
              member,
              member.id
            );
          });

          list.innerHTML = html;

          // Check if all members are valid
          const hasInvalid = verifiedMembers.some(member => !member.verified || (member.name && !member.verified));
          const submitBtn = document.querySelector('.btn-tbank[onclick="confirmAndSubmit()"]');
          if (submitBtn) {
            if (hasInvalid) {
              submitBtn.style.display = 'none';
              showNotification('Some members have verification issues. Please review and correct before submitting.', 'error');
            } else {
              submitBtn.style.display = 'flex';
            }
          }
        })
        .catch(err => {
          console.error('Error verifying members:', err);
          showNotification('Network error. Please check your connection.', 'error');
          goBackToForm();
        });

       // Switch to verification step
       showStep('step4-verify');
    }

    function buildVerificationCard(rolePrefix, title, index, phone, bgColor, textColor, matchData, formIdValue) {
      const hasName = matchData && matchData.name;
      const isVerified = matchData && matchData.verified;
      const notRegistered = !hasName;

      // Determine display name
      let displayName = '';
      if (hasName) {
        displayName = matchData.name;
      } else {
        displayName = 'Not registered with T-Bank';
      }

      const cardTitle = rolePrefix ? `${rolePrefix}` : '';

      // Determine badge
      let statusBadge = '';
      if (isVerified) {
        statusBadge = `<span style="font-size:10px; color:#166534; font-weight:700; background:#dcfce7; padding:3px 8px; border-radius:12px; border:1px solid #166534;">
          <i class="fas fa-check-circle"></i> Verified
        </span>`;
      } else if (!notRegistered) {
        // Has name but ID doesn't match
        statusBadge = `<span style="font-size:10px; color:#991b1b; font-weight:700; background:#fee2e2; padding:3px 8px; border-radius:12px; border:1px solid #991b1b;">
          <i class="fas fa-exclamation-triangle"></i> ID Mismatch
        </span>`;
      } else {
        statusBadge = `<span style="font-size:10px; color:#92400e; font-weight:700; background:#fef3c7; padding:3px 8px; border-radius:12px; border:1px solid #f59e0b;">
          <i class="fas fa-user-slash"></i> Not Registered
        </span>`;
      }

      return `
        <div class="member-card" style="background:${bgColor}; border:1.5px solid ${textColor}; margin-bottom:12px; padding:14px;">
          <!-- Header: Role + Index + Status -->
          <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:10px;">
            <div style="font-weight:700; font-size:13px; color:${textColor}; opacity:0.8;">
              ${cardTitle ? `<i class="fas fa-shield-alt"></i> ${cardTitle}` : `<i class="fas fa-hashtag"></i> Index ${index}`}
            </div>
            <div style="display:flex; gap:6px; align-items:center;">
              <span style="font-size:10px; color:${textColor}; font-weight:700; background:white; padding:3px 8px; border-radius:12px; border:1px solid ${textColor};">
                #${index}
              </span>
              ${statusBadge}
            </div>
          </div>

          <!-- Member Name (Prominent) -->
          ${hasName ? `
            <div style="margin-bottom:10px;">
              <div style="font-size:16px; font-weight:800; color:${textColor}; margin-bottom:3px;">
                <i class="fas fa-user"></i> ${displayName}
              </div>
              ${title ? `<div style="font-size:11px; color:${textColor}; opacity:0.7; font-weight:600; text-transform:uppercase; letter-spacing:0.5px;">${title}</div>` : ''}
            </div>
          ` : `
            <div style="margin-bottom:10px;">
              <div style="font-size:13px; font-weight:700; color:${textColor}; opacity:0.6;">
                <i class="fas fa-user-slash"></i> ${displayName}
              </div>
              ${title ? `<div style="font-size:11px; color:${textColor}; opacity:0.6; font-weight:600; margin-top:2px;">${title}</div>` : ''}
            </div>
          `}

          <!-- Phone Display -->
          <div style="position:relative;">
            <i class="fas fa-phone" style="position:absolute; left:10px; top:50%; transform:translateY(-50%); color:${textColor}; opacity:0.5; font-size:12px;"></i>
            <div style="padding:10px 12px 10px 32px; border:1.5px solid ${textColor}; border-radius:10px; font-size:13px; font-weight:700; color:${textColor}; background:white;">
              ${phone}
            </div>
          </div>
        </div>
      `;
    }



function goBackToForm() {
       showStep('step3-tbank');
       // Refresh trustee title dropdowns to hide already selected titles
       updateTrusteeTitles();
    }

    function confirmAndSubmit() {
      submitTbankRegistration();
    }

     // ─── DOWNLOAD REGISTRATION FORM ────────────────────────────────────
    async function downloadRegistrationForm() {
      const { jsPDF } = window.jspdf;

      // 1. COLLECT ALL MEMBER DATA
      const members = [];

      // Collect trustees
      for (let i = 0; i < STD_TRUSTEES; i++) {
        const idx = i + 1;
        const title = document.getElementById(`t${idx}_title`).value.trim() || 'Trustee';
        members.push({
          index: idx,
          title: title,
          name: `Trustee ${idx}`, // We don't have name field, so use placeholder
          phone: document.getElementById(`t${idx}_phone`).value.trim() || '',
          id: document.getElementById(`t${idx}_id`).value.trim() || '',
          type: 'trustee'
        });
      }

      // Collect officials
      for (let i = 0; i < currentOfficialsCount; i++) {
        const idx = STD_TRUSTEES + i + 1;
        const titleInput = document.getElementById(`official_${idx}_title`);
        const phoneInput = document.getElementById(`official_${idx}_phone`);
        const idInput = document.getElementById(`official_${idx}_id`);
        members.push({
          index: idx,
          title: titleInput ? titleInput.value.trim() || 'Official' : 'Official',
          name: `Official ${i + 1}`,
          phone: phoneInput ? phoneInput.value.trim() : '',
          id: idInput ? idInput.value.trim() : '',
          type: 'official'
        });
      }

      // Collect regular members
      for (let i = 0; i < regularMembersCount; i++) {
        const idx = STD_TRUSTEES + currentOfficialsCount + i + 1;
        const phoneInput = document.getElementById(`member_${idx}_phone`);
        const idInput = document.getElementById(`member_${idx}_id`);
        members.push({
          index: idx,
          title: 'Member',
          name: `Member ${i + 1}`,
          phone: phoneInput ? phoneInput.value.trim() : '',
          id: idInput ? idInput.value.trim() : '',
          type: 'member'
        });
      }

      // Get metadata
      const groupName = groupData.groupName || '';
      const location = `${groupData.ward || ''}, ${groupData.constituency || ''}, ${groupData.county || ''}`;
      const agentName = groupData.agentName || agent?.name || 'Unknown Agent';
      const agentPhone = groupData.agentPhone || agent?.phoneNumber || '';
      const downloadDateTime = new Date().toLocaleString('en-GB', {
        day: '2-digit',
        month: 'short',
        year: 'numeric',
        hour: '2-digit',
        minute: '2-digit'
      });

      // 2. CREATE PDF
      const doc = new jsPDF();
      const pageHeight = doc.internal.pageSize.height || doc.internal.pageSize.getHeight();
      const margin = 15;
      let yPos = margin;

      // Helper function to add text with word wrap
      function addWrappedText(text, x, y, maxWidth, lineHeight = 7) {
        const lines = doc.splitTextToSize(text, maxWidth);
        doc.text(lines, x, y);
        return lines.length * lineHeight;
      }

      // Helper to check if we need a new page
      function checkPageSpace(requiredHeight) {
        if (yPos + requiredHeight > pageHeight - margin) {
          doc.addPage();
          yPos = margin;
        }
      }

      // Header - Title
      doc.setFontSize(16);
      doc.setFont('helvetica', 'bold');
      doc.text('GROUP REGISTRATION FORM', margin, yPos);
      yPos += 10;

      doc.setFontSize(12);
      doc.setFont('helvetica', 'normal');
      doc.text(`Downloaded: ${downloadDateTime}`, margin, yPos);
      yPos += 7;

      // Group Information
      doc.setFont('helvetica', 'bold');
      doc.text('Group Information:', margin, yPos);
      yPos += 7;
      doc.setFont('helvetica', 'normal');
      doc.text(`Group Name: ${groupName}`, margin + 5, yPos);
      yPos += 6;
      doc.text(`Location: ${location}`, margin + 5, yPos);
      yPos += 6;
      doc.text(`Agent: ${agentName} (${agentPhone})`, margin + 5, yPos);
      yPos += 10;

      // Member List Header
      doc.setFont('helvetica', 'bold');
      doc.text('Registered Members', margin, yPos);
      yPos += 7;

      // Table Header
      doc.setFillColor(240, 240, 240);
      doc.rect(margin, yPos, 190, 8, 'F');
      doc.setFont('helvetica', 'bold');
      doc.text('Idx', margin + 5, yPos + 5);
      doc.text('Title', margin + 20, yPos + 5);
      doc.text('Name', margin + 50, yPos + 5);
      doc.text('Phone', margin + 120, yPos + 5);
      doc.text('ID No.', margin + 155, yPos + 5);
      yPos += 8;

      // Table Rows
      doc.setFont('helvetica', 'normal');
      doc.setFontSize(10);

      for (let member of members) {
        checkPageSpace(15);
        // Alternate row colors
        if (members.indexOf(member) % 2 === 0) {
          doc.setFillColor(250, 250, 250);
          doc.rect(margin, yPos, 190, 7, 'F');
        }

        doc.text(String(member.index), margin + 5, yPos + 5);
        doc.text(member.title, margin + 20, yPos + 5);
        doc.text(member.name, margin + 50, yPos + 5);
        doc.text(member.phone || '-', margin + 120, yPos + 5);
        doc.text(member.id || '-', margin + 155, yPos + 5);
        yPos += 7;
      }

      yPos += 5;

      // Summary line
      const totalMembers = members.length;
      checkPageSpace(20);
      doc.setFontSize(11);
      doc.setFont('helvetica', 'bold');
      doc.text(`Total Members: ${totalMembers}`, margin, yPos);
      yPos += 15;

      // Prepared By Section
      doc.setFont('helvetica', 'bold');
      doc.text('Prepared By:', margin, yPos);
      yPos += 7;
      doc.setFont('helvetica', 'normal');
      doc.setFontSize(10);
      doc.text(`Name: ${agentName}`, margin + 5, yPos);
      yPos += 5;
      doc.text(`Phone: ${agentPhone}`, margin + 5, yPos);
      yPos += 5;
      doc.text(`Signature: _____________________________`, margin + 5, yPos);
      yPos += 12;

      // Chairperson Section
      doc.setFont('helvetica', 'bold');
      doc.text('Chairperson Confirmation:', margin, yPos);
      yPos += 7;
      doc.setFont('helvetica', 'normal');
      doc.setFontSize(10);

      // Find chairperson data
      const chairperson = members.find(m => m.type === 'trustee' && m.title.toLowerCase() === 'chairperson');
      const chairName = chairperson ? chairperson.name : '_________________';
      const chairPhone = chairperson ? chairperson.phone : '_________________';

      doc.text(`Name: ${chairName}`, margin + 5, yPos);
      yPos += 5;
      doc.text(`Phone: ${chairPhone}`, margin + 5, yPos);
      yPos += 5;
      doc.text(`Signature: _____________________________`, margin + 5, yPos);
      yPos += 12;

      // Footer
      doc.setFontSize(8);
      doc.setFont('helvetica', 'italic');
      doc.text('This form was automatically generated from the registration system.', margin, yPos);

      // Save the PDF
      const filename = `Group_Registration_${groupName.replace(/\s+/g, '_')}_${new Date().getTime()}.pdf`;
      doc.save(filename);
      showNotification('Registration form downloaded successfully!', 'success');
    }

     // ─── T-BANK SUBMISSION ────────────────────────────────────
    function submitTbankRegistration() {
      const trustees = [];
      
      // Validate all trustees dynamically
      for (let i = 0; i < STD_TRUSTEES; i++) {
        const idx = i + 1;
        const phone = document.getElementById(`t${idx}_phone`).value.trim();
        
        if (i > 0) { // Skip chairperson validation
          if (!phone.match(/^07[0-9]{8}$/)) { 
            showNotification(`Please enter a valid phone for Trustee ${idx}.`); 
            return; 
          }
        }
        
        trustees.push({
          index: String(idx), type: 'trustee', 
          title: document.getElementById(`t${idx}_title`).value.trim() || 'Trustee',
          phone: phone,
          id: document.getElementById(`t${idx}_id`).value.trim()
        });
      }

      // Validate officials that have been added (only validate phone if provided)
      const addedOfficials = [];
      const officialTitles = new Set();
      for (let i = 0; i < currentOfficialsCount; i++) {
        const idx = STD_TRUSTEES + i + 1;
        const title = document.getElementById(`official_${idx}_title`).value.trim();
        const phone = document.getElementById(`official_${idx}_phone`).value.trim();
        
        // Check for duplicate titles
        if (title) {
          if (officialTitles.has(title.toLowerCase())) {
            showNotification(`Duplicate title "${title}" found. Each official must have a unique title.`);
            return;
          }
          officialTitles.add(title.toLowerCase());
        }
        
        // Phone is optional for officials, but if provided must be valid
        if (phone && !phone.match(/^07[0-9]{8}$/)) {
          showNotification(`Please enter a valid phone for Official ${i + 1}.`);
          return;
        }
        addedOfficials.push({
          index: String(idx), type: 'official',
          title: title,
          phone: phone,
          id: document.getElementById(`official_${idx}_id`).value.trim()
        });
      }

      // Validate regular member phones
      for (let i = 0; i < regularMembersCount; i++) {
        const idx = STD_TRUSTEES + currentOfficialsCount + i + 1;
        const phone = document.getElementById(`member_${idx}_phone`).value.trim();
        if (!phone.match(/^07[0-9]{8}$/)) {
          showNotification(`Please enter a valid phone for Member ${i + 1}.`);
          return;
        }
      }

       // Build payload
       const payload = {
         groupName: groupData.groupName,
         county: groupData.county,
         constituency: groupData.constituency,
         ward: groupData.ward,
         totalMembers: totalMembersCount,
         totalAmount: totalPayableAmount,
         paymentMethod: 'tbank',
          trustees: trustees,
         officials: addedOfficials,
         members: []
       };

      for (let i = 0; i < regularMembersCount; i++) {
        const idx = STD_TRUSTEES + currentOfficialsCount + i + 1;
        payload.members.push({
          index: String(idx), type: 'member',
          phone: document.getElementById(`member_${idx}_phone`).value.trim(),
          id: document.getElementById(`member_${idx}_id`).value.trim()
        });
      }

       // Show processing screen
       showStep('step5');

      // POST to server
      fetch('/agent/activate-group', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      })
        .then(r => r.json())
        .then(res => {
          document.getElementById('submitStatusMsg').textContent =
            res.success ? '✓ Group registered successfully!' : `Error: ${res.message || 'Something went wrong.'}`;
          document.getElementById('backToDashBtn').style.display = 'flex';
        })
        .catch(() => {
          document.getElementById('submitStatusMsg').textContent = 'Network error. Please try again.';
          document.getElementById('backToDashBtn').style.display = 'flex';
        });
    }

