     // ─── T-BANK SUBMISSION ────────────────────────────────────
    function submitTbankRegistration() {
      const trustees = [];
      
      // Validate all trustees dynamically
      for (let i = 0; i < STD_TRUSTEES; i++) {
        const idx = i + 1;
        const phone = document.getElementById(`t${idx}_phone`).value.trim();
        
        if (i > 0) { // Skip chairperson validation
          if (!phone.match(/^07[0-9]{8}$/)) { 
            showNotification(`Please enter a valid phone for Trustee ${idx}.`); 
            return; 
          }
        }
        
        trustees.push({
          index: String(idx), type: 'trustee', 
          title: document.getElementById(`t${idx}_title`).value.trim() || 'Trustee',
          memberNumber: document.getElementById(`t${idx}_memberNumber`).value.trim(),
          phone: phone,
          id: document.getElementById(`t${idx}_id`).value.trim()
        });
      }

      // Validate officials that have been added (only validate phone if provided)
      const addedOfficials = [];
      const officialTitles = new Set();
      for (let i = 0; i < currentOfficialsCount; i++) {
        const idx = STD_TRUSTEES + i + 1;
        const title = document.getElementById(`official_${idx}_title`).value.trim();
        const phone = document.getElementById(`official_${idx}_phone`).value.trim();
        
        // Check for duplicate titles
        if (title) {
          if (officialTitles.has(title.toLowerCase())) {
            showNotification(`Duplicate title "${title}" found. Each official must have a unique title.`);
            return;
          }
          officialTitles.add(title.toLowerCase());
        }
        
        // Phone is optional for officials, but if provided must be valid
        if (phone && !phone.match(/^07[0-9]{8}$/)) {
          showNotification(`Please enter a valid phone for Official ${i + 1}.`);
          return;
        }
        addedOfficials.push({
          index: String(idx), type: 'official',
          title: title,
          memberNumber: document.getElementById(`official_${idx}_memberNumber`).value.trim(),
          phone: phone,
          id: document.getElementById(`official_${idx}_id`).value.trim()
        });
      }

      // Validate regular member phones
      for (let i = 0; i < regularMembersCount; i++) {
        const idx = STD_TRUSTEES + currentOfficialsCount + i + 1;
        const phone = document.getElementById(`member_${idx}_phone`).value.trim();
        if (!phone.match(/^07[0-9]{8}$/)) {
          showNotification(`Please enter a valid phone for Member ${i + 1}.`);
          return;
        }
      }

       // Build payload
       const groupType = document.getElementById('groupType').value;
       const groupCertificateNumber = document.getElementById('groupCertificateNumber').value.trim();
       const payload = {
         groupName: groupData.groupName,
         groupType: groupType,
         groupCertificateNumber: groupCertificateNumber,
         county: groupData.county,
         constituency: groupData.constituency,
         ward: groupData.ward,
         totalMembers: totalMembersCount,
         totalAmount: totalPayableAmount,
         paymentMethod: 'tbank',
          trustees: trustees,
         officials: addedOfficials,
         members: []
       };

      for (let i = 0; i < regularMembersCount; i++) {
        const idx = STD_TRUSTEES + currentOfficialsCount + i + 1;
        payload.members.push({
          index: String(idx), type: 'member',
          memberNumber: document.getElementById(`member_${idx}_memberNumber`).value.trim(),
          phone: document.getElementById(`member_${idx}_phone`).value.trim(),
          id: document.getElementById(`member_${idx}_id`).value.trim()
        });
      }

       // Show processing screen
       showStep('step5');

      // POST to server
      fetch('/agent/activate-group', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      })
        .then(r => r.json())
        .then(res => {
          document.getElementById('submitStatusMsg').textContent =
            res.success ? '✓ Group registered successfully!' : `Error: ${res.message || 'Something went wrong.'}`;
          document.getElementById('backToDashBtn').style.display = 'flex';
        })
        .catch(() => {
          document.getElementById('submitStatusMsg').textContent = 'Network error. Please try again.';
          document.getElementById('backToDashBtn').style.display = 'flex';
        });
    }

