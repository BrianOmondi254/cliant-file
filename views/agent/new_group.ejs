        const idx = STD_TRUSTEES + currentOfficialsCount + i + 1;
        const key = `member_${idx}`;
        container.innerHTML += `
          <div class="member-card">
            <div class="member-card-head">
              <div class="member-card-title">
                <i class="fas fa-person" style="color:var(--primary-dark);"></i>
                Member ${i+1}
                <span class="badge member">Member</span>
              </div>
              <span style="font-size:11px; color:var(--primary-dark); font-weight:600;
                           background:#dcfce7; padding:3px 9px; border-radius:20px;">Index ${idx}</span>
            </div>
            <div class="input-group" style="margin-bottom:var(--card-gap);">
