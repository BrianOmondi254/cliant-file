    function syncTrusteeTitles() {
      const selects = document.querySelectorAll('.trustee-title-select');
      const selectedValues = Array.from(selects).map(s => s.value).filter(v => v !== "" && v !== "Trustee");

      selects.forEach(select => {
        const currentValue = select.value;
        const options = select.options;

        for (let i = 0; i < options.length; i++) {
          const opt = options[i];

          // Always enable the current value, and default "Trustee" and empty options
          if (opt.value === currentValue || opt.value === "" || opt.value === "Trustee") {
            opt.disabled = false;
            opt.style.color = ""; // Ensure color is reset
            continue;
          }

          // Disable if this value is selected in another dropdown
          if (selectedValues.includes(opt.value)) {
            opt.disabled = true;
            opt.style.color = "#ccc";
          } else {
            opt.disabled = false;
            opt.style.color = "";
          }
        }
      });
    }

    function toggleAccordion(header) {
