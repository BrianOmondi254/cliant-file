    function handleDetailsContinue() {
      const groupName = window.selectedGroupForDetails;
      const group = window.managedGroups.find(g => g.groupName === groupName);
      if (!group) return;

      const personKeys = Object.keys(group).filter(k => k.match(/^(trustee|official|member)_\d+$/));
      const total = personKeys.length;
      const target = group.totalProposedMembers || 15;

      if (total >= target) {
        // Quorum met: Continue to Constitution Setup
        openConstitutionKeyPrompt();
      } else {
        // Quorum NOT met: Continue with Member Registration
        showRegistrationFormFromDetails();
      }
    }

    function openConstitutionKeyPrompt() {
      const groupName = window.selectedGroupForDetails;
      if (!groupName) {
         console.warn("No group selected for details");
         return;
      }
      const group = window.managedGroups.find(g => g.groupName === groupName);
      if (!group) return;

      // Ensure the details container itself is visible
      const detailsView = document.getElementById('groupDetailsView');
      if (detailsView) detailsView.classList.remove('hidden');

      // Populate inline verification card
      const groupNameEl = document.getElementById('constGroupNameDisplay');
      const chairNameEl = document.getElementById('constChairName');
      const chairPhoneEl = document.getElementById('constChairPhone');
      const keyInput = document.getElementById('constKeyInput');

      if (groupNameEl) groupNameEl.textContent = group.groupName || groupName;
      if (chairNameEl) chairNameEl.textContent = group.trustee_1 || "Chairperson";
      if (chairPhoneEl) chairPhoneEl.textContent = group.phone || "N/A";
      if (keyInput) keyInput.value = ""; 

      // Show Setup Inline View
      hideConstitutionSiblings();
      const setupView = document.getElementById('constitutionSetupView');
      if (setupView) {
        setupView.classList.remove('hidden');
        setupView.style.display = 'block'; // Force display
      }

      // Scroll to the start of the setup flow
      if (setupView) {
        setupView.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }

      // Reset to Step 0 (Verification)
      scrollToStep(0);
    }

    function hideConstitutionSiblings() {
      const ids = [
        'registrationFormPlaceholder', 
        'phaseStatusRow', 
        'existingMembersAccordion', 
        'groupMainInfo', 
        'principlesSection', 
        'phaseActions', 
        'detailsContinueAction'
      ];
      ids.forEach(id => {
        const el = document.getElementById(id);
        if (el) el.classList.add('hidden');
      });
    }

    function exitConstitutionSetup() {
      const setupView = document.getElementById('constitutionSetupView');
      if (setupView) setupView.classList.add('hidden');

      // Re-trigger handleGroupClick to restore normal view
      const groupName = window.selectedGroupForDetails;
      if (groupName) handleGroupClick(groupName);
    }

    function verifySubmittedMembers() {
      const groupName = window.selectedGroupForDetails;
      if (!groupName) return;

      // Visually confirm and show next steps
      const headcount = document.getElementById('detailsTotalHeadcount').textContent;
      alert(`Verification successful. All ${headcount} members for ${groupName} have been confirmed. This group is now entering the final activation phase.`);

      // Optionally reload to update UI status
      setTimeout(() => handleGroupClick(groupName), 1500);
    }

