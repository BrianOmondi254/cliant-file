    async function saveConstitutionKey() {
      const key = document.getElementById('constKeyInput').value;
      const errorEl = document.getElementById('constKeyError');
      errorEl.textContent = "";

      if (!key) {
        errorEl.textContent = "Start Key is required!";
        return;
      }
      const groupName = document.getElementById('detailsGroupName').textContent;

      try {
        const res = await fetch("/agent/set-constitution-key", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ groupName, key })
        });
        const result = await res.json();

        if (result.success) {
          // Reveal Step 1 (Saving Duration) immediately then slide
          document.getElementById('groupSavingPeriodSection').classList.remove('hidden');
          scrollToStep(1);
        } else {
          errorEl.textContent = "Invalid Start Key. Please check and try again.";
        }
      } catch (err) {
        console.error(err);
        errorEl.textContent = "Connection error. Please try again.";
      }
    }

