  <script>
    // ... showPhoneInput, resetGroupSelection, verifyChairperson ...

    async function submitMembers() {
      // 1. Collect all inputs and prepare for verification
      const inputs = document.querySelectorAll('#cAccount input, #cAccount select');
      const memberData = {};
      const phoneNumbersForVerification = [];

      // Group fields by index (e.g., trustee_1, trustee_1_id, trustee_1_phone)
      const grouped = {};
      inputs.forEach(input => {
        if (!input.value) return;
        const nameParts = input.name.split('_');
        const type = nameParts[0]; // trustee, official, member
        const index = nameParts[1];
        const field = nameParts[2] || 'name'; // name, phone, id, title

        const key = `${type}_${index}`;
        if (!grouped[key]) grouped[key] = { type, index };
        grouped[key][field] = input.value;
      });

      // --- Duplication Check ---
      const seenPhones = new Map(); // value -> original key
      const duplicates = [];

      for (const key in grouped) {
        const m = grouped[key];

        // Check Phone only
        if (m.phone) {
          const cleanPhone = String(m.phone).trim();
          if (seenPhones.has(cleanPhone)) {
            const label = key.replace('_', ' ').replace(/\b\w/g, l => l.toUpperCase());
            const firstLabel = seenPhones.get(cleanPhone).replace('_', ' ').replace(/\b\w/g, l => l.toUpperCase());
            duplicates.push(`Phone number "${cleanPhone}" is used for both ${firstLabel} and ${label}.`);
          } else {
            seenPhones.set(cleanPhone, key);
          }
        }
      }

      if (duplicates.length > 0) {
        alert("⚠️ DOUBLE ENTRY DETECTED\n\n" +
          "Each member must have a unique Phone number. Please correct the following:\n\n" +
          duplicates.join("\n"));
        return;
      }
      // --- End Duplication Check ---

      // 2. Validation: Touched Entry & Headcount Compliance
      const targetTotal = window.currentTotalMembers || 0;
      let totalFoundCount = 0;
      const trusteeErrors = [];
      const officialErrors = [];
      const memberErrors = [];

      Object.values(grouped).forEach(m => {
        const hasPhone = m.phone && m.phone.trim() !== '';
        const hasId = m.id && m.id.trim() !== '';
        const hasTitle = m.title && m.title.trim() !== '';

        const isTouched = hasPhone || hasId || hasTitle;

        if (isTouched) {
          // Row is "set", now enforce mandatory fields
          if (m.type === 'official') {
            if (!hasTitle || !hasPhone) {
              officialErrors.push(`Official ${m.index} (Missing Title or Phone)`);
            } else {
              totalFoundCount++;
            }
          } else {
            // Member or Trustee
            if (!hasPhone) {
              memberErrors.push(`${m.type.charAt(0).toUpperCase() + m.type.slice(1)} ${m.index} (Missing Phone)`);
            } else {
              totalFoundCount++;
            }
          }
        }
      });

      // Check if this is a pending/existing group vs a brand new group
      let isExistingGroup = false;
      const currentGroupName = window.selectedGroupForDetails || (document.getElementById("verifyGroup") ? document.getElementById("verifyGroup").value : null);
      if (currentGroupName && window.managedGroups) {
        const groupObj = window.managedGroups.find(g => g.groupName === currentGroupName);
        if (groupObj && groupObj.trustee_1) {
          isExistingGroup = true;
        }
      }

      // Enforce mandatory Trustees count
      const requiredTrustees = (window.tbankCounts && window.tbankCounts.trustees) || 0;
      let foundTrustees = 0;
      Object.values(grouped).forEach(m => {
        if (m.type === 'trustee' && m.phone && m.phone.trim() !== '') foundTrustees++;
      });
      if (!isExistingGroup && foundTrustees < requiredTrustees) {
        trusteeErrors.push(`Mandatory: ${requiredTrustees} Trustees must be fully filled.`);
      }

      // For NEW groups only: enforce minimum members (e.g. 5) based on tbank standard
      if (!isExistingGroup) {
        const minMembers = (window.tbankCounts && window.tbankCounts.members) || 5;
        let foundMembers = 0;
        Object.values(grouped).forEach(m => {
          if (m.type === 'member' && m.phone && m.phone.trim() !== '') foundMembers++;
        });
        if (foundMembers < Math.min(5, minMembers)) {
          memberErrors.push(`Mandatory: At least ${Math.min(5, minMembers)} Members must be fully filled.`);
        }
      }

      // Strict Headcount Check - This check is too rigid for adding members incrementally.
      // It requires the agent to fill all member slots at once.
      // By removing it, we allow agents to submit a partial list for verification.
      /*
      if (totalFoundCount !== targetTotal && targetTotal > 0) { // Only check if a target was set
          memberErrors.push(`Headcount Mismatch: Registration requires exactly ${targetTotal} complete entries. Found ${totalFoundCount}.`);
      }*/

      if (trusteeErrors.length > 0 || officialErrors.length > 0 || memberErrors.length > 0) {
        let errMsg = "Please attention to the following:\n\n";
        if (trusteeErrors.length > 0) errMsg += "• Trustees: " + trusteeErrors.join(", ") + "\n";
        if (officialErrors.length > 0) errMsg += "• Officials: " + officialErrors.join("\n  ") + "\n";
        if (memberErrors.length > 0) errMsg += "• Members: " + memberErrors.join("\n  ") + "\n";
        alert(errMsg);
        return;
      }

      // 3. Extract phone numbers for verification endpoint
      Object.values(grouped).forEach(m => {
        if (m.phone) {
          phoneNumbersForVerification.push({
            type: m.type,
            index: m.index,
            phone: m.phone,
            id: m.id,
            title: m.title || null // Added title
          });
        }
      });

      if (phoneNumbersForVerification.length === 0) {
        alert("No valid member data found.");
        return;
      }

      // 3. Call backend verification
      try {
        const res = await fetch("/general/verify-members", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ phoneNumbers: phoneNumbersForVerification })
        });
        const result = await res.json();

        if (result.success) {
          window.finalMemberData = grouped; // Save for final submission
          displayReviewList(result.results);
        } else {
          alert("Verification failed: " + result.message);
        }
      } catch (err) {
        console.error(err);
        alert("Verification system error.");
      }
    }

