    async function finalizeSubmission() {
      // 1. Check if there are unverified members remaining
      const reviewList = document.getElementById("reviewList");
      const invalidCards = reviewList.querySelectorAll('div[data-status="mismatch"], div[data-status="not_found"]');
      if (invalidCards && invalidCards.length > 0) {
        alert("Action Required: Please remove any invalid or mismatched members (highlighted with errors) using the trash bin icon before you can finalize your submission.");
        return;
      }

      // 2. Re-check required headcounts based on finalMemberData
      let isExistingGroup = false;
      const currentGroupName = window.selectedGroupForDetails || (document.getElementById("verifyGroup") ? document.getElementById("verifyGroup").value : null);
      if (currentGroupName && window.managedGroups) {
        const groupObj = window.managedGroups.find(g => g.groupName === currentGroupName);
        if (groupObj && groupObj.trustee_1) {
          isExistingGroup = true;
        }
      }

      const requiredTrustees = (window.tbankCounts && window.tbankCounts.trustees) || 0;
      let foundTrustees = 0;
      Object.keys(window.finalMemberData).forEach(key => {
        if (key.startsWith('trustee_')) foundTrustees++;
      });

      if (!isExistingGroup && foundTrustees < requiredTrustees) {
        alert(`Validation Error: Registration dropping below minimum requirements. You must have at least ${requiredTrustees} fully verified Trustees to finalize. Please go back and add valid Trustees.`);
        return;
      }

      const groupName = document.getElementById("displayGroup").innerText;
      const chairpersonPhone = document.getElementById("verifyPhone").value;

      const finalPayload = {
        groupName,
        chairpersonalphonenumber: chairpersonPhone,
        membersData: window.finalMemberData,
        totalProposedMembers: window.currentTotalMembers
      };

      try {
        const res = await fetch("/general/update-members", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(finalPayload)
        });
        const result = await res.json();

        if (result.success) {
          alert("✅ Group Account Populated Successfully!");
          // Hide action buttons, show Continue button
          document.getElementById("finalizeActionButtons").style.display = "none";
          document.getElementById("continueToConstitutionBtn").classList.remove("hidden");
          document.getElementById("continueToConstitutionBtn").style.display = "block";
        } else {
          alert("Submission failed: " + result.message);
        }
      } catch (err) {
        console.error(err);
        alert("Final submission error.");
      }
    }

