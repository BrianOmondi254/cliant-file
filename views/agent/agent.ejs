                  <p style="text-align:center; font-size:12px; color:#94a3b8; padding:20px;">Identity the group by
                    searching above.</p>
                </div>
              </div>
            </div>

            <!-- 3. UPDATE GROUP SECTION -->
            <div id="updateGroupSection" class="hidden">
