    // Override the existing verifyChairperson to handle new groups flow
    const originalVerifyChairperson = verifyChairperson;
    async function verifyChairperson() {
      const phone = document.getElementById("verifyPhone").value;
      const group = document.getElementById("verifyGroup").value;
      const msg = document.getElementById("verifyMsg");

      if (!phone || !group) {
        msg.textContent = "Please select a group and enter a phone number.";
        return;
      }

      // Check if this is a new group (no trustee_1)
      const selectedGroup = window.managedGroups.find(g => g.groupName === group);
      if (selectedGroup && !selectedGroup.trustee_1) {
        // This is a new group - skip to member registration directly
        window.pendingChairpersonPhone = phone;

        // Hide verification, show member details directly
        document.getElementById("verificationStep").classList.add("hidden");
        document.getElementById("cAccount").classList.remove("hidden");
        document.getElementById("displayGroup2").textContent = group;
        document.getElementById("displayGroup").textContent = group;

        // Clear and generate member fields
        document.getElementById('trusteesContainer').innerHTML = '';
        document.getElementById('officialsContainer').innerHTML = '';
        document.getElementById('membersContainer').innerHTML = '';

        window.tbankCounts = { trustees: 3, officials: 1 };
        window.currentTotalMembers = 15;

        // Generate fields
        generateFields("Trustee", 3, "trusteesContainer");
        generateFlexibleFields("Official", 1, 1, "officialsContainer");
        generateFlexibleFields("Member", 5, 15, "membersContainer");

        return;
      }

      // Original flow for existing groups
      try {
        const res = await fetch("/general/verify", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            chairpersonalphonenumber: phone,
            groupName: group
          })
        });
        const data = await res.json();

        if (data.success) {
          window.tbankCounts = data.counts;
          window.tbankFees = data.fees;

          document.getElementById("verificationStep").classList.add("hidden");
          document.getElementById("totalMembersStep").classList.remove("hidden");
          document.getElementById("displayGroup").textContent = group;
        } else {
          msg.textContent = data.message || "Verification failed.";
        }
      } catch (err) {
        console.error(err);
        msg.textContent = "Error verifying details.";
      }
    }

