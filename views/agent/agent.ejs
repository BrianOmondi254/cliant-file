                <div class="dashboard-card" style="margin:0; padding:15px; text-align:center;">
                  <div
                    style="font-size:10px; color:#64748b; text-transform:uppercase; font-weight:700; margin-bottom:5px;">
                    Members</div>
                  <div id="detailsMembersCount" style="font-size:24px; font-weight:800; color:#1e293b;">0</div>
                </div>
                <div class="dashboard-card" style="margin:0; padding:15px; text-align:center;">
