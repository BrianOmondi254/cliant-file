    // Sliding Glider Logic
    function updateNavGlider() {
      const activeNav = document.querySelector('.top-nav-container.active');
      const glider = document.getElementById('navGlider');
      const navBar = document.getElementById('topNavBar');

      if (activeNav && glider && navBar) {
        const rect = activeNav.getBoundingClientRect();
        const barRect = navBar.getBoundingClientRect();

        // Calculate relative position
        const left = rect.left - barRect.left;

        // We want the glider to be full width of the item
        const width = rect.width;
        const offset = 0;

        glider.style.width = `${width}px`;
        glider.style.left = `${left}px`;
        glider.style.opacity = '1';
      } else if (glider) {
        glider.style.opacity = '0';
      }
    }

    // Reposition on resize
