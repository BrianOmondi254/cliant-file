                <% 
                  // Professional mapping of groups
                  groups.forEach(g => {
                    let status = "New Request";
                    let statusColor = "#4285f4"; // Blue
                    let statusBg = "#ebf5ff";
                    
                    if (g.principles || g.phase == 3) {
                      status = "Active";
                      statusColor = "#059669"; // Green
                      statusBg = "#ecfdf5";
                    } else if (g.trustee_1) {
                      status = "Pending Setup";
                      statusColor = "#d97706"; // Amber
                      statusBg = "#fffbeb";
                    }
                %>
                  <div class="group-item-container" data-name="<%= g.groupName %>" onclick="handleGroupClick('<%= g.groupName %>', this)"
                    style="display: flex; align-items: center; justify-content: space-between; padding: 15px 20px; background: white; border-radius: 12px; margin-bottom: 12px; border: 1px solid #e2e8f0; cursor: pointer; transition: all 0.2s ease; border-left: 4px solid <%= statusColor %>;">
                    
                    <div style="flex: 1;">
                      <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 4px;">
                        <span style="font-weight: 700; color: #1e293b; font-size: 15px;"><%= g.groupName || 'Unnamed Group' %></span>
                        <span style="font-size: 10px; font-weight: 700; padding: 3px 8px; border-radius: 20px; background: <%= statusBg %>; color: <%= statusColor %>; text-transform: uppercase; letter-spacing: 0.5px;">
                          <%= status %>
                        </span>
                      </div>
                      <div style="font-size: 12px; color: #64748b; font-weight: 500;">
                        <i class="fa-solid fa-map-location-dot" style="margin-right: 4px; opacity: 0.7;"></i>
                        <%= g.ward || 'General' %> · <%= g.constituency || 'Agent' %>
                      </div>
                    </div>

                    <div style="display: flex; align-items: center; gap: 12px;">
                      <% if (status === 'Active') { %>
                        <div style="text-align: right; margin-right: 8px;">
                          <div style="font-size: 10px; color: #94a3b8; font-weight: 700; text-transform: uppercase;">Growth</div>
                          <div style="font-size: 13px; color: #059669; font-weight: 700;">Phase 3</div>
                        </div>
                      <% } %>
                      <i class="fas fa-chevron-right" style="color: #cbd5e1; font-size: 14px;"></i>
                    </div>
                  </div>
                  <div class="group-item-content" id="content-<%= g.groupName.replace(/\s+/g, '-') %>" style="display: none;"></div>
                <% }); %>
                
                <% if (groups.length === 0) { %>
                  <div style="text-align: center; padding: 40px 20px; background: #f8fafc; border-radius: 20px; border: 2px dashed #e2e8f0;">
                    <i class="fa-solid fa-folder-open" style="font-size: 48px; color: #cbd5e1; margin-bottom: 15px;"></i>
                    <h3 style="color: #64748b; font-size: 16px; margin-bottom: 5px;">No Groups Managed</h3>
                    <p style="color: #94a3b8; font-size: 12px;">You are not currently managing any group accounts.</p>
                  </div>
                <% } %>
              </div>
            </div>

            <!-- 2. SEARCH GROUP SECTION -->
