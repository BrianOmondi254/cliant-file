                <div class="input-group">
                  <i class="fas fa-search"></i>
                  <input type="text" id="globalGroupSearch" oninput="performGlobalGroupSearch()"
                    placeholder="Enter account name or number..." style="padding-left:42px;">
                </div>
                <div id="globalSearchResults" style="margin-top:15px; display:flex; flex-direction:column; gap:10px;">
