                      <div style="font-weight:600; color:#2c3e50;">
                        <%= g.groupName %>
                      </div>
                      <span class="badge"
                        style="background:<%= g.phase == 3 ? '#d1fae5' : '#d1fae5' %>; color:<%= g.phase == 3 ? '#065f46' : '#065f46' %>; border:1px solid <%= g.phase == 3 ? '#059669' : '#059669' %>; font-size:9px;">
                        ACTIVE
                      </span>
                    </div>
                    <div style="font-size:12px; color:#7f8c8d; margin-top:4px;">
                      <%= g.phone %> • Acc: <%= g.accountNumber || 'Pending' %>
                    </div>
                  </div>
                  <% }); } else { %>
                    <p style="text-align:center; font-size:12px; color:#95a5a6; padding:30px;">No groups found in Phase
                      2 or 3.</p>
                    <% } %>
              </div>
            </di
            <!-- 4. CREATE GROUP SECTION -->
            <div id="createGroupSection" class="hidden">
              <div style="background:#f8fafc; border-radius:16px; padding:20px; border:1px solid #e2e8f0;">

                <!-- Group Name -->
                <div style="margin-bottom:14px;">
                  <label style="font-size:11px;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:0.8px;display:block;margin-bottom:6px;">Group Name</label>
                  <div style="display:flex;align-items:center;background:white;border:1.5px solid #e2e8f0;border-radius:12px;overflow:hidden;">
