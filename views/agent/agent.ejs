    function continueRegistrationFromDetails() {
      const group = window.managedGroups.find(g => g.groupName === window.selectedGroupForDetails);
      if (!group) return;

      // 1. Identify existing total headcount
      const existingHeadcount = Object.keys(group).filter(k =>
        k.startsWith('trustee_') || k.startsWith('official_') || k.startsWith('member_')
      ).length;

      // Existing members (specifically) to determine the next index
      const existingMemberCount = Object.keys(group).filter(k => k.startsWith('member_')).length;

      const totalTarget = group.totalProposedMembers || 15;
      const remaining = totalTarget - existingHeadcount;

      if (remaining <= 0) {
        openConstitutionKeyPrompt();
        return;
      }

      // 2. Prepare View (Inline)
      const placeholder = document.getElementById('registrationFormPlaceholder');
      const createForm = document.getElementById('createGroupForm');

      if (placeholder && createForm) {
        placeholder.appendChild(createForm);
        placeholder.classList.remove('hidden');
        createForm.classList.remove('hidden');

        // Hide main info
        document.getElementById('groupMainInfo').classList.add('hidden');
        document.getElementById('principlesSection').classList.add('hidden');
        document.getElementById('phaseActions').classList.add('hidden');
      } else {
        showCreateGroupForm();
      }

      document.getElementById('verificationStep').classList.add('hidden');
      document.getElementById('totalMembersStep').classList.add('hidden');
      document.getElementById('paymentStep').classList.add('hidden');
      document.getElementById('cAccount').classList.remove('hidden');
      document.getElementById('displayGroup2').textContent = group.groupName;

      // Sync identifying fields so submission works
      document.getElementById('displayGroup').textContent = group.groupName;
      document.getElementById('verifyPhone').value = group.phone;

      // 3. Clear existing form containers
      document.getElementById('trusteesContainer').innerHTML = '';
      document.getElementById('officialsContainer').innerHTML = '';
      document.getElementById('membersContainer').innerHTML = '';

      // 4. Set state for continuation
      window.tbankCounts = { trustees: 0, officials: 0 };
      window.currentTotalMembers = totalTarget;

      // 5. Generate staggered fields for REMAINING people as 'Members' (starting from next member index)
      generateFlexibleFields("Member", 5, totalTarget - (existingHeadcount - existingMemberCount), "membersContainer", existingMemberCount + 1);
    }
    function addSpecificMember(type) {
      const groupName = window.selectedGroupForDetails;
      const group = window.managedGroups.find(g => g.groupName === groupName);
      if (!group) return;

      // 1. Prepare UI — move form into the details placeholder
      const placeholder = document.getElementById('registrationFormPlaceholder');
      const createForm = document.getElementById('createGroupForm');
      if (placeholder && createForm) {
        placeholder.appendChild(createForm);
        placeholder.classList.remove('hidden');
        createForm.classList.remove('hidden');
        createForm.style.display = 'block'; // Force visible regardless of any inline style
        const groupMainInfo = document.getElementById('groupMainInfo');
        if (groupMainInfo) groupMainInfo.classList.add('hidden');
        const principlesSection = document.getElementById('principlesSection');
        if (principlesSection) principlesSection.classList.add('hidden');
        const phaseActions = document.getElementById('phaseActions');
        if (phaseActions) phaseActions.classList.add('hidden');
        const continueAction = document.getElementById('detailsContinueAction');
        if (continueAction) continueAction.classList.add('hidden');
      }

      // 2. Count existing members from the database group object
      const personKeys = Object.keys(group).filter(k => k.match(/^(trustee|official|member)_\d+$/));
      const trustees = personKeys.filter(k => k.startsWith('trustee_')).length;
      const officials = personKeys.filter(k => k.startsWith('official_')).length;
      const members = personKeys.filter(k => k.startsWith('member_')).length;

      const totalTarget = group.totalProposedMembers || 15;
      window.currentTotalMembers = totalTarget;

      // Read compliance standards
      const stdTrustees = (window.tbankCounts && window.tbankCounts.trustees) || 3;
      const stdOfficials = (window.tbankCounts && window.tbankCounts.officials) || 3;

      // 3. Hide ALL sub-steps first, then ONLY reveal cAccount (the data entry step)
      ['verificationStep', 'totalMembersStep', 'paymentStep', 'reviewStep'].forEach(id => {
        const el = document.getElementById(id);
        if (el) el.classList.add('hidden');
      });
      const cAccount = document.getElementById('cAccount');
      if (cAccount) {
        cAccount.classList.remove('hidden');
        cAccount.style.display = 'block'; // Force visible
      }

      // 4. Sync group name labels in the form header
      const dg = document.getElementById('displayGroup');
      if (dg) dg.textContent = groupName;
      const dg2 = document.getElementById('displayGroup2');
      if (dg2) dg2.textContent = groupName;
      const verifyPhone = document.getElementById('verifyPhone');
      if (verifyPhone) verifyPhone.value = group.phone;

      // 5. Clear all role containers and reset internal tracking counters
      document.getElementById('trusteesContainer').innerHTML = '';
      document.getElementById('officialsContainer').innerHTML = '';
      document.getElementById('membersContainer').innerHTML = '';

      // Crucial: Reset tracking variables so generateFlexibleFields can recalculate capacity correctly
      window.officialsContainerCount = 0;
      window.membersContainerCount = 0;
      window.trusteesContainerCount = 0;

      // 6. Generate ONLY the required role fields with correct sequential indexes
      if (type === 'official') {
        const remaining = stdOfficials - officials;
        if (remaining <= 0) {
          document.getElementById('officialsContainer').innerHTML = `
                <div style="padding: 20px; text-align: center; background: #ecfdf5; border: 1.5px solid #10b981; border-radius: 12px; color: #065f46; margin: 15px 0;">
                    <i class="fas fa-check-double" style="font-size: 28px; color: #10b981; margin-bottom: 12px; display: block;"></i>
                    <h4 style="margin: 0 0 5px; font-size: 14px;">Official Quorum Achieved</h4>
                    <p style="margin: 0; font-size: 11px; font-weight: 400; opacity: 0.8;">This group has fulfilled the standard requirement of ${stdOfficials} officials.</p>
                </div>
            `;
        } else {
          const startIndex = stdTrustees + officials + 1;
          generateFlexibleFields("Official", 1, remaining, "officialsContainer", startIndex);
        }
      } else {
        const remaining = totalTarget - (trustees + officials + members);
        if (remaining <= 0) {
          document.getElementById('membersContainer').innerHTML = `
                <div style="padding: 20px; text-align: center; background: #eff6ff; border: 1.5px solid #3b82f6; border-radius: 12px; color: #1e3a8a; margin: 15px 0;">
                    <i class="fas fa-users-check" style="font-size: 28px; color: #3b82f6; margin-bottom: 12px; display: block;"></i>
                    <h4 style="margin: 0 0 5px; font-size: 14px;">Target Capacity Reached</h4>
                    <p style="margin: 0; font-size: 11px; font-weight: 400; opacity: 0.8;">All ${totalTarget} proposed member slots have been filled.</p>
                </div>
            `;
          return;
        }
        const startIndex = stdTrustees + stdOfficials + members + 1;
        generateFlexibleFields("Member", 1, remaining, "membersContainer", startIndex);
      }

      // 7. Show the Back button (only visible when triggered from Add buttons)
      const backBtn = document.getElementById('cAccountBackBtn');
      if (backBtn) backBtn.classList.remove('hidden');

      // 8. Scroll to the form
      if (placeholder) {
        placeholder.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    }

    function generateUnifiedPendingInputs(group) {
      const groupName = group.groupName;

      // 1. Prepare UI
      const placeholder = document.getElementById('registrationFormPlaceholder');
      const createForm = document.getElementById('createGroupForm');
      if (placeholder && createForm) {
        placeholder.appendChild(createForm);
        placeholder.classList.remove('hidden');
        createForm.classList.remove('hidden');
        createForm.style.display = 'block';
      }

      // 2. State & Counters
      const personKeys = Object.keys(group).filter(k => k.match(/^(trustee|official|member)_\d+$/));
      const trustees = personKeys.filter(k => k.startsWith('trustee_')).length;
      const officials = personKeys.filter(k => k.startsWith('official_')).length;
      const members = personKeys.filter(k => k.startsWith('member_')).length;
      const totalTarget = group.totalProposedMembers || 15;

      window.currentTotalMembers = totalTarget;
      const stdTrustees = (window.tbankCounts && window.tbankCounts.trustees) || 3;
      const stdOfficials = (window.tbankCounts && window.tbankCounts.officials) || 3;

      // 3. Hide Steps
      ['verificationStep', 'totalMembersStep', 'paymentStep', 'reviewStep'].forEach(id => {
        const el = document.getElementById(id);
        if (el) el.classList.add('hidden');
      });
      const cAccount = document.getElementById('cAccount');
      if (cAccount) {
        cAccount.classList.remove('hidden');
        cAccount.style.display = 'block';
      }

      // Hide dashboard Continue button to avoid duplication
      const continueAction = document.getElementById('detailsContinueAction');
      if (continueAction) continueAction.classList.add('hidden');

      // 4. Reset Tracking
      window.officialsInDb = officials;
      window.membersInDb = members;
      window.officialsContainerCount = 0;
      window.membersContainerCount = 0;
      window.trusteesContainerCount = 0;
      document.getElementById('trusteesContainer').innerHTML = '';
      document.getElementById('officialsContainer').innerHTML = '';
      document.getElementById('membersContainer').innerHTML = '';

      // 5. Labels
      document.getElementById('displayGroup').textContent = groupName;
      document.getElementById('verifyPhone').value = group.phone;

      // Hide Back Button as this is the default view
      const backBtn = document.getElementById('cAccountBackBtn');
      if (backBtn) backBtn.classList.add('hidden');

      // 6. Generate Officials (if needed)
      const offRemaining = stdOfficials - officials;
      if (offRemaining > 0) {
        const offStartIndex = stdTrustees + officials + 1;
        generateFlexibleFields("Official", offRemaining, offRemaining, "officialsContainer", offStartIndex);
      } else {
        document.getElementById('officialsContainer').innerHTML = `
            <div style="padding: 15px; text-align: center; background: #ecfdf5; border: 1px solid #10b981; border-radius: 10px; color: #065f46; margin: 10px 0; font-size:11px; font-weight:600;">
                <i class="fas fa-check-circle"></i> Official Quorum Met (${stdOfficials}/${stdOfficials})
            </div>
        `;
      }

      // 7. Generate Members
      // Note: We subtract existing members and either the standard official count or the actual official count (whichever is higher)
      const effectiveOfficials = Math.max(stdOfficials, officials);
      const memRemaining = totalTarget - (stdTrustees + effectiveOfficials + members);
      if (memRemaining > 0) {
        const memStartIndex = stdTrustees + effectiveOfficials + members + 1;
        generateFlexibleFields("Member", memRemaining, memRemaining, "membersContainer", memStartIndex);
      } else {
        document.getElementById('membersContainer').innerHTML = `
            <div style="padding: 15px; text-align: center; background: #eff6ff; border: 1px solid #3b82f6; border-radius: 10px; color: #1e3a8a; margin: 10px 0; font-size:11px; font-weight:600;">
                <i class="fas fa-info-circle"></i> Member Capacity Full (${totalTarget}/${totalTarget})
            </div>
        `;
      }

      // 8. Scroll to the form for better focus
      if (placeholder) {
        placeholder.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    }

