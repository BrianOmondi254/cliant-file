    async function submitGroupPrinciple() {
      const groupName = document.getElementById('detailsGroupName').textContent;
      const endSavingPeriod = document.getElementById('endSavingPeriod').value;
      const groupInterval = document.getElementById('groupInterval').value;

      if (!endSavingPeriod || !groupInterval) {
        alert("⚠️ Please complete all interval selections.");
        return;
      }

      // Get Saving (Row 001)
      const savingAmt = document.querySelector('.charge-row .chg-amt').value;
      if (!savingAmt) {
        alert("Saving amount is required.");
        return;
      }

      // Dynamic fields validation
      if (groupInterval === 'weekly' && !document.getElementById('periodSetup').value) { alert("Please select Meeting Day"); return; }
      if (groupInterval === 'monthly' && (!document.getElementById('periodWeek').value || !document.getElementById('periodDay').value)) { alert("Please select Meeting Week and Day"); return; }
      if (groupInterval === 'yearly' && (!document.getElementById('periodMonth').value || !document.getElementById('periodWeek').value || !document.getElementById('periodDay').value)) { alert("Please select Month, Week and Day"); return; }

      // Aggregating Period String
      let periodSetup = "";
      if (groupInterval === 'daily') {
        periodSetup = "Everyday";
      } else if (groupInterval === 'weekly') {
        periodSetup = document.getElementById('periodSetup').value;
      } else if (groupInterval === 'monthly') {
        periodSetup = `${document.getElementById('periodWeek').value} - ${document.getElementById('periodDay').value}`;
      } else if (groupInterval === 'yearly') {
        periodSetup = `${document.getElementById('periodMonth').value}: ${document.getElementById('periodWeek').value} - ${document.getElementById('periodDay').value}`;
      }

      const otherContributions = [];
      const rows = document.querySelectorAll('#otherChargesList .charge-row');
      rows.forEach(row => {
        const num = row.querySelector('.chg-num').value;
        const name = row.querySelector('.chg-name').value;
        const amt = row.querySelector('.chg-amt').value;
        if (num && name && amt) {
          otherContributions.push({
            accountNumber: num,
            accountName: name,
            expectedAmount: amt
          });
        }
      });

      const principles = {
        otherContributions: otherContributions,
        distribution: {
          model: document.getElementById('benefitDistModel').value,
          officialPct: document.getElementById('officialBenefitPct').value || 0,
          performancePct: document.getElementById('memberPerfPct').value || 0,
          targetAccountName: document.getElementById('benefitAccName').value,
          targetAccountNumber: document.getElementById('benefitAccNum').value
        },
        deductions: {
          primarySource: document.getElementById('dueDedSource').value
        },
        intervals: {
          frequency: groupInterval,
          period: periodSetup,
          endSavingPeriod: endSavingPeriod
        },
        governance: {
          fastNotificationThreshold: document.getElementById('fastNotifyThreshold').value,
          editAccountThreshold: document.getElementById('editAccountThreshold').value,
          memberRemovalThreshold: document.getElementById('memberRemovalThreshold').value,
          requireResponseNote: document.getElementById('requireResponseNote').checked
        },
        balancing: {
          benefitAccounts: Array.from(new Set(Array.from(document.querySelectorAll('.benefit-check:checked')).map(i => i.value)))
        },
        loans: {
          qualificationType: document.getElementById('loanQualifyType').value,
          duration: {
            days: document.getElementById('loanDays').value
          },
          savingTarget: document.getElementById('loanTargetAmount').value,
          repayment: {
            durationDays: document.getElementById('loanRepaymentDuration').value,
            alignment: document.getElementById('loanRepaymentAlignment').value,
            rolloverMethod: document.getElementById('loanRolloverMethod').value,
            maxRollovers: document.getElementById('loanMaxRollovers').value
          },
          interestAndLimits: {
            interestRate: document.getElementById('loanInterestRate').value,
            maxActiveLoans: document.getElementById('loanMaxCount').value,
            limitBasis: document.getElementById('loanLimitBasis').value,
            limitMultiplier: document.getElementById('loanLimitMultiplier').value
          },
          type: {
            category: document.getElementById('loanCategory').value,
            guaranteeMethod: document.getElementById('loanCategory').value === 'long' ? document.getElementById('loanGuaranteeMethod').value : 'self'
          }
        }
      };

      // Only add longTerm configuration if long-term loan is selected
      if (document.getElementById('loanCategory').value === 'long') {
        principles.loans.longTerm = {
          paymentPeriod: document.getElementById('longTermPaymentPeriod').value || null,
          paymentMethod: document.getElementById('longTermPaymentMethod').value,
          installment: document.getElementById('longTermPaymentMethod').value === 'installment' ? {
            scheduleType: document.getElementById('installmentScheduleType').value,
            customRounds: document.getElementById('installmentScheduleType').value === 'set_rounds' ? document.getElementById('customRoundsCount').value : null
          } : null
        };
      }

      // Add Contribution Closer Settings
      principles.contributionCloser = {
        saving: {
          duration: document.getElementById('savingCloseDuration').value,
          intervalBuffer: document.getElementById('savingCloseInterval').value
        },
        loan: {
          duration: document.getElementById('loanCloseDuration').value,
          intervalBuffer: document.getElementById('loanCloseInterval').value
        }
      };

      try {
        const res = await fetch('/general/set-principles', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ groupName, principles })
        });
        const data = await res.json();
        if (data.success) {
          // Populate Success View
          document.getElementById('successGroupName').textContent = data.groupName || groupName;
          document.getElementById('successAccNum').textContent = data.accountNumber;
          document.getElementById('successMemberTotal').textContent = data.totalMembers || 0;

          // Show Success Step
          document.getElementById('constitutionSuccessSection').classList.remove('hidden');
          scrollToStep(8);

          // Note: We don't reload yet so they can see the account number
        } else {
          alert("Error: " + data.message);
        }
      } catch (err) {
        console.error(err);
        alert("Failed to save principles.");
      }
    }

    function closeConstitutionModal() {
      exitConstitutionSetup();
    }

    function showAgentDashboardAndReload() {
      closeConstitutionModal();
      // Refresh dashboard to show the new active group
      location.reload();
    }

    // Load Compliance Standards on Init
    window.addEventListener('DOMContentLoaded', () => {
      // Attempt to pre-load standards for indexing consistency
      fetch('/general/users').then(r => r.json()).then(users => {
        window.allComplianceUsers = users;
      }).catch(e => console.error("Compliance pre-load error:", e));

      // Also get standards from first group if window.tbankCounts is not yet set
      if (!window.tbankCounts || !window.tbankCounts.officials) {
        window.tbankCounts = { trustees: 3, officials: 3, members: 10, maxMembers: 100 }; // Secure defaults
      }
    });

  </script>

</body>

</html>