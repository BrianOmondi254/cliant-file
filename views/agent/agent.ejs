    function validateBookOfAccounts(skipScroll = false) {
      // 1. Basic Validation
      const savingAmt = document.querySelector('.charge-row .chg-amt').value;
      if (!savingAmt) {
        alert("⚠️ Saving amount (A/C 001) is required.");
        return;
      }

      // 2. CHECK REGISTRATION STATUS
      let has002 = false;
      document.querySelectorAll('.chg-num').forEach(input => {
        if (input.value === '002') has002 = true;
      });

      if (!window.regDecisionMade && !has002) {
        const container = document.getElementById('regFeeDecisionContainer');
        container.classList.remove('hidden');
        document.getElementById('regSubmitNote').classList.remove('hidden');
        container.scrollIntoView({ behavior: 'smooth', block: 'center' });
        return;
      }

      const otherRows = document.querySelectorAll('#otherChargesList .charge-row');
      let allValid = true;
      otherRows.forEach(row => {
        const nameInput = row.querySelector('.chg-name');
        const amtInput = row.querySelector('.chg-amt');
        if (!nameInput.value.trim() || !amtInput.value.trim()) allValid = false;
      });

      if (!allValid) {
        alert("⚠️ Please ensure all contribution accounts have names and amounts.");
        return;
      }

      // Auto-populate Benefit Account Number based on last account + 2 (Loan is + 1)
      const allNums = Array.from(document.querySelectorAll('.chg-num')).map(i => parseInt(i.value) || 0);
      const maxAccNum = allNums.length > 0 ? Math.max(...allNums) : 0;

      // Benefit becomes max + 2 because Loan will occupy max + 1 in the review/payload
      const nextNum = String(maxAccNum + 2).padStart(3, '0');
      document.getElementById('benefitAccNum').value = nextNum;

      if (!document.getElementById('benefitAccName').value || document.getElementById('benefitAccName').value === "Group Benefit/Dividend") {
        document.getElementById('benefitAccName').value = "Identify Source Benefit";
      }
      updateBenefitAccountName();
      return true; // Success
    }

