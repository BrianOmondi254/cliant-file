                  <%= groups.filter(g=> g.trustee_1 && (g.phase == 2 || g.phase == 3 || !g.phase)).length %>
                </span>
              </div>
              <div id="updateGroupsList">
                <% const updateEligible=groups.filter(g=> g.trustee_1 && (g.phase == 2 || g.phase == 3 || !g.phase));
                  if (updateEligible.length > 0) {
                  updateEligible.forEach(g => {
                  %>
                  <div class="dashboard-card"
                    style="cursor: pointer; border-left: 3px solid <%= g.phase == 3 ? '#059669' : '#2e7d32' %>;"
