    // Render Group Members List
    function renderGroupMembers(group) {
      const container = document.getElementById('membersListContainer');
      if (!container) return;
      container.innerHTML = '';

      const list = [];

      // Collect Trustees
      Object.keys(group).filter(k => k.startsWith('trustee_') && !k.includes('_id') && !k.includes('_phone')).forEach(k => {
        const entry = group[k];
        if (typeof entry !== 'object') return;
        list.push({
          name: entry.name || `Trustee`,
          phone: entry.phone || 'N/A',
          role: entry.title || 'Trustee',
          icon: 'fa-user-shield',
          color: '#1e3a8a'
        });
      });

      // Collect Officials
      Object.keys(group).filter(k => k.startsWith('official_') && !k.includes('_id') && !k.includes('_phone')).forEach(k => {
        const entry = group[k];
        if (typeof entry !== 'object') return;
        list.push({
          name: entry.name || `Official`,
          phone: entry.phone || 'N/A',
          role: 'Official',
          icon: 'fa-user-tie',
          color: '#854d0e'
        });
      });

      // Collect Members
      Object.keys(group).filter(k => k.startsWith('member_') && !k.includes('_id') && !k.includes('_phone')).forEach(k => {
        const entry = group[k];
        if (typeof entry !== 'object') return;
        list.push({
          name: entry.name || `Member`,
          phone: entry.phone || 'N/A',
          role: 'Member',
          icon: 'fa-user',
          color: '#475569'
        });
      });

      if (list.length === 0) {
        container.innerHTML = '<p style="text-align:center; padding:20px; color:#94a3b8; font-size:12px;">No members found.</p>';
        return;
      }

      // List Header
      const header = document.createElement('div');
      header.style.cssText = 'display:grid; grid-template-columns: 2fr 1fr 1.5fr; gap:10px; padding:10px; background:#f1f5f9; border-radius:8px; margin-bottom:10px; font-size:11px; font-weight:700; color:#475569;';
      header.innerHTML = `
      <div>NAME</div>
