    function populateGroupDetails(group) {
      const nameEl = document.getElementById('detailsGroupName');
      const existingMembersAccordion = document.getElementById('existingMembersAccordion');

      // Check if it's a "New Group" (no trustee_1) - show Agent Verification instead of content
      if (!group.trustee_1) {
        // Show Agent Verification form for new groups
        showAgentVerificationForNewGroup(group);
        return;
      }

      // Existing group: ensure the "Existing Members" accordion is visible again
      if (existingMembersAccordion) existingMembersAccordion.classList.remove('hidden');

      nameEl.textContent = group.groupName;

      // Calculate Stats (Count unique people objects)
      const personKeys = Object.keys(group).filter(k => k.match(/^(trustee|official|member)_\d+$/));

      const trustees = personKeys.filter(k => k.startsWith('trustee_')).length;
      const officials = personKeys.filter(k => k.startsWith('official_')).length;
      const members = personKeys.filter(k => k.startsWith('member_')).length;
      const total = trustees + officials + members;

      if (document.getElementById('detailsTrusteesCount')) {
        document.getElementById('detailsTrusteesCount').textContent = trustees;
      }
      document.getElementById('detailsOfficialsCount').textContent = officials;
      document.getElementById('detailsMembersCount').textContent = members;
      document.getElementById('detailsTotalHeadcount').textContent = total;
      document.getElementById('detailsTargetMembers').textContent = group.totalProposedMembers || (total > 0 ? total : 0);

      // Populate Members List
      renderGroupMembers(group);

      // Phase Status
      const statusText = document.getElementById('phaseStatusText');
      const statusRow = document.getElementById('phaseStatusRow');
      const phaseActionsDiv = document.getElementById('phaseActions');
      const principlesWrapper = document.getElementById('principlesSection');
      const principlesSlider = document.getElementById('principlesSlider');

      // Reset visibility
      statusRow.classList.remove('hidden');
      if (phaseActionsDiv) phaseActionsDiv.classList.remove('hidden');

      // Ensure sections are visible
      const membersListSection = document.getElementById('membersListSection');
      if (membersListSection) membersListSection.classList.remove('hidden');
      const groupMainInfo = document.getElementById('groupMainInfo');
      if (groupMainInfo) groupMainInfo.classList.add('hidden'); // Default hide, show only for active

      const continueAction = document.getElementById('detailsContinueAction');
      if (continueAction) {
        // Show for pending groups (Phase 1 or 2)
        if (group.phase < 3 && !group.principles) {
          continueAction.classList.remove('hidden');
        } else {
          continueAction.classList.add('hidden');
        }
      }

      if (group.phase == 3 || group.principles) {
        statusText.textContent = "Active";
        statusText.style.color = "#059669"; // Emerald/Green
        statusRow.style.background = "#def7ec";

        if (phaseActionsDiv) phaseActionsDiv.classList.remove('hidden');
        if (principlesWrapper && principlesSlider) {
          renderPrinciples(group, principlesSlider);
          principlesWrapper.classList.remove('hidden');
        }
        if (groupMainInfo) groupMainInfo.classList.remove('hidden'); // Show stats for active groups
      } else if (group.trustee_1) {
        const isFull = total >= (group.totalProposedMembers || 15);
        statusText.textContent = isFull ? "Pending (Members Submitted)" : "Pending (Phase 1)";
        statusText.style.color = "#f57c00"; // Orange
        statusRow.style.background = "#fff3cd";

        if (phaseActionsDiv) {
          phaseActionsDiv.classList.remove('hidden');
          const newMemberBtn = document.getElementById('newMemberBtn');
          const addOfficialBtn = document.getElementById('addOfficialBtn');
          const addMemberBtn = document.getElementById('addMemberBtn');
          const stdOfficials = (window.tbankCounts && window.tbankCounts.officials) || 3;
          const officialsFull = officials >= stdOfficials;

          if (isFull) {
            // Quorum met
            if (newMemberBtn) newMemberBtn.classList.add('hidden');
            if (addOfficialBtn) addOfficialBtn.classList.add('hidden');
            if (addMemberBtn) addMemberBtn.classList.add('hidden');
          } else {
            // Quorum NOT met — SHOW INPUTS IMMEDIATELY
            generateUnifiedPendingInputs(group);

            // Hide individual action buttons as they are now redundant
            if (newMemberBtn) newMemberBtn.classList.add('hidden');
            if (addOfficialBtn) addOfficialBtn.classList.add('hidden');
            if (addMemberBtn) addMemberBtn.classList.add('hidden');
          }
        }
        if (principlesWrapper) principlesWrapper.classList.add('hidden');
      } else {
        statusText.textContent = "New Request";
        statusText.style.color = "#0288d1"; // Blue
        statusRow.style.background = "#e1f5fe";

        if (phaseActionsDiv) phaseActionsDiv.classList.remove('hidden');
        if (principlesWrapper) principlesWrapper.classList.add('hidden');
      }
    }

