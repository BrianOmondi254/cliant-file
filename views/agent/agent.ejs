    function addChargeRow() {
      const list = document.getElementById('otherChargesList');
      const rows = list.querySelectorAll('.charge-row');

      // Check if 002 already exists
      let has002 = false;
      document.querySelectorAll('.chg-num').forEach(input => {
        if (input.value === '002') has002 = true;
      });

      // If only 001 exists and 002 hasn't been decided yet
      if (rows.length === 1 && !window.regDecisionMade && !has002) {
        document.getElementById('regFeeDecisionContainer').classList.remove('hidden');
        return;
      }

      // Determine highest current ID and increment
      let maxId = 1;
      document.querySelectorAll('.chg-num').forEach(input => {
        const val = parseInt(input.value);
        if (val > maxId) maxId = val;
      });

      const nextId = String(maxId + 1).padStart(3, '0');
      injectAccountRow(nextId);
    }

    function handleRegDecision(choice) {
      if (!choice) return;
