        input.max = maxDays;
        input.step = intervalDays;

        const note = document.getElementById('loanDaysNote');
        note.innerHTML = `<i class="fas fa-info-circle"></i> Condition set to qualify for fast loan for new members. <br><span style="color:#c53030; font-weight:700;">Aligned to meeting days (Max: ${maxDays} days)</span>`;
        validateLoanDays();
      }
    }

    function validateLoanDays() {
      const input = document.getElementById('loanDays');
      let val = parseInt(input.value || 0);
      const max = parseInt(input.max || 1);
      const step = parseInt(input.step || 1);

      // Collapse to nearest meeting day before (multiple of session interval)
      if (val > 0) {
        const remainder = val % step;
        if (remainder !== 0) {
          val = val - remainder;
          input.value = val;
        }
      }

      if (val > max || (val === 0 && input.value !== "")) {
        input.style.borderColor = '#ef4444';
        input.style.backgroundColor = '#fef2f2';
      } else {
        input.style.borderColor = '#cbd5e1';
        input.style.backgroundColor = '#fff';
      }
    }

