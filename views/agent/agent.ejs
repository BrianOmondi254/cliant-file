    function performGlobalGroupSearch() {
      const query = document.getElementById('globalGroupSearch').value.toLowerCase().trim();
      const resultsDiv = document.getElementById('globalSearchResults');

      if (query.length < 2) {
        resultsDiv.innerHTML = '<p style="text-align:center; font-size:12px; color:#94a3b8; padding:20px;">Identity the group by searching above.</p>';
        return;
      }

      const matches = window.managedGroups.filter(g =>
        g.groupName.toLowerCase().includes(query) ||
        (g.accountNumber && g.accountNumber.toLowerCase().includes(query)) ||
        g.phone.includes(query)
      );

      if (matches.length > 0) {
        resultsDiv.innerHTML = matches.map(g => `
        <div class="dashboard-card" style="cursor: pointer; border-left: 3px solid #64748b;" onclick="handleGroupClick('${g.groupName}')">
          <div style="display:flex; justify-content:space-between; align-items:start;">
            <div style="font-weight:600; color:#2c3e50;">${g.groupName}</div>
            <span class="badge" style="background:${g.phase == 3 ? '#d1fae5' : '#f1f5f9'}; color:${g.phase == 3 ? '#065f46' : '#64748b'}; font-size:9px;">
              ${g.phase ? 'PHASE ' + g.phase : 'NEW'}
            </span>
          </div>
          <div style="font-size:11px; color:#64748b; margin-top:4px;"><b>Acc:</b> ${g.accountNumber || 'N/A'} • <b>Phone:</b> ${g.phone}</div>
          <div style="font-size:10px; color:#94a3b8; margin-top:4px;"><b>Assigned To:</b> Identified and Assigned</div>
          <div style="font-size:10px; color:${g.phase == 3 ? '#059669' : '#f57c00'}; font-weight:700; margin-top:2px;">
            <i class="fas fa-circle" style="font-size:6px; vertical-align:middle; margin-right:4px;"></i> 
            Status: ${g.phase == 3 ? 'Active' : 'Pending Verification'}
          </div>
        </div>
      `).join('');
      } else {
        resultsDiv.innerHTML = '<p style="text-align:center; font-size:12px; color:#ef4444; padding:20px;">No matching group found.</p>';
      }
    }



