                    <input type="text" id="newGroupName" placeholder="Enter group name"
                      style="flex:1;border:none;outline:none;padding:13px 0;font-size:14px;font-weight:600;color:#1e293b;background:transparent;">
                  </div>
                </div>

                <!-- Phone Number -->
                <div style="margin-bottom:14px;">
                  <label style="font-size:11px;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:0.8px;display:block;margin-bottom:6px;">Phone Number</label>
                  <div style="display:flex;align-items:center;background:white;border:1.5px solid #e2e8f0;border-radius:12px;overflow:hidden;">
                    <div style="padding:0 14px;color:#94a3b8;"><i class="fas fa-phone-alt"></i></div>
                    <input type="tel" id="newGroupPhone" placeholder="07XXXXXXXX" maxlength="10"
                      style="flex:1;border:none;outline:none;padding:13px 0;font-size:14px;font-weight:600;color:#1e293b;background:transparent;">
                  </div>
                </div>

                <!-- Total Members -->
                <div style="margin-bottom:14px;">
                  <label style="font-size:11px;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:0.8px;display:block;margin-bottom:6px;">Total Members</label>
                  <div style="display:flex;align-items:center;background:white;border:1.5px solid #e2e8f0;border-radius:12px;overflow:hidden;">
                    <div style="padding:0 14px;color:#94a3b8;"><i class="fas fa-hashtag"></i></div>
                    <input type="number" id="newGroupMembers" placeholder="e.g. 15" min="1"
