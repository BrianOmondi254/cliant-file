    function validateLongTermPeriod() {
      const input = document.getElementById('longTermPaymentPeriod');
      const errorDiv = document.getElementById('longTermPeriodError');
      const errorMsg = document.getElementById('longTermErrorMessage');
      const noteEl = document.getElementById('longTermPeriodNote');

      const paymentPeriodMonths = parseInt(input.value || 0);
      const paymentPeriodDays = paymentPeriodMonths * 30; // approx conversion for buffer checks

      if (paymentPeriodMonths === 0 || !input.value) {
        errorDiv.classList.add('hidden');
        input.style.borderColor = '#cbd5e1';
        input.style.backgroundColor = '#fff';
        return;
      }

      if (paymentPeriodMonths > 60) {
        errorDiv.classList.remove('hidden');
        input.style.borderColor = '#ef4444';
        input.style.backgroundColor = '#fef2f2';
        errorMsg.innerHTML = `Payment period too long!<br><br>Maximum allowed is <b>60 months (5 years)</b>.`;
        return;
      }

      // Get saving period
      const savingPeriodSelect = document.getElementById('endSavingPeriod');
      if (!savingPeriodSelect || !savingPeriodSelect.value) {
        return; // Can't validate without saving period
      }

      const savingPeriod = savingPeriodSelect.value;
      let savingDays = 0;

      // Convert saving period to days
      if (savingPeriod.includes('month')) {
        const months = parseInt(savingPeriod);
        savingDays = months * 30;
      } else if (savingPeriod.includes('year')) {
        const years = parseInt(savingPeriod);
        savingDays = years * 365;
      }

      // Get meeting interval
      const intervalSelect = document.getElementById('groupInterval');
      if (!intervalSelect || !intervalSelect.value) {
        return; // Can't validate without interval
      }

      const interval = intervalSelect.value;
      let intervalDays = 1;

      if (interval === 'daily') intervalDays = 1;
      else if (interval === 'weekly') intervalDays = 7;
      else if (interval === 'monthly') intervalDays = 30;
      else if (interval === 'yearly') intervalDays = 365;

      // Calculate maximum allowed period (saving period - 1 meeting round)
      const maxAllowedDays = savingDays - intervalDays;

      if (paymentPeriodDays > maxAllowedDays) {
        // Show error
        errorDiv.classList.remove('hidden');
        input.style.borderColor = '#ef4444';
        input.style.backgroundColor = '#fef2f2';

        let intervalText = interval.charAt(0).toUpperCase() + interval.slice(1);
        const maxAllowedMonths = Math.floor(maxAllowedDays / 30);

        errorMsg.innerHTML = `Payment period too long!<br><br>
        <b>Group Saving Period:</b> ${savingDays} days (${savingPeriod})<br>
        <b>Meeting Interval:</b> ${intervalText} (${intervalDays} days)<br>
        <b>Maximum Allowed:</b> ~${maxAllowedMonths} months<br><br>
        Long-term loans must be fully repaid with at least 1 meeting round (${intervalDays} days) remaining before the saving period ends.<br><br>
        Please enter a value ≤ <b>${maxAllowedMonths} months</b>.`;
      } else {
        // Valid
        errorDiv.classList.add('hidden');
        input.style.borderColor = '#10b981';
        input.style.backgroundColor = '#f0fdf4';

        const daysRemaining = maxAllowedDays - paymentPeriodDays;
        const roundsRemaining = Math.floor(daysRemaining / intervalDays) + 1;

        noteEl.innerHTML = `<i class="fas fa-check-circle"></i> Valid! Loan will end roughly ${daysRemaining} days before group dissolution, leaving at least ${roundsRemaining} meeting round(s) for final verification.`;
        noteEl.style.color = '#10b981';
      }
    }

