    function generateFlexibleFields(label, minCount, maxCount, containerId, startIndex = 1) {
      const container = document.getElementById(containerId);
      let iconClass = label === "Official" ? "fa-user-tie" : "fa-user";

      container.innerHTML = `
      <div style="display:flex; align-items:center; margin: 25px 0 15px; color:#1e293b; border-bottom: 2px solid #f1f5f9; padding-bottom:10px;">
        <div style="background:#5f9ea0; color:white; width:30px; height:30px; border-radius:8px; display:flex; align-items:center; justify-content:center; margin-right:10px;">
          <i class="fas ${iconClass}" style="font-size:14px;"></i>
        </div>
        <h4 style="margin:0; font-size:14px; text-transform:uppercase; letter-spacing:0.5px;">${label} Details</h4>
      </div>
      <div id="${containerId}_fields"></div>
      <div id="${containerId}_notice" class="hidden" style="margin: 10px 0; padding: 12px; background: #ecfdf5; border: 1px solid #10b981; border-radius: 10px; color: #065f46; font-size: 11px; font-weight: 600; text-align: center;">
         <i class="fas fa-check-circle" style="margin-right: 5px;"></i>
         The required official input matches the standard quorum.
      </div>
      <div id="${containerId}_controls" style="display:grid; grid-template-columns: 1fr 1fr; gap:10px; margin-top: 5px; margin-bottom: 25px; padding: 0 2px;"></div>
    `;

      // Unified limit logic: All roles share the global headcount pool
      const getLimit = () => {
        const globalTo = window.currentTotalMembers || 0;
        const trusteesCount = (window.tbankCounts && window.tbankCounts.trustees) || 0;
        const offInDb = window.officialsInDb || 0;
        const memInDb = window.membersInDb || 0;
        const currentOfficials = window.officialsContainerCount || 0;
        const currentMembers = window.membersContainerCount || 0;
        return globalTo - (trusteesCount + offInDb + memInDb + currentOfficials + currentMembers);
      };

      const limit = getLimit();
      const initialToShow = Math.min(minCount, Math.max(0, limit));

      // Add all initial fields
      for (let i = 0; i < initialToShow; i++) {
        addFieldToContainer(`${containerId}_fields`, label, startIndex + i, iconClass);
      }

      // Track count (for headcount) and last index (for sequential numbering)
      window[`${containerId}Count`] = initialToShow;
      window[`${containerId}LastIndex`] = startIndex + initialToShow - 1;

      // Build singular control footer
      const controlsDiv = document.getElementById(`${containerId}_controls`);
      controlsDiv.style.cssText = "display:flex; justify-content:center; margin-top: 5px; margin-bottom: 25px; padding: 0 2px;";
      // For Members we now use the inline footer Add button only, so omit the top control.
      if (label === 'Official') {
        controlsDiv.innerHTML = `
          <button type="button" id="btnAddOne${label}" onclick="handleDynamicAdd('${containerId}', '${label}', '${iconClass}', 1)" 
                  style="width:100%; padding:14px; font-size:11px; font-weight:800; text-transform:uppercase; background:#f8fafc; color:#475569; border:1px solid #e2e8f0; border-radius:14px; display:flex; align-items:center; justify-content:center; gap:8px;">
            <i class="fas fa-plus-circle" style="color:#5f9ea0;"></i> Add ${label}
          </button>
      `;
      } else {
        controlsDiv.innerHTML = '';
      }

      checkFieldLimits();
    }

    function handleDynamicAdd(baseContainerId, label, iconClass, step) {
      const fieldsContainerId = `${baseContainerId}_fields`;
      const countKey = `${baseContainerId}Count`;
      const lastIndexKey = `${baseContainerId}LastIndex`;

      const globalTotal = window.currentTotalMembers || 0;
      const trustees = window.tbankCounts.trustees || 0;
      const officialsInDb = window.officialsInDb || 0;
      const membersInDb = window.membersInDb || 0;
      const currentOfficials = window.officialsContainerCount || 0;
      const currentMembers = window.membersContainerCount || 0;

      const totalUsed = trustees + officialsInDb + membersInDb + currentOfficials + currentMembers;
      if (totalUsed >= globalTotal) {
        alert(`The maximum headcount of ${globalTotal} for this group has been reached.`);
        return;
      }

      const toAdd = Math.min(step, globalTotal - totalUsed);
      const currentLastIndex = window[lastIndexKey] || 0;

      for (let i = 1; i <= toAdd; i++) {
        const newIndex = currentLastIndex + i;
        addFieldToContainer(fieldsContainerId, label, newIndex, iconClass);
        window[lastIndexKey] = newIndex;
        window[countKey]++;
      }

      checkFieldLimits();
    }

    function checkFieldLimits() {
      const globalTotal = window.currentTotalMembers || 0;
      const trustees = (window.tbankCounts && window.tbankCounts.trustees) || 0;
      const officialsInDb = window.officialsInDb || 0;
      const membersInDb = window.membersInDb || 0;
      const currentOfficials = window.officialsContainerCount || 0;
      const currentMembers = window.membersContainerCount || 0;
      const totalUsed = trustees + officialsInDb + membersInDb + currentOfficials + currentMembers;

      ['Official', 'Member'].forEach(label => {
        const btnOne = document.getElementById(`btnAddOne${label}`);
        if (!btnOne) return;

        const stdOfficials = (window.tbankCounts && window.tbankCounts.officials) || 3;
        let atLimit = totalUsed >= globalTotal;

        // Specific limit for Official
        if (label === 'Official' && (officialsInDb + currentOfficials) >= stdOfficials) {
          atLimit = true;
        }

        btnOne.style.display = atLimit ? 'none' : 'flex';

        // Show/Hide Official Quorum Notice
        if (label === 'Official') {
          const notice = document.getElementById(`officialsContainer_notice`);
          if (notice) {
            if (currentOfficials >= stdOfficials) {
              notice.classList.remove('hidden');
            } else {
              notice.classList.add('hidden');
            }
          }
        }
      });
    }

    function addStaggeredFields(baseContainerId, label, iconClass, maxCount, step) {
      const fieldsContainerId = `${baseContainerId}_fields`;
      const countKey = `${baseContainerId}Count`;
      const currentCount = window[countKey] || 0;

      if (currentCount >= maxCount) {
        alert(`Maximum ${maxCount} ${label.toLowerCase()}s reached.`);
        return;
      }

      const remaining = maxCount - currentCount;
      const toAdd = Math.min(step, remaining);

      for (let i = 1; i <= toAdd; i++) {
        const newIndex = currentCount + i;
        addFieldToContainer(fieldsContainerId, label, newIndex, iconClass);
        window[countKey] = newIndex;
      }

      if (window[countKey] >= maxCount) {
        document.getElementById(`btnAdd${label}`).classList.add('hidden');
      }
    }

    function addDynamicField(baseContainerId, label, iconClass, maxCount) {
      const fieldsContainerId = `${baseContainerId}_fields`;
      const countKey = `${baseContainerId}Count`;
      const currentCount = window[countKey] || 0;

      if (currentCount >= maxCount) {
        alert(`Maximum ${maxCount} ${label.toLowerCase()}s allowed.`);
        return;
      }

      const newIndex = currentCount + 1;
      addFieldToContainer(fieldsContainerId, label, newIndex, iconClass);
      window[countKey] = newIndex;
    }


    function createInputFieldHtml(type, index, fieldName, iconClass, placeholder, value = '', readonly = false, isRequired = true) {
      const readonlyAttr = readonly ? 'readonly style="background-color:#e9ecef;"' : '';
      const requiredAttr = isRequired ? 'required' : '';
      return `
      <div class="input-group" style="flex:1; margin-bottom:0;">
        <i class="fas ${iconClass}"></i>
        <input type="${fieldName.includes('phone') ? 'tel' : 'text'}" name="${type.toLowerCase()}_${index}_${fieldName}" placeholder="${placeholder}" value="${value}" ${readonlyAttr} ${requiredAttr}>
      </div>
    `;
    }

