    async function submitNewGroupCreation() {
      const name = document.getElementById('newGroupName').value.trim();
      const phone = document.getElementById('newGroupPhone').value.trim();
      const members = parseInt(document.getElementById('newGroupMembers').value);
      const mpesa = document.getElementById('newGroupMpesa').value.trim();
      const msg = document.getElementById('newGroupMsg');

      if (!name) { msg.style.color='#ef4444'; msg.textContent='Enter a group name.'; return; }
      if (!phone || phone.length < 10) { msg.style.color='#ef4444'; msg.textContent='Enter a valid phone number.'; return; }
      if (!members || members < 1) { msg.style.color='#ef4444'; msg.textContent='Enter a valid member count.'; return; }
      if (!mpesa || mpesa.length < 10) { msg.style.color='#ef4444'; msg.textContent='Enter a valid M-Pesa number.'; return; }

      msg.style.color='#4285f4'; msg.textContent='Creating group & initiating payment...';

      try {
        const res = await fetch('/agent/create-group', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ groupName: name, phone, totalMembers: members, mpesaPhone: mpesa })
        });
        const result = await res.json();
        if (result.success) {
          msg.style.color='#059669';
          msg.textContent='Group created! STK push sent to ' + mpesa + '.';
          document.getElementById('newGroupName').value = '';
          document.getElementById('newGroupPhone').value = '';
          document.getElementById('newGroupMembers').value = '';
          document.getElementById('newGroupMpesa').value = '';
          document.getElementById('groupFeePreview').style.display = 'none';
        } else {
          msg.style.color='#ef4444'; msg.textContent = result.message || 'Failed to create group.';
        }
      } catch(e) {
        msg.style.color='#ef4444'; msg.textContent='Server error. Try again.';
      }
    }

    // --- TOP NAV CONTROLLER ---
    function appBackNavigation() {
      const detailsView = document.getElementById('groupDetailsView');
      const profileView = document.getElementById('agentProfileView');
      const createView = document.getElementById('createGroupForm');
      const detailedPerfView = document.getElementById('detailedPerformanceView');
      const hubView = document.getElementById('agentFinancialHubView');
      const dashboardView = document.getElementById('agentDashboardView');

      // 1. If within detailed performance, go back to account hub
      if (detailedPerfView && !detailedPerfView.classList.contains('hidden')) {
        showMyAccount();
        return;
      }

      // 2. If within group details, detailed back logic applies (eventually goes to groups list)
      if (detailsView && !detailsView.classList.contains('hidden')) {
        handleDetailBack();
        return;
      }

      // 3. If in Profile or Groups List (Dashboard), go back to Account Hub
      if ((profileView && !profileView.classList.contains('hidden')) ||
        (dashboardView && !dashboardView.classList.contains('hidden')) ||
        (createView && !createView.classList.contains('hidden'))) {
        showMyAccount();
        return;
      }

      // 4. If already in Account Hub, go back to the external home page
      if (hubView && !hubView.classList.contains('hidden')) {
        window.location.href = '/personal'; // Adjust this URL if your "home" is different
        return;
      }

      // Fallback default
      showMyAccount();
    }





