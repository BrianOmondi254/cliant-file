    function toggleFinancialSection(contentId, btn) {
      const sections = ['floatContent', 'perfContent'];
      const content = document.getElementById(contentId);
      const isCurrentlyHidden = content.classList.contains('hidden');

      // Close ALL sections and reset ALL icons first if we are OPENING a new one
      // Note: If we are CLOSING one that is already open, it just closes it normally.
      if (isCurrentlyHidden) {
        sections.forEach(id => {
          const el = document.getElementById(id);
          if (el) el.classList.add('hidden');
        });

        // Reset all icons associated with these sections
        document.querySelectorAll('[onclick^="toggleFinancialSection"]').forEach(b => {
          const i = b.querySelector('i');
          if (i) {
            i.classList.remove('fa-chevron-up');
            i.classList.add('fa-chevron-down');
          }
        });

        // Open the target one
        content.classList.remove('hidden');
        const icon = btn.querySelector('i');
        if (icon) {
          icon.classList.remove('fa-chevron-down');
          icon.classList.add('fa-chevron-up');
        }
      } else {
        // Just hide the current one if it was open
        content.classList.add('hidden');
        const icon = btn.querySelector('i');
        if (icon) {
          icon.classList.remove('fa-chevron-up');
          icon.classList.add('fa-chevron-down');
        }
      }
    }

