  /* ─── Build Step 5 notification rows ─── */
  function buildStep5Rows() {
    const model    = selText('benefitDistModel');
    const modelVal = val('benefitDistModel');
    const dedSource= selText('dueDedSource');
    const benefitAccs = Array.from(document.querySelectorAll('#benefitAccountsList input[type="checkbox"]:checked')).map(cb => cb.value);
