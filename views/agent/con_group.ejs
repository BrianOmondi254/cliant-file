

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>Group Details | Agent Portal</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    :root {
      --primary: #0f9d58; --primary-dark: #0b7d46; --primary-light: #ecfdf5;
      --secondary: #4285f4; --secondary-light: #e8f0fe;
      --accent: #5f9ea0; --dark: #1e293b; --slate: #64748b;
      --light: #f8fafc; --white: #ffffff;
      --danger: #ef4444; --warning: #f59e0b;
      --shadow: 0 10px 25px -5px rgba(0,0,0,.1),0 8px 10px -6px rgba(0,0,0,.1);
      --shadow-lg: 0 20px 25px -5px rgba(0,0,0,.1),0 10px 10px -5px rgba(0,0,0,.1);
    }
    *{box-sizing:border-box;margin:0;padding:0;}
    body{font-family:'Inter',sans-serif;background:linear-gradient(160deg,#0f2027,#203a43,#2c5364);
      display:flex;justify-content:center;align-items:stretch;min-height:100vh;padding:3px;color:var(--dark);}
    .container{background:var(--white);width:100%;max-width:545px;border-radius:5px;
      box-shadow:var(--shadow-lg);overflow:hidden;position:relative;
      animation:slideIn .5s cubic-bezier(.4,0,.2,1);z-index:100;padding:0 2px;margin-bottom:10px;padding-bottom:30px;}
    @keyframes slideIn{from{opacity:0;transform:translateY(30px)}to{opacity:1;transform:translateY(0)}}
    .header{background:linear-gradient(135deg,var(--primary),#34d399);padding:25px 22px;color:var(--white);
      text-align:center;position:sticky;top:0;z-index:1000;border-radius:5px 5px 0 0;}
    .header h1{font-size:22px;font-weight:800;margin-bottom:5px;letter-spacing:-.5px;}
    .header p{font-size:12px;opacity:.9;font-weight:500;text-transform:uppercase;letter-spacing:1px;}
    .back-btn{position:absolute;top:20px;left:16px;color:var(--white);text-decoration:none;font-size:16px;opacity:.8;transition:opacity .2s;}
    .back-btn:hover{opacity:1;}
    .content{padding:20px;padding-bottom:40px;}
    .group-info{background:var(--light);border-radius:12px;padding:15px;margin-bottom:20px;}
    .info-row{display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid #e2e8f0;font-size:13px;}
    .info-row:last-child{border-bottom:none;}
    .info-label{color:var(--slate);font-weight:500;}
    .info-value{font-weight:700;color:var(--dark);}
    .status-badge{display:inline-block;padding:4px 10px;border-radius:20px;font-size:11px;font-weight:700;text-transform:uppercase;}
    .status-pending{background:#fffbeb;color:#d97706;}
    .members-section{margin-bottom:20px;}
    .members-section h3{font-size:14px;color:var(--dark);margin-bottom:12px;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;}
    .member-card{background:var(--white);border:1px solid #e2e8f0;border-radius:10px;
      padding:12px 15px;margin-bottom:10px;display:flex;align-items:center;justify-content:space-between;}
    .member-card:hover{border-color:var(--primary);}
    .member-info{display:flex;align-items:center;gap:12px;}
    .member-icon{width:36px;height:36px;background:var(--primary-light);border-radius:50%;
      display:flex;align-items:center;justify-content:center;color:var(--primary);}
    .member-details h4{font-size:14px;font-weight:600;color:var(--dark);}
    .member-details p{font-size:11px;color:var(--slate);margin-top:2px;}
    .member-phone{font-size:12px;font-weight:600;color:var(--secondary);}
    .btn{display:block;width:100%;padding:14px;border:none;border-radius:10px;
      background:var(--primary);color:white;font-size:14px;font-weight:700;
      cursor:pointer;transition:all .3s ease;text-align:center;text-decoration:none;}
    .btn:hover{background:var(--primary-dark);transform:translateY(-2px);}
    .btn-secondary{background:var(--secondary);}
    .btn-secondary:hover{background:#3367d6;}
    .btn-row{display:flex;gap:10px;}
    .btn-row .btn{flex:1;}
    .empty-members{text-align:center;padding:30px;color:var(--slate);}
    .empty-members i{font-size:40px;margin-bottom:10px;opacity:.5;}
    .hidden{display:none!important;}
    .constitution-form{margin-top:20px;padding-top:20px;border-top:2px dashed #e2e8f0;animation:slideUp 0.3s ease;}
    @keyframes slideUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
    .form-group{margin-bottom:15px;}
    .form-group label{display:block;font-size:12px;font-weight:600;color:var(--dark);margin-bottom:8px;}
    .form-group input{width:100%;padding:14px;border:2px solid #e2e8f0;border-radius:10px;
      font-size:16px;font-weight:600;letter-spacing:3px;text-align:center;transition:all 0.3s ease;}
    .form-group input:focus{border-color:var(--accent);outline:none;box-shadow:0 0 0 3px rgba(95,158,160,0.2);}
 
    /* Progress */
    .step-progress{display:flex;align-items:center;justify-content:center;gap:0;
      padding:14px 20px 10px;background:#f8fafc;border-bottom:1px solid #e2e8f0;
      margin-bottom:18px;border-radius:8px;overflow-x:auto;}
    .step-dot{display:flex;flex-direction:column;align-items:center;gap:4px;cursor:default;min-width:36px;}
    .step-dot .dot{width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;
      font-size:11px;font-weight:800;border:2px solid #e2e8f0;background:white;color:#94a3b8;transition:all 0.3s ease;}
    .step-dot.active .dot{background:#008080;border-color:#008080;color:white;box-shadow:0 0 0 3px rgba(0,128,128,0.2);}
    .step-dot.completed .dot{background:#10b981;border-color:#10b981;color:white;}
    .step-dot .label{font-size:9px;font-weight:700;color:#94a3b8;text-transform:uppercase;text-align:center;white-space:nowrap;}
    .step-dot.active .label{color:#008080;}
    .step-dot.completed .label{color:#10b981;}
    .step-connector{height:2px;flex:1;min-width:10px;background:#e2e8f0;margin-bottom:16px;transition:background 0.3s;}
    .step-connector.done{background:#10b981;}
 
    /* Step panels */
    .step-panel{display:none;animation:slideUp 0.3s ease;}
    .step-panel.active{display:block;}
    .step-card{background:linear-gradient(135deg,#f8fafc 0%,#f1f5f9 100%);
      padding:20px;border-radius:12px;margin-bottom:20px;border:1px solid #e2e8f0;}
    .step-card-title{color:#008080;margin-bottom:15px;font-size:15px;
      border-bottom:2px solid #e0f2f1;padding-bottom:12px;display:flex;align-items:center;gap:10px;}
    .step-card-title i{background:#e0f2f1;padding:8px;border-radius:8px;}
    .nav-row{display:flex;gap:10px;margin-top:8px;}
    .nav-row .btn{padding:13px;font-size:14px;}
    .btn-back{background:#95a5a6;flex:1;}
    .btn-back:hover{background:#7f8c8d;transform:none;}
    .btn-next{background:linear-gradient(135deg,#5f9ea0,#008080);flex:2;}
    .btn-next:hover{background:linear-gradient(135deg,#008080,#005f5f);}
    .btn-activate{background:linear-gradient(135deg,#0f9d58,#2e7d32);flex:2;}
    .btn-activate:hover{background:#1b5e20;}
    .field-label{display:block;font-size:11px;font-weight:700;color:#475569;
      text-transform:uppercase;letter-spacing:0.5px;margin-bottom:8px;}
    .field-select,.field-input{width:100%;padding:10px 12px;font-size:13px;border-radius:8px;
      border:1.5px solid #cbd5e1;background:white;margin-bottom:14px;}
    .field-select:focus,.field-input:focus{border-color:#008080;outline:none;}
    .field-with-icon{position:relative;}
    .field-with-icon i{position:absolute;left:12px;top:50%;transform:translateY(-50%);color:#94a3b8;font-size:14px;}
    .field-with-icon select,.field-with-icon input{padding-left:40px;}
    .info-box{font-size:10px;color:#5f9ea0;margin-top:-10px;margin-bottom:12px;font-style:italic;}
    .acct-header{display:grid;grid-template-columns:35px 1fr 55px 24px;gap:4px;
      margin-bottom:8px;padding:8px 0;background:#e0f2f1;border-radius:8px;}
    .acct-header div{font-size:10px;font-weight:800;color:#00695c;}
    .charge-row{display:grid;grid-template-columns:35px 1fr 55px 24px;gap:4px;
      margin-bottom:8px;background:white;padding:8px 0;border-radius:8px;border:1px solid #e2e8f0;}
    .charge-row input{width:100%;height:36px;font-size:12px;border:1px solid #cbd5e1;border-radius:6px;}
    .charge-row .chg-num{background:#f8fafc;color:#64748b;text-align:center;font-weight:800;}
    .charge-row .chg-name{padding:0 8px;font-weight:600;}
    .charge-row .chg-amt{padding:0 8px;font-weight:700;color:#008080;text-align:right;}
    .charge-row .del-btn{background:#ef4444;color:white;border:none;border-radius:6px;width:100%;height:36px;cursor:pointer;font-size:14px;}
 
    /* ── WHOLE-STEP NOTIFICATION OVERLAY ── */
    .step-notif{
      display:none; margin-top:16px; border-radius:12px; overflow:hidden;
      border:2px solid #f59e0b; box-shadow:0 8px 24px rgba(245,158,11,0.18);
      animation:notifPop 0.35s cubic-bezier(.4,0,.2,1);
    }
    @keyframes notifPop{from{opacity:0;transform:scale(0.97)}to{opacity:1;transform:scale(1)}}
    .step-notif-header{
      background:linear-gradient(135deg,#f59e0b,#d97706);
      color:white; padding:12px 16px; font-size:13px; font-weight:800;
      display:flex; align-items:center; gap:8px;
    }
    .step-notif-body{background:#fffbeb; padding:14px 16px;}
    .step-notif-body p{font-size:12px;color:#78350f;line-height:1.7;margin-bottom:12px;}
    .notif-summary-grid{
      display:grid; grid-template-columns:1fr; gap:6px; margin-bottom:14px;
    }
    .notif-row{
      display:flex; justify-content:space-between; align-items:center;
      background:white; border-radius:8px; padding:8px 12px;
      border-left:3px solid #f59e0b; font-size:12px;
    }
    .notif-row .notif-key{color:#92400e; font-weight:700;}
    .notif-row .notif-val{color:#1e293b; font-weight:800; text-align:right; max-width:60%;}
    .notif-ack-row{
      display:flex; align-items:center; gap:10px; padding:10px 12px;
      background:white; border-radius:8px; border:1.5px solid #fcd34d; cursor:pointer;
    }
    .notif-ack-row input[type="checkbox"]{width:18px;height:18px;accent-color:#d97706;cursor:pointer;flex-shrink:0;}
    .notif-ack-row label{font-size:12px;color:#78350f;font-weight:700;cursor:pointer;}
 
    #reviewContentArea{max-height:500px;overflow-y:auto;}
 
    /* Review notification summary cards */
    .review-notif-card{
      background:linear-gradient(135deg,#fffbeb,#fef9c3);
      border-radius:10px; border:1px solid #fcd34d; padding:14px; margin-bottom:12px;
    }
    .review-notif-card h6{font-size:10px;color:#92400e;text-transform:uppercase;font-weight:800;
      letter-spacing:1px;margin-bottom:10px;display:flex;align-items:center;gap:6px;}
    .review-notif-item{font-size:12px;color:#78350f;padding:4px 0;
      border-bottom:1px dashed #fde68a;display:flex;justify-content:space-between;}
    .review-notif-item:last-child{border-bottom:none;}
    .review-notif-item span:last-child{font-weight:800;color:#1e293b;}
  </style>
</head>
<body>
<div class="container">
  <div class="header">
    <a href="/agent" class="back-btn"><i class="fas fa-arrow-left"></i></a>
    <h1><%= group.groupName %></h1>
    <p>Pending Approval Group</p>
  </div>
 
  <div class="content">
 
    <!-- GROUP INFO -->
    <div id="groupInfoSection" class="group-info">
      <div class="info-row">
        <span class="info-label">Location</span>
        <span class="info-value"><%= group.ward %>, <%= group.constituency %></span>
      </div>
      <div class="info-row">
        <span class="info-label">Status</span>
        <span class="info-value">
          <span class="status-badge status-pending">
            <%= group.phase === 2 ? 'Pending Approval' : 'Phase ' + group.phase %>
          </span>
        </span>
      </div>
      <div class="info-row">
        <span class="info-label">Chairperson</span>
        <span class="info-value"><%= group.phone || 'N/A' %></span>
      </div>
      <% if (group.totalProposedMembers) { %>
      <div class="info-row">
        <span class="info-label">Total Members</span>
        <span class="info-value"><%= group.totalProposedMembers %></span>
      </div>
      <% } %>
      <% if (group.createdAt) { %>
      <div class="info-row">
        <span class="info-label">Created</span>
        <span class="info-value"><%= new Date(group.createdAt).toLocaleDateString() %></span>
      </div>
      <% } %>
    </div>
 
    <!-- MEMBERS -->
    <div id="membersSection" class="members-section">
      <h3>Registered Members</h3>
      <% if (group.membersList && group.membersList.length > 0) { %>
        <%
          const trustees = group.membersList.filter(m => m.type === 'trustee');
          const officials = group.membersList.filter(m => m.type === 'official');
          const members  = group.membersList.filter(m => m.type === 'member');
        %>
        <% trustees.forEach((m, i) => { %>
          <div class="member-card">
            <div class="member-info">
              <div class="member-icon"><i class="fas fa-user-tie"></i></div>
              <div class="member-details">
                <h4><%= m.name || 'Unknown' %></h4>
                <p>Trustee <%= i+1 %> · <%= m.title || 'Member' %></p>
              </div>
            </div>
            <span class="member-phone"><%= m.phone %></span>
          </div>
        <% }); %>
        <% officials.forEach((m, i) => { %>
          <div class="member-card">
            <div class="member-info">
              <div class="member-icon"><i class="fas fa-user-gear"></i></div>
              <div class="member-details">
                <h4><%= m.name || 'Unknown' %></h4>
                <p>Official <%= i+1 %></p>
              </div>
            </div>
            <span class="member-phone"><%= m.phone %></span>
          </div>
        <% }); %>
        <% members.forEach((m, i) => { %>
          <div class="member-card">
            <div class="member-info">
              <div class="member-icon"><i class="fas fa-user"></i></div>
              <div class="member-details">
                <h4><%= m.name || 'Unknown' %></h4>
                <p>Member <%= i+1 %></p>
              </div>
            </div>
            <span class="member-phone"><%= m.phone %></span>
          </div>
        <% }); %>
      <% } else { %>
        <div class="empty-members">
          <i class="fas fa-users"></i>
          <p>No members registered yet</p>
        </div>
      <% } %>
    </div>
 
    <!-- CONTINUE BUTTONS -->
    <div id="continueSection">
      <button onclick="showConstitutionForm()" class="btn" style="background:linear-gradient(135deg,#5f9ea0,#008080);">
        <i class="fas fa-file-contract"></i> Continue to Constitution
      </button>
      <a href="/agent/conform?groupName=<%= encodeURIComponent(group.groupName) %>" target="_blank"
         class="btn btn-secondary" style="margin-top:10px;display:flex;align-items:center;justify-content:center;gap:8px;">
        <i class="fas fa-download"></i> View Constitution
      </a>
    </div>
 
    <!-- KEY VERIFICATION FORM -->
    <div id="constitutionForm" class="hidden constitution-form">
      <% if (existingKey) { %>
      <h3 style="font-size:14px;color:var(--dark);margin-bottom:15px;font-weight:700;text-transform:uppercase;">
        <i class="fas fa-key"></i> Constitution Start Key
      </h3>
      <div class="form-group">
        <label for="startKey">Enter Key to Confirm</label>
        <input type="text" id="startKey" maxlength="4" placeholder="----" autocomplete="off" inputmode="numeric">
      </div>
      <div id="startKeyError" style="color:var(--danger);font-size:12px;margin-bottom:10px;display:none;">
        <i class="fas fa-exclamation-circle"></i> Incorrect key. Please try again.
      </div>
      <div class="btn-row">
        <button onclick="verifyStartKey()" class="btn" style="background:linear-gradient(135deg,#5f9ea0,#008080);">
          <i class="fas fa-check"></i> Verify & Continue
        </button>
        <button onclick="cancelConstitution()" class="btn" style="background:#64748b;">
          <i class="fas fa-times"></i> Cancel
        </button>
      </div>
      <% } else { %>
      <h3 style="font-size:14px;color:var(--dark);margin-bottom:15px;font-weight:700;text-transform:uppercase;">
        <i class="fas fa-key"></i> Set Constitution Start Key
      </h3>
      <div class="form-group">
        <label for="startKey">Start Key (4 digits)</label>
        <input type="text" id="startKey" maxlength="4" placeholder="----" autocomplete="off" inputmode="numeric">
      </div>
      <div id="startKeyError" style="color:var(--danger);font-size:12px;margin-bottom:10px;display:none;">
        <i class="fas fa-exclamation-circle"></i> Please enter a valid 4-digit key
      </div>
      <div class="btn-row">
        <button onclick="submitStartKey()" class="btn" style="background:linear-gradient(135deg,#5f9ea0,#008080);">
          <i class="fas fa-check"></i> Submit
        </button>
        <button onclick="cancelConstitution()" class="btn" style="background:#64748b;">
          <i class="fas fa-times"></i> Cancel
        </button>
      </div>
      <% } %>
    </div>
 
    <!-- SETUP WIZARD -->
    <div id="step1Section" style="display:none;">
 
      <!-- Wizard header -->
      <div style="text-align:center;padding:20px 20px 10px;">
        <div style="width:50px;height:50px;background:#e0f2f1;color:#008080;border-radius:14px;display:inline-flex;
          align-items:center;justify-content:center;font-size:22px;margin-bottom:12px;box-shadow:0 6px 16px rgba(0,128,128,0.15);">
          <i class="fas fa-file-shield"></i>
        </div>
        <h4 style="color:#1e293b;font-size:16px;font-weight:800;margin-bottom:4px;">Constitution Setup</h4>
        <p style="color:#64748b;font-size:12px;">Complete each step to configure group principles</p>
      </div>
 
      <!-- Progress bar -->
      <div class="step-progress" id="stepProgress">
        <div class="step-dot active" id="dot1"><div class="dot">1</div><div class="label">Timing</div></div>
        <div class="step-connector" id="con1"></div>
        <div class="step-dot" id="dot2"><div class="dot">2</div><div class="label">Govern</div></div>
        <div class="step-connector" id="con2"></div>
        <div class="step-dot" id="dot3"><div class="dot">3</div><div class="label">Accounts</div></div>
        <div class="step-connector" id="con3"></div>
        <div class="step-dot" id="dot4"><div class="dot">4</div><div class="label">Loans</div></div>
        <div class="step-connector" id="con4"></div>
        <div class="step-dot" id="dot5"><div class="dot">5</div><div class="label">Benefits</div></div>
        <div class="step-connector" id="con5"></div>
        <div class="step-dot" id="dot6"><div class="dot">6</div><div class="label">Closer</div></div>
        <div class="step-connector" id="con6"></div>
        <div class="step-dot" id="dot7"><div class="dot"><i class="fas fa-check" style="font-size:9px;"></i></div><div class="label">Review</div></div>
      </div>
 
      <!-- ═══════════════ STEP 1: Duration & Frequency ═══════════════ -->
      <div class="step-panel active" id="panel1">
        <div class="step-card">
          <h4 class="step-card-title"><i class="fas fa-hourglass-end"></i> Step 1: Duration &amp; Frequency</h4>
 
          <label class="field-label">End Saving Period</label>
          <div class="field-with-icon" style="margin-bottom:14px;">
            <i class="fas fa-hourglass-end"></i>
            <select id="endSavingPeriod" class="field-select" style="padding-left:40px;margin-bottom:0;" onchange="onPeriodChange()">
              <option value="" disabled selected>Select Save Duration</option>
              <option value="6-months">6 Months</option>
              <option value="1-year">1 Year</option>
              <option value="2-years">2 Years</option>
              <option value="3-years">3 Years</option>
              <option value="4-years">4 Years</option>
              <option value="5-years">5 Years</option>
            </select>
          </div>
 
          <label class="field-label">Contribution Interval</label>
          <div class="field-with-icon" style="margin-bottom:14px;">
            <i class="fas fa-history"></i>
            <select id="groupInterval" class="field-select" style="padding-left:40px;margin-bottom:0;" onchange="updateIntervalDetail()">
              <option value="" disabled selected>Select Frequency</option>
              <option value="daily">Daily</option>
              <option value="weekly">Weekly</option>
              <option value="monthly">Monthly</option>
              <option value="yearly">Yearly</option>
            </select>
          </div>
 
          <!-- Weekly -->
          <div id="intervalDetailContainer" style="display:none;margin-top:8px;">
            <label class="field-label">Day of Week</label>
            <select id="contributionDay" class="field-select">
              <option value="" disabled selected>Select Day</option>
              <option value="Monday">Monday</option><option value="Tuesday">Tuesday</option>
              <option value="Wednesday">Wednesday</option><option value="Thursday">Thursday</option>
              <option value="Friday">Friday</option><option value="Saturday">Saturday</option>
              <option value="Sunday">Sunday</option>
            </select>
          </div>
          <!-- Yearly: month -->
          <div id="monthContainer" style="display:none;margin-top:8px;">
            <label class="field-label">Month</label>
            <select id="contributionMonth" class="field-select" onchange="updateMonthDetail()">
              <option value="" disabled selected>Select Month</option>
              <option value="January">January</option><option value="February">February</option>
              <option value="March">March</option><option value="April">April</option>
              <option value="May">May</option><option value="June">June</option>
              <option value="July">July</option><option value="August">August</option>
              <option value="September">September</option><option value="October">October</option>
              <option value="November">November</option><option value="December">December</option>
            </select>
          </div>
          <!-- Monthly / yearly: week of month -->
          <div id="weekOfMonthContainer" style="display:none;margin-top:8px;">
            <label class="field-label">Week of Month</label>
            <select id="weekOfMonth" class="field-select" onchange="updateDayOfWeekOptions()">
              <option value="" disabled selected>Select Week</option>
              <option value="1st Week">1st Week</option><option value="2nd Week">2nd Week</option>
              <option value="3rd Week">3rd Week</option><option value="4th Week">4th Week</option>
            </select>
          </div>
