<script>
  /* ─── Data store for confirmed notifications ─── */
  const confirmedSteps = {};
 
  const groupName   = '<%= group.groupName %>';
  const existingKey = '<%= existingKey || "" %>';
  const keyRequired = <%= keyRequired ? 'true' : 'false' %>;
  let currentStep = 1;
  const TOTAL_STEPS = 7;
 
  /* ─── Progress indicator ─── */
  function updateProgress(step) {
    for (let i = 1; i <= TOTAL_STEPS; i++) {
      const dot = document.getElementById('dot' + i);
      dot.classList.remove('active', 'completed');
      if (i < step)        dot.classList.add('completed');
      else if (i === step) dot.classList.add('active');
    }
    for (let i = 1; i < TOTAL_STEPS; i++) {
      const con = document.getElementById('con' + i);
      if (con) con.classList.toggle('done', i < step);
    }
  }
 
  function showPanel(step) {
    document.querySelectorAll('.step-panel').forEach(p => p.classList.remove('active'));
    const panel = document.getElementById('panel' + step);
    if (panel) {
      panel.classList.add('active');
      panel.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
    currentStep = step;
    updateProgress(step);
  }
 
  /* ─── Helper: build notif summary row ─── */
  function notifRow(key, val) {
    return `<div class="notif-row"><span class="notif-key">${key}</span><span class="notif-val">${val}</span></div>`;
  }
 
  /* ─── Show step notification ─── */
  function showStepNotif(step, rows, ackId, notifId) {
    const grid = document.getElementById(notifId + 'Grid');
    if (grid) grid.innerHTML = rows.map(r => notifRow(r[0], r[1])).join('');
    const notif = document.getElementById(notifId);
    const cb = document.getElementById(ackId);
    if (notif) {
      cb.checked = false;
      notif.style.display = 'block';
      setTimeout(() => notif.scrollIntoView({ behavior: 'smooth', block: 'center' }), 100);
    }
  }
 
  /* ─── Build Step 1 notification rows ─── */
  function buildStep1Rows() {
    const period = selText('endSavingPeriod');
    const freq   = selText('groupInterval');
    const freqVal = val('groupInterval');
    const rows = [
      ['Saving Period', period],
      ['Contribution Frequency', freq],
    ];
    if (freqVal === 'weekly') {
      rows.push(['Day of Week', selText('contributionDay')]);
    } else if (freqVal === 'monthly') {
      rows.push(['Week of Month', selText('weekOfMonth')]);
      rows.push(['Day of Week', selText('dayOfWeek')]);
    } else if (freqVal === 'yearly') {
      rows.push(['Month', selText('contributionMonth')]);
      rows.push(['Week of Month', selText('weekOfMonth')]);
      rows.push(['Day of Week', selText('dayOfWeek')]);
    }
    return rows;
  }
 
