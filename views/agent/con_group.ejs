      ['Interest Rate', val('loanInterestRate') + '%'],
      ['Limit Basis', basisText],
      ['Limit Multiplier', val('loanLimitMultiplier') + 'x'],
      ['Max Concurrent Loans', val('loanMaxCount')],
    );
    if (catVal === 'long') {
      rows.push(['Guarantee Method', selText('loanGuaranteeMethod')]);
      rows.push(['Payment Period', val('longTermPaymentPeriod') + ' months']);
      rows.push(['Payment Method', selText('longTermPaymentMethod')]);
