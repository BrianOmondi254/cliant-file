  /* ─── Small helpers ─── */
  function val(id) { const el = document.getElementById(id); return el ? el.value : ''; }
  function selText(id) {
    const el = document.getElementById(id);
    if (!el) return '';
    if (el.tagName === 'SELECT') return el.options[el.selectedIndex]?.text || '';
    return el.value;
  }
 
  /* ─── nextStep – the authoritative navigation handler ─── */
  function nextStep(from) {
    if (!validateStep(from)) return;
 
    /* ----- STEP 1 ----- */
    if (from === 1) {
      const cb   = document.getElementById('step1AckCheckbox');
      const notif= document.getElementById('step1Notification');
      if (!cb.checked) {
        showStepNotif(1, buildStep1Rows(), 'step1AckCheckbox', 'step1Notification');
        return;
      }
      confirmedSteps[1] = buildStep1Rows();
      notif.style.display = 'none';
    }
 
    /* ----- STEP 2 ----- */
    if (from === 2) {
      const cb   = document.getElementById('step2AckCheckbox');
      const notif= document.getElementById('step2Notification');
      if (!cb.checked) {
        showStepNotif(2, buildStep2Rows(), 'step2AckCheckbox', 'step2Notification');
        return;
      }
      confirmedSteps[2] = buildStep2Rows();
      notif.style.display = 'none';
    }
 
    /* ----- STEP 3 ----- */
    if (from === 3) {
      const cb   = document.getElementById('step3AckCheckbox');
      const notif= document.getElementById('step3Notification');
      if (!cb.checked) {
        showStepNotif(3, buildStep3Rows(), 'step3AckCheckbox', 'step3Notification');
        return;
      }
      confirmedSteps[3] = buildStep3Rows();
      notif.style.display = 'none';
    }
 
    /* ----- STEP 4 ----- */
    if (from === 4) {
      const cb   = document.getElementById('step4AckCheckbox');
      const notif= document.getElementById('step4Notification');
      if (!cb.checked) {
        showStepNotif(4, buildStep4Rows(), 'step4AckCheckbox', 'step4Notification');
        return;
      }
      confirmedSteps[4] = buildStep4Rows();
      notif.style.display = 'none';
    }
 
    /* ----- STEP 5 ----- */
    if (from === 5) {
      const cb   = document.getElementById('step5AckCheckbox');
      const notif= document.getElementById('step5Notification');
      if (!cb.checked) {
        showStepNotif(5, buildStep5Rows(), 'step5AckCheckbox', 'step5Notification');
        return;
      }
      confirmedSteps[5] = buildStep5Rows();
      notif.style.display = 'none';
    }
 
    /* ----- STEP 6 ----- */
    if (from === 6) {
      const cb   = document.getElementById('step6AckCheckbox');
      const notif= document.getElementById('step6Notification');
      if (!cb.checked) {
        showStepNotif(6, buildStep6Rows(), 'step6AckCheckbox', 'step6Notification');
        return;
      }
      confirmedSteps[6] = buildStep6Rows();
      notif.style.display = 'none';
      buildReview();
    }
 
    showPanel(from + 1);
  }
 
  function prevStep(from) { showPanel(from - 1); }
 
  /* ─── Validation per step ─── */
  function validateStep(step) {
    if (step === 1) {
      const period = val('endSavingPeriod');
      const freq   = val('groupInterval');
      if (!period) { alert('Please select End Saving Period'); return false; }
      if (!freq)   { alert('Please select Contribution Interval'); return false; }
      if (freq === 'weekly') {
        if (!val('contributionDay')) { alert('Please select Day of Week'); return false; }
      } else if (freq === 'monthly') {
        if (!val('weekOfMonth')) { alert('Please select Week of Month'); return false; }
        if (!val('dayOfWeek'))   { alert('Please select Day of Week'); return false; }
      } else if (freq === 'yearly') {
        if (!val('contributionMonth')) { alert('Please select Month'); return false; }
        if (!val('weekOfMonth'))       { alert('Please select Week of Month'); return false; }
        if (!val('dayOfWeek'))         { alert('Please select Day of Week'); return false; }
      }
      return true;
    }
    if (step === 2) {
      const ft = +val('fastThreshold');
      const et = +val('editThreshold');
      const rt = +val('removeThreshold');
      if (!ft||ft<51||ft>99) { alert('Fast Notification Threshold must be 51–99%'); return false; }
      if (!et||et<51||et>99) { alert('Edit Account Threshold must be 51–99%'); return false; }
      if (!rt||rt<51||rt>99) { alert('Member Removal Threshold must be 51–99%'); return false; }
      return true;
    }
    if (step === 3) {
      if (!val('regChoiceSelect')) { alert('Please select whether a registration fee is charged'); return false; }
      if (!window.confirmedAccounts || window.confirmedAccounts.length === 0) {
        alert('Please confirm accounts by clicking the OK / Confirm button first'); return false;
      }
      return true;
    }
    if (step === 4) {
      const repDays = val('loanRepaymentDuration');
      if (!repDays || +repDays <= 0) { alert('Please enter Loan Repayment Duration'); return false; }
      const qualType = val('loanQualifyType');
      if (qualType === 'duration' || qualType === 'both') {
        if (!val('loanDays') || +val('loanDays') <= 0) { alert('Please enter Waiting Period (Days)'); return false; }
      }
      if (qualType === 'saving' || qualType === 'both') {
        if (!val('loanTargetAmount') || +val('loanTargetAmount') <= 0) { alert('Please enter Targeted Saving Amount'); return false; }
      }
      if (val('loanCategory') === 'long') {
        if (!val('longTermPaymentPeriod') || +val('longTermPaymentPeriod') <= 0) { alert('Please enter Long Term Payment Period'); return false; }
        if (val('longTermPaymentMethod') === 'installment' && val('installmentScheduleType') === 'set_rounds') {
          if (!val('customRoundsCount') || +val('customRoundsCount') <= 0) { alert('Please enter Number of Rounds'); return false; }
        }
      }
      const ir = val('loanInterestRate');
      if (ir === '' || +ir < 0) { alert('Please enter a valid Interest Rate'); return false; }
      if (!val('loanMaxCount') || +val('loanMaxCount') <= 0) { alert('Please enter Max Concurrent Active Loans'); return false; }
      return true;
    }
    return true; // steps 5, 6 — no strict validation required
  }
 
  /* ─── Interval detail ─── */
  function onPeriodChange() {
    const period = val('endSavingPeriod');
    const intervalSelect = document.getElementById('groupInterval');
    const yearlyOpt = intervalSelect.querySelector('option[value="yearly"]');
    if (period === '6-months' || period === '1-year') {
      yearlyOpt.style.display = 'none';
      if (intervalSelect.value === 'yearly') { intervalSelect.value = ''; updateIntervalDetail(); }
    } else {
      yearlyOpt.style.display = '';
    }
  }
 
  function updateIntervalDetail() {
    const freq = val('groupInterval');
    document.getElementById('intervalDetailContainer').style.display = 'none';
    document.getElementById('weekOfMonthContainer').style.display    = 'none';
    document.getElementById('dayOfWeekContainer').style.display      = 'none';
    document.getElementById('monthContainer').style.display          = 'none';
    document.getElementById('contributionDay').value  = '';
    document.getElementById('weekOfMonth').value      = '';
    document.getElementById('dayOfWeek').value        = '';
    document.getElementById('contributionMonth').value= '';
    if (freq === 'weekly') {
      document.getElementById('intervalDetailContainer').style.display = 'block';
    } else if (freq === 'monthly') {
      document.getElementById('weekOfMonthContainer').style.display = 'block';
    } else if (freq === 'yearly') {
      document.getElementById('monthContainer').style.display = 'block';
    }
  }
 
  function updateDayOfWeekOptions() {
    document.getElementById('dayOfWeekContainer').style.display = val('weekOfMonth') ? 'block' : 'none';
  }
 
  function updateMonthDetail() {
    const month = val('contributionMonth');
    document.getElementById('weekOfMonthContainer').style.display = month ? 'block' : 'none';
    document.getElementById('dayOfWeekContainer').style.display   = 'none';
    document.getElementById('weekOfMonth').value = '';
    document.getElementById('dayOfWeek').value   = '';
  }
 
  /* ─── Accounts ─── */
  function addChargeRow() {
    const container = document.getElementById('otherChargesList');
