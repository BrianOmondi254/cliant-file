              <i class="fas fa-clipboard-check" style="background:#a7f3d0;"></i> Step 7: Review &amp; Activate
            </h4>
            <div id="reviewContentArea"></div>
          </div>

          <div class="nav-row">
            <button class="btn btn-back" onclick="prevStep(7)"><i class="fas fa-arrow-left"></i> Back</button>
            <button class="btn btn-activate" onclick="savePrinciples()">
