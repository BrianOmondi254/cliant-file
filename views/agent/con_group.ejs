            <div>Type: <b>${selText('loanCategory')}</b> &nbsp;·&nbsp; Qualification: <b>${selText('loanQualifyType')}</b></div>
            <div>Repayment: <b>${val('loanRepaymentDuration')} days</b> &nbsp;·&nbsp; Interest: <b>${val('loanInterestRate')}%</b></div>
            <div>Rollovers: <b>${val('loanMaxRollovers')} max</b> &nbsp;·&nbsp; Multiplier: <b>${val('loanLimitMultiplier')}x</b></div>
          </div>
        </div>
 
        <!-- Closer summary -->
        <div style="background:#f0fdf4;border-radius:10px;border:1px solid #bbf7d0;padding:14px;">
          <h6 style="font-size:10px;color:#065f46;text-transform:uppercase;font-weight:800;margin-bottom:10px;letter-spacing:1px;"><i class="fas fa-door-closed"></i> Contribution Closers</h6>
          <div style="font-size:12px;line-height:2;color:#1e293b;">
            <div>Saving: closes <b>${val('savingCloseDuration')} day(s)</b> before end, <b>${val('savingCloseInterval')} round(s)</b> buffer</div>
            <div>Loan: closes <b>${val('loanCloseDuration')} day(s)</b> before end, <b>${val('loanCloseInterval')} round(s)</b> buffer</div>
          </div>
        </div>
 
        <!-- ═══ NOTIFICATION SUMMARIES ═══ -->
        <div style="margin-top:8px;padding:4px 0;">
          <div style="font-size:11px;font-weight:800;color:#92400e;text-transform:uppercase;letter-spacing:1px;margin-bottom:10px;
            padding-bottom:6px;border-bottom:2px dashed #fde68a;display:flex;align-items:center;gap:6px;">
            <i class="fas fa-file-signature" style="color:#d97706;"></i> Acknowledged Step Confirmations
          </div>
 
          ${confirmedSteps[1] ? reviewNotifCard('fas fa-hourglass-end','Step 1 – Timing', confirmedSteps[1]) : ''}
          ${confirmedSteps[2] ? reviewNotifCard('fas fa-vote-yea','Step 2 – Governance', confirmedSteps[2]) : ''}
          ${confirmedSteps[3] ? reviewNotifCard('fas fa-coins','Step 3 – Accounts', confirmedSteps[3]) : ''}
          ${confirmedSteps[4] ? reviewNotifCard('fas fa-balance-scale','Step 4 – Loans', confirmedSteps[4]) : ''}
          ${confirmedSteps[5] ? reviewNotifCard('fas fa-chart-pie','Step 5 – Benefits', confirmedSteps[5]) : ''}
          ${confirmedSteps[6] ? reviewNotifCard('fas fa-door-closed','Step 6 – Closers', confirmedSteps[6]) : ''}
        </div>
 
      </div>
    `;
    document.getElementById('reviewContentArea').innerHTML = html;
  }
 
  /* ─── Save / Submit ─── */
  function savePrinciples() {
    const accounts = window.confirmedAccounts || [];
    const principles = {
      otherContributions: accounts,
      distribution: {
        model: val('benefitDistModel'),
        performancePct: val('memberPerfPct') || 70,
        officialPct: val('officialBenefitPct') || 0,
        targetAccountName: val('benefitAccName') || 'Group Benefit Account',
        targetAccountNumber: String(accounts.length + 1).padStart(3, '0')
      },
      intervals: {
        frequency: val('groupInterval'),
        endSavingPeriod: val('endSavingPeriod'),
        contributionDay: val('contributionDay') || val('dayOfWeek') || '',
        weekOfMonth: val('weekOfMonth') || '',
        month: val('contributionMonth') || ''
      },
      governance: {
        fastNotificationThreshold: val('fastThreshold'),
        editAccountThreshold: val('editThreshold'),
        memberRemovalThreshold: val('removeThreshold'),
        requireResponseNote: document.getElementById('requireNote').checked
      },
      deductions: { primarySource: val('dueDedSource') },
      balancing: {
        benefitAccounts: Array.from(document.querySelectorAll('#benefitAccountsList input[type="checkbox"]:checked')).map(cb => cb.value)
      },
      loans: {
        qualificationType: val('loanQualifyType'),
        waitingDays: val('loanDays') || '',
        savingTarget: val('loanTargetAmount') || '',
        repayment: {
          durationDays: val('loanRepaymentDuration') || '30',
          alignment: val('loanRepaymentAlignment'),
          rolloverMethod: val('loanRolloverMethod'),
          maxRollovers: val('loanMaxRollovers')
        },
        interestAndLimits: {
          interestRate: val('loanInterestRate') || '0',
          maxActiveLoans: val('loanMaxCount'),
          limitBasis: val('loanLimitBasis'),
          limitMultiplier: val('loanLimitMultiplier')
        },
        type: {
          category: val('loanCategory'),
          guaranteeMethod: val('loanCategory') === 'long' ? val('loanGuaranteeMethod') : 'self'
        }
      },
      closer: {
        saving: { durationDays: val('savingCloseDuration'), intervalBuffer: val('savingCloseInterval') },
        loan:   { durationDays: val('loanCloseDuration'),   intervalBuffer: val('loanCloseInterval') }
      },
      confirmedStepNotifications: confirmedSteps
    };
 
    if (val('loanCategory') === 'long') {
      principles.loans.longTerm = {
        paymentPeriod: val('longTermPaymentPeriod'),
        paymentMethod: val('longTermPaymentMethod'),
        installmentSchedule: val('installmentScheduleType'),
        customRounds: val('customRoundsCount')
      };
    }
 
    fetch('/general/set-principles', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ groupName, principles })
    })
    .then(res => res.json())
    .then(data => {
      if (data.success) {
        alert('✓ Principles activated successfully!');
        window.location.href = '/agent';
      } else {
        alert('Error: ' + data.message);
      }
    })
    .catch(err => alert('Error saving principles: ' + err.message));
  }
 
  /* ─── Key flow ─── */
  function showConstitutionForm() {
    document.getElementById('continueSection').style.display  = 'none';
    document.getElementById('groupInfoSection').style.display = 'none';
    document.getElementById('membersSection').style.display   = 'none';
    document.getElementById('constitutionForm').classList.remove('hidden');
    setTimeout(() => document.getElementById('startKey').focus(), 300);
  }
 
  function cancelConstitution() {
    document.getElementById('constitutionForm').classList.add('hidden');
    document.getElementById('continueSection').style.display  = 'block';
    document.getElementById('groupInfoSection').style.display = 'block';
    document.getElementById('membersSection').style.display   = 'block';
    document.getElementById('startKey').value = '';
    document.getElementById('startKeyError').style.display = 'none';
  }
 
  function openWizard() {
    document.getElementById('constitutionForm').classList.add('hidden');
    document.getElementById('groupInfoSection').style.display = 'none';
    document.getElementById('membersSection').style.display   = 'none';
    document.getElementById('continueSection').style.display  = 'none';
    document.getElementById('step1Section').style.display     = 'block';
    showPanel(1);
  }
 
  function backToVerification() {
    document.getElementById('step1Section').style.display = 'none';
    document.getElementById('groupInfoSection').style.display = 'block';
    document.getElementById('membersSection').style.display   = 'block';
    document.getElementById('continueSection').style.display  = 'block';
    cancelConstitution();
  }
 
  function submitStartKey() {
    const key = document.getElementById('startKey').value.trim();
    const err = document.getElementById('startKeyError');
    if (!key || key.length !== 4 || isNaN(key)) { err.style.display = 'block'; return; }
    err.style.display = 'none';
    fetch('/agent/set-constitution-key', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ groupName, key })
    })
    .then(r => r.json())
    .then(d => { if (d.success) openWizard(); else alert('Error: ' + d.message); })
    .catch(e => alert('Error: ' + e.message));
  }
 
  function verifyStartKey() {
    const key = document.getElementById('startKey').value.trim();
    const err = document.getElementById('startKeyError');
    if (!key || key.length !== 4 || isNaN(key)) {
      err.style.display = 'block';
      err.innerHTML = '<i class="fas fa-exclamation-circle"></i> Please enter a valid 4-digit key';
      return;
    }
    err.style.display = 'none';
    fetch('/agent/verify-constitution-key', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ groupName, key })
    })
    .then(r => r.json())
    .then(d => {
      if (d.success) openWizard();
      else {
        err.style.display = 'block';
        err.innerHTML = '<i class="fas fa-exclamation-circle"></i> Incorrect key. Please try again.';
      }
    })
    .catch(() => {
      err.style.display = 'block';
      err.innerHTML = '<i class="fas fa-exclamation-circle"></i> Error verifying key.';
    });
  }
 
  document.getElementById('startKey').addEventListener('keypress', e => {
    if (!/\d/.test(e.key)) e.preventDefault();
  });
</script>
</body>
</html>