  <script>
    const groupName  = '<%= group.groupName %>';
    const existingKey = '<%= existingKey || "" %>';
    const keyRequired = <%= keyRequired ? 'true' : 'false' %>;

    let currentStep = 1;
    const TOTAL_STEPS = 7;

    /* ─── Progress indicator ─── */
    function updateProgress(step) {
      for (let i = 1; i <= TOTAL_STEPS; i++) {
        const dot = document.getElementById('dot' + i);
        dot.classList.remove('active', 'completed');
        if (i < step)       dot.classList.add('completed');
        else if (i === step) dot.classList.add('active');
      }
      for (let i = 1; i < TOTAL_STEPS; i++) {
        const con = document.getElementById('con' + i);
        if (con) con.classList.toggle('done', i < step);
      }
    }

    function showPanel(step) {
      document.querySelectorAll('.step-panel').forEach(p => p.classList.remove('active'));
      const panel = document.getElementById('panel' + step);
      if (panel) {
        panel.classList.add('active');
        panel.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
      currentStep = step;
      updateProgress(step);
    }

    /* ─── Navigation ─── */
     function nextStep(from) {
       if (!validateStep(from)) return;
       if (from === 1) {
         showStep1Confirmation();
       }
       if (from === 6) { buildReview(); }
       showPanel(from + 1);
     }

      function showStep1Confirmation() {
        const periodSelect = document.getElementById('endSavingPeriod');
        const periodText = periodSelect.options[periodSelect.selectedIndex].text;
        const freqSelect = document.getElementById('groupInterval');
        const freqText = freqSelect.options[freqSelect.selectedIndex].text;
        let detailText = '';

        if (freqSelect.value === 'weekly') {
          const daySelect = document.getElementById('contributionDay');
          detailText = daySelect.options[daySelect.selectedIndex].text;
        } else if (freqSelect.value === 'monthly') {
          const weekSelect = document.getElementById('weekOfMonth');
          const daySelect = document.getElementById('dayOfWeek');
          const weekText = weekSelect.options[weekSelect.selectedIndex].text;
          const dayText = daySelect.options[daySelect.selectedIndex].text;
          detailText = weekText + ' on ' + dayText;
        } else if (freqSelect.value === 'yearly') {
          const monthSelect = document.getElementById('contributionMonth');
          const weekSelect = document.getElementById('weekOfMonth');
          const daySelect = document.getElementById('dayOfWeek');
          const monthText = monthSelect.options[monthSelect.selectedIndex].text;
          const weekText = weekSelect.options[weekSelect.selectedIndex].text;
          const dayText = daySelect.options[daySelect.selectedIndex].text;
          detailText = monthText + ', ' + weekText + ' on ' + dayText;
        }

        let message = `Group is set to operator within ${periodText}. Contribution set to ${freqText}`;
        if (detailText) {
          message += ' on ' + detailText;
        }
        message += '.';
        alert(message);
      }

    function prevStep(from) {
      showPanel(from - 1);
    }

     /* ─── Validation per step ─── */
     function validateStep(step) {
       if (step === 1) {
         const period = document.getElementById('endSavingPeriod').value;
         const freq   = document.getElementById('groupInterval').value;
         if (!period) { alert('Please select End Saving Period'); return false; }
         if (!freq)   { alert('Please select Contribution Interval'); return false; }

         if (freq === 'weekly') {
           const day = document.getElementById('contributionDay').value;
           if (!day) { alert('Please select Day of Week'); return false; }
         } else if (freq === 'monthly') {
           const week = document.getElementById('weekOfMonth').value;
           const day = document.getElementById('dayOfWeek').value;
           if (!week) { alert('Please select Week of Month'); return false; }
           if (!day)  { alert('Please select Day of Week'); return false; }
         } else if (freq === 'yearly') {
           const month = document.getElementById('contributionMonth').value;
           const week = document.getElementById('weekOfMonth').value;
           const day = document.getElementById('dayOfWeek').value;
           if (!month) { alert('Please select Month'); return false; }
           if (!week)  { alert('Please select Week of Month'); return false; }
           if (!day)   { alert('Please select Day of Week'); return false; }
         }
         return true;
       }
      if (step === 2) {
        const ft = +document.getElementById('fastThreshold').value;
        const et = +document.getElementById('editThreshold').value;
        const rt = +document.getElementById('removeThreshold').value;
        if (!ft || ft < 51 || ft > 99) { alert('Fast Notification Threshold must be 51–99%'); return false; }
        if (!et || et < 51 || et > 99) { alert('Edit Account Threshold must be 51–99%'); return false; }
        if (!rt || rt < 51 || rt > 99) { alert('Member Removal Threshold must be 51–99%'); return false; }
        return true;
      }
      if (step === 3) {
        if (!window.confirmedAccounts || window.confirmedAccounts.length === 0) {
          alert('Please confirm accounts by clicking the OK / Confirm button first');
          return false;
        }
        return true;
      }
      if (step === 4) {
        const repDays = document.getElementById('loanRepaymentDuration').value;
        if (!repDays || +repDays <= 0) { alert('Please enter Loan Repayment Duration'); return false; }
        return true;
      }
      return true; // steps 5, 6 – no strict requirement
    }

    /* ─── Interval detail ─── */
    function updateIntervalDetail() {
      const freq = document.getElementById('groupInterval').value;
      const weeklyContainer = document.getElementById('intervalDetailContainer');
      const weeklyLabel = document.getElementById('intervalDetailLabel');
      const weeklySel = document.getElementById('contributionDay');
      const monthWeekContainer = document.getElementById('weekOfMonthContainer');
      const monthDayContainer = document.getElementById('dayOfWeekContainer');
      const weekSelect = document.getElementById('weekOfMonth');
      const daySelect = document.getElementById('dayOfWeek');
      const monthContainer = document.getElementById('monthContainer');
      const monthSelect = document.getElementById('contributionMonth');

      // Reset all
      weeklyContainer.style.display = 'none';
      monthWeekContainer.style.display = 'none';
      monthDayContainer.style.display = 'none';
      monthContainer.style.display = 'none';
      weeklySel.value = '';
      weekSelect.value = '';
      daySelect.value = '';
      monthSelect.value = '';

      if (freq === 'weekly') {
        weeklyLabel.textContent = 'Day of Week';
        weeklySel.innerHTML = '<option value="" disabled selected>Select Day</option><option value="monday">Monday</option><option value="tuesday">Tuesday</option><option value="wednesday">Wednesday</option><option value="thursday">Thursday</option><option value="friday">Friday</option><option value="saturday">Saturday</option><option value="sunday">Sunday</option>';
        weeklyContainer.style.display = 'block';
      } else if (freq === 'monthly') {
        // Show week of month selector
        monthWeekContainer.style.display = 'block';
      } else if (freq === 'yearly') {
        // Show month selector
        monthContainer.style.display = 'block';
      }
    }

    // Called when a week of month is selected - shows day of week dropdown
    function updateDayOfWeekOptions() {
      const weekSelect = document.getElementById('weekOfMonth');
      const monthDayContainer = document.getElementById('dayOfWeekContainer');

      if (weekSelect.value) {
        monthDayContainer.style.display = 'block';
      } else {
        monthDayContainer.style.display = 'none';
      }
    }

    // Called when a month is selected (for yearly) - shows week of month dropdown
    function updateMonthDetail() {
      const monthSelect = document.getElementById('contributionMonth');
      const weekContainer = document.getElementById('weekOfMonthContainer');
      const dayContainer = document.getElementById('dayOfWeekContainer');
      const weekSelect = document.getElementById('weekOfMonth');
      const daySelect = document.getElementById('dayOfWeek');

      if (monthSelect.value) {
        weekContainer.style.display = 'block';
        // Reset day selection and hide it (week changed)
        daySelect.value = '';
        dayContainer.style.display = 'none';
      } else {
        weekContainer.style.display = 'none';
        dayContainer.style.display = 'none';
      }
    }

    /* ─── Accounts ─── */
    function addChargeRow() {
      const container = document.getElementById('otherChargesList');
      const rowCount  = container.querySelectorAll('.charge-row').length + 1;
      const row = document.createElement('div');
      row.className = 'charge-row';
      row.innerHTML = `
        <input type="text"   class="chg-num"  value="${String(rowCount).padStart(3,'0')}" readonly>
        <input type="text"   class="chg-name" placeholder="Name">
        <input type="number" class="chg-amt"  placeholder="0">
        <button type="button" class="del-btn" onclick="this.closest('.charge-row').remove()">×</button>
      `;
      container.appendChild(row);
    }

    function handleRegDecision(choice) {
      if (!choice) return;
      window.regDecisionMade = true;

      const list = document.getElementById('otherChargesList');
      let row2 = Array.from(list.querySelectorAll('.charge-row')).find(row => row.querySelector('.chg-num').value === '002');

      if (!row2) {
        if (choice === 'charged') {
          injectAccountRow('002', 'Registration', true);
        } else {
          injectAccountRow('002', '', false);
        }
      } else {
        const nameInput = row2.querySelector('.chg-name');
        if (choice === 'charged') {
          nameInput.value = 'Registration';
          nameInput.readOnly = true;
          nameInput.style.cssText = 'background:#f8fafc; color:#64748b; font-weight:800; padding:0 8px;';
        } else {
          nameInput.value = '';
          nameInput.readOnly = false;
          nameInput.style.cssText = 'padding:0 8px;';
        }
      }

      document.getElementById('accountsConfigArea').style.display = 'block';
    }

    function injectAccountRow(id, nameValue, readonly) {
      const list = document.getElementById('otherChargesList');
      const div  = document.createElement('div');
      div.className = 'charge-row';
      const nameInput = readonly
        ? `<input type="text" class="chg-name" value="${nameValue}" readonly style="background:#f8fafc; color:#64748b; font-weight:800; padding:0 8px;">`
        : `<input type="text" class="chg-name" value="${nameValue}" placeholder="Name" style="padding:0 8px;">`;
      div.innerHTML = `
        <input type="text" class="chg-num" value="${id}" readonly>
        ${nameInput}
        <input type="number" class="chg-amt" placeholder="0">
        <button type="button" class="del-btn" onclick="this.closest('.charge-row').remove()">×</button>
      `;
      list.appendChild(div);
    }

    function confirmAccounts() {
      const accounts = [];
      document.querySelectorAll('#otherChargesList .charge-row').forEach(row => {
        const inputs = row.querySelectorAll('input');
        const num    = inputs[0].value;
        const name   = inputs[1].value.trim();
        const amt    = inputs[2]?.value;
        if (name && amt && parseFloat(amt) > 0) {
          accounts.push({ accountNumber: num, accountName: name, expectedAmount: amt });
        }
      });

      if (accounts.length === 0) {
        alert('Please add at least one account with name and amount');
        return;
      }

      window.confirmedAccounts = accounts;

      // Populate benefit accounts checkboxes
      const benefitList = document.getElementById('benefitAccountsList');
      benefitList.innerHTML = '';
      accounts.forEach(acc => {
        if (acc.accountName.toLowerCase() === 'saving') return;
        const div = document.createElement('div');
        div.style.cssText = 'display:flex; align-items:center; gap:8px; padding:8px; background:white; border-radius:6px; border:1px solid #e2e8f0;';
        div.innerHTML = `
          <input type="checkbox" id="benefit_${acc.accountNumber}" value="${acc.accountName}" checked style="width:18px; height:18px; accent-color:#008080;">
          <label for="benefit_${acc.accountNumber}" style="font-size:11px; font-weight:600; color:#475569;">${acc.accountName}</label>
        `;
        benefitList.appendChild(div);
      });

      const loanIntDiv = document.createElement('div');
      loanIntDiv.style.cssText = 'display:flex; align-items:center; gap:8px; padding:8px; background:white; border-radius:6px; border:1px solid #e2e8f0;';
      loanIntDiv.innerHTML = `
        <input type="checkbox" id="benefit_loan_interest" value="Loan Interest" checked style="width:18px; height:18px; accent-color:#008080;">
        <label for="benefit_loan_interest" style="font-size:11px; font-weight:600; color:#475569;">Loan Interest</label>
      `;
      benefitList.appendChild(loanIntDiv);

      // Set benefit account name
      document.getElementById('benefitAccName').value = 'Group Benefit Account';

      document.getElementById('accountsConfirmedBadge').style.display = 'block';
      alert(`✓ ${accounts.length} account(s) confirmed!`);
    }

    /* ─── Toggle helpers ─── */
    function toggleBenefitModel() {
      const model = document.getElementById('benefitDistModel').value;
      document.getElementById('distEqualConfig').style.display = (model === 'equal')        ? 'block' : 'none';
      document.getElementById('distPerfConfig').style.display  = (model === 'performance')  ? 'block' : 'none';
    }

    function toggleDueDedSource() {
      const src = document.getElementById('dueDedSource').value;
      document.getElementById('dueLogicSavings').style.display = (src === 'savings')                    ? 'block' : 'none';
      document.getElementById('dueLogicBenefit').style.display = (src === 'benefit' || src === 'bad_debt') ? 'block' : 'none';
    }

    function toggleLoanFields() {
      const type = document.getElementById('loanQualifyType').value;
      document.getElementById('loanDurationParams').style.display = (type === 'duration' || type === 'both') ? 'block' : 'none';
      document.getElementById('loanSavingParams').style.display   = (type === 'saving'   || type === 'both') ? 'block' : 'none';
    }

    function toggleLoanCategoryFields() {
      const cat = document.getElementById('loanCategory').value;
      document.getElementById('longTermGuaranteeDiv').style.display = (cat === 'long') ? 'block' : 'none';
      document.getElementById('longTermLoanConfig').style.display   = (cat === 'long') ? 'block' : 'none';
    }

    function toggleLongTermPaymentOptions() {
      const method = document.getElementById('longTermPaymentMethod').value;
      document.getElementById('installmentOptionsDiv').style.display = (method === 'installment') ? 'block' : 'none';
    }

    function toggleInstallmentSchedule() {
      const type = document.getElementById('installmentScheduleType').value;
      document.getElementById('customRoundsDiv').style.display = (type === 'set_rounds') ? 'block' : 'none';
    }

    /* ─── Build Review ─── */
    function buildReview() {
      const accounts    = window.confirmedAccounts || [];
      const distModel   = document.getElementById('benefitDistModel').value;
      const dueSource   = document.getElementById('dueDedSource').value;
      const benefitAcc  = document.getElementById('benefitAccName').value;
      const freq        = document.getElementById('groupInterval').value;
      const period      = document.getElementById('contributionDay')?.value || '';
      const endPeriod   = document.getElementById('endSavingPeriod').value;
      const fastT       = document.getElementById('fastThreshold').value;
      const editT       = document.getElementById('editThreshold').value;
      const removeT     = document.getElementById('removeThreshold').value;

      const dueLabel = dueSource === 'savings' ? 'Member Savings' : dueSource === 'benefit' ? 'Group Benefit' : 'Bad Debt';
      const distLabel = distModel === 'equal' ? 'Equal Distribution' : 'Performance Based';
      const benefitAccs = Array.from(document.querySelectorAll('#benefitAccountsList input[type="checkbox"]:checked')).map(cb => cb.value);

      const html = `
        <div style="display:flex; flex-direction:column; gap:12px;">

          <div style="background:white; border-radius:10px; border:1px solid #e2e8f0; padding:14px;">
            <h6 style="font-size:10px; color:#64748b; text-transform:uppercase; font-weight:800; margin-bottom:10px; letter-spacing:1px;"><i class="fas fa-history"></i> Timing</h6>
            <div style="display:flex; justify-content:space-between; font-size:13px;">
              <div>Freq: <b style="color:#1e293b;">${freq.toUpperCase()}</b></div>
              <div>Period: <b style="color:#1e293b;">${period}</b></div>
              <div>Ends: <b style="color:#c53030;">${endPeriod}</b></div>
            </div>
          </div>

          <div style="background:white; border-radius:10px; border:1px solid #e2e8f0; padding:14px;">
            <h6 style="font-size:10px; color:#64748b; text-transform:uppercase; font-weight:800; margin-bottom:10px; letter-spacing:1px;"><i class="fas fa-gavel"></i> Governance</h6>
            <div style="display:grid; grid-template-columns:1fr 1fr 1fr; font-size:12px; gap:6px;">
              <div style="text-align:center; background:#f0fdfa; border-radius:6px; padding:8px;">
                <div style="color:#64748b; font-size:9px; font-weight:700;">FAST EDIT</div>
                <div style="color:#008080; font-weight:800; font-size:15px;">${fastT}%</div>
              </div>
              <div style="text-align:center; background:#f0fdfa; border-radius:6px; padding:8px;">
                <div style="color:#64748b; font-size:9px; font-weight:700;">A/C EDIT</div>
                <div style="color:#008080; font-weight:800; font-size:15px;">${editT}%</div>
              </div>
              <div style="text-align:center; background:#f0fdfa; border-radius:6px; padding:8px;">
                <div style="color:#64748b; font-size:9px; font-weight:700;">REMOVAL</div>
                <div style="color:#008080; font-weight:800; font-size:15px;">${removeT}%</div>
              </div>
            </div>
          </div>

          <div style="background:#f0fdf4; border-radius:10px; border:1px solid #86efac; padding:14px;">
            <h6 style="font-size:10px; color:#065f46; text-transform:uppercase; font-weight:800; margin-bottom:10px; letter-spacing:1px;"><i class="fas fa-coins"></i> Accounts</h6>
            ${accounts.map(a => `
              <div style="display:flex; justify-content:space-between; font-size:12px; padding:6px 0; border-bottom:1px solid #dcfce7;">
                <span><span style="color:#94a3b8; font-family:monospace; font-weight:800;">${a.accountNumber}</span> ${a.accountName}</span>
                <b style="color:#065f46;">KES ${parseFloat(a.expectedAmount || 0).toLocaleString()}</b>
              </div>
            `).join('')}
            <div style="display:flex; justify-content:space-between; font-size:12px; padding:6px 0; border-bottom:1px solid #e0f2fe;">
              <span><span style="color:#94a3b8; font-family:monospace; font-weight:800;">${String(accounts.length + 1).padStart(3,'0')}</span> Loan (Interest)</span>
              <b style="color:#1e40af;">Variable</b>
            </div>
            <div style="display:flex; justify-content:space-between; font-size:12px; padding:6px 0; border-bottom:1px solid #fecaca;">
              <span>Group Benefit Account</span>
              <b style="color:#c53030;">Final Dist.</b>
            </div>
            ${benefitAccs.length > 0 ? `
            <div style="padding:8px; background:#fff5f5; border-radius:6px; border:1px dashed #fecaca; margin-top:8px;">
              <span style="color:#c53030; font-size:10px; font-weight:800; text-transform:uppercase;">Profit Sources</span>
              <div style="font-size:12px; color:#7f1d1d; margin-top:3px; font-weight:600;">
                ${benefitAccs.join(' • ')}
              </div>
            </div>
            ` : ''}
          </div>

          <div style="background:#fff5f5; border-radius:10px; border:1px solid #fecaca; padding:14px;">
            <h6 style="font-size:10px; color:#c53030; text-transform:uppercase; font-weight:800; margin-bottom:10px; letter-spacing:1px;"><i class="fas fa-chart-pie"></i> Distribution &amp; Deductions</h6>
            <div style="font-size:12px; line-height:1.8; color:#7f1d1d;">
              <div>Model: <b>${distLabel}</b></div>
              <div>Target: <b>${benefitAcc}</b></div>
              <div>Loss Source: <b>${dueLabel}</b></div>
            </div>
          </div>

        </div>
      `;

      document.getElementById('reviewContentArea').innerHTML = html;
    }

    /* ─── Save / Submit ─── */
    function savePrinciples() {
      const accounts = window.confirmedAccounts || [];

      const principles = {
        otherContributions: accounts,
        distribution: {
          model: document.getElementById('benefitDistModel').value,
          performancePct: document.getElementById('memberPerfPct').value || 70,
          officialPct: document.getElementById('officialBenefitPct').value || 0,
          targetAccountName: document.getElementById('benefitAccName').value || 'Loan',
          targetAccountNumber: String(accounts.length + 1).padStart(3, '0')
        },
        intervals: {
          frequency: document.getElementById('groupInterval').value,
          period: document.getElementById('contributionDay')?.value || '',
          endSavingPeriod: document.getElementById('endSavingPeriod').value
        },
        governance: {
          fastNotificationThreshold: document.getElementById('fastThreshold').value,
          editAccountThreshold: document.getElementById('editThreshold').value,
          memberRemovalThreshold: document.getElementById('removeThreshold').value,
          requireResponseNote: document.getElementById('requireNote').checked
        },
        deductions: { primarySource: document.getElementById('dueDedSource').value },
        balancing: {
          benefitAccounts: Array.from(document.querySelectorAll('#benefitAccountsList input[type="checkbox"]:checked')).map(cb => cb.value)
        },
        loans: {
          qualificationType: document.getElementById('loanQualifyType').value,
          duration: { days: document.getElementById('loanDays')?.value || '' },
          savingTarget: document.getElementById('loanTargetAmount')?.value || '',
          repayment: {
            durationDays: document.getElementById('loanRepaymentDuration').value || '30',
            alignment: document.getElementById('loanRepaymentAlignment').value,
            rolloverMethod: document.getElementById('loanRolloverMethod').value,
            maxRollovers: document.getElementById('loanMaxRollovers').value
          },
          interestAndLimits: {
            interestRate: document.getElementById('loanInterestRate').value || '0',
            maxActiveLoans: document.getElementById('loanMaxCount').value,
            limitBasis: document.getElementById('loanLimitBasis').value,
            limitMultiplier: document.getElementById('loanLimitMultiplier').value
          },
          type: {
            category: document.getElementById('loanCategory').value,
            guaranteeMethod: document.getElementById('loanCategory').value === 'long'
              ? document.getElementById('loanGuaranteeMethod').value : 'self'
          }
        },
        closer: {
          saving: {
            durationDays: document.getElementById('savingCloseDuration').value,
            intervalBuffer: document.getElementById('savingCloseInterval').value
          },
          loan: {
            durationDays: document.getElementById('loanCloseDuration').value,
            intervalBuffer: document.getElementById('loanCloseInterval').value
          }
        }
      };

      if (document.getElementById('loanCategory').value === 'long') {
        principles.loans.longTerm = {
          paymentPeriod: document.getElementById('longTermPaymentPeriod').value,
          paymentMethod: document.getElementById('longTermPaymentMethod').value,
          installment: {
            scheduleType: document.getElementById('installmentScheduleType').value,
            customRounds: document.getElementById('customRoundsCount').value
          }
        };
      }

      fetch('/general/set-principles', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ groupName, principles })
      })
      .then(res => res.json())
      .then(data => {
        if (data.success) {
          alert('✓ Principles activated successfully!');
          window.location.href = '/agent';
        } else {
          alert('Error: ' + data.message);
        }
      })
      .catch(err => alert('Error saving principles: ' + err.message));
    }

    /* ─── Key flow ─── */
    function showConstitutionForm() {
      document.getElementById('continueSection').style.display  = 'none';
      document.getElementById('groupInfoSection').style.display = 'none';
      document.getElementById('membersSection').style.display   = 'none';
      document.getElementById('constitutionForm').classList.remove('hidden');
      setTimeout(() => document.getElementById('startKey').focus(), 300);
    }

    function cancelConstitution() {
      document.getElementById('constitutionForm').classList.add('hidden');
      document.getElementById('continueSection').style.display  = 'block';
      document.getElementById('groupInfoSection').style.display = 'block';
      document.getElementById('membersSection').style.display   = 'block';
      document.getElementById('startKey').value = '';
      document.getElementById('startKeyError').style.display = 'none';
    }

    function openWizard() {
      document.getElementById('constitutionForm').classList.add('hidden');
      document.getElementById('groupInfoSection').style.display = 'none';
      document.getElementById('membersSection').style.display   = 'none';
      document.getElementById('continueSection').style.display  = 'none';
      document.getElementById('step1Section').style.display     = 'block';
      showPanel(1);
    }

    function backToVerification() {
      document.getElementById('step1Section').style.display = 'none';
      document.getElementById('constitutionForm').classList.remove('hidden');
      document.getElementById('groupInfoSection').style.display = 'block';
      document.getElementById('membersSection').style.display   = 'block';
      document.getElementById('continueSection').style.display  = 'block';
      cancelConstitution();
    }

    function submitStartKey() {
      const key = document.getElementById('startKey').value.trim();
      const err = document.getElementById('startKeyError');
      if (!key || key.length !== 4 || isNaN(key)) { err.style.display = 'block'; return; }
      err.style.display = 'none';
      fetch('/agent/set-constitution-key', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ groupName, key })
      })
      .then(r => r.json())
      .then(d => { if (d.success) openWizard(); else alert('Error: ' + d.message); })
      .catch(e => alert('Error: ' + e.message));
    }

    function verifyStartKey() {
      const key = document.getElementById('startKey').value.trim();
      const err = document.getElementById('startKeyError');
      if (!key || key.length !== 4 || isNaN(key)) {
        err.style.display = 'block';
        err.innerHTML = '<i class="fas fa-exclamation-circle"></i> Please enter a valid 4-digit key';
        return;
      }
      err.style.display = 'none';
      fetch('/agent/verify-constitution-key', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ groupName, key })
      })
      .then(r => r.json())
      .then(d => {
        if (d.success) openWizard();
        else {
          err.style.display = 'block';
          err.innerHTML = '<i class="fas fa-exclamation-circle"></i> Incorrect key. Please try again.';
        }
      })
      .catch(() => {
        err.style.display = 'block';
        err.innerHTML = '<i class="fas fa-exclamation-circle"></i> Error verifying key.';
      });
    }

    document.getElementById('startKey').addEventListener('keypress', e => {
      if (!/\d/.test(e.key)) e.preventDefault();
    });
  </script>
</body>
</html>