  /* ─── Build Step 6 notification rows ─── */
  function buildStep6Rows() {
    return [
      ['Saving Closer – Duration', val('savingCloseDuration') + ' day(s) before end'],
      ['Saving Closer – Buffer', val('savingCloseInterval') + ' round(s) before end'],
