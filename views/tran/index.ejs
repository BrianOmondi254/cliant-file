<%- include('../partials/header') %>

<div class="container mx-auto px-4 py-8">
    <div class="max-w-6xl mx-auto">
        <div class="bg-white rounded-lg shadow-lg p-6 mb-6">
            <h1 class="text-3xl font-bold text-gray-800 mb-4">Transaction Account Dashboard</h1>
            
            <!-- Summary Cards -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
                <div class="bg-blue-50 p-4 rounded-lg">
                    <h3 class="text-blue-800 text-sm font-semibold">Total Groups</h3>
                    <p class="text-2xl font-bold text-blue-600"><%= Object.keys(groupData || {}).length %></p>
                </div>
                <div class="bg-green-50 p-4 rounded-lg">
                    <h3 class="text-green-800 text-sm font-semibold">Total Members</h3>
                    <p class="text-2xl font-bold text-green-600"><%= Object.keys(memberData.members || memberData.group || {}).length %></p>
                </div>
            </div>
        </div>

        <!-- Groups List -->
        <div class="bg-white rounded-lg shadow-lg p-6">
            <div class="flex justify-between items-center mb-4">
                <h2 class="text-2xl font-bold text-gray-800">Transaction Groups</h2>
            </div>

            <% if (groupData && Object.keys(groupData).length > 0) { %>
                <div class="overflow-x-auto">
                    <table class="min-w-full bg-white border">
                        <thead class="bg-gray-100">
                            <tr>
                                <th class="py-3 px-4 text-left text-sm font-semibold text-gray-600">Group Name</th>
                                <th class="py-3 px-4 text-left text-sm font-semibold text-gray-600">Account Number</th>
                                <th class="py-3 px-4 text-left text-sm font-semibold text-gray-600">Location</th>
                                <th class="py-3 px-4 text-left text-sm font-semibold text-gray-600">Closing Balance</th>
                                <th class="py-3 px-4 text-left text-sm font-semibold text-gray-600">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% Object.entries(groupData).forEach(([key, group]) => { %>
                                <tr class="border-t hover:bg-gray-50">
                                    <td class="py-3 px-4"><%= group.groupName || 'N/A' %></td>
                                    <td class="py-3 px-4"><%= group.accountNumber || 'N/A' %></td>
                                    <td class="py-3 px-4"><%= group.county || '' %> / <%= group.constituency || '' %> / <%= group.ward || '' %></td>
                                    <td class="py-3 px-4 font-semibold <%= group.groupFinancials && group.groupFinancials.totalClosingBalance > 0 ? 'text-green-600' : 'text-gray-600' %>">
                                        <%= group.groupFinancials ? 'KES ' + group.groupFinancials.totalClosingBalance : 'N/A' %>
                                    </td>
                                    <td class="py-3 px-4">
                                        <a href="/tran/group/<%= encodeURIComponent(group.groupName) %>" class="text-blue-600 hover:text-blue-800 text-sm">View Details</a>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            <% } else { %>
                <div class="text-center py-8 text-gray-500">
                    <p>No transaction groups found. <a href="/general" class="text-blue-600 hover:text-blue-800">Create a group</a> to get started.</p>
                </div>
            <% } %>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>