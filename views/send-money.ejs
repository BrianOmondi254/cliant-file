<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Send Money - Group Account</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #0f9d58;
            --secondary: #7c3aed;
            --bg: #f8fafc;
            --card: #ffffff;
            --text: #1e293b;
            --border: #e2e8f0;
        }
        body {
            font-family: 'Inter', sans-serif;
            background: #f1f5f9;
            margin: 0;
            padding: 20px;
            display: flex;
            justify-content: center;
        }
        .container {
            width: 100%;
            max-width: 420px;
            background: var(--card);
            border-radius: 20px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
            overflow: hidden;
        }
        .header {
            background: linear-gradient(135deg, var(--primary), #34d399);
            padding: 25px;
            color: white;
            text-align: center;
        }
        .content {
            padding: 25px;
        }
        .form-group {
            margin-bottom: 20px;
        }
        label {
            display: block;
            margin-bottom: 8px;
            font-weight: 600;
            font-size: 0.9rem;
            color: var(--text);
        }
        select, input {
            width: 100%;
            padding: 12px;
            border: 1px solid var(--border);
            border-radius: 10px;
            font-size: 1rem;
            outline: none;
        }
        button {
            width: 100%;
            padding: 14px;
            background: var(--primary);
            color: white;
            border: none;
            border-radius: 10px;
            font-weight: 600;
            cursor: pointer;
            margin-top: 10px;
        }
        .btn-secondary {
            background: #e2e8f0;
            color: #475569;
            margin-top: 10px;
        }
        .result-box {
            background: #f0fdf4;
            border: 1px solid #bbf7d0;
            padding: 20px;
            border-radius: 12px;
            text-align: center;
        }
    </style>
</head>
<body>
<div class="container">
    <div class="header">
        <h2><i class="fas fa-money-bill-transfer"></i> Deposit to Group</h2>
    </div>
    <div class="content">
        <% if (step === 'select-account') { %>
            <form action="/personal/send-money/details" method="POST">
                <div class="form-group">
                    <label>Select Target Group</label>
                    <select name="groupName" required>
                        <% groups.forEach(g => { %>
                            <option value="<%= g.groupName %>"><%= g.groupName %></option>
                        <% }) %>
                    </select>
                </div>
                <button type="submit">Continue <i class="fas fa-arrow-right"></i></button>
            </form>
        <% } else if (step === 'details') { %>
            <form action="/personal/send-money/submit" method="POST">
                <input type="hidden" name="groupName" value="<%= groupName %>">
                <div class="form-group">
                    <label>Amount (KES)</label>
                    <input type="number" name="amount" placeholder="0.00" required>
                </div>
                <button type="submit">Verify Amount <i class="fas fa-check"></i></button>
            </form>
        <% } else if (step === 'confirm') { %>
            <div style="text-align: center;">
                <p>Transfer to: <strong><%= groupName %></strong></p>
                <h3 style="font-size: 2rem; color: var(--primary); margin: 10px 0;"><%= amount %></h3>
                <form action="/personal/send-money/complete" method="POST">
                    <input type="hidden" name="groupName" value="<%= groupName %>">
                    <input type="hidden" name="amount" value="<%= amount %>">
                    <button type="submit">Confirm Transfer</button>
                    <button type="button" class="btn-secondary" onclick="history.back()">Cancel</button>
                </form>
            </div>
        <% } else if (step === 'success') { %>
            <div class="result-box">
                <i class="fas fa-check-circle" style="font-size: 3rem; color: var(--primary); margin-bottom: 15px;"></i>
                <h3>Transfer Successful!</h3>
                <p>Deposited <strong><%= amount %></strong> to group <strong><%= groupName %></strong>.</p>
                <button onclick="window.location.href='/personal'">Return Home</button>
            </div>
        <% } %>
    </div>
</div>
</body>
</html>
