

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>General Account</title>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<style>
:root {
  --primary: #0f9d58;
  --primary-dark: #0b7d46;
  --card: #ffffff;
  --text: #1e293b;
  --text-muted: #64748b;
  --border: #e2e8f0;
  --focus-ring: rgba(15, 157, 88, 0.15);
}
 
/* ── Reset ── */
*, *::before, *::after { box-sizing: border-box; }
 
/* ── Root shell: full viewport, no overflow ── */
html, body {
  margin: 0;
  padding: 2px;
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  background: linear-gradient(160deg, #0f2027, #203a43, #2c5364);
  display: flex;
  justify-content: center;
  align-items: flex-start;
  font-family: 'Outfit', sans-serif;
}
 
/* ── Main card: fixed height, flex column ── */
.main-container {
  width: calc(100% - 4px);
  height: calc(100vh - 4px);
  background: var(--card);
  border-radius: 5px;
  box-shadow: 0 25px 60px rgba(0,0,0,0.35);
  display: flex;
  flex-direction: column;
  overflow: hidden;          /* clip decoration only, children scroll internally */
  animation: slideUp 0.5s ease-out;
}
 
@keyframes slideUp {
  from { opacity: 0; transform: translateY(30px); }
  to   { opacity: 1; transform: translateY(0); }
}
 
/* ── Header: never shrinks ── */
.header-section {
  flex-shrink: 0;
  background: linear-gradient(135deg, #0f9d58, #34d399);
  padding: 20px;
  color: white;
  position: relative;
  overflow: hidden;
  text-align: center;
}
.header-section::before {
  content: '';
  position: absolute;
  top: -50%; right: -20%;
  width: 300px; height: 300px;
  background: rgba(255,255,255,0.1);
  border-radius: 50%;
}
.back-arrow {
  position: absolute; top: 15px; left: 15px;
  color: white; font-size: 1.2rem; cursor: pointer; z-index: 10;
  padding: 5px;
  display: flex; align-items: center; justify-content: center;
  text-decoration: none;
  transition: transform 0.2s ease;
}
.back-arrow:hover { transform: translateX(-3px); opacity: 0.8; }
.header-content { position: relative; z-index: 1; text-align: center; }
.header-content h2 { margin: 0 0 5px; font-size: 1.4rem; font-weight: 700; }
.header-content p  { margin: 0; opacity: 0.9; font-size: 0.8rem; }
 
/* ── Tab bar: never shrinks ── */
.tab-navigation {
  flex-shrink: 0;
  display: flex;
  background: #f8fafc;
  border-bottom: 1px solid var(--border);
  padding: 0 10px;
}
.tab-button {
  flex: 1;
  padding: 14px 10px;
  background: none; border: none;
  font-size: 0.85rem; font-weight: 600; color: var(--text-muted);
  cursor: pointer;
  position: relative;
  transition: all 0.3s ease;
  display: flex; align-items: center; justify-content: center; gap: 6px;
}
.tab-button:hover { color: var(--primary); background: rgba(34,197,94,0.05); }
.tab-button.active { color: var(--primary); }
.tab-button.active::after {
  content: '';
  position: absolute; bottom: 0; left: 0;
  width: 100%; height: 3px;
  background: var(--primary);
  border-radius: 3px 3px 0 0;
}
.tab-button i { font-size: 0.9rem; }
 
/* ── Scrollable content panes ── */
/* Both panes share these rules; they grow to fill remaining height */
#mySavingSection,
#createGroupContentArea {
  flex: 1 1 0;     /* grow + shrink from 0 base so flex math is clean */
  min-height: 0;   /* allow shrinking below content height — critical for overflow:auto */
  overflow-y: auto;
  padding: 10px;
  padding-bottom: 120px;
  scrollbar-width: thin;
  scrollbar-color: var(--primary) #f8fafc;
}
#mySavingSection::-webkit-scrollbar,
#createGroupContentArea::-webkit-scrollbar { width: 6px; }
#mySavingSection::-webkit-scrollbar-thumb,
#createGroupContentArea::-webkit-scrollbar-thumb {
  background-color: var(--primary);
  border-radius: 10px;
}
 
/* ── Create-group form wrapper ── */
.form-wrapper { width: 100%; padding: 5px 0; }
 
/* ── Step boxes ── */
.step-box {
  background: var(--card);
  padding: 15px;
  border-radius: 14px;
  border: none;
  animation: fade 0.5s ease-out;
}
@keyframes fade {
  from { opacity: 0; transform: translateY(20px); }
  to   { opacity: 1; transform: translateY(0); }
}
 
/* ── Typography ── */
h3 { margin: 0 0 15px; text-align: center; color: var(--text); font-weight: 700; font-size: 1.2rem; }
h3 i { color: var(--primary); margin-right: 8px; vertical-align: middle; }
h4 { margin: 0 0 10px; color: var(--text); font-weight: 600; font-size: 1rem; }
label { display: block; font-size: 0.8rem; margin: 12px 0 6px; color: var(--text); font-weight: 600; }
 
/* ── Input groups ── */
.input-group { position: relative; }
.input-group i.fa,
.input-group i.fas {
  position: absolute; left: 12px; top: 50%; transform: translateY(-50%);
  color: var(--text-muted); font-size: 0.85rem; pointer-events: none;
}
.input-group:focus-within i.fa,
.input-group:focus-within i.fas { color: var(--primary); }
 
input, select {
  width: 100%;
  padding: 12px 12px 12px 35px;
  border-radius: 10px;
  border: 1.5px solid #e2e8f0;
  font-size: 13px; color: var(--text);
  background-color: #fff;
  transition: all 0.3s ease;
  font-weight: 500; outline: none;
}
input::placeholder { color: var(--text-muted); font-weight: 400; font-size: 12px; }
input:focus, select:focus {
  border-color: var(--primary);
  box-shadow: 0 0 0 4px var(--focus-ring);
}
 
/* ── Buttons ── */
button {
  width: 100%; padding: 12px; margin-top: 15px;
  font-size: 0.9rem; font-weight: 700;
  border: none; border-radius: 10px; cursor: pointer;
  background: var(--primary); color: white;
  transition: all 0.3s ease;
  display: flex; align-items: center; justify-content: center; gap: 8px;
}
button:hover { background: var(--primary-dark); transform: translateY(-2px); box-shadow: 0 6px 20px rgba(34,197,94,0.2); }
button:active { transform: translateY(0); box-shadow: none; }
button.secondary { background: #e2e8f0; color: var(--text-muted); font-weight: 600; }
button.secondary:hover { background: #cbd5e1; color: var(--text); }
 
/* ── Utility ── */
.top-nav{position:fixed;bottom:15px;left:50%;transform:translateX(-50%);width:calc(100% - 4px);max-width:540px;background:rgba(2, 44, 34, 0.95);backdrop-filter:blur(12px);display:flex;padding:10px 0 25px 0;border-radius:5px;box-shadow:0 10px 40px rgba(0,0,0,0.5);border:1px solid rgba(15,157,88,0.3);z-index:10000;overflow:hidden;}
.indicator{position:absolute;height:3px;bottom:10px;left:0;background:linear-gradient(90deg, #00f2fe, #4facfe);box-shadow:0 0 15px rgba(0,242,254,0.6);transition:0.4s cubic-bezier(0.4,0,0.2,1);z-index:2;border-radius:3px 3px 0 0;}
.nav-btn{flex:1;text-align:center;padding:5px 0 10px 0;font-size:13px;font-weight:600;color:rgba(255,255,255,0.6);cursor:pointer;position:relative;z-index:1;display:flex;align-items:center;justify-content:center;text-decoration:none;}
.nav-btn:hover{color:#fff;}
.nav-btn.active{color:#00f2fe;text-shadow:0 0 8px rgba(0,242,254,0.3);}
.nav-btn.out{color:#dc2626;}
.hidden{display:none !important;}

/* Custom premium toast notification */
.premium-toast {
  position: fixed;
  top: 20px;
  left: 50%;
  transform: translate(-50%, -20px);
  background: rgba(15, 23, 42, 0.95);
  backdrop-filter: blur(12px);
  border: 1px solid rgba(255, 255, 255, 0.15);
  color: #f8fafc;
  padding: 14px 24px;
  border-radius: 12px;
  font-size: 0.9rem;
  font-weight: 600;
  display: flex;
  align-items: center;
  gap: 10px;
  box-shadow: 0 20px 25px -5px rgba(0,0,0,0.3), 0 10px 10px -5px rgba(0,0,0,0.3);
  z-index: 99999;
  opacity: 0;
  pointer-events: none;
  transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
}
.premium-toast.show {
  opacity: 1;
  transform: translate(-50%, 0);
  pointer-events: auto;
}
.premium-toast.success {
  border-color: rgba(34, 197, 94, 0.3);
  background: rgba(6, 78, 59, 0.95);
}
.premium-toast.error {
  border-color: rgba(239, 68, 68, 0.3);
  background: rgba(127, 29, 29, 0.95);
}
.premium-toast.info {
  border-color: rgba(59, 130, 246, 0.3);
  background: rgba(30, 58, 138, 0.95);
}
</style>
</head>
 
<body>
<div class="main-container">
 
  <!-- Header -->
  <div class="header-section">
    <a href="/personal" class="back-arrow">
      <i class="fas fa-arrow-left"></i>
    </a>
    <div class="header-content">
      <h2><i class="fas fa-users-cog"></i> Group Account</h2>
      <p>Manage your savings</p>
    </div>
  </div>
 
  <!-- Tab Navigation -->
  <div class="tab-navigation">
    <button class="tab-button active" id="tabMySaving" onclick="switchTab('mySaving')">
      <i class="fas fa-piggy-bank"></i> My Saving
    </button>
    <button class="tab-button" id="tabCreateGroup" onclick="switchTab('createGroup')">
      <i class="fas fa-plus-circle"></i> Create Group
    </button>
  </div>
 
  <!-- My Saving Section -->
  <div id="mySavingSection">
    <div class="step-box">
      <h3><i class="fas fa-piggy-bank"></i> My Saving</h3>
 
      <!-- Loading -->
      <div id="myGroupsLoading" style="text-align:center;padding:20px;">
        <i class="fas fa-spinner fa-spin" style="font-size:24px;color:var(--primary);"></i>
        <p style="margin-top:10px;color:var(--text-muted);">Loading...</p>
      </div>
 
      <!-- Group List -->
      <div id="groupAccountView" class="hidden">
        <div id="groupListContainer"></div>
      </div>
 
      <!-- No Groups -->
      <div id="noGroupsMessage" class="hidden" style="text-align:center;padding:30px 10px;">
        <i class="fas fa-folder-open" style="font-size:48px;color:var(--border);margin-bottom:15px;"></i>
        <p style="color:var(--text-muted);">You are not a member of any group yet.</p>
        <p style="font-size:0.85rem;color:var(--text-muted);">Create a group or ask to be added to an existing group.</p>
        <button type="button" onclick="switchTab('createGroup')" style="margin-top:20px;">
          <i class="fas fa-plus-circle"></i> Create Group Account
        </button>
      </div>
 
      <!-- Pending Group Notice -->
      <div id="pendingGroupView" class="hidden" style="text-align:center;padding:10px 5px;">
        <div id="pendingViewBox" style="background:#fffbeb;border:1px solid #fef3c7;border-radius:16px;padding:25px;box-shadow:0 10px 15px -3px rgba(0,0,0,0.05);">
          <i id="pendingViewIcon" class="fas fa-hourglass-half" style="font-size:48px;color:#f59e0b;margin-bottom:20px;"></i>
          <h4 id="pendingViewTitle" style="color:#92400e;margin-bottom:12px;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;">Account Processing</h4>
          <p id="pendingViewText" style="color:#92400e;font-size:0.9rem;line-height:1.6;margin:0;">
            This group account is pending and awaits group constitution setup by an Agent.
          </p>
        </div>
        <div style="display:flex;gap:10px;margin-top:25px;">
          <button type="button" onclick="backToGroupList()" class="secondary" style="margin-top:0;border-radius:12px;flex:1;">
            <i class="fas fa-arrow-left"></i> Back to Groups
          </button>
          <button type="button" id="pendingDeleteBtn" onclick="deleteCurrentRequest()" style="margin-top:0;border-radius:12px;background:#fee2e2;color:#dc2626;font-weight:700;flex:1;" class="hidden">
            <i class="fas fa-trash"></i> Delete Request
          </button>
        </div>
      </div>
    </div>
  </div>
 
  <!-- Create Group Section -->
  <div id="createGroupContentArea" class="content-area hidden">
    <div class="form-wrapper" id="createGroupContent"></div>
  </div>

  <%
    const navLinks = [];
    if (showAgent) navLinks.push({ name: 'Agent', action: "switchRole('Agent')" });
    if (showDealer) navLinks.push({ name: 'Dealer', action: "handleDealerClick()" });
    navLinks.push({ name: 'General', action: "handleGeneralClick()" });
    navLinks.push({ name: 'Personal', action: "switchRole('Personal')" });
    navLinks.push({ name: 'Message', action: "openInbox()" });
    const activeIndex = navLinks.findIndex(l => l.name === 'General');
  %>
  <div class="top-nav" style="margin-bottom: 0;">
    <div class="indicator" id="navIndicator" style="width: <%= 100 / navLinks.length %>%; left: <%= activeIndex * (100 / navLinks.length) %>%;"></div>
    <% navLinks.forEach((link, index) => { %>
        <div class="nav-btn <%= link.name === 'General' ? 'active' : '' %>" onclick="moveIndicator(<%= index %>, <%= navLinks.length %>); <%= link.action %>">
            <%= link.name %>
            <% if (link.name === 'Message') { %>
                <span id="msgBadge" class="hidden" style="display:inline-block;background:red;color:white;border-radius:50%;padding:2px 5px;font-size:10px;margin-left:4px;">0</span>
            <% } %>
        </div>
    <% }) %>
  </div>

</div><!-- /.main-container -->

<div id="modalOverlay" style="position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.6);backdrop-filter:blur(4px);display:flex;justify-content:center;align-items:center;z-index:1000;opacity:0;visibility:hidden;transition:all 0.3s ease;">
    <div style="background:white;padding:2rem 5px;border-radius:5px;width:85%;max-width:400px;text-align:center;box-shadow:0 25px 50px rgba(0,0,0,0.4);max-height:90vh;display:flex;flex-direction:column;position:relative;">
        <button onclick="closeModal()" style="position:absolute;top:15px;right:15px;background:transparent;border:none;color:#64748b;font-size:1.5rem;cursor:pointer;z-index:10;width:auto;margin:0;padding:0;"><i class="fa-solid fa-xmark"></i></button>
        <div id="modalTitle" style="margin-bottom:1.5rem;font-size:1.25rem;font-weight:700;color:#1e293b;"></div>
        <div id="modalBody" style="flex:1;overflow-y:auto;text-align:left;padding:0 15px;"></div>
    </div>
</div>

<!-- Custom Premium Confirmation Modal -->
<div id="confirmModalOverlay" style="position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(15,23,42,0.6);backdrop-filter:blur(8px);display:flex;justify-content:center;align-items:center;z-index:11000;opacity:0;visibility:hidden;transition:all 0.3s cubic-bezier(0.16, 1, 0.3, 1);">
    <div style="background:white;padding:25px;border-radius:18px;width:90%;max-width:380px;text-align:center;box-shadow:0 25px 50px -12px rgba(0,0,0,0.25);transform:scale(0.9);transition:all 0.3s cubic-bezier(0.16, 1, 0.3, 1);" id="confirmModalCard">
        <div style="width:60px;height:60px;background:#fee2e2;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 20px;">
            <i class="fas fa-exclamation-triangle" style="font-size:24px;color:#dc2626;"></i>
        </div>
        <h4 style="margin:0 0 10px;font-size:1.2rem;font-weight:800;color:#0f172a;" id="confirmModalTitle">Confirm Action</h4>
        <p style="margin:0 0 25px;font-size:0.9rem;color:#64748b;line-height:1.5;" id="confirmModalText">Are you sure you want to proceed?</p>
        <div style="display:flex;gap:12px;">
            <button type="button" id="confirmCancelBtn" style="margin-top:0;border-radius:12px;background:#f1f5f9;color:#475569;font-weight:600;flex:1;">Cancel</button>
            <button type="button" id="confirmOkBtn" style="margin-top:0;border-radius:12px;background:#dc2626;color:white;font-weight:700;flex:1;">Confirm</button>
        </div>
    </div>
</div>

<!-- Toast Container -->
<div id="premiumToast" class="premium-toast">
  <span id="premiumToastIcon"></span>
  <span id="premiumToastMessage"></span>
</div>
 
<script>
let userRoleData = null;
let selectedGroup = null;

/* ========== PREMIUM NOTIFICATIONS ========== */
function showToast(message, type = 'info') {
  const toast = document.getElementById('premiumToast');
  const icon = document.getElementById('premiumToastIcon');
  const msgEl = document.getElementById('premiumToastMessage');
  
  if (!toast || !icon || !msgEl) return;
  
  toast.className = 'premium-toast show ' + type;
  
  let iconHtml = '';
  if (type === 'success') {
    iconHtml = '<i class="fas fa-check-circle" style="color: #4ade80; font-size: 1.1rem;"></i>';
  } else if (type === 'error') {
    iconHtml = '<i class="fas fa-exclamation-circle" style="color: #f87171; font-size: 1.1rem;"></i>';
  } else {
    iconHtml = '<i class="fas fa-info-circle" style="color: #60a5fa; font-size: 1.1rem;"></i>';
  }
  
  icon.innerHTML = iconHtml;
  msgEl.innerText = message;
  
  setTimeout(() => {
    toast.classList.remove('show');
  }, 3500);
}

function showConfirm(title, text, callback) {
  const overlay = document.getElementById('confirmModalOverlay');
  const card = document.getElementById('confirmModalCard');
  const titleEl = document.getElementById('confirmModalTitle');
  const textEl = document.getElementById('confirmModalText');
  const okBtn = document.getElementById('confirmOkBtn');
  const cancelBtn = document.getElementById('confirmCancelBtn');
  
  if (!overlay || !card || !titleEl || !textEl || !okBtn || !cancelBtn) {
    if (confirm(text)) callback();
    return;
  }
  
  titleEl.innerText = title;
  textEl.innerText = text;
  
  const cleanUp = () => {
    overlay.style.opacity = '0';
    overlay.style.visibility = 'hidden';
    card.style.transform = 'scale(0.9)';
    okBtn.replaceWith(okBtn.cloneNode(true));
    cancelBtn.replaceWith(cancelBtn.cloneNode(true));
  };
  
  overlay.style.visibility = 'visible';
  overlay.style.opacity = '1';
  card.style.transform = 'scale(1)';
  
  document.getElementById('confirmOkBtn').addEventListener('click', () => {
    cleanUp();
    callback();
  });
  
  document.getElementById('confirmCancelBtn').addEventListener('click', () => {
    cleanUp();
  });
}
 
/* ========== TAB SWITCHING ========== */
function switchTab(tab) {
  const mySavingTab = document.getElementById('tabMySaving');
  const createGroupTab = document.getElementById('tabCreateGroup');
  const mySavingSection = document.getElementById('mySavingSection');
  const createGroupArea = document.getElementById('createGroupContentArea');
  const createGroupContent = document.getElementById('createGroupContent');
 
  if (tab === 'mySaving') {
    mySavingTab.classList.add('active');
    createGroupTab.classList.remove('active');
    mySavingSection.classList.remove('hidden');
    createGroupArea.classList.add('hidden');
    createGroupContent.innerHTML = '';
    loadUserRoleData();
  } else {
    createGroupTab.classList.add('active');
    mySavingTab.classList.remove('active');
    mySavingSection.classList.add('hidden');
    createGroupArea.classList.remove('hidden');
    createGroupContent.innerHTML = `
      <form action="/general" method="POST" onsubmit="return handleGeneralSubmit(event)" style="margin-top:10px;">
 
        <div class="step-box" id="cAccount">
          <h3><i class="fas fa-users-cog"></i> Create Group Account</h3>
 
          <label>Group Name</label>
          <div class="input-group">
            <i class="fas fa-users"></i>
            <input type="text" name="groupName" id="confirmedGroup" placeholder="e.g. Umoja Savings Group" required oninput="clearGroupNameError()">
          </div>
          <small id="groupNameError" style="color:#dc2626;font-size:0.7rem;display:none;margin-top:6px;"></small>
 
          <div style="border:1px solid var(--border);padding:14px;border-radius:12px;margin-top:14px;background:#f8f9fa;">
            <h4 style="margin:0 0 12px;color:var(--primary);font-size:0.95rem;border-bottom:2px solid var(--primary);padding-bottom:8px;">
              <i class="fas fa-user-tie"></i> Chairperson Details
            </h4>
 
            <label style="margin-top:0;">Chairperson Phone</label>
            <div class="input-group">
              <i class="fas fa-phone"></i>
              <input type="tel" name="chairpersonalphonenumber" id="confirmedPhone" placeholder="Phone Number" inputmode="numeric" required oninput="this.value=this.value.replace(/[^0-9]/g,'')">
            </div>
 
            <label>Chairperson Full Name</label>
            <div class="input-group">
              <i class="fas fa-user-tie"></i>
              <input type="text" name="name" id="fullNameInput" placeholder="First Middle Last" required oninput="parseFullName()">
            </div>
            <small id="nameError" style="color:red;font-size:0.7rem;display:none;margin-bottom:12px;">Please enter three names (First Middle Last).</small>
            <input type="hidden" name="firstName" id="firstName">
            <input type="hidden" name="secondName" id="secondName">
            <input type="hidden" name="lastName" id="lastName">
          </div>
 
          <div style="display:flex;gap:8px;margin-top:14px;">
            <button type="button" onclick="switchTab('mySaving')" style="flex:1;background:#e2e8f0;color:#333;">
              <i class="fas fa-arrow-left"></i> Back
            </button>
            <button type="button" id="createGroupNextBtn" onclick="goToRegions()" style="flex:1;">
              Next <i class="fas fa-arrow-right"></i>
            </button>
          </div>
        </div>
 
        <div class="step-box hidden" id="gRegions">
          <h3><i class="fas fa-map-marked-alt"></i> Group Location</h3>
          <label>County</label>
          <div class="input-group">
            <i class="fas fa-globe-africa"></i>
            <select name="county" id="countySelect" onchange="loadConstituencies()" required>
              <option value="">-- Select County --</option>
            </select>
          </div>
          <label>Constituency</label>
          <div class="input-group">
            <i class="fas fa-map-pin"></i>
            <select name="constituency" id="constituencySelect" onchange="loadWards()" required>
              <option value="">-- Select Constituency --</option>
            </select>
          </div>
          <label>Ward</label>
          <div class="input-group">
            <i class="fas fa-map-marker-alt"></i>
            <select name="ward" id="wardSelect" required>
              <option value="">-- Select Ward --</option>
            </select>
          </div>
          <div style="display:flex;gap:8px;margin-top:14px;">
            <button type="button" onclick="backToGroupForm()" style="flex:1;background:#e2e8f0;color:#333;">
              <i class="fas fa-arrow-left"></i> Back
            </button>
            <button type="submit" style="flex:1;">
              Submit <i class="fas fa-check-circle"></i>
            </button>
          </div>
        </div>
 
      </form>
    `;
    initCounties();
    
    // Dynamic Phone Maxlength
    const confirmedPhoneInput = document.getElementById('confirmedPhone');
    if(confirmedPhoneInput) {
      confirmedPhoneInput.addEventListener('input', function() {
          let val = this.value.trim();
          if (val.startsWith('+254')) {
              this.maxLength = 13;
          } else if (val.startsWith('254')) {
              this.maxLength = 12;
          } else if (val.startsWith('07') || val.startsWith('01')) {
              this.maxLength = 10;
          } else {
              this.maxLength = 13; // default
          }
      });
    }
  }
}
 
/* ========== MY SAVING — GROUP LIST ========== */
async function loadUserRoleData() {
  const loadingEl = document.getElementById('myGroupsLoading');
  const noGroupsEl = document.getElementById('noGroupsMessage');

  hideAllMySavingViews();
  noGroupsEl.classList.add('hidden');
  loadingEl.classList.remove('hidden');

  try {
    // Fetch both JSON and MongoDB groups in parallel
    const [jsonRes, mongoRes] = await Promise.allSettled([
      fetch('/general/user-role-type'),
      fetch('/general/mongo-groups')
    ]);

    let allGroups = [];

    // Process JSON groups (from general.json)
    if (jsonRes.status === 'fulfilled') {
      const jsonData = await jsonRes.value.json();
      if (jsonData.success && jsonData.groups) {
        allGroups = jsonData.groups.map(g => ({ ...g, source: 'json' }));
        userRoleData = jsonData;
      }
    }

    // Process MongoDB groups — merge without duplicates
    if (mongoRes.status === 'fulfilled') {
      const mongoData = await mongoRes.value.json();
      if (mongoData.success && mongoData.groups) {
        for (const mongoGroup of mongoData.groups) {
          const exists = allGroups.some(g => g.groupName === mongoGroup.groupName);
          if (!exists) {
            allGroups.push({ ...mongoGroup });
          }
        }
      }
    }

    loadingEl.classList.add('hidden');
    userRoleData = userRoleData || { success: true, groups: [] };
    userRoleData.groups = allGroups;

    if (allGroups.length > 0) {
      showGroupListView();
    } else {
      noGroupsEl.classList.remove('hidden');
    }
  } catch (err) {
    console.error('Error loading role data:', err);
    loadingEl.classList.add('hidden');
    noGroupsEl.classList.remove('hidden');
  }
}

 
function showGroupListView() {
  const groups = userRoleData.groups || [];
  const container = document.getElementById('groupListContainer');
  const view = document.getElementById('groupAccountView');
 
  selectedGroup = null;
  hideAllMySavingViews();
  view.classList.remove('hidden');
 
  let html = '<p style="font-size:0.85rem;color:var(--text-muted);margin-bottom:20px;text-align:center;">Choose a group to proceed:</p>';
 
  groups.forEach((group) => {
    const phase = parseInt(group.phase) || 1;
    let statusHtml = '';
 
    if (phase === 1) {
      statusHtml = '<span style="background:#eff6ff;color:#3b82f6;font-size:0.65rem;padding:4px 10px;border-radius:30px;font-weight:800;border:1px solid #dbeafe;">NEW REQUEST</span>';
    } else if (phase === 2 || !group.accountNumber) {
      statusHtml = '<span style="background:#fffbeb;color:#d97706;font-size:0.65rem;padding:4px 10px;border-radius:30px;font-weight:800;border:1px solid #fef3c7;">PENDING</span>';
    } else {
      statusHtml = '<span style="background:#f0fdf4;color:#16a34a;font-size:0.65rem;padding:4px 10px;border-radius:30px;font-weight:800;border:1px solid #dcfce7;">ACTIVE</span>';
    }
 
    const timeOptionsShort = { month:'short', day:'numeric', hour:'numeric', minute:'2-digit', hour12:true };
    const creationTimeStr = new Date(group.createdAt).toLocaleString([], timeOptionsShort).replace(',', ' at');
    const creationShort = new Date(group.createdAt).toLocaleString([], { month:'short', day:'numeric' });
 
    let pendingDateInfo = '';
    if (phase === 2 && group.membersPopulatedAt) {
      const updateShort = new Date(group.membersPopulatedAt).toLocaleString([], { month:'short', day:'numeric' });
      pendingDateInfo = `<span style="font-size:0.65rem;color:#94a3b8;font-weight:500;margin-left:5px;">(C: ${creationShort} / U: ${updateShort})</span>`;
    }
 
    let metaHtml = `<div style="font-size:0.7rem;color:var(--text-muted);margin-top:8px;border-top:1px solid #f1f5f9;padding-top:8px;display:flex;flex-wrap:wrap;gap:10px;">
                      <span><i class="far fa-calendar-alt"></i> Created: ${creationTimeStr}</span>`;
    if (phase === 3) {
      metaHtml += `<span><i class="fas fa-rotate"></i> Round: ${group.activeRound || 1} / 52</span>
                   <span><i class="fas fa-hourglass-start"></i> Remain: ${group.remainRounds || 51}</span>`;
    }
    metaHtml += '</div>';
 
    const roleIcon = group.role === 'trustee' ? 'fa-user-tie' : (group.role === 'official' ? 'fa-user-gear' : 'fa-user');
    const roleColor = group.role === 'trustee' ? '#7c3aed' : '#0891b2';
    const displayRole = (phase >= 2 && group.roleTitle) ? group.roleTitle : group.role;
 
    const deleteBtn = phase === 1
      ? `<button onclick="event.stopPropagation();deleteNewRequest('${group.groupName}')" style="background:#fee2e2;border:none;color:#dc2626;padding:6px 10px;border-radius:8px;cursor:pointer;margin-left:8px;font-size:0.75rem;font-weight:600;"><i class="fas fa-trash"></i> Delete</button>`
      : '';
 
    html += `
      <div onclick="selectGroupForAccess('${group.groupName}')" style="background:#fff;padding:14px 16px;border-radius:12px;margin-bottom:8px;cursor:pointer;box-shadow:0 2px 6px rgba(0,0,0,0.08);transition:all 0.2s;">
        <div style="display:flex;justify-content:space-between;align-items:start;">
          <div style="flex:1;">
            <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-bottom:4px;">
              <span style="font-weight:700;color:var(--text);font-size:14px;letter-spacing:-0.2px;">${group.groupName}</span>
              ${pendingDateInfo}
              <span style="font-size:0.65rem;color:${roleColor};font-weight:700;background:${roleColor}10;padding:2px 8px;border-radius:6px;display:flex;align-items:center;gap:4px;border:1px solid ${roleColor}20;">
                <i class="fas ${roleIcon}"></i> ${displayRole.toUpperCase()}
              </span>
            </div>
            ${metaHtml}
          </div>
          <div style="text-align:right;padding-top:2px;display:flex;align-items:center;gap:8px;justify-content:flex-end;">${statusHtml}<i class="fas fa-chevron-right" style="color:#cbd5e1;font-size:0.85rem;"></i></div>
        </div>
      </div>
    `;
  });
 
  container.innerHTML = html;
}
 
async function deleteNewRequest(groupName) {
  showConfirm('Delete Request', 'Are you sure you want to delete this group request?', async () => {
    try {
      const res = await fetch('/general/delete-group', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ groupName })
      });
      const data = await res.json();
      if (data.success) {
        showToast('Group deleted successfully', 'success');
        loadUserRoleData();
      } else {
        showToast(data.message || 'Failed to delete group', 'error');
      }
    } catch (err) {
      console.error(err);
      showToast('Error deleting group', 'error');
    }
  });
}
 
function selectGroupForAccess(groupName) {
  const group = userRoleData.groups.find(g => g.groupName === groupName);
  if (!group) return;
 
  selectedGroup = group;
  const phase = parseInt(group.phase) || 1;
  const isNotActive = !group.accountNumber || phase < 3;
 
  if (isNotActive) {
    hideAllMySavingViews();
 
    const viewBox   = document.getElementById('pendingViewBox');
    const viewIcon  = document.getElementById('pendingViewIcon');
    const viewTitle = document.getElementById('pendingViewTitle');
    const viewText  = document.getElementById('pendingViewText');
    const pendingDeleteBtn = document.getElementById('pendingDeleteBtn');
 
    if (phase === 1) {
      viewBox.style.background    = '#eff6ff';
      viewBox.style.borderColor   = '#dbeafe';
      viewIcon.className          = 'fas fa-plus-circle';
      viewIcon.style.color        = '#3b82f6';
      viewTitle.textContent       = 'New Request Application';
      viewTitle.style.color       = '#1e40af';
      const agentName  = group.assignedAgentName  || 'System Agent';
      const agentPhone = group.assignedAgentPhone || 'N/A';
      viewText.innerHTML  = `Group awaits member population by agent: <strong>${agentName}</strong> (${agentPhone}).<br><br>Please wait as your request is being processed.`;
      viewText.style.color = '#1e40af';
      if (pendingDeleteBtn) pendingDeleteBtn.classList.remove('hidden');
    } else {
      viewBox.style.background    = '#fffbeb';
      viewBox.style.borderColor   = '#fef3c7';
      viewIcon.className          = 'fas fa-hourglass-half';
      viewIcon.style.color        = '#f59e0b';
      viewTitle.textContent       = 'Account Processing';
      viewTitle.style.color       = '#92400e';
      viewText.textContent        = 'This group account is pending and awaits group constitution setup by an Agent.';
      viewText.style.color        = '#92400e';
      if (pendingDeleteBtn) pendingDeleteBtn.classList.add('hidden');
    }
 
    document.getElementById('pendingGroupView').classList.remove('hidden');
  } else {
    window.location.href = '/general/group/' + encodeURIComponent(group.groupName);
  }
}
 
function backToGroupList() {
  hideAllMySavingViews();
  showGroupListView();
}
 
function deleteCurrentRequest() {
  if (selectedGroup && selectedGroup.groupName) {
    deleteNewRequest(selectedGroup.groupName);
  }
}
 
function hideAllMySavingViews() {
  ['groupAccountView','noGroupsMessage','pendingGroupView','groupContextHeader','myGroupsLoading']
    .forEach(id => { const el = document.getElementById(id); if (el) el.classList.add('hidden'); });
}
 
/* ========== CREATE GROUP HELPERS ========== */
function parseFullName() {
  const full  = document.getElementById('fullNameInput').value.trim();
  const parts = full.split(/\s+/);
  document.getElementById('firstName').value  = parts[0] || '';
  document.getElementById('secondName').value = parts[1] || '';
  document.getElementById('lastName').value   = parts.slice(2).join(' ') || '';
}
 
async function goToRegions() {
  const name     = document.getElementById('confirmedGroup').value.trim();
  const phone    = document.getElementById('confirmedPhone').value.trim();
  const fullName = document.getElementById('fullNameInput').value.trim();
  const nextBtn  = document.getElementById('createGroupNextBtn');
  const isValidP = (p) => /^\+?254[0-9]{9}$/.test(p) || /^0[17][0-9]{8}$/.test(p);
  
  if (!name)                                    { showToast('Please enter a group name.', 'error'); return; }
  if (!phone)                                   { showToast('Please enter phone number', 'error'); return; }
  if (!isValidP(phone))                         { showToast('Invalid phone format. Use +254XXXXXXXXX (13), 254XXXXXXXXX (12) or 07/01XXXXXXXX (10 digits).', 'error'); return; }
  if (fullName.split(/\s+/).length < 3)         { document.getElementById('nameError').style.display = 'block'; return; }
  document.getElementById('nameError').style.display = 'none';

  const original = nextBtn ? nextBtn.innerHTML : '';
  if (nextBtn) {
    nextBtn.disabled = true;
    nextBtn.style.opacity = '0.65';
    nextBtn.innerHTML = '<i class="fas fa-circle-notch fa-spin"></i> Verifying...';
  }

  try {
    const nameOk = await verifyGroupName();
    if (!nameOk) return;
    document.getElementById('cAccount').classList.add('hidden');
    document.getElementById('gRegions').classList.remove('hidden');
  } finally {
    if (nextBtn) {
      nextBtn.disabled = false;
      nextBtn.style.opacity = '';
      nextBtn.innerHTML = original || 'Next <i class="fas fa-arrow-right"></i>';
    }
  }
}

async function verifyGroupName() {
  const name  = document.getElementById('confirmedGroup').value.trim();
  const error = document.getElementById('groupNameError');
  if (!name) {
    error.textContent = 'Please enter a group name.';
    error.style.display = 'block';
    return false;
  }

  error.textContent = 'Verifying group name...';
  error.style.display = 'block';

  try {
    const res = await fetch(`/general/verify-group-name?groupName=${encodeURIComponent(name)}`, {
      headers: { 'Accept': 'application/json' },
      cache: 'no-store'
    });
    const result = await res.json();

    if (result.unavailable) {
      error.textContent = result.message || 'MongoDB verification is not available.';
      error.style.display = 'block';
      return false;
    }

    if (result.exists) {
      error.textContent = 'Group name exists. Please choose a different group name.';
      error.style.display = 'block';
      return false;
    }

    error.textContent = '';
    error.style.display = 'none';
    return true;
  } catch (e) {
    error.textContent = 'Could not verify group name. Please try again.';
    error.style.display = 'block';
    return false;
  }
}

function clearGroupNameError() {
  const error = document.getElementById('groupNameError');
  if (error) {
    error.textContent = '';
    error.style.display = 'none';
  }
}
 
function backToGroupForm() {
  document.getElementById('gRegions').classList.add('hidden');
  document.getElementById('cAccount').classList.remove('hidden');
}
 
function handleGeneralSubmit(event) {
  const wardSelect = document.getElementById('wardSelect');
  if (wardSelect && wardSelect.value === 'OTHER') {
    const manualWard = document.getElementById('manualWardInput')?.value.trim();
    if (!manualWard) { showToast('Please enter your ward name.', 'error'); return false; }
    const opt = document.createElement('option');
    opt.value = manualWard; opt.text = manualWard;
    wardSelect.appendChild(opt); wardSelect.value = manualWard;
  }
  return true;
}
 
function initCounties() {
  const countySelect = document.getElementById('countySelect');
  if (!countySelect) return;
  countySelect.innerHTML = '<option value="">-- Select County --</option>';
  fetch('/api/locations/counties').then(r => r.json()).then(list => {
    list.forEach(county => {
      const opt = document.createElement('option');
      opt.value = county; opt.textContent = county;
      countySelect.appendChild(opt);
    });
  });
}
 
function loadConstituencies() {
  const county = document.getElementById('countySelect').value;
  const constituencySelect = document.getElementById('constituencySelect');
  const wardSelect = document.getElementById('wardSelect');
  constituencySelect.innerHTML = '<option value="">-- Select Constituency --</option>';
  wardSelect.innerHTML = '<option value="">-- Select Ward --</option>';
  if (!county) return;
  fetch(`/api/locations/${encodeURIComponent(county)}/constituencies`).then(r => r.json()).then(list => {
    list.forEach(c => {
      const opt = document.createElement('option'); opt.value = c; opt.textContent = c;
      constituencySelect.appendChild(opt);
    });
  });
}
 
function loadWards() {
  const county = document.getElementById('countySelect').value;
  const constituency = document.getElementById('constituencySelect').value;
  const wardSelect = document.getElementById('wardSelect');
  wardSelect.innerHTML = '<option value="">-- Select Ward --</option>';
  if (!county || !constituency) return;
  fetch(`/api/locations/${encodeURIComponent(county)}/${encodeURIComponent(constituency)}/wards`).then(r => r.json()).then(list => {
    if (!Array.isArray(list) || list.length === 0) {
      const opt = document.createElement('option'); opt.value = ''; opt.textContent = '(No Wards Listed)'; opt.disabled = true;
      wardSelect.appendChild(opt); return;
    }
    list.sort().forEach(ward => {
      const opt = document.createElement('option'); opt.value = ward; opt.textContent = ward;
      wardSelect.appendChild(opt);
    });
  });
}
 
/* ========== NAVIGATION & ROLE SWITCHING ========== */
function moveIndicator(idx, total) {
  const ind = document.getElementById('navIndicator');
  if (ind) ind.style.left = (idx * (100 / total)) + '%';
  const btns = document.querySelectorAll('.nav-btn');
  btns.forEach((b, i) => b.classList.toggle('active', i === idx));
}

function switchRole(role) {
  if (role === 'Personal') window.location.href = '/personal';
  if (role === 'Agent') window.location.href = '/personal?role=Agent';
}

function handleDealerClick() {
  window.location.href = '/personal?role=Dealer';
}

function handleGeneralClick() {
  window.location.href = '/general';
}

function openInbox() {
    const modal = document.getElementById('modalOverlay');
    const title = document.getElementById('modalTitle');
    const body = document.getElementById('modalBody');
    
    title.innerText = "Inbox";
    
    const stored = localStorage.getItem("regionalOfficerMessage");
    if (stored) {
      try {
        const msg = JSON.parse(stored);
        const now = Date.now();
        if (now - msg.timestamp < 86400000) {
          body.innerHTML = `
            <div style="text-align:center;padding:20px;">
              <div style="width:50px;height:50px;background:#dce8fa;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 15px;font-size:24px;">✅</div>
              <h4 style="margin:0 0 10px;color:#1e4080;">Initiation Successful</h4>
              <p style="font-size:13px;color:#4b5563;line-height:1.6;margin:0 0 6px;">You have successfully initiated the creation process of <strong>Regional Officer</strong>.</p>
              <p style="font-size:13px;color:#4b5563;line-height:1.6;margin:0 0 6px;">Please ask the number <strong>${msg.phone}</strong> to proceed to create PIN by clicking <strong>Continue</strong>.</p>
              <p style="font-size:12px;color:#9ca3af;margin-top:15px;">Super Admin will be notified to assist with login details.</p>
              <button onclick="dismissMessage()" style="margin-top:15px;padding:10px;border-radius:10px;background:#1f5cbf;color:white;border:none;cursor:pointer;font-size:13px;font-weight:600;width:auto;padding-left:24px;padding-right:24px;">Dismiss</button>
            </div>
          `;
          modal.style.opacity = '1';
          modal.style.visibility = 'visible';
          return;
        }
      } catch (e) {}
    }
    
    let html = '<div style="text-align:center;padding:40px 20px;color:#94a3b8;"><i class="fa-solid fa-envelope-open" style="font-size:40px;margin-bottom:15px;display:block;opacity:0.3;"></i><p style="font-size:14px;">Your inbox is empty.</p></div>';
    body.innerHTML = html;
    modal.style.opacity = '1';
    modal.style.visibility = 'visible';
  }

  function dismissMessage() {
    localStorage.removeItem("regionalOfficerMessage");
    closeModal();
  }

function closeModal() {
    const modal = document.getElementById('modalOverlay');
    modal.style.opacity = '0';
    modal.style.visibility = 'hidden';
}

document.addEventListener('DOMContentLoaded', () => {
  switchTab('mySaving');
  loadUserRoleData();
});
</script>
