<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>General Account</title>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<style>
:root {
  --primary: #0f9d58;
  --primary-dark: #0b7d46;
  --card: #ffffff;
  --text: #1e293b;
  --text-muted: #64748b;
  --border: #e2e8f0;
  --focus-ring: rgba(15, 157, 88, 0.15);
}
* { box-sizing: border-box; }
body {
  font-family: 'Inter', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
  background: linear-gradient(160deg, #0f2027, #203a43, #2c5364);
  display: flex; justify-content: center; align-items: flex-start;
  min-height: 100vh; margin: 0; padding: 20px;
}
.main-container {
  width: 95%; max-width: 420px; background: var(--card);
  border-radius: 22px; box-shadow: 0 25px 60px rgba(0, 0, 0, 0.35);
  overflow: hidden; animation: slideUp 0.5s ease-out;
}
@keyframes slideUp {
  from { opacity: 0; transform: translateY(30px); }
  to { opacity: 1; transform: translateY(0); }
}
.header-section {
  background: linear-gradient(135deg, #0f9d58, #34d399);
  padding: 20px; color: white; position: relative;
  overflow: hidden; text-align: center;
}
.back-arrow {
  position: absolute; top: 15px; left: 15px; color: white; font-size: 1.2rem;
  cursor: pointer; z-index: 10; transition: transform 0.2s ease;
  padding: 5px; display: flex; align-items: center; justify-content: center;
  text-decoration: none;
}
.back-arrow:hover { transform: translateX(-3px); opacity: 0.8; }
.header-section::before {
  content: ''; position: absolute; top: -50%; right: -20%;
  width: 300px; height: 300px; background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}
.header-content { position: relative; z-index: 1; text-align: center; }
.header-content h2 { margin: 0 0 5px; font-size: 1.4rem; font-weight: 700; }
.header-content p { margin: 0; opacity: 0.9; font-size: 0.8rem; }

.tab-navigation {
  display: flex; background: #f8fafc; border-bottom: 1px solid var(--border);
  padding: 0 10px;
}
.tab-button {
  flex: 1; padding: 14px 10px; background: none; border: none;
  font-size: 0.85rem; font-weight: 600; color: var(--text-muted);
  cursor: pointer; position: relative; transition: all 0.3s ease;
  display: flex; align-items: center; justify-content: center; gap: 6px;
}
.tab-button:hover { color: var(--primary); background: rgba(34, 197, 94, 0.05); }
.tab-button.active { color: var(--primary); }
.tab-button.active::after {
  content: ''; position: absolute; bottom: 0; left: 0; width: 100%;
  height: 3px; background: var(--primary); border-radius: 3px 3px 0 0;
}
.tab-button i { font-size: 0.9rem; }

.content-area { padding: 15px; }
.form-wrapper { width: 100%; max-width: 100%; }

.step-box {
  background: var(--card); padding: 15px; border-radius: 14px;
  animation: fade 0.5s ease-out; border: none;
}
@keyframes fade {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}

h3 { margin: 0 0 15px; text-align: center; color: var(--text); font-weight: 700; font-size: 1.2rem; }
h3 i { color: var(--primary); margin-right: 8px; vertical-align: middle; }
h4 { margin: 0 0 10px; color: var(--text); font-weight: 600; font-size: 1rem; }

label { display: block; font-size: 0.8rem; margin-bottom: 6px; margin-top: 12px; color: var(--text); font-weight: 600; }

.input-group { position: relative; }
.input-group i.fa, .input-group i.fas {
  position: absolute; left: 12px; top: 50%; transform: translateY(-50%);
  color: var(--text-muted); font-size: 0.85rem; pointer-events: none;
}

input, select {
  width: 100%; padding: 12px 12px 12px 35px; border-radius: 10px;
  border: 1.5px solid #e2e8f0; font-size: 13px; color: var(--text);
  background-color: #fff; transition: all 0.3s ease; font-weight: 500; outline: none;
}
input::placeholder { color: var(--text-muted); font-weight: 400; font-size: 12px; }
input:focus, select:focus {
  outline: none; border-color: var(--primary);
  box-shadow: 0 0 0 4px var(--focus-ring); background-color: #fff;
}
.input-group:focus-within i.fa, .input-group:focus-within i.fas { color: var(--primary); }

button {
  width: 100%; padding: 12px; margin-top: 15px; font-size: 0.9rem;
  font-weight: 700; border: none; border-radius: 10px; cursor: pointer;
  background: var(--primary); color: white; transition: all 0.3s ease;
  display: flex; align-items: center; justify-content: center; gap: 8px;
}
button:hover { background: var(--primary-dark); transform: translateY(-2px); box-shadow: 0 6px 20px rgba(34, 197, 94, 0.2); }
button:active { transform: translateY(0); box-shadow: none; }
button.secondary { background: #e2e8f0; color: var(--text-muted); font-weight: 600; }
button.secondary:hover { background: #cbd5e1; color: var(--text); }

.hidden { display: none; }
</style>
</head>

<body>

<div class="main-container">

  <!-- Header -->
  <div class="header-section">
    <a href="/personal" class="back-arrow">
      <i class="fas fa-arrow-left"></i>
    </a>
    <div class="header-content">
      <h2><i class="fas fa-users-cog"></i> Group Account</h2>
      <p>Manage your savings</p>
    </div>
  </div>

  <!-- Tab Navigation -->
  <div class="tab-navigation">
    <button class="tab-button active" id="tabMySaving" onclick="switchTab('mySaving')">
      <i class="fas fa-piggy-bank"></i> My Saving
    </button>
    <button class="tab-button" id="tabCreateGroup" onclick="switchTab('createGroup')">
      <i class="fas fa-plus-circle"></i> Create Group
    </button>
  </div>

  <!-- My Saving Section -->
  <div id="mySavingSection" class="step-box">
    <h3><i class="fas fa-piggy-bank"></i> My Saving</h3>

    <!-- Loading -->
    <div id="myGroupsLoading" style="text-align: center; padding: 20px;">
      <i class="fas fa-spinner fa-spin" style="font-size: 24px; color: var(--primary);"></i>
      <p style="margin-top: 10px; color: var(--text-muted);">Loading...</p>
    </div>

    <!-- Group List -->
    <div id="groupAccountView" class="hidden">
      <div id="groupListContainer"></div>
    </div>

    <!-- No Groups -->
    <div id="noGroupsMessage" class="hidden" style="text-align: center; padding: 30px 10px;">
      <i class="fas fa-folder-open" style="font-size: 48px; color: var(--border); margin-bottom: 15px;"></i>
      <p style="color: var(--text-muted);">You are not a member of any group yet.</p>
      <p style="font-size: 0.85rem; color: var(--text-muted);">Create a group or ask to be added to an existing group.</p>
      <button type="button" onclick="switchTab('createGroup')" style="margin-top: 20px;">
        <i class="fas fa-plus-circle"></i> Create Group Account
      </button>
    </div>

    <!-- Pending Group Notice -->
    <div id="pendingGroupView" class="hidden" style="text-align: center; padding: 10px 5px;">
      <div style="background: #fffbeb; border: 1px solid #fef3c7; border-radius: 16px; padding: 25px; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.05);">
        <i class="fas fa-hourglass-half" style="font-size: 48px; color: #f59e0b; margin-bottom: 20px;"></i>
        <h4 style="color: #92400e; margin-bottom: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px;">Account Processing</h4>
        <p style="color: #92400e; font-size: 0.9rem; line-height: 1.6; margin: 0;">
          This group account is pending and awaits group constitution setup by an Agent.
        </p>
      </div>
      <button type="button" onclick="backToGroupList()" class="secondary" style="margin-top: 25px; border-radius: 12px;">
        <i class="fas fa-arrow-left"></i> Back to Groups
      </button>
    </div>

  </div>

  <!-- Create Group Section -->
  <div class="content-area">
    <div class="form-wrapper hidden" id="createGroupContent"></div>
  </div>

</div>

<script>
let userRoleData = null;
let selectedGroup = null;

/* ========== TAB SWITCHING ========== */
function switchTab(tab) {
  const mySavingTab = document.getElementById('tabMySaving');
  const createGroupTab = document.getElementById('tabCreateGroup');
  const mySavingSection = document.getElementById('mySavingSection');
  const createGroupContent = document.getElementById('createGroupContent');

  if (tab === 'mySaving') {
    mySavingTab.classList.add('active');
    createGroupTab.classList.remove('active');
    mySavingSection.classList.remove('hidden');
    createGroupContent.classList.add('hidden');
    createGroupContent.innerHTML = '';
    loadUserRoleData();
  } else {
    createGroupTab.classList.add('active');
    mySavingTab.classList.remove('active');
    mySavingSection.classList.add('hidden');
    createGroupContent.classList.remove('hidden');
    createGroupContent.innerHTML = `
      <form action="/general" method="POST" onsubmit="return handleGeneralSubmit(event)" style="margin-top:10px;">

        <div class="step-box" id="cAccount">
          <h3><i class="fas fa-users-cog"></i> Create Group Account</h3>

          <label>Group Name</label>
          <div class="input-group">
            <i class="fas fa-users"></i>
            <input type="text" name="groupName" id="confirmedGroup" placeholder="e.g. Umoja Savings Group" required>
          </div>

          <div style="border:1px solid var(--border);padding:14px;border-radius:12px;margin-top:14px;background:#f8f9fa;">
            <h4 style="margin:0 0 12px;color:var(--primary);font-size:0.95rem;border-bottom:2px solid var(--primary);padding-bottom:8px;">
              <i class="fas fa-user-tie"></i> Chairperson Details
            </h4>

            <label style="margin-top:0;">Chairperson Phone</label>
            <div class="input-group">
              <i class="fas fa-phone"></i>
              <input type="tel" name="chairpersonalphonenumber" id="confirmedPhone" placeholder="07XXXXXXXX" maxlength="10" inputmode="numeric" required>
            </div>

            <label>Chairperson Full Name</label>
            <div class="input-group">
              <i class="fas fa-user"></i>
              <input type="text" id="fullNameInput" placeholder="First Middle Last" required oninput="parseFullName()">
            </div>
            <small style="color:red;font-size:0.7rem;display:none;" id="nameError">Please enter at least 2 names.</small>
            <input type="hidden" name="firstName" id="firstName">
            <input type="hidden" name="secondName" id="secondName">
            <input type="hidden" name="lastName" id="lastName">
          </div>

          <div style="display:flex;gap:8px;margin-top:14px;">
            <button type="button" onclick="switchTab('mySaving')" style="flex:1;background:#e2e8f0;color:#333;">
              <i class="fas fa-arrow-left"></i> Back
            </button>
            <button type="button" onclick="goToRegions()" style="flex:1;">
              Next <i class="fas fa-arrow-right"></i>
            </button>
          </div>
        </div>

        <div class="step-box hidden" id="gRegions">
          <h3><i class="fas fa-map-marked-alt"></i> Group Location</h3>
          <label>County</label>
          <div class="input-group">
            <i class="fas fa-globe-africa"></i>
            <select name="county" id="countySelect" onchange="loadConstituencies()" required>
              <option value="">-- Select County --</option>
            </select>
          </div>
          <label>Constituency</label>
          <div class="input-group">
            <i class="fas fa-map-pin"></i>
            <select name="constituency" id="constituencySelect" onchange="loadWards()" required>
              <option value="">-- Select Constituency --</option>
            </select>
          </div>
          <label>Ward</label>
          <div class="input-group">
            <i class="fas fa-map-marker-alt"></i>
            <select name="ward" id="wardSelect" required>
              <option value="">-- Select Ward --</option>
            </select>
          </div>
          <div style="display:flex;gap:8px;margin-top:14px;">
            <button type="button" onclick="backToGroupForm()" style="flex:1;background:#e2e8f0;color:#333;">
              <i class="fas fa-arrow-left"></i> Back
            </button>
            <button type="submit" style="flex:1;">
              Submit <i class="fas fa-check-circle"></i>
            </button>
          </div>
        </div>

      </form>
    `;
    initCounties();
  }
}

/* ========== MY SAVING — GROUP LIST ========== */
async function loadUserRoleData() {
  const loadingEl = document.getElementById('myGroupsLoading');
  const noGroupsEl = document.getElementById('noGroupsMessage');

  hideAllMySavingViews();
  noGroupsEl.classList.add('hidden');
  loadingEl.classList.remove('hidden');

  try {
    const res = await fetch('/general/user-role-type');
    userRoleData = await res.json();
    loadingEl.classList.add('hidden');

    if (userRoleData.success && userRoleData.groups && userRoleData.groups.length > 0) {
      showGroupListView();
    } else {
      noGroupsEl.classList.remove('hidden');
    }
  } catch (err) {
    console.error('Error loading role data:', err);
    loadingEl.classList.add('hidden');
    noGroupsEl.classList.remove('hidden');
  }
}

function showGroupListView() {
  const groups = userRoleData.groups || [];
  const container = document.getElementById('groupListContainer');
  const view = document.getElementById('groupAccountView');

  selectedGroup = null;
  hideAllMySavingViews();
  view.classList.remove('hidden');

  let html = '<p style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 20px; text-align: center;">Choose a group to proceed:</p>';

  groups.forEach((group) => {
    const isPending = !group.accountNumber || (parseInt(group.phase) || 1) < 3;
    const roleIcon = group.role === 'trustee' ? 'fa-user-tie' : (group.role === 'official' ? 'fa-user-gear' : 'fa-user');
    const roleColor = group.role === 'trustee' ? '#7c3aed' : '#0891b2';

    html += `
      <div onclick="selectGroupForAccess('${group.groupName}')" style="background: #f8fafc; padding: 16px; border-radius: 14px; margin-bottom: 12px; cursor: pointer; border: 1px solid var(--border); transition: all 0.2s;">
        <div style="display: flex; justify-content: space-between; align-items: center;">
          <div>
            <div style="font-weight: 700; color: var(--text); font-size: 1.05rem; margin-bottom: 4px;">${group.groupName}</div>
            <div style="font-size: 0.75rem; color: ${roleColor}; font-weight: 600; display: flex; align-items: center; gap: 5px;">
              <i class="fas ${roleIcon}"></i> ${group.role.toUpperCase()}
            </div>
          </div>
          <div style="text-align: right;">
            ${isPending
              ? '<span style="background: #fffbeb; color: #d97706; font-size: 0.65rem; padding: 4px 10px; border-radius: 30px; font-weight: 800; border: 1px solid #fef3c7;">PENDING</span>'
              : '<span style="background: #f0fdf4; color: #16a34a; font-size: 0.65rem; padding: 4px 10px; border-radius: 30px; font-weight: 800; border: 1px solid #dcfce7;">ACTIVE</span>'}
          </div>
        </div>
      </div>
    `;
  });

  container.innerHTML = html;
}

function selectGroupForAccess(groupName) {
  const group = userRoleData.groups.find(g => g.groupName === groupName);
  if (!group) return;

  selectedGroup = group;
  const isPending = !group.accountNumber || (parseInt(group.phase) || 1) < 3;

  if (isPending) {
    hideAllMySavingViews();
    document.getElementById('pendingGroupView').classList.remove('hidden');
  } else {
    // Active group — navigate to group details page
    window.location.href = '/general/group/' + encodeURIComponent(group.groupName);
  }
}

function backToGroupList() {
  hideAllMySavingViews();
  showGroupListView();
}

function hideAllMySavingViews() {
  ['groupAccountView', 'noGroupsMessage', 'pendingGroupView', 'groupContextHeader', 'myGroupsLoading'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.classList.add('hidden');
  });
}

/* ========== CREATE GROUP HELPERS ========== */
function parseFullName() {
  const full = document.getElementById('fullNameInput').value.trim();
  const parts = full.split(/\s+/);
  document.getElementById('firstName').value = parts[0] || '';
  document.getElementById('secondName').value = parts[1] || '';
  document.getElementById('lastName').value = parts.slice(2).join(' ') || '';
}

function goToRegions() {
  const name = document.getElementById('confirmedGroup').value.trim();
  const phone = document.getElementById('confirmedPhone').value.trim();
  const fullName = document.getElementById('fullNameInput').value.trim();
  if (!name) { alert('Please enter a group name.'); return; }
  if (!phone || phone.length < 10) { alert('Enter a valid 10-digit phone number.'); return; }
  if (fullName.split(/\s+/).length < 2) { document.getElementById('nameError').style.display = 'block'; return; }
  document.getElementById('nameError').style.display = 'none';
  document.getElementById('cAccount').classList.add('hidden');
  document.getElementById('gRegions').classList.remove('hidden');
}

function backToGroupForm() {
  document.getElementById('gRegions').classList.add('hidden');
  document.getElementById('cAccount').classList.remove('hidden');
}

function handleGeneralSubmit(event) {
  const wardSelect = document.getElementById('wardSelect');
  if (wardSelect && wardSelect.value === 'OTHER') {
    const manualWard = document.getElementById('manualWardInput')?.value.trim();
    if (!manualWard) { alert('Please enter your ward name.'); return false; }
    const opt = document.createElement('option');
    opt.value = manualWard; opt.text = manualWard;
    wardSelect.appendChild(opt); wardSelect.value = manualWard;
  }
  return true;
}

function initCounties() {
  const countySelect = document.getElementById('countySelect');
  if (!countySelect) return;
  countySelect.innerHTML = '<option value="">-- Select County --</option>';
  fetch('/api/locations/counties').then(r => r.json()).then(list => {
    list.forEach(county => {
      const opt = document.createElement('option');
      opt.value = county; opt.textContent = county;
      countySelect.appendChild(opt);
    });
  });
}

function loadConstituencies() {
  const county = document.getElementById('countySelect').value;
  const constituencySelect = document.getElementById('constituencySelect');
  const wardSelect = document.getElementById('wardSelect');
  constituencySelect.innerHTML = '<option value="">-- Select Constituency --</option>';
  wardSelect.innerHTML = '<option value="">-- Select Ward --</option>';
  if (!county) return;
  fetch(`/api/locations/${encodeURIComponent(county)}/constituencies`).then(r => r.json()).then(list => {
    list.forEach(c => {
      const opt = document.createElement('option'); opt.value = c; opt.textContent = c;
      constituencySelect.appendChild(opt);
    });
  });
}

function loadWards() {
  const county = document.getElementById('countySelect').value;
  const constituency = document.getElementById('constituencySelect').value;
  const wardSelect = document.getElementById('wardSelect');
  wardSelect.innerHTML = '<option value="">-- Select Ward --</option>';
  if (!county || !constituency) return;
  fetch(`/api/locations/${encodeURIComponent(county)}/${encodeURIComponent(constituency)}/wards`).then(r => r.json()).then(list => {
    if (!Array.isArray(list) || list.length === 0) {
      const opt = document.createElement('option'); opt.value = ''; opt.textContent = '(No Wards Listed)'; opt.disabled = true;
      wardSelect.appendChild(opt); return;
    }
    list.sort().forEach(ward => {
      const opt = document.createElement('option'); opt.value = ward; opt.textContent = ward;
      wardSelect.appendChild(opt);
    });
  });
}

/* ========== INIT ========== */
document.addEventListener('DOMContentLoaded', () => {
  loadUserRoleData();
});
</script>
</body>
</html>
