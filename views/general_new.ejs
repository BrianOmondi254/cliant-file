<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>General Account</title>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<style>
:root {
  --primary: #0f9d58;
  --primary-dark: #0b7d46;
  --bg: #f1f5f9;
  --card: #ffffff;
  --text: #1e293b;
  --text-muted: #64748b;
  --border: #e2e8f0;
  --focus-ring: rgba(15, 157, 88, 0.15);
}
* { box-sizing: border-box; }
body {
  font-family: 'Inter', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
  background: linear-gradient(160deg, #0f2027, #203a43, #2c5364);
  display: flex; justify-content: center; align-items: flex-start;
  min-height: 100vh; margin: 0; padding: 20px;
}
.main-container {
  width: 95%; max-width: 420px; background: var(--card);
  border-radius: 22px; box-shadow: 0 25px 60px rgba(0, 0, 0, 0.35);
  overflow: hidden; animation: slideUp 0.5s ease-out;
}
@keyframes slideUp {
  from { opacity: 0; transform: translateY(30px); }
  to { opacity: 1; transform: translateY(0); }
}
.header-section {
  background: linear-gradient(135deg, #0f9d58, #34d399);
  padding: 20px; color: white; position: relative;
  overflow: hidden; text-align: center;
}
.back-arrow {
  position: absolute; top: 15px; left: 15px; color: white; font-size: 1.2rem;
  cursor: pointer; z-index: 10; transition: transform 0.2s ease;
  padding: 5px; display: flex; align-items: center; justify-content: center;
  text-decoration: none;
}
.back-arrow:hover { transform: translateX(-3px); opacity: 0.8; }
.header-section::before {
  content: ''; position: absolute; top: -50%; right: -20%;
  width: 300px; height: 300px; background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}
.header-content { position: relative; z-index: 1; text-align: center; }
.header-content h2 { margin: 0 0 5px; font-size: 1.4rem; font-weight: 700; }
.header-content p { margin: 0; opacity: 0.9; font-size: 0.8rem; }

.tab-navigation {
  display: flex; background: #f8fafc; border-bottom: 1px solid var(--border);
  padding: 0 10px;
}
.tab-button {
  flex: 1; padding: 14px 10px; background: none; border: none;
  font-size: 0.85rem; font-weight: 600; color: var(--text-muted);
  cursor: pointer; position: relative; transition: all 0.3s ease;
  display: flex; align-items: center; justify-content: center; gap: 6px;
}
.tab-button:hover { color: var(--primary); background: rgba(34, 197, 94, 0.05); }
.tab-button.active { color: var(--primary); }
.tab-button.active::after {
  content: ''; position: absolute; bottom: 0; left: 0; width: 100%;
  height: 3px; background: var(--primary); border-radius: 3px 3px 0 0;
}
.tab-button i { font-size: 0.9rem; }

.content-area { padding: 15px; min-height: auto; }
.form-wrapper { width: 100%; max-width: 100%; }

.progress-bar {
  display: flex; justify-content: space-around; align-items: center;
  margin-bottom: 15px; position: relative; width: 80%; margin: 0 auto 15px;
}
.progress-bar::before {
  content: ''; position: absolute; top: 50%; left: 0; transform: translateY(-50%);
  height: 2px; width: 100%; background-color: var(--border); z-index: 1;
}
.step-indicator {
  z-index: 2; position: relative; width: 30px; height: 30px;
  border-radius: 50%; background-color: var(--card); border: 2px solid var(--border);
  display: flex; justify-content: center; align-items: center;
  font-weight: 600; font-size: 0.75rem; color: var(--text-muted);
}
.step-indicator.active { border-color: var(--primary); background-color: var(--primary); color: white; }
.step-indicator.completed { border-color: var(--primary); background-color: white; color: var(--primary); }

.step-box {
  background: var(--card); padding: 15px; border-radius: 14px;
  box-shadow: none; animation: fade 0.5s ease-out; border: none;
}
@keyframes fade {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}

h3 { margin: 0 0 15px; text-align: center; color: var(--text); font-weight: 700; font-size: 1.2rem; }
h3 i { color: var(--primary); margin-right: 8px; vertical-align: middle; }
h4 { margin: 0 0 10px; color: var(--text); font-weight: 600; font-size: 1rem; }

label { display: block; font-size: 0.8rem; margin-bottom: 6px; margin-top: 12px; color: var(--text); font-weight: 600; }

.input-group { position: relative; }
.input-group i.fa, .input-group i.fas {
  position: absolute; left: 12px; top: 50%; transform: translateY(-50%);
  color: var(--text-muted); font-size: 0.85rem; pointer-events: none;
}

input, select {
  width: 100%; padding: 12px 12px 12px 35px; border-radius: 10px;
  border: 1.5px solid #e2e8f0; font-size: 13px; color: var(--text);
  background-color: #fff; transition: all 0.3s ease; font-weight: 500; outline: none;
}
input::placeholder { color: var(--text-muted); font-weight: 400; font-size: 12px; }
input:focus, select:focus {
  outline: none; border-color: var(--primary);
  box-shadow: 0 0 0 4px var(--focus-ring); background-color: #fff;
}
.input-group:focus-within i.fa, .input-group:focus-within i.fas { color: var(--primary); }

button {
  width: 100%; padding: 12px; margin-top: 15px; font-size: 0.9rem;
  font-weight: 700; border: none; border-radius: 10px; cursor: pointer;
  background: var(--primary); color: white; transition: all 0.3s ease;
  display: flex; align-items: center; justify-content: center; gap: 8px;
}
button:hover { background: var(--primary-dark); transform: translateY(-2px); box-shadow: 0 6px 20px rgba(34, 197, 94, 0.2); }
button:active { transform: translateY(0); box-shadow: none; }

.button-group { display: flex; gap: 10px; margin-top: 15px; }
.button-group button, .button-group button[type=button] { flex: 1; margin-top: 0; }
button.secondary { background: #e2e8f0; color: var(--text-muted); font-weight: 600; }
button.secondary:hover { background: #cbd5e1; color: var(--text); }

.hidden { display: none; }
.account-type-btn {
  padding: 15px; margin-bottom: 10px; border-radius: 12px; cursor: pointer;
  transition: all 0.3s ease; border: 2px solid transparent;
}
.account-type-btn:hover { border-color: var(--primary); }
.account-type-btn.selected { border-color: var(--primary); background: rgba(15, 157, 88, 0.1); }
.account-type-btn i { font-size: 1.5rem; margin-bottom: 8px; }
.account-type-btn h4 { margin: 0 0 5px; }
.account-type-btn p { margin: 0; font-size: 0.8rem; color: var(--text-muted); }
</style>
</head>

<body>

<div class="main-container">
  <div class="header-section">
    <a href="/personal" class="back-arrow">
      <i class="fas fa-arrow-left"></i>
    </a>
    <div class="header-content">
      <h2><i class="fas fa-users-cog"></i> Group Account</h2>
      <p>Manage your savings</p>
    </div>
  </div>

  <div class="tab-navigation">
    <button class="tab-button active" id="tabMySaving" onclick="switchTab('mySaving')">
      <i class="fas fa-piggy-bank"></i> My Saving
    </button>
    <button class="tab-button" id="tabCreateGroup" onclick="switchTab('createGroup')">
      <i class="fas fa-plus-circle"></i> Create Group
    </button>
  </div>

  <!-- My Saving Section -->
  <div id="mySavingSection" class="step-box">
    <h3><i class="fas fa-piggy-bank"></i> My Saving</h3>
    
    <!-- Loading -->
    <div id="myGroupsLoading" style="text-align: center; padding: 20px;">
      <i class="fas fa-spinner fa-spin" style="font-size: 24px; color: var(--primary);"></i>
      <p style="margin-top: 10px; color: var(--text-muted);">Loading...</p>
    </div>
    
    <!-- Group Context Header (Shows which group is selected) -->
    <div id="groupContextHeader" class="hidden" style="margin-bottom: 20px; padding: 15px; background: linear-gradient(135deg, #0f9d58, #10b981); border-radius: 12px; color: white;">
      <h4 id="selectedGroupNameDisplay" style="margin: 0; color: white; font-size: 1.1rem;">Group Name</h4>
      <p id="selectedGroupRoleDisplay" style="margin: 5px 0 0; font-size: 0.8rem; opacity: 0.9; font-weight: 500;">Role: Member</p>
    </div>

    <!-- Account Type Selection -->
    <div id="accountTypeSelection" class="hidden">
      <p style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 15px; text-align: center;">
        Select an account type to proceed:
      </p>
      
      <!-- My Account (shown for ALL users: member, official, trustee) -->
      <div id="myAccountBtn" class="account-type-btn" onclick="selectAccountType('myAccount')">
        <i class="fas fa-user" style="color: var(--primary);"></i>
        <h4><i class="fas fa-user"></i> My Account</h4>
        <p>View your personal savings</p>
      </div>
      
      <!-- Change PIN (shown for ALL users who have a PIN) -->
      <% if (typeof hasPersonalPin !== 'undefined' && hasPersonalPin) { %>
      <div id="changePinBtn" class="account-type-btn" onclick="selectAccountType('changePin')">
        <i class="fas fa-key" style="color: #f59e0b;"></i>
        <h4><i class="fas fa-key"></i> Change PIN</h4>
        <p>Update your personal PIN</p>
      </div>
      <% } %>
      
      <!-- Group Account (shown ONLY for trustees and officials) -->
      <div id="groupAccountBtn" class="account-type-btn hidden" onclick="selectAccountType('groupAccount')">
        <i class="fas fa-users" style="color: #7c3aed;"></i>
        <h4><i class="fas fa-users"></i> Group Account</h4>
        <p>Manage group savings (Trustees/Officials)</p>
      </div>
    </div>
    
    <!-- PIN Verification for Group -->
    <div id="pinVerification" class="hidden">
      <p style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 15px;">
        Enter your constitution start key to access group account:
      </p>
      <label>Constitution Key (PIN)</label>
      <div class="input-group">
        <i class="fas fa-lock"></i>
        <input type="text" id="groupPinInput" placeholder="Enter 6-digit key" maxlength="6">
      </div>
      <button type="button" onclick="verifyGroupPin()">Verify <i class="fas fa-check"></i></button>
      <button type="button" onclick="showGenerateKey()" style="background: #f59e0b; margin-top: 10px;">
        <i class="fas fa-key"></i> Generate New Key
      </button>
      <p id="pinVerifyMsg" style="color: red; text-align: center; margin-top: 10px;"></p>
    </div>
    
    <!-- Create PIN Section (when no key exists) -->
    <div id="createPinSection" class="hidden">
      <p style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 15px;">
        No constitution key found. Create one to access your group account:
      </p>
      <label>Create Constitution Key</label>
      <div class="input-group">
        <i class="fas fa-key"></i>
        <input type="text" id="newPinInput" placeholder="Enter 4-6 digit PIN" maxlength="6">
      </div>
      <label style="margin-top: 12px;">Confirm PIN</label>
      <div class="input-group">
        <i class="fas fa-key"></i>
        <input type="text" id="confirmPinInput" placeholder="Confirm PIN" maxlength="6">
      </div>
      <button type="button" onclick="createNewPin()">
        <i class="fas fa-plus-circle"></i> Create PIN
      </button>
      <button type="button" onclick="backToAccountSelection()" class="secondary">
        <i class="fas fa-arrow-left"></i> Back
      </button>
      <p id="createPinMsg" style="color: red; text-align: center; margin-top: 10px;"></p>
    </div>
    
    <!-- Pending Group Note -->
    <div id="pendingGroupView" class="hidden" style="text-align: center; padding: 10px 5px;">
      <div style="background: #fffbeb; border: 1px solid #fef3c7; border-radius: 16px; padding: 25px; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.05);">
        <i class="fas fa-hourglass-half" style="font-size: 48px; color: #f59e0b; margin-bottom: 20px;"></i>
        <h4 style="color: #92400e; margin-bottom: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px;">Account Processing</h4>
        <p style="color: #92400e; font-size: 0.9rem; line-height: 1.6; margin: 0;">
          This group account selected is pending and awaits group constitution setup by an Agent.
        </p>
      </div>
      <button type="button" onclick="backToAccountSelection()" class="secondary" style="margin-top: 25px; border-radius: 12px;">
        <i class="fas fa-arrow-left"></i> Back to Groups
      </button>
    </div>

    <!-- Generate Key Section -->
    <div id="generateKeySection" class="hidden">
      <p style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 15px;">
        Generate a new constitution key? The new key will be sent to the chairperson's phone.
      </p>
      <div style="background: #fef3c7; padding: 15px; border-radius: 10px; margin-bottom: 15px;">
        <p style="font-size: 0.85rem; color: #92400e; margin: 0;">
          <i class="fas fa-info-circle"></i> A new 6-digit key will be generated and sent to the group chairperson's phone number for verification.
        </p>
      </div>
      <button type="button" onclick="generateNewKey()">
        <i class="fas fa-key"></i> Generate & Send Key
      </button>
      <button type="button" onclick="backToPinVerify()" class="secondary">
        <i class="fas fa-arrow-left"></i> Back
      </button>
      <p id="generateKeyMsg" style="color: var(--primary); text-align: center; margin-top: 10px;"></p>
    </div>

    <!-- My Account View -->
    <div id="myAccountView" class="hidden">
      <div style="text-align: center; padding: 20px;">
        <i class="fas fa-user-circle" style="font-size: 64px; color: var(--primary); margin-bottom: 15px;"></i>
        <h4 style="color: var(--text); margin-bottom: 10px;">My Personal Account</h4>
        <p style="color: var(--text-muted); font-size: 0.85rem;">Your personal savings are managed here.</p>
        
        <!-- Change PIN Section -->
        <div id="changePinSection" style="margin-top: 25px; padding: 15px; background: var(--background); border-radius: 10px;">
          <p style="color: var(--text-muted); font-size: 0.8rem; margin-bottom: 15px;">Secure your account with a PIN</p>
          <% if (typeof hasPersonalPin !== 'undefined' && hasPersonalPin) { %>
            <button type="button" onclick="showChangePinForm()" class="primary" style="padding: 10px 20px; border-radius: 8px;">
              <i class="fas fa-key"></i> Change PIN
            </button>
          <% } else { %>
            <button type="button" onclick="showSetPinForm()" class="primary" style="padding: 10px 20px; border-radius: 8px;">
              <i class="fas fa-lock"></i> Set PIN
            </button>
          <% } %>
        </div>
        
        <!-- Change PIN Form (hidden by default) -->
        <div id="changePinForm" class="hidden" style="margin-top: 20px; text-align: left; max-width: 300px; margin-left: auto; margin-right: auto;">
          <% if (typeof hasPersonalPin !== 'undefined' && hasPersonalPin) { %>
            <div class="form-group">
              <label style="font-size: 0.85rem;">Current PIN</label>
              <input type="password" id="oldPinGeneral" class="form-input" maxlength="4" placeholder="****" inputmode="numeric">
            </div>
          <% } %>
          <div class="form-group">
            <label style="font-size: 0.85rem;">New PIN</label>
            <input type="password" id="newPinGeneral" class="form-input" maxlength="4" placeholder="****" inputmode="numeric">
          </div>
          <div class="form-group">
            <label style="font-size: 0.85rem;">Confirm PIN</label>
            <input type="password" id="confirmPinGeneral" class="form-input" maxlength="4" placeholder="****" inputmode="numeric">
          </div>
          <button type="button" onclick="submitPinChangeGeneral()" class="primary" style="width: 100%; padding: 12px; border-radius: 8px; margin-top: 10px;">
            <i class="fas fa-check"></i> Save PIN
          </button>
          <button type="button" onclick="cancelPinChangeGeneral()" class="secondary" style="width: 100%; padding: 10px; border-radius: 8px; margin-top: 8px;">
            Cancel
          </button>
        </div>
        
        <p id="pinMessage" style="color: var(--primary); font-size: 0.8rem; margin-top: 15px;"></p>
      </div>
      <button type="button" onclick="backToAccountSelection()" class="secondary">
        <i class="fas fa-arrow-left"></i> Back
      </button>
    </div>
    
    <!-- Group Account View -->
    <div id="groupAccountView" class="hidden">
      <div id="groupListContainer"></div>
      <button type="button" onclick="backToAccountSelection()" class="secondary">
        <i class="fas fa-arrow-left"></i> Back
      </button>
    </div>
    
    <!-- No Groups -->
    <div id="noGroupsMessage" class="hidden" style="text-align: center; padding: 30px 10px;">
      <i class="fas fa-folder-open" style="font-size: 48px; color: var(--border); margin-bottom: 15px;"></i>
      <p style="color: var(--text-muted);">You are not a member of any group yet.</p>
      <p style="font-size: 0.85rem; color: var(--text-muted);">Create a group or ask to be added to an existing group.</p>
    </div>
    
    <!-- Change PIN View -->
    <div id="changePinView" class="hidden">
      <div style="text-align: center; padding: 20px; position: relative;">
        <button onclick="backToAccountSelection()" style="position: absolute; top: 10px; right: 10px; background: none; border: none; font-size: 1.2rem; cursor: pointer; color: var(--text-muted);"><i class="fas fa-times"></i></button>
        <i class="fas fa-key" style="font-size: 64px; color: #f59e0b; margin-bottom: 15px;"></i>
        <h4 style="color: var(--text); margin-bottom: 10px;">Change PIN</h4>
        <p style="color: var(--text-muted); font-size: 0.85rem;">Update your personal security PIN</p>
        
        <!-- Change PIN Options -->
        <div id="changePinOptionsGN" style="margin-top: 25px;">
          <div style="display: flex; gap: 10px;">
            <button onclick="showNewPinFormGN()" class="primary" style="flex: 1; padding: 12px; border-radius: 8px;">
              <i class="fas fa-edit"></i> New PIN
            </button>
            <button onclick="showForgotPinFormGN()" class="primary" style="flex: 1; padding: 12px; border-radius: 8px; background: #f59e0b;">
              <i class="fas fa-question-circle"></i> Forgot PIN
            </button>
          </div>
        </div>
        
        <!-- New PIN Form -->
        <div id="newPinFormGN" class="hidden" style="margin-top: 25px; text-align: left; max-width: 300px; margin-left: auto; margin-right: auto; position: relative; padding: 15px; background: #f8fafc; border-radius: 10px;">
          <button onclick="backToAccountSelection()" style="position: absolute; top: 10px; right: 10px; background: none; border: none; font-size: 1.2rem; cursor: pointer; color: var(--text-muted);"><i class="fas fa-times"></i></button>
          <div class="form-group">
            <label style="font-size: 0.85rem;">Current PIN</label>
            <input type="password" id="oldPinGeneral2" class="form-input" maxlength="4" placeholder="****" inputmode="numeric">
          </div>
          <div class="form-group">
            <label style="font-size: 0.85rem;">New PIN</label>
            <input type="password" id="newPinGeneral2" class="form-input" maxlength="4" placeholder="****" inputmode="numeric">
          </div>
          <div class="form-group">
            <label style="font-size: 0.85rem;">Confirm PIN</label>
            <input type="password" id="confirmPinGeneral2" class="form-input" maxlength="4" placeholder="****" inputmode="numeric">
          </div>
          <button type="button" onclick="submitChangePinGeneral()" class="primary" style="width: 100%; padding: 12px; border-radius: 8px; margin-top: 10px;">
            <i class="fas fa-check"></i> Change PIN
          </button>
          <p id="pinMessage2" style="color: var(--primary); font-size: 0.8rem; margin-top: 15px; text-align: center;"></p>
        </div>
        
        <!-- Forgot PIN Form -->
        <div id="forgotPinFormGN" class="hidden" style="margin-top: 25px; text-align: left; max-width: 300px; margin-left: auto; margin-right: auto; position: relative; padding: 15px; background: #f8fafc; border-radius: 10px;">
          <button onclick="backToAccountSelection()" style="position: absolute; top: 10px; right: 10px; background: none; border: none; font-size: 1.2rem; cursor: pointer; color: var(--text-muted);"><i class="fas fa-times"></i></button>
          <p style="font-size: 0.85rem; color: var(--text-muted); text-align: center; margin-bottom: 15px;">Request a start key via SMS to reset your PIN</p>
          <button type="button" onclick="requestStartKeyGN()" class="primary" style="width: 100%; padding: 12px; border-radius: 8px; margin-bottom: 15px; background: #7c3aed;">
            <i class="fas fa-sms"></i> Request Start Key (SMS)
          </button>
          
          <div id="startKeyInputGN" class="hidden">
            <div class="form-group">
              <label style="font-size: 0.85rem;">Start Key (from SMS)</label>
              <input type="text" id="startKeyGN" class="form-input" placeholder="Enter start key" inputmode="numeric">
            </div>
            <div class="form-group">
              <label style="font-size: 0.85rem;">New PIN</label>
              <input type="password" id="resetNewPinGN" class="form-input" maxlength="4" placeholder="****" inputmode="numeric">
            </div>
            <div class="form-group">
              <label style="font-size: 0.85rem;">Confirm PIN</label>
              <input type="password" id="resetConfirmPinGN" class="form-input" maxlength="4" placeholder="****" inputmode="numeric">
            </div>
            <button type="button" onclick="submitResetPinGN()" class="primary" style="width: 100%; padding: 12px; border-radius: 8px; margin-top: 10px;">
              <i class="fas fa-check"></i> Reset PIN
            </button>
          </div>
          
          <p id="forgotPinMessageGN" style="color: var(--primary); font-size: 0.8rem; margin-top: 15px; text-align: center;"></p>
        </div>
        
      </div>
    </div>
  </div>

  <!-- Create Group Section -->
  <div class="content-area">
    <div class="form-wrapper hidden" id="createGroupContent">
    <form action="/general" method="POST" onsubmit="return handleGeneralSubmit(event)">
      <div class="progress-bar">
        <div class="step-indicator active" id="indicator-1">1</div>
        <div class="step-indicator" id="indicator-2">2</div>
        <div class="step-indicator" id="indicator-3">3</div>
      </div>

      <% if (!locals.isCreation) { %>
      <div class="step-box" id="verificationStep">
        <h3><i class="fas fa-user-check"></i> Agent Verification</h3>
        <label>Select Group Name</label>
        <div class="input-group">
          <i class="fas fa-users"></i>
          <select id="verifyGroup" onchange="showPhoneInput()">
            <option value="" disabled selected>-- Select Group --</option>
            <% if (locals.groups && groups.length > 0) { %>
              <% groups.forEach(function(group) { %>
                <option value="<%= group.groupName %>" data-pending="<%= !group.accountNumber %>"><%= group.groupName %></option>
              <% }); %>
            <% } else { %>
              <option value="" disabled>No groups found</option>
            <% } %>
          </select>
        </div>
        <div id="pendingGroupNote" class="hidden" style="margin-top: 10px; padding: 12px; background: #fffbeb; border: 1px solid #fef3c7; border-radius: 10px; display: flex; align-items: flex-start; gap: 10px;">
          <i class="fas fa-clock" style="color: #d97706; margin-top: 2px;"></i>
          <p style="margin: 0; font-size: 0.8rem; color: #92400e; line-height: 1.4;">
            <strong>Group Pending:</strong> This group account selected is pending and awaits group constitution setup by an agent.
          </p>
        </div>
        <div id="phoneVerifyContainer" class="hidden">
          <label>Enter Chairperson Phone Number</label>
          <div class="input-group">
            <i class="fas fa-phone"></i>
            <input type="number" id="verifyPhone" placeholder="07XX XXX XXX">
          </div>
          <button type="button" onclick="verifyChairperson()">Verify <i class="fas fa-search"></i></button>
        </div>
        <p id="verifyMsg" style="color: red; text-align: center; margin-top: 10px;"></p>
      </div>
      <% } %>

      <div class="step-box <%= locals.isCreation ? '' : 'hidden' %>" id="cAccount">
        <h3><i class="fas fa-users-cog"></i>Create Group Account</h3>
        <label>Group Name</label>
        <div class="input-group" style="margin-bottom: 10px;">
          <i class="fas fa-users"></i>
          <% if (locals.isCreation) { %>
            <input type="text" name="groupName" id="confirmedGroup" placeholder="Enter group name" required>
          <% } else { %>
            <input type="text" name="groupName" id="confirmedGroup" placeholder="Enter group name" readonly required style="background:#e9ecef;">
          <% } %>
        </div>

        <div style="border: 1px solid var(--border); padding: 12px; border-radius: 10px; margin-bottom: 8px; background: #f8f9fa;">
            <h4 style="margin-top: 0; color: var(--primary); font-size: 0.95rem; margin-bottom: 12px; border-bottom: 2px solid var(--primary); padding-bottom: 8px;">
                <i class="fas fa-user-tie"></i> Group Chairperson
            </h4>
            <label style="margin-top: 0;">Chairperson Phone</label>
            <div class="input-group">
            <i class="fas fa-phone"></i>
            <% if (locals.isCreation) { %>
                <input type="number" name="chairpersonalphonenumber" id="confirmedPhone" placeholder="Enter phone number" required>
            <% } else { %>
                <input type="number" name="chairpersonalphonenumber" id="confirmedPhone" readonly required style="background:#e9ecef;">
            <% } %>
            </div>
            <label>Chairperson Name</label>
            <div class="input-group">
            <i class="fas fa-user"></i>
            <input type="text" id="fullNameInput" placeholder="First Middle Last" required oninput="parseFullName()">
            </div>
            <small style="color:red; font-size:0.7rem; display:none;" id="nameError">Please enter at least 3 names.</small>
            <input type="hidden" name="firstName" id="firstName">
            <input type="hidden" name="secondName" id="secondName">
            <input type="hidden" name="lastName" id="lastName">
        </div>

        <div style="display: flex; gap: 8px; margin-top: 8px;">
            <button type="button" onclick="goBackFromStep1()" style="flex: 1; background: #e2e8f0; color: #333;">
                <i class="fas fa-arrow-left"></i> Back
            </button>
            <button type="button" onclick="nextStep()" style="flex: 1;">
                Next <i class="fas fa-arrow-right"></i>
            </button>
        </div>
      </div>

      <div class="step-box hidden" id="Regions">
        <h3><i class="fas fa-map-marked-alt"></i>Update Group Location</h3>
        <label>County</label>
        <div class="input-group">
          <i class="fas fa-globe-africa"></i>
          <select name="county" id="countySelect" onchange="loadConstituencies()" required>
            <option value="">-- Select County --</option>
          </select>
        </div>
        <label>Constituency</label>
        <div class="input-group">
          <i class="fas fa-map-pin"></i>
          <select name="constituency" id="constituencySelect" onchange="loadWards()" required>
            <option value="">-- Select Constituency --</option>
          </select>
        </div>
        <label>Ward</label>
        <div class="input-group">
          <i class="fas fa-map-marker-alt"></i>
          <select name="ward" id="wardSelect" onchange="checkManualWard()" required>
            <option value="">-- Select Ward --</option>
          </select>
        </div>
        <div id="manualWardContainer" class="hidden" style="margin-top: 8px;">
          <label>Enter Ward Name Manually</label>
          <div class="input-group">
            <i class="fas fa-edit"></i>
            <input type="text" id="manualWardInput" placeholder="Type Ward Name">
          </div>
        </div>
        <div class="button-group">
            <button type="button" onclick="goToStep1()" class="secondary">
                <i class="fas fa-arrow-left"></i> Back
            </button>
            <button type="button" onclick="showMembership()">Next <i class="fas fa-arrow-right"></i></button>
        </div>
      </div>

      <div class="step-box hidden" id="Membership">
        <h3><i class="fas fa-users"></i> Membership Details</h3>
        <div id="trusteesContainer"></div>
        <div id="officialsContainer"></div>
        <div id="membersContainer"></div>
        <div id="inlineSummary" style="margin-top: 15px; margin-bottom: 12px;"></div>
        <div class="button-group">
            <button type="button" onclick="goToStep2()" class="secondary">
                <i class="fas fa-arrow-left"></i> Back
            </button>
            <button type="submit">Submit <i class="fas fa-check-circle"></i></button>
        </div>
      </div>
    </form>
    </div>
  </div>
</div>

<script>
// Global state
let userRoleData = null;
let selectedGroupForPin = null;

function showPhoneInput() {
  const select = document.getElementById("verifyGroup");
  const selectedOption = select.options[select.selectedIndex];
  const group = select.value;
  const isPending = selectedOption ? selectedOption.getAttribute('data-pending') === 'true' : false;
  
  const phoneContainer = document.getElementById("phoneVerifyContainer");
  const pendingNote = document.getElementById("pendingGroupNote");
  
  if (group) {
    phoneContainer.classList.remove("hidden");
    if (isPending) {
      pendingNote.classList.remove("hidden");
    } else {
      pendingNote.classList.add("hidden");
    }
  } else {
    phoneContainer.classList.add("hidden");
    pendingNote.classList.add("hidden");
  }
}

async function verifyChairperson() {
  const phone = document.getElementById("verifyPhone").value;
  const group = document.getElementById("verifyGroup").value;
  const msg = document.getElementById("verifyMsg");
  if (!phone || !group) { msg.textContent = "Please select a group and enter phone."; return; }
  try {
    const res = await fetch("/general/verify", {
      method: "POST", headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ chairpersonalphonenumber: phone, groupName: group })
    });
    const data = await res.json();
    if (data.success) {
      document.getElementById("verificationStep").classList.add("hidden");
      document.getElementById("cAccount").classList.remove("hidden");
      document.getElementById("confirmedPhone").value = phone;
      document.getElementById("confirmedGroup").value = group;
      generateFields("Trustee", data.counts.trustees, "trusteesContainer");
      generateFields("Official", data.counts.officials, "officialsContainer");
      generateFields("Member", data.counts.members, "membersContainer");
      updateProgress(1);
    } else { msg.textContent = data.message || "Verification failed."; }
  } catch (err) { msg.textContent = "Error verifying details."; }
}

function generateFields(label, count, containerId) {
  const container = document.getElementById(containerId);
  container.innerHTML = `<h4>${label}s (${count})</h4>`;
  for (let i = 1; i <= count; i++) {
    const div = document.createElement("div");
    div.className = "input-group";
    div.style.marginBottom = "8px";
    div.innerHTML = `<input type="text" name="${label.toLowerCase()}_${i}" placeholder="${label} ${i} Name" required>`;
    container.appendChild(div);
  }
}

function goBackFromStep1() {
  const verifyStep = document.getElementById("verificationStep");
  if (verifyStep) {
    document.getElementById("cAccount").classList.add("hidden");
    verifyStep.classList.remove("hidden");
    updateProgress(0);
  } else { window.location.href = '/personal'; }
}

function parseFullName() {
  const full = document.getElementById('fullNameInput').value.trim();
  const parts = full.split(/\s+/);
  document.getElementById('firstName').value = parts[0] || '';
  document.getElementById('secondName').value = parts[1] || '';
  document.getElementById('lastName').value = parts.slice(2).join(' ') || '';
}

function nextStep() {
  const stepBox = document.getElementById("cAccount");
  const inputs = stepBox.querySelectorAll("input[required], select[required]");
  let valid = true;
  inputs.forEach(input => { if (!input.checkValidity()) { input.reportValidity(); valid = false; } });
  if (!valid) return;
  document.getElementById("cAccount").classList.add("hidden");
  document.getElementById("Regions").classList.remove("hidden");
  updateProgress(2);
}

function showMembership() {
  document.getElementById("Regions").classList.add("hidden");
  document.getElementById("Membership").classList.remove("hidden");
  updateProgress(3);
  const loc = document.getElementById('countySelect').value + ' / ' + document.getElementById('constituencySelect').value + ' / ' + document.getElementById('wardSelect').value;
  document.getElementById('inlineSummary').innerHTML = '<div style="background:#f8f9fa; padding:10px; border-radius:8px;"><p><b>Group:</b> ' + (document.getElementById('confirmedGroup').value || '-') + '</p><p><b>Location:</b> ' + loc + '</p></div>';
}

function goToStep1() { document.getElementById("Membership").classList.add("hidden"); document.getElementById("cAccount").classList.remove("hidden"); updateProgress(1); }
function goToStep2() { document.getElementById('Membership').classList.add('hidden'); document.getElementById('Regions').classList.remove('hidden'); updateProgress(2); }

function handleGeneralSubmit(event) {
  const wardSelect = document.getElementById("wardSelect");
  if (wardSelect.value === "OTHER") {
    const manualWard = document.getElementById("manualWardInput").value.trim();
    if (!manualWard) { alert("Please enter your ward name."); return false; }
    const opt = document.createElement("option"); opt.value = manualWard; opt.text = manualWard; wardSelect.appendChild(opt); wardSelect.value = manualWard;
  }
  return true;
}

function initCounties() {
  const countySelect = document.getElementById("countySelect");
  if (!countySelect) return;
  countySelect.innerHTML = '<option value="">-- Select County --</option>';
  fetch('/api/locations/counties').then(r => r.json()).then(list => {
    list.forEach(county => {
      const option = document.createElement('option'); option.value = county; option.textContent = county;
      countySelect.appendChild(option);
    });
  });
}

function loadConstituencies() {
  const countySelect = document.getElementById("countySelect");
  const constituencySelect = document.getElementById("constituencySelect");
  const wardSelect = document.getElementById("wardSelect");
  const selectedCounty = countySelect.value;
  constituencySelect.innerHTML = '<option value="">-- Select Constituency --</option>';
  wardSelect.innerHTML = '<option value="">-- Select Ward --</option>';
  if (!selectedCounty) return;
  fetch(`/api/locations/${encodeURIComponent(selectedCounty)}/constituencies`).then(r => r.json()).then(list => {
    list.forEach(cons => {
      const option = document.createElement('option'); option.value = cons; option.textContent = cons;
      constituencySelect.appendChild(option);
    });
  });
}

function loadWards() {
  const countySelect = document.getElementById("countySelect");
  const constituencySelect = document.getElementById("constituencySelect");
  const wardSelect = document.getElementById("wardSelect");
  const selectedCounty = countySelect.value;
  const selectedConstituency = constituencySelect.value;
  wardSelect.innerHTML = '<option value="">-- Select Ward --</option>';
  if (!selectedCounty || !selectedConstituency) return;
  fetch(`/api/locations/${encodeURIComponent(selectedCounty)}/${encodeURIComponent(selectedConstituency)}/wards`).then(r => r.json()).then(list => {
    if (!Array.isArray(list) || list.length === 0) {
      const option = document.createElement('option'); option.value = ''; option.textContent = '(No Wards Listed)'; option.disabled = true;
      wardSelect.appendChild(option); return;
    }
    list.sort().forEach(ward => {
      const option = document.createElement('option'); option.value = ward; option.textContent = ward;
      wardSelect.appendChild(option);
    });
  });
}

document.addEventListener("DOMContentLoaded", () => { initCounties(); updateProgress(1); });

function updateProgress(step) {
  for (let i = 1; i <= 3; i++) {
    const indicator = document.getElementById(`indicator-${i}`);
    if (i < step) { indicator.classList.add('completed'); indicator.classList.remove('active'); }
    else if (i === step) { indicator.classList.add('active'); indicator.classList.remove('completed'); }
    else { indicator.classList.remove('active', 'completed'); }
  }
}

/* ========== TAB SWITCHING ========== */
function switchTab(tab) {
  const mySavingTab = document.getElementById('tabMySaving');
  const createGroupTab = document.getElementById('tabCreateGroup');
  const mySavingSection = document.getElementById('mySavingSection');
  const createGroupContent = document.getElementById('createGroupContent');
  
  if (tab === 'mySaving') {
    mySavingTab.classList.add('active');
    createGroupTab.classList.remove('active');
    mySavingSection.classList.remove('hidden');
    createGroupContent.classList.add('hidden');
    loadUserRoleData();
  } else {
    createGroupTab.classList.add('active');
    mySavingTab.classList.remove('active');
    createGroupContent.classList.remove('hidden');
    mySavingSection.classList.add('hidden');
  }
}

/* ========== MY SAVING FUNCTIONS ========== */
async function loadUserRoleData() {
  const loadingEl = document.getElementById('myGroupsLoading');
  const noGroupsEl = document.getElementById('noGroupsMessage');
  
  // Clean all views
  const views = [
    'accountTypeSelection', 'myAccountView', 'groupAccountView', 
    'pinVerification', 'createPinSection', 'generateKeySection', 
    'pendingGroupView', 'changePinView'
  ];
  views.forEach(id => {
    const el = document.getElementById(id);
    if (el) el.classList.add('hidden');
  });
  
  noGroupsEl.classList.add('hidden');
  loadingEl.classList.remove('hidden');
  
  try {
    const res = await fetch('/general/user-role-type');
    userRoleData = await res.json();
    loadingEl.classList.add('hidden');
    
    if (userRoleData.success && userRoleData.groups && userRoleData.groups.length > 0) {
      showGroupListView();
    } else {
      noGroupsEl.classList.remove('hidden');
    }
  } catch (err) {
    console.error('Error loading role data:', err);
    loadingEl.classList.add('hidden');
    noGroupsEl.classList.remove('hidden');
  }
}

function showGroupListView() {
  const groups = userRoleData.groups || [];
  const container = document.getElementById('groupListContainer');
  const view = document.getElementById('groupAccountView');
  
  // Reset selection
  selectedGroupForPin = null;

  // Show only list
  const views = ['accountTypeSelection', 'myAccountView', 'pinVerification', 'createPinSection', 'generateKeySection', 'pendingGroupView', 'groupContextHeader'];
  views.forEach(id => {
      const el = document.getElementById(id);
      if (el) el.classList.add('hidden');
  });
  
  view.classList.remove('hidden');
  
  let groupHtml = '<p style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 20px; text-align: center;">Choose a group to proceed:</p>';
  
  groups.forEach((group) => {
    const isPending = !group.accountNumber || (parseInt(group.phase) || 1) < 3;
    const roleIcon = group.role === 'trustee' ? 'fa-user-tie' : (group.role === 'official' ? 'fa-user-gear' : 'fa-user');
    const roleColor = group.role === 'trustee' ? '#7c3aed' : '#0891b2';
    
    groupHtml += `
      <div onclick="selectGroupForAccess('${group.groupName}')" style="background: #f8fafc; padding: 16px; border-radius: 14px; margin-bottom: 12px; cursor: pointer; border: 1px solid var(--border); transition: all 0.2s;">
        <div style="display: flex; justify-content: space-between; align-items: center;">
          <div>
            <div style="font-weight: 700; color: var(--text); font-size: 1.05rem; margin-bottom: 4px;">${group.groupName}</div>
            <div style="font-size: 0.75rem; color: ${roleColor}; font-weight: 600; display: flex; align-items: center; gap: 5px;">
              <i class="fas ${roleIcon}"></i> ${group.role.toUpperCase()}
            </div>
          </div>
          <div style="text-align: right;">
            ${isPending 
              ? '<span style="background: #fffbeb; color: #d97706; font-size: 0.65rem; padding: 4px 10px; border-radius: 30px; font-weight: 800; border: 1px solid #fef3c7;">PENDING</span>'
              : '<span style="background: #f0fdf4; color: #16a34a; font-size: 0.65rem; padding: 4px 10px; border-radius: 30px; font-weight: 800; border: 1px solid #dcfce7;">ACTIVE</span>'}
          </div>
        </div>
      </div>
    `;
  });
  
  container.innerHTML = groupHtml;
}

function selectAccountType(type) {
  const selectionDiv = document.getElementById('accountTypeSelection');
  selectionDiv.classList.add('hidden');

  if (type === 'myAccount') {
    document.getElementById('myAccountView').classList.remove('hidden');
  } else if (type === 'changePin') {
    document.getElementById('changePinView').classList.remove('hidden');
  } else if (type === 'groupAccount') {
    // Phase 3 proceed after choices
    const group = userRoleData.groups.find(g => g.groupName === selectedGroupForPin);
    const hasPin = group && group.constitutionStartKey && group.constitutionStartKey.length > 0;
    
    if (hasPin) {
      document.getElementById('pinVerification').classList.remove('hidden');
    } else {
      document.getElementById('createPinSection').classList.remove('hidden');
    }
  }
}

function selectGroupForAccess(groupName) {
  const group = userRoleData.groups.find(g => g.groupName === groupName);
  if (!group) return;
  
  selectedGroupForPin = groupName;
  const isPending = !group.accountNumber || (parseInt(group.phase) || 1) < 3;

  // Clean all views first
  const views = ['accountTypeSelection', 'myAccountView', 'pinVerification', 'createPinSection', 'generateKeySection', 'pendingGroupView', 'groupAccountView', 'groupContextHeader'];
  views.forEach(id => {
      const el = document.getElementById(id);
      if (el) el.classList.add('hidden');
  });

  if (isPending) {
    // Show Pending Note ONLY - Ensure header is hidden
    document.getElementById('pendingGroupView').classList.remove('hidden');
  } else {
    // Populate and Show Group Context Header
    document.getElementById('selectedGroupNameDisplay').textContent = group.groupName;
    document.getElementById('selectedGroupRoleDisplay').textContent = 'Role: ' + group.role.charAt(0).toUpperCase() + group.role.slice(1);
    document.getElementById('groupContextHeader').classList.remove('hidden');

    // Show Account Options (Proceeding)
    document.getElementById('accountTypeSelection').classList.remove('hidden');
    
    // Toggle Group button based on authorization
    const groupBtn = document.getElementById('groupAccountBtn');
    if (group.role === 'trustee' || group.role === 'official') {
        groupBtn.classList.remove('hidden');
    } else {
        groupBtn.classList.add('hidden');
    }
  }
}

function backToAccountSelection() {
  const views = ['myAccountView', 'groupAccountView', 'pinVerification', 'createPinSection', 'generateKeySection', 'changePinView', 'pendingGroupView', 'accountTypeSelection', 'groupContextHeader'];
  views.forEach(id => {
    const el = document.getElementById(id);
    if (el) el.classList.add('hidden');
  });
  
  // New flow: Always go back to the list of groups
  showGroupListView();
}

async function submitChangePinGeneral() {
  const oldPin = document.getElementById('oldPinGeneral2').value;
  const newPin = document.getElementById('newPinGeneral2').value;
  const confirmPin = document.getElementById('confirmPinGeneral2').value;
  const msg = document.getElementById('pinMessage2');
  
  // Validation
  if (!oldPin || oldPin.length < 4) {
    msg.textContent = 'Please enter your current PIN';
    msg.style.color = 'red';
    return;
  }
  if (!newPin || newPin.length < 4) {
    msg.textContent = 'New PIN must be 4 digits';
    msg.style.color = 'red';
    return;
  }
  if (newPin !== confirmPin) {
    msg.textContent = 'PINs do not match';
    msg.style.color = 'red';
    return;
  }
  if (oldPin === newPin) {
    msg.textContent = 'New PIN must be different from current PIN';
    msg.style.color = 'red';
    return;
  }
  
  try {
    const res = await fetch('/personal/change-pin', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ oldPin, newPin })
    });
    
    const result = await res.json();
    if (result.success) {
      msg.textContent = 'PIN changed successfully!';
      msg.style.color = 'green';
      setTimeout(() => {
        backToAccountSelection();
      }, 1500);
    } else {
      msg.textContent = result.message || 'Failed to change PIN';
      msg.style.color = 'red';
    }
  } catch (e) {
    console.error(e);
    msg.textContent = 'Server error occurred';
    msg.style.color = 'red';
  }
}

// Forgot PIN Functions for General New
function showNewPinFormGN() {
  document.getElementById('changePinOptionsGN').classList.add('hidden');
  document.getElementById('newPinFormGN').classList.remove('hidden');
}

function showForgotPinFormGN() {
  document.getElementById('changePinOptionsGN').classList.add('hidden');
  document.getElementById('forgotPinFormGN').classList.remove('hidden');
}

function backToChangePinOptionsGN() {
  document.getElementById('changePinOptionsGN').classList.remove('hidden');
  document.getElementById('newPinFormGN').classList.add('hidden');
  document.getElementById('forgotPinFormGN').classList.add('hidden');
  // Clear inputs
  document.getElementById('oldPinGeneral2').value = '';
  document.getElementById('newPinGeneral2').value = '';
  document.getElementById('confirmPinGeneral2').value = '';
  document.getElementById('pinMessage2').textContent = '';
  document.getElementById('startKeyGN').value = '';
  document.getElementById('resetNewPinGN').value = '';
  document.getElementById('resetConfirmPinGN').value = '';
  document.getElementById('forgotPinMessageGN').textContent = '';
  document.getElementById('startKeyInputGN').classList.add('hidden');
}

async function requestStartKeyGN() {
  const msg = document.getElementById('forgotPinMessageGN');
  // TODO: Integrate with SMS service to send start key
  msg.textContent = 'SMS integration pending. Please contact support for start key.';
  msg.style.color = '#f59e0b';
  // Show the start key input for now
  document.getElementById('startKeyInputGN').classList.remove('hidden');
}

async function submitResetPinGN() {
  const startKey = document.getElementById('startKeyGN').value;
  const newPin = document.getElementById('resetNewPinGN').value;
  const confirmPin = document.getElementById('resetConfirmPinGN').value;
  const msg = document.getElementById('forgotPinMessageGN');
  
  // Validation
  if (!startKey || startKey.length < 4) {
    msg.textContent = 'Please enter the start key from SMS';
    msg.style.color = 'red';
    return;
  }
  if (!newPin || newPin.length < 4) {
    msg.textContent = 'New PIN must be 4 digits';
    msg.style.color = 'red';
    return;
  }
  if (newPin !== confirmPin) {
    msg.textContent = 'PINs do not match';
    msg.style.color = 'red';
    return;
  }
  
  // TODO: Verify start key with backend and reset PIN
  msg.textContent = 'Start key verification integration pending.';
  msg.style.color = '#f59e0b';
}

// Personal PIN Change Functions
function showSetPinForm() {
  document.getElementById('changePinSection').classList.add('hidden');
  document.getElementById('changePinForm').classList.remove('hidden');
}

function showChangePinForm() {
  document.getElementById('changePinSection').classList.add('hidden');
  document.getElementById('changePinForm').classList.remove('hidden');
}

function cancelPinChangeGeneral() {
  document.getElementById('changePinForm').classList.add('hidden');
  document.getElementById('changePinSection').classList.remove('hidden');
  document.getElementById('oldPinGeneral').value = '';
  document.getElementById('newPinGeneral').value = '';
  document.getElementById('confirmPinGeneral').value = '';
  document.getElementById('pinMessage').textContent = '';
}

async function submitPinChangeGeneral() {
  const oldPinField = document.getElementById('oldPinGeneral');
  const oldPin = oldPinField ? oldPinField.value : '';
  const newPin = document.getElementById('newPinGeneral').value;
  const confirmPin = document.getElementById('confirmPinGeneral').value;
  const msg = document.getElementById('pinMessage');
  const hasPersonalPin = oldPinField !== null && oldPinField !== undefined;
  
  // Validation
  if (hasPersonalPin && (!oldPin || oldPin.length < 4)) {
    msg.textContent = 'Please enter your current PIN';
    msg.style.color = 'red';
    return;
  }
  if (!newPin || newPin.length < 4) {
    msg.textContent = 'New PIN must be 4 digits';
    msg.style.color = 'red';
    return;
  }
  if (newPin !== confirmPin) {
    msg.textContent = 'PINs do not match';
    msg.style.color = 'red';
    return;
  }
  if (hasPersonalPin && oldPin === newPin) {
    msg.textContent = 'New PIN must be different from current PIN';
    msg.style.color = 'red';
    return;
  }
  
  try {
    let res;
    if (hasPersonalPin) {
      // Change existing PIN
      res = await fetch('/personal/change-pin', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ oldPin, newPin })
      });
    } else {
      // Set new PIN
      res = await fetch('/personal/set-pin', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ pin: newPin })
      });
    }
    
    const result = await res.json();
    if (result.success) {
      msg.textContent = hasPersonalPin ? 'PIN changed successfully!' : 'PIN set successfully!';
      msg.style.color = 'green';
      setTimeout(() => {
        cancelPinChangeGeneral();
        location.reload();
      }, 1500);
    } else {
      msg.textContent = result.message || 'Failed to save PIN';
      msg.style.color = 'red';
    }
  } catch (e) {
    console.error(e);
    msg.textContent = 'Server error occurred';
    msg.style.color = 'red';
  }
}

async function verifyGroupPin() {
  const pin = document.getElementById('groupPinInput').value;
  const msg = document.getElementById('pinVerifyMsg');
  
  if (!pin || pin.length < 4) {
    msg.textContent = "Please enter a valid 4-6 digit Constitution Key.";
    return;
  }
  
  try {
    const res = await fetch("/general/verify-pin", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ groupName: selectedGroupForPin, pin: pin })
    });
    const data = await res.json();
    
    if (data.success) {
      document.getElementById('pinVerification').classList.add('hidden');
      // Find the group object to pass to view
      const group = userRoleData.groups.find(g => g.groupName === selectedGroupForPin);
      showGroupAccountView(group);
    } else {
      msg.textContent = data.message || "Invalid Constitution Key.";
    }
  } catch (err) {
    msg.textContent = "Error verifying key.";
  }
}

function showGenerateKey() {
  document.getElementById('pinVerification').classList.add('hidden');
  document.getElementById('generateKeySection').classList.remove('hidden');
  document.getElementById('generateKeyMsg').textContent = '';
}

function backToPinVerify() {
  document.getElementById('generateKeySection').classList.add('hidden');
  document.getElementById('createPinSection').classList.add('hidden');
  document.getElementById('pinVerification').classList.remove('hidden');
}

async function createNewPin() {
  const newPin = document.getElementById('newPinInput').value;
  const confirmPin = document.getElementById('confirmPinInput').value;
  const msg = document.getElementById('createPinMsg');
  
  if (!newPin || newPin.length < 4) {
    msg.textContent = "Please enter a valid 4-6 digit Constitution Key.";
    return;
  }
  
  if (newPin !== confirmPin) {
    msg.textContent = "PINs do not match. Please try again.";
    return;
  }
  
  const groups = userRoleData.groups || [];
  const groupWithAccess = groups.find(g => g.groupName === selectedGroupForPin);
  
  if (!groupWithAccess) {
    msg.textContent = "You are not authorized to create a PIN.";
    return;
  }
  
  try {
    const res = await fetch('/general/generate-key', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ groupName: groupWithAccess.groupName, customKey: newPin })
    });
    const data = await res.json();
    
    if (data.success) {
      msg.style.color = 'var(--primary)';
      msg.innerHTML = '<i class="fas fa-check-circle"></i> PIN set and Security Key generated!';
      
      setTimeout(() => {
        document.getElementById('createPinSection').classList.add('hidden');
        // Update local data so it knows PIN is now set
        groupWithAccess.constitutionStartKey = "****"; 
        showGroupAccountView(groupWithAccess);
      }, 1500);
    } else {
      msg.style.color = 'red';
      msg.textContent = data.message || "Failed to create PIN.";
    }
  } catch (err) {
    msg.style.color = 'red';
    msg.textContent = "Error creating PIN.";
  }
}

async function generateNewKey() {
  const msg = document.getElementById('generateKeyMsg');
  
  const groups = userRoleData.groups || [];
  const groupWithAccess = groups.find(g => g.groupName === selectedGroupForPin);
  
  if (!groupWithAccess) {
    msg.style.color = 'red';
    msg.textContent = "You are not authorized to generate a key.";
    return;
  }
  
  try {
    const res = await fetch('/general/generate-key', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ groupName: groupWithAccess.groupName })
    });
    const data = await res.json();
    
    if (data.success) {
      msg.style.color = 'var(--primary)';
      msg.innerHTML = '<i class="fas fa-check-circle"></i> New key generated: ' + data.newKey + '<br>Sent to chairperson: ' + data.chairpersonPhone;
      
      setTimeout(() => {
        backToPinVerify();
      }, 3000);
    } else {
      msg.style.color = 'red';
      msg.textContent = data.message || "Failed to generate key.";
    }
  } catch (err) {
    msg.style.color = 'red';
    msg.textContent = "Error generating key.";
  }
}

function showGroupAccountView(group) {
  const container = document.getElementById('groupListContainer');
  document.getElementById('groupAccountView').classList.remove('hidden');
  
  const roleIcon = group.role === 'trustee' ? 'fa-user-tie' : 'fa-user-gear';
  const roleColor = group.role === 'trustee' ? '#7c3aed' : '#0891b2';
  
  container.innerHTML = `
    <div style="background: linear-gradient(135deg, #7c3aed, #a78bfa); padding: 20px; border-radius: 12px; color: white; margin-bottom: 20px; text-align: center; box-shadow: 0 10px 15px -3px rgba(124, 58, 237, 0.3);">
      <i class="fas fa-users" style="font-size: 2rem; margin-bottom: 10px;"></i>
      <h3 style="color: white; margin: 0 0 5px; font-size: 1.25rem;">${group.groupName}</h3>
      <p style="margin: 0; opacity: 0.9; font-size: 0.85rem; font-weight: 500;">
        <i class="fas ${roleIcon}"></i> ${group.role.toUpperCase()}
        ${group.accountNumber ? '<br><span style="background:rgba(255,255,255,0.2); padding:2px 8px; border-radius:4px; font-family:monospace; margin-top:5px; display:inline-block;">A/C: ' + group.accountNumber + '</span>' : ''}
      </p>
    </div>
    
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 20px;">
      <button onclick="window.location.href='/personal/send-money?group=' + encodeURIComponent('${group.groupName}')" style="margin-top: 0; flex-direction: column; height: 80px; background: #fff; color: var(--text); border: 1px solid var(--border); font-size: 0.8rem;">
        <i class="fas fa-paper-plane" style="font-size: 1.2rem; color: var(--primary); margin-bottom: 5px;"></i>
        Deposit
      </button>
      <button onclick="alert('Withdrawal coming soon')" style="margin-top: 0; flex-direction: column; height: 80px; background: #fff; color: var(--text); border: 1px solid var(--border); font-size: 0.8rem;">
        <i class="fas fa-hand-holding-dollar" style="font-size: 1.2rem; color: #f59e0b; margin-bottom: 5px;"></i>
        Withdraw
      </button>
      <button onclick="alert('Statement coming soon')" style="margin-top: 0; flex-direction: column; height: 80px; background: #fff; color: var(--text); border: 1px solid var(--border); font-size: 0.8rem;">
        <i class="fas fa-file-invoice-dollar" style="font-size: 1.2rem; color: #0891b2; margin-bottom: 5px;"></i>
        Statement
      </button>
      <button onclick="alert('Member list coming soon')" style="margin-top: 0; flex-direction: column; height: 80px; background: #fff; color: var(--text); border: 1px solid var(--border); font-size: 0.8rem;">
        <i class="fas fa-user-group" style="font-size: 1.2rem; color: #7c3aed; margin-bottom: 5px;"></i>
        Members
      </button>
    </div>
  `;
}
</script>
</body>
</html>
