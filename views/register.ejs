<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Tbank Investment - Registration</title>
  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  
  <style>
    :root {
      --primary: #007bff;
      --primary-dark: #0056b3;
      --secondary: #6c757d;
      --success: #28a745;
      --bg-gradient: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
      --card-bg: #ffffff;
      --text-color: #333;
      --input-bg: #f8f9fa;
      --border-color: #dee2e6;
      --shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    }

    body { 
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; 
      background: var(--bg-gradient);
      display: flex; 
      justify-content: center; 
      align-items: center; 
      min-height: 100vh; 
      margin: 0;
      color: var(--text-color);
      padding: 20px;
    }

    .reg-box { 
      background: var(--card-bg); 
      padding: 40px; 
      border-radius: 20px; 
      width: 100%;
      max-width: 450px; 
      box-shadow: var(--shadow);
      position: relative;
      overflow: visible;
      animation: slideUp 0.6s ease-out;
    }

    .back-btn {
      position: absolute;
      right: 18px;
      top: 18px;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 10px;
      border-radius: 8px;
      background: transparent;
      border: 1px solid rgba(2,6,23,0.04);
      color: var(--primary);
      text-decoration: none;
      font-weight: 600;
      font-size: 13px;
    }
    .back-btn:hover { background: rgba(0,0,0,0.02); }

    @keyframes slideUp {
      from { opacity: 0; transform: translateY(30px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .reg-box h1 { 
      text-align: center; 
      margin: 0 0 10px 0; 
      font-size: 26px; 
      color: var(--primary); 
      font-weight: 700;
      letter-spacing: 0.5px;
    }

    .reg-box h1 i {
      margin-right: 10px;
    }

    .reg-box h2 { 
      text-align: center; 
      margin: 0 0 30px 0; 
      font-size: 16px; 
      font-weight: 500; 
      color: var(--secondary);
    }

    /* Progress Indicator */
    .progress-bar {
      display: flex;
      justify-content: center;
      margin-bottom: 25px;
      gap: 10px;
    }
    .dot {
      width: 10px;
      height: 10px;
      background: #e0e0e0;
      border-radius: 50%;
      transition: background 0.3s;
    }
    .dot.active { background: var(--primary); }

    /* Input Styling */
    .input-group {
      position: relative;
      margin-bottom: 20px;
    }

    .input-group i.icon {
      position: absolute;
      left: 15px;
      top: 50%;
      transform: translateY(-50%);
      color: #aaa;
      font-size: 16px;
      transition: color 0.3s;
    }

    .input-group i.toggle-password {
      position: absolute;
      right: 15px;
      top: 50%;
      transform: translateY(-50%);
      color: #aaa;
      cursor: pointer;
      z-index: 10;
      transition: color 0.3s;
    }
    .input-group i.toggle-password:hover { color: var(--primary); }

    input, select { 
      width: 100%; 
      padding: 14px 14px 14px 45px; 
      border: 1px solid var(--border-color); 
      border-radius: 10px; 
      box-sizing: border-box; 
      font-size: 15px;
      background-color: var(--input-bg);
      color: var(--text-color);
      transition: all 0.3s;
      -webkit-appearance: none; /* make select rendering consistent */
      -moz-appearance: none;
      appearance: none;
    }

    /* Make select options clearly visible */
    select { background-color: #ffffff; color: #0f172a; z-index: 9999; }
    .input-group select { position: relative; z-index: 9999; }
    option { color: #0f172a; background: #ffffff; }

    input:focus, select:focus {
      border-color: var(--primary);
      outline: none;
      background-color: #fff;
      box-shadow: 0 0 0 4px rgba(0, 123, 255, 0.1);
    }

    input:focus + .icon, select:focus + .icon, .input-group:focus-within .icon {
      color: var(--primary);
    }

    /* Buttons */
    button { 
      width: 100%; 
      padding: 15px; 
      background: var(--primary); 
      color: #fff; 
      border: none; 
      border-radius: 10px; 
      cursor: pointer; 
      margin-top: 15px; 
      font-weight: 600;
      font-size: 16px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      transition: all 0.3s;
    }
    button:hover { 
      background: var(--primary-dark); 
      transform: translateY(-2px);
      box-shadow: 0 5px 15px rgba(0, 123, 255, 0.3);
    }
    button:active { transform: translateY(0); }

    /* Radio Buttons */
    .radio-container {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      margin-top: 5px;
    }
    
    .radio-option {
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 12px;
      border: 1px solid var(--border-color);
      border-radius: 10px;
      cursor: pointer;
      transition: all 0.2s;
      font-size: 14px;
      background: var(--input-bg);
    }

    .radio-option:hover {
      background-color: #eaeaea;
    }

    .radio-option input {
      display: none; /* Hide default radio */
    }

    .radio-option.selected {
      border-color: var(--primary);
      background-color: rgba(0, 123, 255, 0.1);
      color: var(--primary);
      font-weight: 600;
    }

    /* Helper Classes */
    .hidden { display: none; }
    .fade-in { animation: fadeIn 0.5s ease-in-out; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

    p { text-align: center; margin-top: 25px; font-size: 0.9em; color: #666; }
    a { color: var(--primary); text-decoration: none; font-weight: 600; }
    a:hover { text-decoration: underline; }
    
    label { 
      display: block; 
      margin-bottom: 8px; 
      font-size: 0.9rem; 
      color: #555; 
      font-weight: 600;
      margin-top: 15px;
    }
    label:first-of-type { margin-top: 0; }
  </style>
</head>
<body>
  <div class="reg-box">
    <a href="/login" class="back-btn"><i class="fa-solid fa-arrow-left"></i> Back</a>
    <h1><i class="fa-solid fa-building-columns"></i> Tbank Investment</h1>
    <h2>Create your account</h2>

    <% if (typeof message !== 'undefined' && message) { %>
      <div style="background:#fff7ed;border:1px solid rgba(245,166,35,0.12);padding:10px;border-radius:8px;margin-bottom:14px;color:#92400e;font-weight:600;text-align:center;"><%= message %></div>
    <% } %>

    <form id="registerForm" action="/register" method="POST" onsubmit="return handleRegisterSubmit(event)">
      <!-- Hidden fields for backend splitting -->
      <input type="hidden" name="FirstName" id="extFirstName">
      <input type="hidden" name="MiddleName" id="extMiddleName">
      <input type="hidden" name="LastName" id="extLastName">

      <!-- Step 1 -->
      <div id="step1" class="form-step">
        <div class="input-group">
          <input type="text" id="fullNameInput" placeholder="Full Name (First, Middle, Last)" required />
          <i class="fa-solid fa-user icon"></i>
        </div>

        <div class="input-group">
          <input type="email" name="email" placeholder="Email Address" required />
          <i class="fa-solid fa-envelope icon"></i>
        </div>

        <div class="input-group">
          <input type="password" id="password" name="password" placeholder="Password" required />
          <i class="fa-solid fa-lock icon"></i>
          <i class="fa-solid fa-eye-slash toggle-password" onclick="togglePassword('password', this)"></i>
        </div>

        <div class="input-group">
          <input type="password" id="confirmPassword" placeholder="Confirm Password" required />
          <i class="fa-solid fa-lock icon"></i>
          <i class="fa-solid fa-eye-slash toggle-password" onclick="togglePassword('confirmPassword', this)"></i>
        </div>

        <div class="input-group">
          <input type="number" name="phoneNumber" placeholder="Phone Number" required value="<%= (form && form.phoneNumber) ? form.phoneNumber : '' %>" />
          <i class="fa-solid fa-phone icon"></i>
        </div>

        <div class="input-group">
          <input type="text" name="idNumber" placeholder="ID Number" />
          <i class="fa-solid fa-id-card icon"></i>
        </div>

        <div class="input-group">
          <select name="gender" id="genderSelect" required>
            <option value="" disabled selected>Select Gender</option>
            <option value="Male">Male</option>
            <option value="Female">Female</option>
            <option value="Other">Other</option>
          </select>
          <i class="fa-solid fa-venus-mars icon"></i>
        </div>

        <div style="display:flex; gap:10px; justify-content:flex-end; margin-top:8px;">
          <button type="button" id="nextBtn" class="" onclick="goToStep(2)">Next</button>
        </div>
      </div>

      <!-- Step 2 -->
      <div id="step2" class="form-step hidden">

        <div>
          <label>County</label>
          <div class="input-group">
            <i class="fa-solid fa-globe-africa icon"></i>
            <select name="county" id="countySelect" onchange="loadConstituencies()" onfocus="initCounties()" onclick="initCounties()" required>
              <option value="" disabled selected>-- Select County --</option>
              <!-- Populated by JS -->
            </select>
          </div>
        </div>

        <div>
          <label>Constituency</label>
          <div class="input-group">
            <i class="fa-solid fa-map-pin icon"></i>
            <select name="constituency" id="constituencySelect" onchange="loadWards()" onfocus="loadConstituencies()" onclick="loadConstituencies()" required>
              <option value="" disabled selected>-- Select Constituency --</option>
            </select>
          </div>
        </div>

        <div>
          <label>Ward</label>
          <div class="input-group">
            <i class="fa-solid fa-map-marker-alt icon"></i>
            <select name="ward" id="wardSelect" onfocus="loadWards()" onclick="loadWards()" required>
              <option value="" disabled selected>-- Select Ward --</option>
            </select>
          </div>
        </div>

        <div>
          <label>Age Bracket</label>
          <div class="radio-container">
            <label class="radio-option">
              <input type="radio" name="ageBracket" value="18-25" required onclick="highlightRadio(this)"> 
              <span>18 – 25</span>
            </label>
            <label class="radio-option">
              <input type="radio" name="ageBracket" value="26-35" onclick="highlightRadio(this)"> 
              <span>26 – 35</span>
            </label>
            <label class="radio-option">
              <input type="radio" name="ageBracket" value="36-45" onclick="highlightRadio(this)"> 
              <span>36 – 45</span>
            </label>
            <label class="radio-option">
              <input type="radio" name="ageBracket" value="46+" onclick="highlightRadio(this)"> 
              <span>46+</span>
            </label>
          </div>
        </div>

        <div style="display:flex; gap:10px; justify-content:space-between; margin-top:12px;">
          <button type="button" onclick="goToStep(1)" class="secondary-btn">Previous</button>
          <button type="submit">Complete Registration <i class="fa-solid fa-check-circle"></i></button>
        </div>
      </div>
    </form>

    <p>Already have an account? <a href="/login">Login</a></p>
  </div>

  <script>
    // === PASSWORD TOGGLE LOGIC ===
    function togglePassword(inputId, icon) {
      const input = document.getElementById(inputId);
      const isPassword = input.type === "password";
      input.type = isPassword ? "text" : "password";
      icon.classList.toggle("fa-eye-slash", !isPassword);
      icon.classList.toggle("fa-eye", isPassword);
    }

    // === FORM SUBMISSION LOGIC ===
    function handleRegisterSubmit(event) {
      const form = event.target;
      
      // Password Match Check
      const password = document.getElementById("password").value;
      const confirmPassword = document.getElementById("confirmPassword").value;
      
      if (password !== confirmPassword) {
        alert("Passwords do not match!");
        document.getElementById("confirmPassword").focus();
        event.preventDefault();
        return false;
      }

      // Populate hidden fields for backend
      const fullName = document.getElementById("fullNameInput").value.trim();
      const nameParts = fullName.split(/\s+/);
      
      let firstName = nameParts[0] || "";
      let middleName = "";
      let lastName = "";

      if (nameParts.length === 2) {
        lastName = nameParts[1];
      } else if (nameParts.length > 2) {
        middleName = nameParts.slice(1, -1).join(" ");
        lastName = nameParts[nameParts.length - 1];
      }

      document.getElementById("extFirstName").value = firstName;
      document.getElementById("extMiddleName").value = middleName;
      document.getElementById("extLastName").value = lastName;

      // No manual ward option: ward must be selected from list
      const wardSelect = document.getElementById("wardSelect");
      if (!wardSelect.value) {
        alert('Please select a ward from the list.');
        event.preventDefault();
        return false;
      }

      return true; // Allow submission
    }

    // Manual ward entry removed — users must select a ward from the list

    // Initialize on load
    window.onload = function() {
      initCounties();
      // radio highlight handler
      document.querySelectorAll('.radio-option input').forEach(i => i.addEventListener('change', function(){ highlightRadio(this); }));
    };

    // === RADIO HIGHLIGHT LOGIC ===
    function highlightRadio(radioInput) {
      document.querySelectorAll('.radio-option').forEach(opt => opt.classList.remove('selected'));
      radioInput.parentElement.classList.add('selected');
    }

    // Fetch counties from API
    function initCounties() {
      const countySelect = document.getElementById("countySelect");
      if(!countySelect) return;
      if (countySelect.options.length > 1) return;
      fetch('/api/locations/counties')
        .then(r => r.json())
        .then(list => {
          list.forEach(county => {
            const option = document.createElement('option');
            option.value = county;
            option.textContent = county;
            countySelect.appendChild(option);
          });
        }).catch(err => console.error('Failed to load counties', err));
    }

    // Load constituencies via API
    function loadConstituencies() {
      const countySelect = document.getElementById("countySelect");
      const constituencySelect = document.getElementById("constituencySelect");
      const wardSelect = document.getElementById("wardSelect");
      if(!constituencySelect) return;
      if (constituencySelect.options.length > 1) return;
      const selectedCounty = countySelect ? countySelect.value : '';

      constituencySelect.innerHTML = '<option value="" disabled selected>-- Select Constituency --</option>';
      wardSelect.innerHTML = '<option value="" disabled selected>-- Select Ward --</option>';

      if (!selectedCounty) return;
      fetch(`/api/locations/${encodeURIComponent(selectedCounty)}/constituencies`)
        .then(r => r.json())
        .then(list => {
          list.forEach(cons => {
            const option = document.createElement('option');
            option.value = cons;
            option.textContent = cons;
            constituencySelect.appendChild(option);
          });
        }).catch(err => console.error('Failed to load constituencies', err));
    }

    function loadWards() {
      const countySelect = document.getElementById("countySelect");
      const constituencySelect = document.getElementById("constituencySelect");
      const wardSelect = document.getElementById("wardSelect");
      if(!wardSelect) return;
      if (wardSelect.options.length > 1) return;

      const selectedCounty = countySelect ? countySelect.value : '';
      const selectedConstituency = constituencySelect ? constituencySelect.value : '';

      // Clear previous options
      wardSelect.innerHTML = '<option value="" disabled selected>-- Select Ward --</option>';

      if (!selectedCounty || !selectedConstituency) return;

      fetch(`/api/locations/${encodeURIComponent(selectedCounty)}/${encodeURIComponent(selectedConstituency)}/wards`)
        .then(r => r.json())
        .then(list => {
          if (!Array.isArray(list) || list.length === 0) {
            const option = document.createElement('option');
            option.value = '';
            option.textContent = '(No Wards Listed)';
            option.disabled = true;
            wardSelect.appendChild(option);
            return;
          }
          list.sort().forEach(ward => {
            const option = document.createElement('option');
            option.value = ward;
            option.textContent = ward;
            wardSelect.appendChild(option);
          });
        }).catch(err => console.error('Failed to load wards', err));
      }
  </script>
    <script>
      // Simple step controller
      function goToStep(n) {
        const step1 = document.getElementById('step1');
        const step2 = document.getElementById('step2');
        if (n === 2) {
          // validate step1 required fields
          const full = document.getElementById('fullNameInput').value.trim();
          const email = document.querySelector('input[name="email"]').value.trim();
          const pwd = document.getElementById('password').value;
          const conf = document.getElementById('confirmPassword').value;
          const phone = document.querySelector('input[name="phoneNumber"]').value.trim();
          const gender = document.getElementById('genderSelect').value;
          if (!full || !email || !pwd || !conf || !phone || !gender) {
            alert('Please fill all required fields on this step.');
            return false;
          }
          if (pwd !== conf) { alert('Passwords do not match'); return false; }
          step1.classList.add('hidden'); step2.classList.remove('hidden');
          return true;
        }
        // n === 1
        step2.classList.add('hidden'); step1.classList.remove('hidden');
        return true;
      }
    </script>
</body>
</html>
