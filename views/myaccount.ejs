<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Groups</title>
    <!-- FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #4f46e5;
            --primary-hover: #4338ca;
            --bg-body: #f1f5f9;
            --bg-card: #ffffff;
            --text-main: #1e293b;
            --text-muted: #64748b;
            --border: #e2e8f0;
            --shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
            --radius: 0.75rem;
        }
        body {
            background-color: var(--bg-body);
            color: var(--text-main);
            font-family: 'Inter', sans-serif;
            margin: 0;
            padding: 1rem;
        }
        main {
            max-width: 700px;
            margin: 0 auto;
        }
        h1 {
            text-align: center;
            margin-bottom: 2rem;
            color: var(--text-main);
            font-weight: 700;
        }
        .group-card {
            background: var(--bg-card);
            padding: 1.5rem;
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            border: 1px solid var(--border);
            margin-bottom: 1rem;
        }
        .group-card h2 {
            margin: 0 0 1rem;
            font-size: 1.25rem;
            color: var(--primary);
        }
        .group-details p {
            margin: 0.5rem 0;
            color: var(--text-muted);
        }
        .group-details span {
            font-weight: 600;
            color: var(--text-main);
        }
        .no-groups {
            text-align: center;
            padding: 2rem;
            background: var(--bg-card);
            border-radius: var(--radius);
        }
        .alert {
            padding: 1rem;
            margin-bottom: 1rem;
            border-radius: var(--radius);
            background-color: #e0f2fe;
            color: #0c5464;
            border: 1px solid #b3e0ff;
        }
         .btn-primary {
            display: inline-block;
            margin-top: 1rem;
            padding: 0.75rem 1.5rem;
            background-color: var(--primary);
            color: white;
            text-decoration: none;
            border-radius: 0.5rem;
            font-weight: 600;
            transition: background-color 0.2s;
        }
        .btn-primary:hover {
            background-color: var(--primary-hover);
        }
    </style>
</head>
<body>
    <main>
        <h1>My Group Accounts</h1>

        <% if (alert) { %>
            <div class="alert">
                <%= alert %>
            </div>
        <% } %>

        <% if (groups && groups.length > 0) { %>
            <% groups.forEach(function(group) { %>
                <div class="group-card">
                    <h2><a href="/personal/group/<%= encodeURIComponent(group.groupName) %>"><%= group.groupName %></a></h2>
                    <div class="group-details">
                        <p>Chairperson: <span><%= group.firstName %> <%= group.lastName %></span></p>
                        
                        <p>Created At: <span><%= new Date(group.createdAt).toLocaleDateString() %></span></p>
                    </div>
                </div>
            <% }); %>
        <% } else { %>
            <div class="no-groups">
                <p>You are not yet part of any group.</p>
                <a href="/personal/general?mode=create" class="btn-primary">Create a Group</a>
            </div>
        <% } %>
    </main>
</body>
</html>
