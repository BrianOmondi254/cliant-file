<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Group Details</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        /* CSS matched to general.ejs */
        :root {
            --primary: #0f9d58;
            --primary-dark: #0b7d46;
            --bg: #f1f5f9;
            --card: #ffffff;
            --text: #1e293b;
            --text-muted: #64748b;
            --border: #e2e8f0;
            --focus-ring: rgba(15, 157, 88, 0.15);
            --danger: #ef4444;
            --success: #10b981;
        }
        * { box-sizing: border-box; }
        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(160deg, #0f2027, #203a43, #2c5364);
            display: flex; justify-content: center; align-items: flex-start;
            min-height: 100vh; margin: 0; padding: 20px;
        }
        .main-container {
            width: 95%; max-width: 420px; background: var(--card);
            border-radius: 22px; box-shadow: 0 25px 60px rgba(0, 0, 0, 0.35);
            overflow: hidden; animation: slideUp 0.5s ease-out;
        }
        @keyframes slideUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .header-section {
            background: linear-gradient(135deg, #0f9d58, #34d399);
            padding: 20px; color: white; position: relative;
            overflow: hidden; text-align: center;
        }
        .header-section::before {
            content: ''; position: absolute; top: -50%; right: -20%;
            width: 300px; height: 300px; background: rgba(255, 255, 255, 0.1);
            border-radius: 50%;
        }
        .header-content { position: relative; z-index: 1; text-align: center; }
        .header-content h2 { margin: 0 0 5px; font-size: 1.4rem; font-weight: 700; }
        .header-content p { margin: 0; opacity: 0.9; font-size: 0.8rem; }

        .tab-navigation {
            display: flex; background: #f8fafc; border-bottom: 1px solid var(--border);
            padding: 0 10px;
        }
        .tab-button {
            flex: 1; padding: 14px 10px; background: none; border: none;
            font-size: 0.85rem; font-weight: 600; color: var(--text-muted);
            cursor: pointer; position: relative; transition: all 0.3s ease;
            display: flex; align-items: center; justify-content: center; gap: 6px;
        }
        .tab-button:hover { color: var(--primary); background: rgba(34, 197, 94, 0.05); }
        .tab-button.active { color: var(--primary); }
        .tab-button.active::after {
            content: ''; position: absolute; bottom: 0; left: 0; width: 100%;
            height: 3px; background: var(--primary); border-radius: 3px 3px 0 0;
        }
        
        .step-box {
            padding: 20px;
            animation: fade 0.5s ease-out;
        }
        @keyframes fade {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        h3 { margin: 0 0 15px; text-align: center; color: var(--text); font-weight: 700; font-size: 1.2rem; }
        
        .info-item { margin-bottom: 15px; }
        .info-label { display: block; font-size: 0.8rem; color: var(--text-muted); margin-bottom: 5px; font-weight: 600; }
        .form-input {
            width: 100%; padding: 12px; border-radius: 10px;
            border: 1.5px solid var(--border); font-size: 13px;
            outline: none; transition: all 0.3s;
        }
        .form-input:focus { border-color: var(--primary); box-shadow: 0 0 0 4px var(--focus-ring); }
        
        .action-button {
            width: 100%; padding: 12px; margin-bottom: 10px; font-size: 0.9rem;
            font-weight: 600; border: none; border-radius: 10px; cursor: pointer;
            background: var(--primary); color: white; transition: all 0.3s ease;
            display: flex; align-items: center; justify-content: center; gap: 8px;
            text-decoration: none;
        }
        .action-button:hover { background: var(--primary-dark); transform: translateY(-2px); }

        .btn-disabled {
            opacity: 0.6;
            cursor: not-allowed;
            pointer-events: none;
            background-color: var(--text-muted) !important;
        }
        
        .hidden { display: none; }
        
        .back-nav {
            position: absolute; left: 15px; top: 20px; z-index: 10;
            color: white; font-size: 1.2rem; cursor: pointer;
        }
    </style>
</head>
<body>
    <div class="main-container">
        <% if (group) { %>
            <div class="header-section">
                <a href="/personal/myaccount" class="back-nav"><i class="fas fa-arrow-left"></i></a>
                <div class="header-content">
                    <h2><i class="fas fa-users"></i> <%= group.groupName %></h2>
                    <p>
                        <% if (group.phase) { %>
                            Phase <%= group.phase %>
                        <% } else { %>
                            Active
                        <% } %>
                    </p>
                </div>
            </div>

            <div class="tab-navigation">
                <button class="tab-button active" id="tabMyAccount" onclick="switchTab('myAccount')">
                    <i class="fas fa-user-circle"></i> My Account
                </button>
                <% if (userRole === 'official' || userRole === 'trustee') { %>
                <button class="tab-button" id="tabGroupAccount" onclick="switchTab('groupAccount')">
                    <i class="fas fa-building-columns"></i> Group Account
                </button>
                <% } %>
            </div>

            <!-- MY ACCOUNT SECTION -->
            <div id="myAccountSection" class="step-box">
                <div style="text-align: center; margin-bottom: 20px;">
                    <p style="color: var(--text-muted); font-size: 0.9rem;">
                        Manage your personal contributions and loans.
                    </p>
                </div>
                
                <a href="#" class="action-button <%= userRole === 'member' ? 'btn-disabled' : '' %>">
                    <i class="fas fa-hand-holding-usd"></i> Contribution
                </a>
                <a href="#" class="action-button <%= userRole === 'member' ? 'btn-disabled' : '' %>">
                    <i class="fas fa-money-bill-wave"></i> Loan
                </a>
                <a href="#" class="action-button <%= userRole === 'member' ? 'btn-disabled' : '' %>">
                    <i class="fas fa-id-card"></i> Membership
                </a>
                <a href="#" class="action-button <%= userRole === 'member' ? 'btn-disabled' : '' %>">
                    <i class="fas fa-file-invoice"></i> Account Details
                </a>

                <% if (userRole === 'member') { %>
                    <p style="font-size: 0.8rem; color: var(--danger); margin-top: 15px; text-align: center;">
                        <i class="fas fa-lock"></i> Member access is currently read-only.
                    </p>
                <% } %>
            </div>

            <!-- GROUP ACCOUNT SECTION -->
            <% if (userRole === 'official' || userRole === 'trustee') { %>
            <div id="groupAccountSection" class="step-box hidden">
                <!-- Step 1: Verification -->
                <div id="ga-step-verify">
                    <div style="text-align: center; margin-bottom: 20px;">
                        <i class="fas fa-shield-alt" style="font-size: 3rem; color: var(--primary); margin-bottom: 10px;"></i>
                        <h3 style="margin: 0;">Security Check</h3>
                        <p style="color: var(--text-muted); font-size: 0.9rem;">Enter Constitution Key to access.</p>
                    </div>
                    
                    <div class="info-item">
                        <span class="info-label">Constitution Key</span>
                        <input type="password" id="constitutionKeyInput" class="form-input" placeholder="Enter Key">
                    </div>
                    <button onclick="verifyConstitutionKey()" class="action-button">
                        Verify Access
                    </button>
                    <p id="verifyError" style="color: var(--danger); margin-top: 10px; display: none; text-align: center;">Incorrect Key.</p>
                </div>

                <!-- Step 2: PIN Creation -->
                <div id="ga-step-pin" class="hidden">
                    <div style="text-align: center; margin-bottom: 20px;">
                        <i class="fas fa-check-circle" style="color: var(--success); font-size: 3rem; margin-bottom: 10px;"></i>
                        <h3 style="margin: 0;">Access Granted</h3>
                        <p style="color: var(--text-muted); font-size: 0.9rem;">Create a secure PIN for this Group.</p>
                    </div>
                    
                    <div class="info-item">
                        <span class="info-label">New PIN</span>
                        <input type="password" id="newGroupPin" class="form-input" placeholder="****" maxlength="4">
                    </div>
                    <div class="info-item">
                        <span class="info-label">Confirm PIN</span>
                        <input type="password" id="confirmGroupPin" class="form-input" placeholder="****" maxlength="4">
                    </div>
                    
                    <button id="submitPinBtn" onclick="submitGroupPin()" class="action-button" style="background-color: var(--success);">
                        Create PIN & Generate Key
                    </button>
                </div>
            </div>
            <% } %>

        <% } else { %>
            <div class="step-box" style="text-align: center;">
                <i class="fas fa-exclamation-circle" style="font-size: 3rem; color: var(--text-muted); margin-bottom: 15px;"></i>
                <h3>Group Not Found</h3>
                <a href="/personal/myaccount" class="action-button" style="background: var(--text-muted);">Back</a>
            </div>
        <% } %>
    </div>

    <script>
        // Store the correct key from server-side (only available if authorized)
        const correctKey = "<%= (userRole === 'official' || userRole === 'trustee') ? (group.constitutionStartKey || '') : '' %>";

        function switchTab(tab) {
            const myAccountTab = document.getElementById('tabMyAccount');
            const groupAccountTab = document.getElementById('tabGroupAccount');
            const myAccountSection = document.getElementById('myAccountSection');
            const groupAccountSection = document.getElementById('groupAccountSection');

            if (tab === 'myAccount') {
                myAccountTab.classList.add('active');
                if(groupAccountTab) groupAccountTab.classList.remove('active');
                myAccountSection.classList.remove('hidden');
                if(groupAccountSection) groupAccountSection.classList.add('hidden');
            } else {
                if(groupAccountTab) groupAccountTab.classList.add('active');
                myAccountTab.classList.remove('active');
                if(groupAccountSection) groupAccountSection.classList.remove('hidden');
                myAccountSection.classList.add('hidden');
            }
        }

        function verifyConstitutionKey() {
            const input = document.getElementById('constitutionKeyInput').value.trim();
            const errorMsg = document.getElementById('verifyError');
            
            // Fast verify against the key rendered in the template
            if (input && input === correctKey) {
                errorMsg.style.display = 'none';
                document.getElementById('ga-step-verify').classList.add('hidden');
                document.getElementById('ga-step-pin').classList.remove('hidden');
            } else {
                errorMsg.style.display = 'block';
            }
        }

        function submitGroupPin() {
            const btn = document.getElementById('submitPinBtn');
            // As requested: "the submit button should display to bencontinued soon"
            btn.innerText = "To be continued soon";
            btn.disabled = true;
            btn.style.opacity = "0.7";
            btn.style.cursor = "default";
        }
    </script>
</body>
</html>
