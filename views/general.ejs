<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>General Account</title>
<!-- Font Awesome -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
:root {
  --primary: #28a745;
  --primary-dark: #218838;
  --bg: #eceff1;
  --card: #ffffff;
  --text: #333;
  --text-muted: #666;
  --border: #ddd;
  --focus-ring: rgba(40, 167, 69, 0.25);
}

* {
  box-sizing: border-box;
}

body {
  font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
  background: var(--bg);
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 100vh;
  margin: 0;
  padding: 20px;
}

.form-wrapper {
  width: 100%;
  max-width: 420px;
}

.step-box {
  background: var(--card);
  padding: 40px 30px;
  border-radius: 16px;
  box-shadow: 0 15px 35px rgba(0,0,0,0.1);
  animation: fade 0.5s ease-out;
}

@keyframes fade {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}

h3 {
  margin: 0 0 25px;
  text-align: center;
  color: var(--text);
  font-weight: 600;
  font-size: 1.5rem;
}

h3 i {
  color: var(--primary);
  margin-right: 10px;
}

label {
  display: block;
  font-size: 0.9rem;
  margin-bottom: 8px;
  margin-top: 16px;
  color: var(--text);
  font-weight: 500;
}

.input-group {
  position: relative;
}

.input-group i {
  position: absolute;
  left: 14px;
  top: 50%;
  transform: translateY(-50%);
  color: var(--text-muted);
  font-size: 1rem;
  pointer-events: none;
  transition: color 0.3s ease;
}

input, select {
  width: 100%;
  padding: 12px 12px 12px 42px; /* Left padding for icon */
  border-radius: 8px;
  border: 1px solid var(--border);
  font-size: 1rem;
  color: var(--text);
  background-color: #fafafa;
  transition: all 0.3s ease;
}

input:focus, select:focus {
  outline: none;
  border-color: var(--primary);
  box-shadow: 0 0 0 4px var(--focus-ring);
  background-color: #fff;
}

input:focus + i, select:focus + i,
.input-group:focus-within i {
  color: var(--primary);
}

button {
  width: 100%;
  padding: 14px;
  margin-top: 30px;
  font-size: 1rem;
  font-weight: 600;
  border: none;
  border-radius: 8px;
  cursor: pointer;
  background: var(--primary);
  color: white;
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
}

button:hover {
  background: var(--primary-dark);
  transform: translateY(-2px);
  box-shadow: 0 5px 15px rgba(40, 167, 69, 0.3);
}

button:active {
  transform: translateY(0);
}

/* Hide step by default */
.hidden {
  display: none;
}
</style>
</head>

<body>

<div class="form-wrapper">
  
  <div class="view-selector" style="display: flex; gap: 10px; margin-bottom: 20px;">
    <a href="/general?view=my_groups" style="flex: 1; text-align: center; padding: 12px; border-radius: 8px; background: <%= locals.view === 'my_groups' ? 'var(--primary)' : '#fff' %>; color: <%= locals.view === 'my_groups' ? '#fff' : 'var(--primary)' %>; border: 1px solid var(--primary); text-decoration: none; font-weight: 600; font-size: 0.9rem;">
      <i class="fas fa-user-circle"></i> My Groups Account
    </a>
    <a href="/general" style="flex: 1; text-align: center; padding: 12px; border-radius: 8px; background: <%= !locals.view ? 'var(--primary)' : '#fff' %>; color: <%= !locals.view ? '#fff' : 'var(--primary)' %>; border: 1px solid var(--primary); text-decoration: none; font-weight: 600; font-size: 0.9rem;">
      <i class="fas fa-plus-circle"></i> Create Group Account
    </a>
  </div>

  <% if (locals.view === 'my_groups') { %>
    <div class="step-box" id="myGroupsView">
      <h3><i class="fas fa-users"></i> My Created Groups</h3>
      <% if (groups && groups.length > 0) { %>
        <ul style="list-style-type: none; padding: 0; margin-top: 20px;">
          <% groups.forEach(function(group) { %>
            <li style="background: #f8f9fa; padding: 15px; border-radius: 8px; margin-bottom: 10px; border-left: 5px solid var(--primary); display: flex; align-items: center;">
              <i class="fas fa-users" style="color: var(--primary); margin-right: 15px;"></i>
              <strong style="font-size: 1.1rem; color: var(--text);"><%= group.groupName %></strong>
            </li>
          <% }); %>
        </ul>
      <% } else { %>
        <p style="text-align: center; color: var(--text-muted); padding: 20px 0;">You have not created any groups yet.</p>
      <% } %>
    </div>
  <% } else { %>
    <form action="/general" method="POST" onsubmit="return handleGeneralSubmit(event)">
      <!-- STEP 0: VERIFICATION (Only if NOT creating directly) -->
      <% if (!locals.isCreation) { %>
      <div class="step-box" id="verificationStep">
        <h3><i class="fas fa-user-check"></i> Agent Verification</h3>
        
        <label>Select Group Name</label>
        <div class="input-group">
          <i class="fas fa-users"></i>
          <select id="verifyGroup" onchange="showPhoneInput()">
            <option value="" disabled selected>-- Select Group --</option>
            <% if (locals.groups && groups.length > 0) { %>
              <% groups.forEach(function(group) { %>
                <option value="<%= group.groupName %>"><%= group.groupName %></option>
              <% }); %>
            <% } else { %>
              <option value="" disabled>No groups found. Debug: <%= locals.debugMsg %></option>
            <% } %>
          </select>
        </div>

        <div id="phoneVerifyContainer" class="hidden">
          <label>Enter Chairperson Phone Number</label>
          <div class="input-group">
            <i class="fas fa-phone"></i>
            <input type="number" id="verifyPhone" placeholder="07XX XXX XXX">
          </div>
          <button type="button" onclick="verifyChairperson()">Verify <i class="fas fa-search"></i></button>
        </div>
        
        <p id="verifyMsg" style="color: red; text-align: center; margin-top: 10px;"></p>
      </div>
      <% } %>

      <!-- STEP 1 (Shown directly if isCreation is true) -->
      <div class="step-box <%= locals.isCreation ? '' : 'hidden' %>" id="cAccount">
        <h3><i class="fas fa-users-cog"></i>Create Group Account</h3>

        <label>Group Name</label>
        <div class="input-group" style="margin-bottom: 15px;">
          <i class="fas fa-users"></i>
          <% if (locals.isCreation) { %>
            <input type="text" name="groupName" id="confirmedGroup" placeholder="Enter group name" required>
          <% } else { %>
            <input type="text" name="groupName" id="confirmedGroup" placeholder="Enter group name" readonly required style="background:#e9ecef;">
          <% } %>
        </div>

        <div style="border: 1px solid var(--border); padding: 20px; border-radius: 12px; margin-bottom: 10px; background: #f8f9fa;">
            <h4 style="margin-top: 0; color: var(--primary); font-size: 1.1rem; margin-bottom: 20px; border-bottom: 2px solid var(--primary); padding-bottom: 10px; font-weight: 700;">
                <i class="fas fa-user-tie"></i> Group Chairperson
            </h4>

            <label style="margin-top: 0;">Chairperson Phone</label>
            <div class="input-group">
            <i class="fas fa-phone"></i>
            <% if (locals.isCreation) { %>
                <input type="number" name="chairpersonalphonenumber" id="confirmedPhone" placeholder="Enter phone number" required>
            <% } else { %>
                <input type="number" name="chairpersonalphonenumber" id="confirmedPhone" readonly required style="background:#e9ecef;">
            <% } %>
            </div>

            <label>Chairperson Name (Enter First, Middle & Last Name)</label>
            <div class="input-group">
            <i class="fas fa-user"></i>
            <input type="text" id="fullNameInput" placeholder="First Middle Last" required oninput="parseFullName()">
            </div>
            <small style="color:red; font-size:0.8rem; display:none;" id="nameError">Please enter at least 3 names separated by spaces.</small>
            
            <!-- Hidden fields for backend compatibility -->
            <input type="hidden" name="firstName" id="firstName">
            <input type="hidden" name="secondName" id="secondName">
            <input type="hidden" name="lastName" id="lastName">
        </div>

        <div style="display: flex; gap: 10px; margin-top: 10px;">
            <button type="button" onclick="goBackFromStep1()" style="flex: 1; background: #e2e8f0; color: #333; border: 1px solid #cbd5e1; justify-content: center; padding: 8px; font-size: 0.85rem;">
                <i class="fas fa-arrow-left"></i> Back
            </button>
            <button type="button" onclick="nextStep()" style="flex: 1; background: var(--primary); color: white; justify-content: center; padding: 8px; font-size: 0.85rem;">
                Next <i class="fas fa-arrow-right"></i>
            </button>
        </div>
      </div>

      <!-- STEP 2 -->
      <div class="step-box hidden" id="Regions">
        <h3><i class="fas fa-map-marked-alt"></i>Update Group Location</h3>

        <label>County</label>
        <div class="input-group">
          <i class="fas fa-globe-africa"></i>
          <select name="county" id="countySelect" onchange="loadConstituencies()" required>
            <option value="">-- Select County --</option>
          </select>
        </div>

        <label>Constituency</label>
        <div class="input-group">
          <i class="fas fa-map-pin"></i>
          <select name="constituency" id="constituencySelect" onchange="loadWards()" required>
            <option value="">-- Select Constituency --</option>
          </select>
        </div>

        <label>Ward</label>
        <div class="input-group">
          <i class="fas fa-map-marker-alt"></i>
          <select name="ward" id="wardSelect" onchange="checkManualWard()" required>
            <option value="">-- Select Ward --</option>
          </select>
        </div>

        <!-- Manual Ward Input -->
        <div id="manualWardContainer" class="hidden" style="margin-top: 10px;">
          <label>Enter Ward Name Manually</label>
          <div class="input-group">
            <i class="fas fa-edit"></i>
            <input type="text" id="manualWardInput" placeholder="Type Ward Name">
          </div>
        </div>

        <button type="button" onclick="showMembership()">Next <i class="fas fa-arrow-right"></i></button>
      </div>

      <!-- STEP 3: MEMBERSHIP (Dynamic) -->
      <div class="step-box hidden" id="Membership">
        <h3><i class="fas fa-users"></i> Membership Details</h3>
        
        <div id="trusteesContainer"></div>
        <div id="officialsContainer"></div>
        <div id="membersContainer"></div>

        <div id="inlineSummary" style="margin-top: 25px; margin-bottom: 20px;"></div>

        <div style="display: flex; gap: 10px;">
            <button type="button" onclick="goToStep1()" style="flex: 1; background: #e2e8f0; color: #333; border: 1px solid #cbd5e1; justify-content: center; padding: 12px; font-size: 1rem; border-radius: 8px;">
                <i class="fas fa-edit"></i> Edit
            </button>
            <button type="submit" style="flex: 1; background: var(--primary); color: white; justify-content: center; padding: 12px; font-size: 1rem; border-radius: 8px;">
                Submit <i class="fas fa-check-circle"></i>
            </button>
        </div>
      </div>
    </form>
  <% } %>
</div>
<script>
// The entire original script tag content remains unchanged.
function showPhoneInput() {
  const group = document.getElementById("verifyGroup").value;
  const phoneContainer = document.getElementById("phoneVerifyContainer");
  const phoneInput = document.getElementById("verifyPhone");
  
  if (group) {
    phoneContainer.classList.remove("hidden");
  } else {
    phoneContainer.classList.add("hidden");
    phoneInput.value = ""; // Clear input if no group selected
  }
}

async function verifyChairperson() {
  const phone = document.getElementById("verifyPhone").value;
  const group = document.getElementById("verifyGroup").value;
  const msg = document.getElementById("verifyMsg");
  
  if (!phone || !group) {
    msg.textContent = "Please select a group and enter a phone number.";
    return;
  }

  try {
    const res = await fetch("/general/verify", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ 
        chairpersonalphonenumber: phone,
        groupName: group
      })
    });
    const data = await res.json();

    if (data.success) {
      document.getElementById("verificationStep").classList.add("hidden");
      document.getElementById("cAccount").classList.remove("hidden");
      
      // Auto-fill and lock phone AND group
      document.getElementById("confirmedPhone").value = phone;
      document.getElementById("confirmedGroup").value = group;

      // Generate Fields from Counts
      generateFields("Trustee", data.counts.trustees, "trusteesContainer");
      generateFields("Official", data.counts.officials, "officialsContainer");
      generateFields("Member", data.counts.members, "membersContainer");

    } else {
      msg.textContent = data.message || "Verification failed.";
    }
  } catch (err) {
    console.error(err);
    msg.textContent = "Error verifying details.";
  }
}

function generateFields(label, count, containerId) {
  const container = document.getElementById(containerId);
  container.innerHTML = `<h4>${label}s (${count})</h4>`; // Header
  
  for (let i = 1; i <= count; i++) {
    const div = document.createElement("div");
    div.className = "input-group";
    div.style.marginBottom = "10px";
    div.innerHTML = `
      <input type="text" name="${label.toLowerCase()}_${i}" placeholder="${label} ${i} Name" required>
    `;
    container.appendChild(div);
  }
}

function goBackFromStep1() {
  const verifyStep = document.getElementById("verificationStep");
  if (verifyStep) {
    document.getElementById("cAccount").classList.add("hidden");
    verifyStep.classList.remove("hidden");
  } else {
    window.location.href = '/personal'; // Or window.history.back()
  }
}

function parseFullName() {
  const full = document.getElementById('fullNameInput').value.trim();
  const parts = full.split(/\s+/);
  
  const f = document.getElementById('firstName');
  const s = document.getElementById('secondName');
  const l = document.getElementById('lastName');
  const input = document.getElementById('fullNameInput');
  const err = document.getElementById('nameError');

  if (parts.length >= 1) f.value = parts[0]; else f.value = '';
  if (parts.length >= 2) s.value = parts[1]; else s.value = '';
  if (parts.length >= 3) {
      l.value = parts.slice(2).join(' '); // Remaining parts go to last name
      input.setCustomValidity("");
      err.style.display = 'none';
  } else {
      l.value = '';
      input.setCustomValidity("Please enter at least three names.");
      if (full.length > 0) err.style.display = 'block';
  }
}

function nextStep() {
  // Validate Step 1 (cAccount) inputs
  const stepBox = document.getElementById("cAccount");
  const inputs = stepBox.querySelectorAll("input[required], select[required]");
  let valid = true;
  inputs.forEach(input => {
      if (!input.checkValidity()) {
          input.reportValidity();
          valid = false;
      }
  });
  if (!valid) return;

  document.getElementById("cAccount").classList.add("hidden");
  document.getElementById("Regions").classList.remove("hidden");
}

function showMembership() {
  document.getElementById("Regions").classList.add("hidden");
  document.getElementById("Membership").classList.remove("hidden");

  // Populate Inline Summary
  let summary = '<div style="background:#f8f9fa; padding:15px; border-radius:8px; border:1px solid #eee;">';
  
  summary += '<h4 style="margin:0 0 10px; color:var(--primary); font-size:0.95rem; border-bottom:1px solid #ddd; padding-bottom:5px;">Application Summary</h4>';
  
  // Group Info
  summary += '<div style="display:flex; justify-content:space-between; margin-bottom:8px; font-size:0.9rem;">';
  summary += '<span style="color:#555;">Group Name:</span> <b>' + (document.getElementById('confirmedGroup').value || '-') + '</b>';
  summary += '</div>';
  
  summary += '<div style="display:flex; justify-content:space-between; margin-bottom:8px; font-size:0.9rem;">';
  summary += '<span style="color:#555;">Chairperson:</span> <b>' + (document.getElementById('fullNameInput').value || '-') + '</b>';
  summary += '</div>';

  summary += '<div style="display:flex; justify-content:space-between; margin-bottom:8px; font-size:0.9rem;">';
  summary += '<span style="color:#555;">Phone:</span> <b>' + (document.getElementById('confirmedPhone').value || '-') + '</b>';
  summary += '</div>';

  // Location
  const loc = document.getElementById('countySelect').value + ' / ' + document.getElementById('constituencySelect').value + ' / ' + document.getElementById('wardSelect').value;
  summary += '<div style="margin-top:10px; padding-top:10px; border-top:1px dashed #ddd; font-size:0.9rem;">';
  summary += '<span style="color:#555; display:block; margin-bottom:4px;">Location:</span>';
  summary += '<b>' + loc + '</b>';
  summary += '</div>';

  summary += '</div>';
  document.getElementById('inlineSummary').innerHTML = summary;
}

function goToStep1() {
  document.getElementById("Membership").classList.add("hidden");
  document.getElementById("cAccount").classList.remove("hidden");
}

function handleGeneralSubmit(event) {
  const wardSelect = document.getElementById("wardSelect");
  if (wardSelect.value === "OTHER") {
    const manualWard = document.getElementById("manualWardInput").value.trim();
    if (!manualWard) {
      alert("Please enter your ward name.");
      document.getElementById("manualWardInput").focus();
      return false;
    }
    const opt = document.createElement("option");
    opt.value = manualWard;
    opt.text = manualWard;
    wardSelect.appendChild(opt);
    wardSelect.value = manualWard;
  }
  return true;
}

// Manual ward entry removed for consistency — users must select from lists

function initCounties() {
  const countySelect = document.getElementById("countySelect");
  if (!countySelect) return;
  countySelect.innerHTML = '<option value="">-- Select County --</option>';
  fetch('/api/locations/counties')
    .then(r => r.json())
    .then(list => {
      list.forEach(county => {
        const option = document.createElement('option');
        option.value = county;
        option.textContent = county;
        countySelect.appendChild(option);
      });
    }).catch(err => console.error('Failed to load counties', err));
}

function loadConstituencies() {
  const countySelect = document.getElementById("countySelect");
  const constituencySelect = document.getElementById("constituencySelect");
  const wardSelect = document.getElementById("wardSelect");
  const selectedCounty = countySelect.value;
  constituencySelect.innerHTML = '<option value="">-- Select Constituency --</option>';
  wardSelect.innerHTML = '<option value="">-- Select Ward --</option>';
  if (!selectedCounty) return;
  fetch(`/api/locations/${encodeURIComponent(selectedCounty)}/constituencies`)
    .then(r => r.json())
    .then(list => {
      list.forEach(cons => {
        const option = document.createElement('option');
        option.value = cons;
        option.textContent = cons;
        constituencySelect.appendChild(option);
      });
    }).catch(err => console.error('Failed to load constituencies', err));
}

function loadWards() {
  const countySelect = document.getElementById("countySelect");
  const constituencySelect = document.getElementById("constituencySelect");
  const wardSelect = document.getElementById("wardSelect");
  const selectedCounty = countySelect.value;
  const selectedConstituency = constituencySelect.value;
  wardSelect.innerHTML = '<option value="">-- Select Ward --</option>';
  if (!selectedCounty || !selectedConstituency) return;
  fetch(`/api/locations/${encodeURIComponent(selectedCounty)}/${encodeURIComponent(selectedConstituency)}/wards`)
    .then(r => r.json())
    .then(list => {
      if (!Array.isArray(list) || list.length === 0) {
        const option = document.createElement('option');
        option.value = '';
        option.textContent = '(No Wards Listed)';
        option.disabled = true;
        wardSelect.appendChild(option);
        return;
      }
      list.sort().forEach(ward => {
        const option = document.createElement('option');
        option.value = ward;
        option.textContent = ward;
        wardSelect.appendChild(option);
      });
    }).catch(err => console.error('Failed to load wards', err));
}

document.addEventListener("DOMContentLoaded", () => {
  initCounties();
});

function reviewDetails() {
    const step3 = document.getElementById('Membership');
    // Simple validation for Step 3
    const inputs = step3.querySelectorAll("input[required]");
    let valid = true;
    inputs.forEach(input => {
        if (!input.checkValidity()) {
            input.reportValidity();
            valid = false;
        }
    });
    if (!valid) return;

    // Build Summary
    let summary = '<div style="background:#f8f9fa; padding:15px; border-radius:8px; border:1px solid #eee;">';
    
    // Group Info
    summary += '<h4 style="margin:0 0 5px; color:var(--primary); font-size:0.95rem; border-bottom:1px solid #ddd; padding-bottom:5px;">Group Info</h4>';
    summary += '<div style="margin-bottom:10px;">';
    summary += '<div><b>Name:</b> ' + (document.getElementById('confirmedGroup').value || 'N/A') + '</div>';
    summary += '<div><b>Chairperson:</b> ' + (document.getElementById('fullNameInput').value || 'N/A') + '</div>';
    summary += '<div><b>Phone:</b> ' + (document.getElementById('confirmedPhone').value || 'N/A') + '</div>';
    summary += '</div>';

    // Location
    summary += '<h4 style="margin:0 0 5px; color:var(--primary); font-size:0.95rem; border-bottom:1px solid #ddd; padding-bottom:5px;">Location</h4>';
    summary += '<div style="margin-bottom:10px;">';
    summary += '<div><b>Region:</b> ' + document.getElementById('countySelect').value + ' / ' + document.getElementById('constituencySelect').value + '</div>';
    summary += '<div><b>Ward:</b> ' + document.getElementById('wardSelect').value + '</div>';
    summary += '</div>';

    // Membership details removed from summary as requested
    /*
    const getValues = (prefix) => {
        const els = document.querySelectorAll(`input[name^="${prefix}"]`);
        if(els.length === 0) return 'None';
        return Array.from(els).map(i => i.value).filter(v=>v).join(', ');
    };
    summary += '<h4 style="margin:0 0 5px; color:var(--primary); font-size:0.95rem; border-bottom:1px solid #ddd; padding-bottom:5px;">Membership</h4>';
    summary += '<div style="margin-bottom:5px;"><b>Trustees:</b> <span style="color:#555;">' + getValues('trustee') + '</span></div>';
    summary += '<div style="margin-bottom:5px;"><b>Officials:</b> <span style="color:#555;">' + getValues('official') + '</span></div>';
    summary += '<div><b>Members:</b> <span style="color:#555;">' + getValues('member') + '</span></div>';
    */
    
    summary += '</div>';

    document.getElementById('confirmSummary').innerHTML = summary;
    document.getElementById('Membership').classList.add('hidden');
    document.getElementById('Confirmation').classList.remove('hidden');
}

function editDetails() {
    document.getElementById('Confirmation').classList.add('hidden');
    document.getElementById('Membership').classList.remove('hidden');
}
</script>
</body>
</html>
