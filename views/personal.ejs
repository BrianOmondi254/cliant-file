<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Account Options</title>
  <!-- Icons -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  
  <style>
    /* === GLOBAL & BODY === */
    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
      margin: 0;
      padding: 20px;
    }

    /* === CONTAINER BOXING === */
    .box {
      background: #fff;
      padding: 30px;
      border-radius: 16px;
      width: 340px;
      box-shadow: 0 15px 35px rgba(50, 50, 93, 0.1), 0 5px 15px rgba(0, 0, 0, 0.07);
      text-align: center;
      border: 1px solid rgba(255,255,255,0.5);
      /* Animation for transitions */
      animation: fadeIn 0.4s ease-in-out;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }

    /* === HEADINGS === */
    h2, h3 { 
      margin: 0 0 25px 0; 
      color: #2c3e50; 
      font-weight: 700; 
      font-size: 22px; 
    }
    p {
      color: #666;
      font-size: 14px;
      margin-bottom: 20px;
    }

    /* === INPUTS === */
    .input-group {
      position: relative;
      margin-bottom: 15px;
      text-align: left;
    }

    .input-group i {
      position: absolute;
      left: 15px;
      top: 50%;
      transform: translateY(-50%);
      color: #aaa;
      font-size: 14px;
    }

    input {
      width: 100%;
      padding: 12px 12px 12px 40px; /* Space for icon */
      margin: 5px 0;
      border: 1px solid #e0e0e0;
      border-radius: 8px;
      box-sizing: border-box;
      font-size: 15px;
      transition: all 0.3s;
    }

    input:focus {
      border-color: #007bff;
      outline: none;
      box-shadow: 0 0 0 3px rgba(0, 123, 255, 0.1);
    }

    label {
      display: block;
      text-align: left;
      font-size: 13px;
      font-weight: 600;
      color: #555;
      margin-bottom: 6px;
    }

    /* === BUTTONS === */
    button {
      width: 100%;
      padding: 14px;
      margin: 8px 0;
      font-size: 15px;
      font-weight: 600;
      border: none;
      border-radius: 8px;
      cursor: pointer;
      transition: transform 0.1s, box-shadow 0.2s, background 0.2s;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
    }

    button:active { transform: scale(0.98); }

    /* Button Variants */
    .btn-primary { background: #007bff; color: white; box-shadow: 0 4px 6px rgba(0, 123, 255, 0.2); }
    .btn-primary:hover { background: #0069d9; box-shadow: 0 6px 10px rgba(0, 123, 255, 0.25); }

    .btn-success { background: #28a745; color: white; box-shadow: 0 4px 6px rgba(40, 167, 69, 0.2); }
    .btn-success:hover { background: #218838; box-shadow: 0 6px 10px rgba(40, 167, 69, 0.25); }

    .btn-action { 
      background: #f8f9fa; 
      color: #333; 
      border: 1px solid #e9ecef; 
      text-align: left; 
      justify-content: flex-start;
    }
    .btn-action:hover { background: #e2e6ea; border-color: #ced4da; }
    .btn-action i { width: 25px; color: #007bff; }

    .btn-back { 
      background: transparent; 
      color: #6c757d; 
      margin-top: 20px; 
      border: 1px solid #dee2e6; 
    }
    .btn-back:hover { background: #e9ecef; color: #495057; }

  </style>
</head>

<body>

  <!-- MAIN OPTIONS -->
  <div class="box" id="mainOptions">
    <h2><i class="fa-solid fa-wallet"></i> Select Account</h2>
    <button class="btn-primary" onclick="personal()">
      <i class="fa-solid fa-user"></i> Personal Account
    </button>
    <button class="btn-success" onclick="generalAccount()">
      <i class="fa-solid fa-users"></i> General Account
    </button>
  </div>

  <!-- PERSONAL ACCOUNT -->
  <div class="box" id="personal" style="display:none;">
    <h2>Personal Account</h2>
    <button class="btn-action" onclick="send()">
      <i class="fa-solid fa-paper-plane"></i> SEND MONEY
    </button>
    <button class="btn-action">
      <i class="fa-solid fa-money-bill-wave"></i> WITHDRAW
    </button>
    <button class="btn-action">
      <i class="fa-solid fa-scale-balanced"></i> ACCOUNT BALANCE
    </button>
    <button class="btn-action">
      <i class="fa-solid fa-file-invoice"></i> STATEMENTS
    </button>
    <button class="btn-action">
      <i class="fa-solid fa-lock"></i> CHANGE PIN
    </button>
    <button class="btn-back" onclick="backHome()">
      <i class="fa-solid fa-arrow-left"></i> Back
    </button>
  </div>

  <!-- OTHER PERSONAL ACCOUNT (SEND FORM) -->
  <div class="box" id="otherPersonal" style="display:none;">
    <h3>Other Personal Account</h3>

    <div class="input-group">
      <label>Phone Number</label>
      <i class="fa-solid fa-phone"></i>
      <input type="number" placeholder="Enter phone number" required>
    </div>

    <div class="input-group">
      <label>Amount</label>
      <i class="fa-solid fa-sack-dollar"></i>
      <input type="number" placeholder="Enter amount" required>
    </div>

    <div class="input-group">
      <label>PIN</label>
      <i class="fa-solid fa-key"></i>
      <input type="password" placeholder="Enter PIN" required>
    </div>

    <button class="btn-primary" onclick="submitTransfer()">
      <i class="fa-solid fa-check"></i> Send
    </button>
    <button class="btn-back" onclick="backHome()">
      <i class="fa-solid fa-arrow-left"></i> Back
    </button>
  </div>

  <!-- GENERAL ACCOUNT / GROUPS -->
  <div class="box" id="groups" style="display:none;">
    <h2><i class="fa-solid fa-users-rectangle"></i> Group Accounts</h2>
    <button class="btn-action" onclick="window.location.href='/personal/myaccount'">
      <i class="fa-solid fa-list-check"></i> MY GROUPS
    </button>
    <button class="btn-action" onclick="window.location.href='/personal/general?mode=create'">
      <i class="fa-solid fa-plus-circle"></i> CREATE GROUP ACCOUNT
    </button>
    <button class="btn-back" onclick="backHome()">
      <i class="fa-solid fa-arrow-left"></i> Back
    </button>
  </div>

  <!-- GROUP DETAILS -->
  <div class="box" id="groupDetails" style="display:none;">
    <h3 id="groupTitle"></h3>
    <p>Group transactions and actions go here.</p>
    <button class="btn-back" onclick="generalAccount()">
      <i class="fa-solid fa-arrow-left"></i> Back to Groups
    </button>
  </div>

  <!-- JAVASCRIPT -->
  <script>
    function hideAll() {
      const ids = [
        "mainOptions",
        "personal",
        "send", // Kept in array as requested, though element doesn't exist
        "otherPersonal",
        "groups",
        "groupDetails"
      ];

      ids.forEach(id => {
        const el = document.getElementById(id);
        if (el) el.style.display = "none";
      });
    }

    function backHome() {
      hideAll();
      document.getElementById("mainOptions").style.display = "block";
    }

    function personal() {
      hideAll();
      document.getElementById("personal").style.display = "block";
    }

    // This function was called in HTML but not defined in script. Added here to make the UI work.
    function send() {
      hideAll();
      document.getElementById("otherPersonal").style.display = "block";
    }

    // Kept original function name from your code
    function personalAccount() {
      hideAll();
      document.getElementById("otherPersonal").style.display = "block";
    }

    function generalAccount() {
      hideAll();
      document.getElementById("groups").style.display = "block";
    }
  </script>

</body>
</html>