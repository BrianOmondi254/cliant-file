     <!-- Menu Dropdown -->
     <div id="menuDropdown" class="menu-dropdown">
              <div class="dropdown-content">
                  <div class="dropdown-body">
                      <button class="btn btn-primary" onclick="closeDropdown(); openModal('meetingModal')" style="width: 100%; padding: 8px 12px; font-size: 14px; margin-bottom: 12px;">
                          + New Meeting
                      </button>
                      <button class="btn btn-secondary" onclick="closeDropdown(); openModal('projectModal')" style="width: 100%; padding: 8px 12px; font-size: 14px;">
                          + New Project
                      </button>
