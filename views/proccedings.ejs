                <div class="card-header">
                    <h3 class="card-title">✍️ Official Signatures</h3>
                </div>
                <div class="card-body">
                    <div class="signature-section">
                        <div class="signature-box">
                            <div class="signature-title">Chairperson Signature</div>
                            <div class="signature-line"></div>
                            <div class="signature-name"><%= currentMeeting && currentMeeting.chairperson ? currentMeeting.chairperson : 'Chairperson Name' %></div>
                            <div class="signature-date">Date: _______________</div>
                        </div>
                        <div class="signature-box">
                            <div class="signature-title">Secretary Signature</div>
                            <div class="signature-line"></div>
                            <div class="signature-name"><%= currentMeeting && currentMeeting.secretary ? currentMeeting.secretary : 'Secretary Name' %></div>
                            <div class="signature-date">Date: _______________</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <footer class="footer">
        <div class="footer-title">Meeting Proceedings Portfolio System</div>
        <div class="footer-subtitle">Professional Meeting Management</div>
    </footer>

