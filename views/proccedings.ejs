    <script>
        // Global vars
        let currentMeetingId = '<%= currentMeeting ? currentMeeting.id : "" %>';
        const groupName = '<%= groupName %>';
        let attendanceState = {};

        // Tab switching
        function openTab(tabName) {
            // Hide all tabs
            document.querySelectorAll('.tab-content').forEach(tab => {
                tab.classList.remove('active');
            });
            
            // Remove active from all tab buttons
            document.querySelectorAll('.tab-item').forEach(btn => {
                btn.classList.remove('active');
            });
            
            // Show selected tab
            const content = document.getElementById(tabName);
            if (content) {
                content.classList.add('active');
            }
            
            // Activate button
            const buttons = document.querySelectorAll('.tab-item');
            buttons.forEach((btn, index) => {
                const tabs = ['details', 'attendance', 'minutes', 'agenda', 'voting', 'final'];
                if (tabs[index] === tabName) {
                    btn.classList.add('active');
                }
            });

            // Scroll to top
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        // Modal functions
        function openModal(modalId) {
            document.getElementById(modalId).classList.add('active');
            document.body.style.overflow = 'hidden';
        }

        function closeModal(modalId) {
            document.getElementById(modalId).classList.remove('active');
            document.body.style.overflow = '';
        }

        // Close modal when clicking outside
        document.querySelectorAll('.modal').forEach(modal => {
            modal.addEventListener('click', function(e) {
                if (e.target === this) {
                    closeModal(this.id);
                }
            });
        });

        // Toggle guest inputs
        function toggleChairpersonGuest() {
            const select = document.getElementById('meetingChairpersonSelect');
            const guestInput = document.getElementById('meetingChairpersonGuest');
            guestInput.style.display = select.value === 'guest' ? 'block' : 'none';
        }

        function toggleSecretaryGuest() {
            const select = document.getElementById('meetingSecretarySelect');
            const guestInput = document.getElementById('meetingSecretaryGuest');
            guestInput.style.display = select.value === 'guest' ? 'block' : 'none';
        }

        // Meeting selection
        function selectMeeting() {
            const select = document.getElementById('meetingSelect');
            if (select.value) {
                window.location.href = '/proceedings/' + encodeURIComponent(groupName) + '?meetingId=' + select.value;
            }
        }

        // Create meeting
        async function createMeeting() {
            const data = {
                groupName: groupName,
                title: document.getElementById('meetingTitle').value,
                project: document.getElementById('meetingProject').value,
                date: document.getElementById('meetingDate').value,
                venue: document.getElementById('meetingVenue').value,
                startTime: document.getElementById('meetingStartTime').value,
                endTime: document.getElementById('meetingEndTime').value,
                chairperson: document.getElementById('meetingChairpersonSelect').value === 'guest' 
                             ? document.getElementById('meetingChairpersonGuest').value 
                             : document.getElementById('meetingChairpersonSelect').value,
                secretary: document.getElementById('meetingSecretarySelect').value === 'guest' 
                             ? document.getElementById('meetingSecretaryGuest').value 
                             : document.getElementById('meetingSecretarySelect').value,
                status: document.getElementById('meetingStatus').value
            };

            if (!data.title || !data.date || !data.chairperson) {
                alert('Please fill in required fields');
                return;
            }

            try {
                const response = await fetch('/proceedings/api/meetings', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                
                if (response.ok) {
                    const result = await response.json();
                    window.location.href = '/proceedings/' + encodeURIComponent(groupName) + 
                                         '?meetingId=' + result.meeting.id + '&tab=attendance';
                }
            } catch (error) {
                alert('Error creating meeting');
            }
        }

        // Attendance functions
        function toggleApology(memberId) {
            const apologyDiv = document.getElementById('apology_' + memberId);
            apologyDiv.classList.toggle('show');
        }

        function markAttendance(memberId, status, apology = '') {
            attendanceState[memberId] = { status, apology };

            const container = document.querySelector(`[id="apology_${memberId}"]`).parentElement;
            const item = container.querySelector('.member-item');
            const btns = container.querySelectorAll('.att-btn');
            const apologyDiv = document.getElementById('apology_' + memberId);
            const apologyBtns = container.querySelectorAll('.apology-btn');

            // Update border
            if (status === 'present') item.style.borderLeftColor = '#38a169';
            else if (status === 'absent') item.style.borderLeftColor = '#e53e3e';
            else if (status === 'late') item.style.borderLeftColor = '#d69e2e';

            // Update buttons
            btns.forEach(btn => {
                btn.classList.remove('active');
                if (status === 'present' && btn.classList.contains('present')) btn.classList.add('active');
                if (status === 'absent' && btn.classList.contains('absent')) btn.classList.add('active');
                if (status === 'late' && btn.classList.contains('late')) btn.classList.add('active');
            });

            // Show/hide apology
            if (status === 'absent') {
                apologyDiv.classList.add('show');
            } else {
                apologyDiv.classList.remove('show');
            }

            // Update apology buttons
            apologyBtns.forEach(btn => {
                btn.classList.remove('active');
                if (apology === 'With Apology' && btn.textContent.includes('With')) btn.classList.add('active');
                if (apology === 'Without Apology' && btn.textContent.includes('No')) btn.classList.add('active');
            });
        }

        async function bulkSaveAttendance() {
            if (!currentMeetingId) {
                alert('Please select a meeting first');
                return;
            }

            const updatesCount = Object.keys(attendanceState).length;
            if (updatesCount === 0) {
                alert('No changes to save');
                return;
            }

            try {
                const response = await fetch('/proceedings/api/attendance/bulk', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        meetingId: currentMeetingId,
                        groupName: groupName,
                        updates: attendanceState
                    })
                });

                if (response.ok) {
                    window.location.href = window.location.pathname + '?meetingId=' + currentMeetingId + '&tab=minutes';
                } else {
                    alert('Error saving data');
                }
            } catch (error) {
                alert('Error connecting to server');
            }
        }

        // Visitor
        async function addVisitor() {
            if (!currentMeetingId) return;

            const name = document.getElementById('visitorName').value;
            const description = document.getElementById('visitorDescription').value;

            if (!name) {
                alert('Please enter visitor name');
                return;
            }

            try {
                const response = await fetch('/proceedings/api/meetings/' + currentMeetingId + '/visitors', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ name, description })
                });
                
                if (response.ok) {
                    window.location.reload();
                }
            } catch (error) {
                alert('Error adding visitor');
            }
        }

        // Agenda
        async function createAgenda() {
            if (!currentMeetingId) {
                alert('Please select a meeting first');
                return;
            }

            const data = {
                meetingId: currentMeetingId,
                groupName: groupName,
                title: document.getElementById('agendaTitle').value,
                description: document.getElementById('agendaDescription').value,
                proposerId: document.getElementById('agendaProposer').value,
                seconderId: document.getElementById('agendaSeconder').value,
                thirdId: document.getElementById('agendaThird').value
            };

            if (!data.title) {
                alert('Please enter agenda title');
                return;
            }

            try {
                const response = await fetch('/proceedings/api/agenda', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                
                if (response.ok) {
                    window.location.href = window.location.pathname + '?meetingId=' + currentMeetingId + '&tab=agenda';
                }
            } catch (error) {
                alert('Error creating agenda');
            }
        }

        async function updateAgendaStatus(agendaId, status) {
            try {
                const response = await fetch('/proceedings/api/agenda/' + agendaId, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ status })
                });
                
                if (response.ok) {
                    window.location.reload();
                }
            } catch (error) {
                alert('Error updating agenda');
            }
        }

        // Voting
        async function castVote(agendaId, memberId, voteType) {
            try {
                const response = await fetch('/proceedings/api/votes', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        agendaId,
                        memberId,
                        voteType,
                        groupName
                    })
                });
                
                if (response.ok) {
                    window.location.reload();
                }
            } catch (error) {
                alert('Error casting vote');
            }
        }

        // Minutes
        async function createMinute() {
            if (!currentMeetingId) {
                alert('Please select a meeting first');
                return;
            }

            const data = {
                meetingId: currentMeetingId,
                groupName: groupName,
                title: document.getElementById('minuteTitle').value,
                content: document.getElementById('minuteContent').value
            };

            if (!data.title || !data.content) {
                alert('Please fill in required fields');
                return;
            }

            try {
                await fetch('/proceedings/api/minutes', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                window.location.reload();
            } catch (error) {
                alert('Error creating minute');
            }
        }

        async function updateMinuteStatus(minuteId, status) {
            try {
                await fetch('/proceedings/api/minutes/' + minuteId, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ status })
                });
                window.location.reload();
            } catch (error) {
                alert('Error updating minute');
            }
        }

        // Final tab
        async function saveChairpersonNote() {
            if (!currentMeetingId) return;
            
            const note = document.getElementById('chairpersonNote').value;
            try {
                await fetch('/proceedings/api/meetings/' + currentMeetingId, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ chairpersonNote: note })
                });
                alert('Comments saved');
            } catch (error) {
                alert('Error saving');
            }
        }

        async function saveAdjournment() {
            if (!currentMeetingId) return;
            
            const note = document.getElementById('adjournmentNote').value;
            try {
                await fetch('/proceedings/api/meetings/' + currentMeetingId, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ adjournmentNote: note, status: 'adjourned' })
                });
                alert('Meeting adjourned');
            } catch (error) {
                alert('Error saving');
            }
        }

        // Project
        async function createProject() {
            const data = {
                groupName: groupName,
                title: document.getElementById('projectTitle').value,
                objective: document.getElementById('projectObjective').value,
                budget: document.getElementById('projectBudget').value,
                targetDate: document.getElementById('projectTargetDate').value
            };

            if (!data.title) {
                alert('Please enter project title');
                return;
            }

            try {
                const response = await fetch('/proceedings/api/projects', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                
                if (response.ok) {
                    alert('Project created!');
                    closeModal('projectModal');
                    window.location.reload();
                }
            } catch (error) {
                alert('Error creating project');
            }
        }

        // Meeting status
        async function updateMeetingStatus(meetingId, status) {
            try {
                const response = await fetch('/proceedings/api/meetings/' + meetingId, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ status })
                });
                
                if (response.ok) {
                    window.location.reload();
                }
            } catch (error) {
                alert('Error updating status');
            }
        }

        // Collapse toggle
        function toggleCollapse(id) {
            const body = document.getElementById(id);
            const arrow = document.getElementById('arrow_' + id);
            
            if (body.style.display === 'none') {
                body.style.display = 'block';
                arrow.classList.add('open');
            } else {
                body.style.display = 'none';
                arrow.classList.remove('open');
            }
        }

        // Quick actions
        function showQuickActions() {
            openModal('menuModal');
        }

        // Check for tab parameter on load
        window.addEventListener('load', () => {
            const urlParams = new URLSearchParams(window.location.search);
            const tabParam = urlParams.get('tab');
            if (tabParam) {
                setTimeout(() => openTab(tabParam), 100);
            }
        });

        // Prevent double-tap zoom on buttons
        let lastTouchEnd = 0;
        document.addEventListener('touchend', function(event) {
            const now = Date.now();
            if (now - lastTouchEnd <= 300) {
                event.preventDefault();
            }
            lastTouchEnd = now;
        }, false);
    </script>
</body>
</html>