    <!-- Minute Modal -->
    <div id="minuteModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3 class="modal-title">New Minute</h3>
                <p class="modal-subtitle">Add meeting minute</p>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label class="form-label">Title *</label>
                    <input type="text" class="form-input" id="minuteTitle" placeholder="Minute title">
                </div>
                
                <div class="form-group">
                    <label class="form-label">Content *</label>
                    <textarea class="form-textarea" id="minuteContent" placeholder="Detailed content..."></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" onclick="closeModal('minuteModal')" style="flex: 1;">Cancel</button>
