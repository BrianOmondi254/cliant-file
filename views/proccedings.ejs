                <h3 class="modal-title">Add Meeting Minute</h3>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label class="form-label">Title *</label>
                    <input type="text" class="form-input" id="minuteTitle" placeholder="e.g., Approval of previous minutes">
                </div>
