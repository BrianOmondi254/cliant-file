    <!-- Agenda Modal -->
    <div id="agendaModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3 class="modal-title">New Agenda</h3>
                <p class="modal-subtitle">Add agenda item</p>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label class="form-label">Title *</label>
                    <input type="text" class="form-input" id="agendaTitle" placeholder="Agenda title">
                </div>
                
                <div class="form-group">
                    <label class="form-label">Description</label>
                    <textarea class="form-textarea" id="agendaDescription" placeholder="Details..."></textarea>
                </div>
                
                <div class="form-group">
                    <label class="form-label">Proposer</label>
                    <select class="form-select" id="agendaProposer">
                        <option value="">Select</option>
                        <% if (members) { %>
                            <% members.forEach(function(m) { %>
                                <option value="<%= m.id %>"><%= m.name %></option>
                            <% }); %>
                        <% } %>
                    </select>
                </div>
                
                <div class="form-group">
                    <label class="form-label">Seconder</label>
                    <select class="form-select" id="agendaSeconder">
                        <option value="">Select</option>
                        <% if (members) { %>
                            <% members.forEach(function(m) { %>
                                <option value="<%= m.id %>"><%= m.name %></option>
                            <% }); %>
                        <% } %>
                    </select>
                </div>
                
                <div class="form-group">
                    <label class="form-label">Third Supporter</label>
                    <select class="form-select" id="agendaThird">
