     </div>

    <!-- New Meeting Modal -->
    <div id="meetingModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3 class="modal-title">New Meeting</h3>
                <p class="modal-subtitle">Create a new meeting</p>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label class="form-label">Title *</label>
                    <input type="text" class="form-input" id="meetingTitle" placeholder="Meeting title">
                </div>
                
                <div class="form-group">
                    <label class="form-label">Description</label>
                    <input type="text" class="form-input" id="meetingProject" placeholder="Meeting description">
                </div>
                
                <div class="form-group">
                    <label class="form-label">Date *</label>
                    <input type="date" class="form-input" id="meetingDate">
                </div>
                
                <div class="form-group">
                    <label class="form-label">Status *</label>
                    <select class="form-select" id="meetingStatus">
                        <option value="active">Active (Roll-call enabled)</option>
                        <option value="pending">Pending (Future)</option>
                    </select>
                </div>
                
                <div class="form-group">
                    <label class="form-label">Venue</label>
                    <input type="text" class="form-input" id="meetingVenue" placeholder="Meeting location">
                </div>
                
                <div class="form-group">
                    <label class="form-label">Start Time</label>
                    <input type="time" class="form-input" id="meetingStartTime">
                </div>
                
                <div class="form-group">
                    <label class="form-label">End Time</label>
                    <input type="time" class="form-input" id="meetingEndTime">
                </div>
                
                <div class="form-group">
                    <label class="form-label">Moderator</label>
                    <select class="form-select" id="meetingChairpersonSelect" onchange="toggleChairpersonGuest()">
                        <option value="">-- Select --</option>
                        <% if (members && members.length > 0) { %>
                            <% members.forEach(function(m) { %>
                                <option value="<%= m.name %>"><%= m.name %></option>
                            <% }); %>
                        <% } %>
                        <option value="guest">👤 External Guest</option>
                    </select>
                    <input type="text" class="form-input" id="meetingChairpersonGuest" 
                           placeholder="Guest name" style="display: none; margin-top: 8px;">
                </div>
                
                <div class="form-group">
                    <label class="form-label">Secretary</label>
                    <select class="form-select" id="meetingSecretarySelect" onchange="toggleSecretaryGuest()">
                        <option value="">-- Select --</option>
                        <% if (members && members.length > 0) { %>
                            <% members.forEach(function(m) { %>
                                <option value="<%= m.name %>"><%= m.name %></option>
                            <% }); %>
                        <% } %>
                        <option value="guest">👤 External Guest</option>
                    </select>
                    <input type="text" class="form-input" id="meetingSecretaryGuest" 
                           placeholder="Guest name" style="display: none; margin-top: 8px;">
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" onclick="closeModal('meetingModal')" style="flex: 1;">Cancel</button>
                <button class="btn btn-primary" onclick="createMeeting()" style="flex: 2;">Create</button>
            </div>
        </div>
    </div>

    <!-- Delete Meeting Modal -->
    <div id="deleteMeetingModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3 class="modal-title" style="color: #e53e3e;">Delete Meeting</h3>
                <p class="modal-subtitle">This action cannot be undone.</p>
            </div>
            <div class="modal-body">
                <p id="deleteMeetingMsg" style="font-size: 14px; color: var(--text-secondary); line-height: 1.6;"></p>
                <div style="background: #fff5f5; border: 1px solid #feb2b2; padding: 12px; border-radius: 8px; margin-top: 12px; display: flex; gap: 10px; align-items: flex-start;">
                    <i class="fas fa-exclamation-triangle" style="color: #e53e3e; margin-top: 3px;"></i>
                    <p style="font-size: 12px; color: #c53030; font-weight: 500;">
                        Deleting this meeting will permanently remove all associated agenda items, votes, minutes, and attendance records.
                    </p>
                </div>
