            <div class="modal-footer">
                <button class="btn btn-secondary" onclick="closeModal('deleteMeetingModal')" style="flex: 1;">Cancel</button>
                <button class="btn btn-danger" id="confirmDeleteBtn" style="flex: 1; background: #e53e3e; color: white; border: none;">Delete</button>
            </div>
        </div>
