    <!-- Previous Minutes Modal -->
    <div id="previousMinutesModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3 class="modal-title">Reading of Previous Minutes</h3>
                <p class="modal-subtitle">
                    <% if (previousMeeting) { %>
                        <%= previousMeeting.title %> - <%= new Date(previousMeeting.date).toLocaleDateString() %>
                    <% } %>
                </p>
            </div>
            <div class="modal-body" style="max-height: 60vh; overflow-y: auto;">
                <% if (previousMeeting) { %>
                    <% if (previousMinutes && previousMinutes.length > 0) { %>
                        <% previousMinutes.forEach(function(pm, idx) { %>
                            <div style="margin-bottom: 16px; padding-bottom: 16px; border-bottom: 1px solid #edf2f7;">
                                <h4 style="font-size: 14px; color: #2d3748; margin-bottom: 8px;">MIN <%= idx + 1 %>: <%= pm.title %></h4>
                                <p style="font-size: 13px; color: #4a5568; line-height: 1.5; white-space: pre-wrap;"><%= pm.content %></p>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <div style="text-align: center; padding: 20px; color: #718096; font-style: italic; font-size: 13px;">
                            No approved minutes found for the previous meeting.
                        </div>
                    <% } %>
                <% } %>
            </div>
            <div class="modal-footer">
                <button class="btn btn-primary" onclick="proceedToMinutesTab()" style="width: 100%;">Mark as Read & Continue</button>
            </div>
        </div>
    </div>

    <script>
        function continueToMinutes() {
            // Check if there is a previous meeting and minutes to show
            <% if (previousMeeting) { %>
                document.getElementById('previousMinutesModal').classList.add('active');
            <% } else { %>
                openTab('minutes');
            <% } %>
        }

        function proceedToMinutesTab() {
            closeModal('previousMinutesModal');
            openTab('minutes');
        }

        function toggleMinute(headerElement) {
            const body = headerElement.nextElementSibling;
            if (!body || !body.classList.contains('minute-body')) return;
            if (body.style.display === 'none' || body.style.display === '') {
                body.style.display = 'block';
            } else {
                body.style.display = 'none';
            }
        }

        // Global vars
        let currentMeetingId = '<%= currentMeeting ? currentMeeting.id : "" %>';
        const groupName = '<%= groupName %>';
        let attendanceState = {};

        // Tab switching
        function toggleAgendaProposal() {
            if (!currentMeetingId) {
                showNotification('No active meeting selected', 'warning');
                return;
            }
            const form = document.getElementById('inlineAgendaForm');
            const backdrop = document.getElementById('proposalBackdrop');
            const fabIcon = document.querySelector('.fab i');
            
            if (form.style.display === 'none' || !form.style.display) {
                form.style.display = 'block';
                backdrop.style.display = 'block';
                fabIcon.classList.remove('fa-plus');
                fabIcon.classList.add('fa-times');
            } else {
                form.style.display = 'none';
                backdrop.style.display = 'none';
                fabIcon.classList.remove('fa-times');
                fabIcon.classList.add('fa-plus');
            }
        }

        function toggleAgenda(header) {
            const body = header.nextElementSibling;
            const icon = header.querySelector('.fa-chevron-down');
            const isActive = body.style.display === 'block';
            
            // Close other agendas (optional, but keep it consistent with minutes if they do this)
            // document.querySelectorAll('.agenda-body').forEach(b => b.style.display = 'none');
            // document.querySelectorAll('.agenda-header .fa-chevron-down').forEach(i => i.style.transform = 'rotate(0deg)');

            if (isActive) {
                body.style.display = 'none';
                icon.style.transform = 'rotate(0deg)';
                header.style.background = '#fff';
            } else {
                body.style.display = 'block';
                icon.style.transform = 'rotate(180deg)';
                header.style.background = '#f7fafc';
            }
        }

        function openTab(tabName) {
            // Hide all tabs
            document.querySelectorAll('.tab-content').forEach(tab => {
                tab.classList.remove('active');
            });
            
            // Remove active from all tab buttons
            document.querySelectorAll('.tab-item').forEach(btn => {
                btn.classList.remove('active');
            });
            
            // Show selected tab
            const content = document.getElementById(tabName);
            if (content) {
                content.classList.add('active');
            }
            
            // Activate button
            const buttons = document.querySelectorAll('.tab-item');
            buttons.forEach((btn, index) => {
                const tabs = ['details', 'attendance', 'minutes', 'agenda', 'final'];
                if (tabs[index] === tabName) {
                    btn.classList.add('active');
                }
            });

            // Scroll to top
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        // Modal functions
        function openModal(modalId) {
            document.getElementById(modalId).classList.add('active');
            document.body.style.overflow = 'hidden';
        }

        function closeModal(modalId) {
            document.getElementById(modalId).classList.remove('active');
            document.body.style.overflow = '';
        }

        function toggleMenuDropdown() {
            const dropdown = document.getElementById('menuDropdown');
            const isActive = dropdown.classList.contains('active');
            
            // Close any open modals first
            document.querySelectorAll('.modal.active').forEach(m => {
                m.classList.remove('active');
            });
            document.body.style.overflow = '';
            
            // Toggle dropdown
            if (isActive) {
                dropdown.classList.remove('active');
            } else {
                dropdown.classList.add('active');
            }
        }

        function closeDropdown() {
            document.getElementById('menuDropdown').classList.remove('active');
        }

        // Close modal when clicking outside
        document.querySelectorAll('.modal').forEach(modal => {
            modal.addEventListener('click', function(e) {
                if (e.target === this) {
                    closeModal(this.id);
                }
            });
        });

        // Close dropdown when clicking outside
        document.addEventListener('click', function(e) {
            const dropdown = document.getElementById('menuDropdown');
            const menuBtn = document.querySelector('.menu-btn');
            if (dropdown && dropdown.classList.contains('active')) {
                if (!dropdown.contains(e.target) && !menuBtn.contains(e.target)) {
                    closeDropdown();
                }
            }
        });

        // Toggle guest inputs
        function toggleChairpersonGuest() {
            const select = document.getElementById('meetingChairpersonSelect');
            const guestInput = document.getElementById('meetingChairpersonGuest');
            guestInput.style.display = select.value === 'guest' ? 'block' : 'none';
        }

        function toggleSecretaryGuest() {
            const select = document.getElementById('meetingSecretarySelect');
            const guestInput = document.getElementById('meetingSecretaryGuest');
            guestInput.style.display = select.value === 'guest' ? 'block' : 'none';
        }

        // Meeting selection
        function selectMeeting() {
            const select = document.getElementById('meetingSelect');
            const deleteBtn = document.getElementById('deleteMeetingBtn');
            
            if (select.value) {
                if (deleteBtn) deleteBtn.style.display = 'flex';
                window.location.href = '/proceedings/' + encodeURIComponent(groupName) + '?meetingId=' + select.value;
            } else {
                if (deleteBtn) deleteBtn.style.display = 'none';
                window.location.href = '/proceedings/' + encodeURIComponent(groupName);
            }
        }

        // Create meeting
        async function createMeeting() {
            const data = {
                groupName: groupName,
                title: document.getElementById('meetingTitle').value,
                project: document.getElementById('meetingProject').value,
                date: document.getElementById('meetingDate').value,
                venue: document.getElementById('meetingVenue').value,
                startTime: document.getElementById('meetingStartTime').value,
                endTime: document.getElementById('meetingEndTime').value,
                chairperson: document.getElementById('meetingChairpersonSelect').value === 'guest' 
                             ? document.getElementById('meetingChairpersonGuest').value 
                             : document.getElementById('meetingChairpersonSelect').value,
                secretary: document.getElementById('meetingSecretarySelect').value === 'guest' 
                             ? document.getElementById('meetingSecretaryGuest').value 
                             : document.getElementById('meetingSecretarySelect').value,
                status: document.getElementById('meetingStatus').value
            };

            if (!data.title || !data.date || !data.chairperson) {
                alert('Please fill in required fields');
                return;
            }

            try {
                const response = await fetch('/proceedings/api/meetings', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                
                if (response.ok) {
                    const result = await response.json();
                    window.location.href = '/proceedings/' + encodeURIComponent(groupName) + 
                                         '?meetingId=' + result.meeting.id + '&tab=attendance';
                }
            } catch (error) {
                alert('Error creating meeting');
            }
        }

        function goBackToCallToOrder() {
            document.getElementById('callToOrderSection').style.display = 'block';
            document.getElementById('rollCallContent').style.display = 'none';
            document.getElementById('saveAttendanceAction').style.display = 'none';
            window.scrollTo({ top: 0, behavior: 'smooth' });
            showNotification('Editing Meeting Start Details');
        }

        async function confirmCallToOrder() {
            const select = document.getElementById('calledByOfficial');
            const officialValue = select.value;
            const officialName = select.options[select.selectedIndex].getAttribute('data-name');
            const remarks = document.getElementById('openingRemarks').value;
            
            if (!remarks || !officialValue) {
                if (!remarks) document.getElementById('remarksError').style.display = 'block';
                if (!officialValue) document.getElementById('officialError').style.display = 'block';
                return;
            }
            
            try {
                const response = await fetch('/proceedings/api/meetings/' + currentMeetingId, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ 
                        callToOrderNote: remarks,
                        calledByOfficial: officialName || officialValue,
                        status: 'active'
                    })
                });
                
                if (response.ok) {
                    document.getElementById('callToOrderSection').style.display = 'none';
                    document.getElementById('rollCallContent').style.display = 'block';
                    document.getElementById('saveAttendanceAction').style.display = 'block';
                    
                    document.getElementById('reviewRemarksText').textContent = remarks;
                    document.getElementById('reviewOfficialName').textContent = officialName || officialValue;
                    window.scrollTo({ top: 0, behavior: 'smooth' });
                    showNotification('Meeting Activated');
                }
            } catch (error) {
                showNotification('Error starting meeting', 'error');
            }
        }

        // Attendance functions
        const totalMemberCount = <%= members.length %>;

        function toggleApology(safeId) {
            const apologyDiv = document.getElementById('apology_' + safeId);
            if (apologyDiv) apologyDiv.classList.toggle('show');
        }

        function markAttendance(memberId, status, memberName = 'Member', apology = '', safeId = '') {
            attendanceState[memberId] = { status, apology };
            
            showNotification(memberName + ' marked as ' + status + (apology ? ' (' + apology + ')' : ''));

            const targetId = safeId || memberId.toString().replace(/[^a-zA-Z0-9]/g, '_');
            const wrapper = document.getElementById('wrapper_' + targetId);
            
            if (wrapper) {
                const item = wrapper.querySelector('.member-item');
                const btns = wrapper.querySelectorAll('.att-btn');
                const apologyDiv = document.getElementById('apology_' + targetId);
                const apologyBtns = wrapper.querySelectorAll('.apology-btn');

                // Update border
                if (status === 'present') item.style.borderLeftColor = '#38a169';
                else if (status === 'absent') item.style.borderLeftColor = '#e53e3e';
                else if (status === 'late') item.style.borderLeftColor = '#d69e2e';

                // Update status buttons
                btns.forEach(btn => {
                    btn.classList.remove('active');
                    if (status === 'present' && btn.classList.contains('present')) btn.classList.add('active');
                    if (status === 'absent' && btn.classList.contains('absent')) btn.classList.add('active');
                    if (status === 'late' && btn.classList.contains('late')) btn.classList.add('active');
                });

                // Show/hide apology
                if (status === 'absent' && !apology) {
                    if (apologyDiv) apologyDiv.classList.add('show');
                } else {
                    if (apologyDiv) apologyDiv.classList.remove('show');
                }

                // Update apology buttons
                apologyBtns.forEach(btn => {
                    btn.classList.remove('active');
                    if (apology === 'With Apology' && btn.textContent.includes('With')) btn.classList.add('active');
                    if (apology === 'Without Apology' && btn.textContent.includes('No')) btn.classList.add('active');
                });
            }
        }

        async function bulkSaveAttendance() {
            if (!currentMeetingId) {
                showNotification('Please select a meeting first', 'error');
                return;
            }

            const markedCount = Object.keys(attendanceState).length;
            if (markedCount < totalMemberCount) {
                showNotification(`Selection required! (${markedCount}/${totalMemberCount} members marked)`, 'error');
                return;
            }

            // Calculate counts
            const counts = { present: 0, absent: 0, late: 0 };
            Object.values(attendanceState).forEach(record => {
                if (record.status === 'present') counts.present++;
                else if (record.status === 'absent') counts.absent++;
                else if (record.status === 'late') counts.late++;
            });

            try {
                const response = await fetch('/proceedings/api/attendance/bulk', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        meetingId: currentMeetingId,
                        groupName: groupName,
                        updates: attendanceState
                    })
                });

                if (response.ok) {
                    showNotification('Attendance saved successfully', 'success');
                    
                    // Update confirmation summary
                    document.getElementById('attendanceSummary').innerHTML = `
                        <span style="background: #dcfce7; padding: 4px 10px; border-radius: 6px; border: 1px solid #86efac;">✅ Present: ${counts.present}</span>
                        <span style="background: #fee2e2; padding: 4px 10px; border-radius: 6px; border: 1px solid #fca5a5;">❌ Absent: ${counts.absent}</span>
                        <span style="background: #fef3c7; padding: 4px 10px; border-radius: 6px; border: 1px solid #fcd34d;">◐ Late: ${counts.late}</span>
                    `;
                    
                    // Hide save button, show confirmation
                    document.getElementById('saveAttendanceAction').style.display = 'none';
                    document.getElementById('attendanceConfirmation').style.display = 'block';
                    
                    // Clear attendance state
                    attendanceState = {};
                } else {
                    showNotification('Error saving data', 'error');
                }
            } catch (error) {
                showNotification('Connection error', 'error');
            }
        }

        function resetAttendance() {
            // Reload page to reset attendance marks
            window.location.reload();
        }

        // Visitor Management
        function editVisitor(name, phone, description) {
            document.getElementById('visitorName').value = name;
            document.getElementById('visitorPhone').value = phone || '';
            document.getElementById('visitorDescription').value = description;
            
            const btn = document.getElementById('addVisitorBtn');
            btn.textContent = 'Update Visitor';
            btn.className = 'btn btn-primary mb-16';
            
            document.getElementById('visitorForm').scrollIntoView({ behavior: 'smooth' });
            showNotification('Loaded ' + name + ' for editing');
        }

        async function deleteVisitor(name) {
            if (!currentMeetingId) return;
            
            try {
                const response = await fetch(`/proceedings/api/meetings/${currentMeetingId}/visitors/${encodeURIComponent(name)}`, {
                    method: 'DELETE'
                });
                
                if (response.ok) {
                    showNotification('Visitor removed');
                    window.location.reload();
                }
            } catch (error) {
                showNotification('Error deleting visitor', 'error');
            }
        }

        function handleVisitorOk() {
            const name = document.getElementById('visitorName').value;
            if (name && name.trim() !== '') {
                addVisitor(false);
            } else {
                showNotification('Visitor configuration finished');
            }
        }

        async function addVisitor(shouldSlide = true) {
            if (!currentMeetingId) return;

            const name = document.getElementById('visitorName').value;
            const phone = document.getElementById('visitorPhone').value;
            const description = document.getElementById('visitorDescription').value;

            if (!name) {
                showNotification('Please enter visitor name', 'error');
                return;
            }

            try {
                const response = await fetch('/proceedings/api/meetings/' + currentMeetingId + '/visitors', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ name, phone, description })
                });
                if (response.ok) {
                    showNotification('Visitor added successfully');
                    
                    // Clear inputs
                    document.getElementById('visitorName').value = '';
                    document.getElementById('visitorPhone').value = '';
                    document.getElementById('visitorDescription').value = '';
                    
                    // Update button back to adding mode if it was in edit mode
                    const btn = document.getElementById('addVisitorBtn');
                    btn.textContent = '+ Save Visitor';
                    btn.className = 'btn btn-secondary btn-small';
                    
                    if (shouldSlide) {
                        // Smoothly scroll back up to the header
                        document.getElementById('addVisitorHeader').scrollIntoView({ behavior: 'smooth', block: 'start' });
                    }
                    
                    // Dynamically append the visitor to avoid a hard page reload
                    const visitorList = document.getElementById('visitorListContainer');
                    const safeName = name.replace(/'/g, "\\'");
                    const safePhone = phone.replace(/'/g, "\\'");
                    const safeDesc = description.replace(/'/g, "\\'");
                    
                    // Look to remove existing item if it was an update
                    const items = visitorList.getElementsByClassName('visitor-item');
                    for (let i = 0; i < items.length; i++) {
                        if (items[i].innerHTML.includes(name)) {
                            items[i].remove();
                            break;
                        }
                    }

                    const newItem = document.createElement('div');
                    newItem.className = 'visitor-item';
                    newItem.innerHTML = `
                        <div class="visitor-icon">👤</div>
                        <div class="visitor-info">
                            <div class="visitor-name">${name} ${phone ? '(' + phone + ')' : ''}</div>
                            <div class="visitor-desc">${description}</div>
                        </div>
                        <div class="visitor-actions">
                            <button class="btn btn-secondary btn-small" style="font-size: 10px; padding: 2px 8px; height: 24px;" 
                                    onclick="editVisitor('${safeName}', '${safePhone}', '${safeDesc}')">
                                EDIT
                            </button>
                            <button class="btn" style="font-size: 10px; color: #c53030; background: #fff5f5; border: 1px solid #feb2b2; padding: 2px 8px; height: 24px;" 
                                    onclick="deleteVisitor('${safeName}')">
                                DELETE
                            </button>
                        </div>
                    `;
                    visitorList.appendChild(newItem);
                }
            } catch (error) {
                showNotification('Error adding visitor', 'error');
            }
        }

        // Agenda
        async function createAgenda(isInline = false) {
            if (!currentMeetingId) {
                showNotification('No active meeting selected', 'warning');
                return;
            }

            const suffix = isInline ? 'inline' : '';
            const id = (type) => isInline ? 'inlineAgenda' + type : 'agenda' + type;

            const data = {
                meetingId: currentMeetingId,
                groupName: groupName,
                title: document.getElementById(isInline ? 'inlineAgendaTitle' : 'agendaTitle').value,
                description: document.getElementById(isInline ? 'inlineAgendaDescription' : 'agendaDescription').value,
                proposerId: isInline ? '' : document.getElementById('agendaProposer').value,
                seconderId: isInline ? '' : document.getElementById('agendaSeconder').value,
                thirdId: isInline ? '' : document.getElementById('agendaThird').value
            };

            if (!data.title) {
                showNotification('Please enter agenda title', 'error');
                return;
            }

            try {
                const response = await fetch('/proceedings/api/agenda', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                
                if (response.ok) {
                    showNotification('Agenda item created!');
                    setTimeout(() => {
                        window.location.href = window.location.pathname + '?meetingId=' + currentMeetingId + '&tab=agenda';
                    }, 1000);
                }
            } catch (error) {
                showNotification('Error creating agenda', 'error');
            }
        }

        async function updateAgendaStatus(agendaId, status) {
            try {
                const response = await fetch('/proceedings/api/agenda/' + agendaId, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ status })
                });
                
                if (response.ok) {
                    showNotification('Agenda status updated');
                    setTimeout(() => window.location.reload(), 800);
                }
            } catch (error) {
                showNotification('Error updating agenda', 'error');
            }
        }

        // Voting logic
        let pendingVotes = {};

        function setLocalVote(agendaId, memberId, voteType, btn) {
            if (!pendingVotes[agendaId]) pendingVotes[agendaId] = {};
            
            // Toggle active state in UI
            const row = btn.closest('.vote-options-local');
            row.querySelectorAll('.v-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');

            // Store in local state
            pendingVotes[agendaId][memberId] = voteType;
        }

        async function submitVotes(agendaId) {
            const votesForAgenda = pendingVotes[agendaId] || {};
            const voteData = [];

            // Get comments too
            const agendaArea = document.getElementById(`voting-area-${agendaId}`);
            const memberRows = agendaArea.querySelectorAll('.member-vote-row');
            
            memberRows.forEach(row => {
                const buttons = row.querySelector('.v-btn.active');
                if (!buttons) return; // Skip if no vote cast for this member in this session
                
                const memberId = buttons.getAttribute('data-member');
                const voteType = pendingVotes[agendaId][memberId];
                const commentInput = row.querySelector('.vote-comment-input');
                const comment = commentInput ? commentInput.value : '';

                voteData.push({
                    memberId,
                    voteType,
                    comment
                });
            });

            if (voteData.length === 0) {
                showNotification('Please record at least one vote before submitting.', 'error');
                return;
            }

            try {
                const response = await fetch('/proceedings/api/votes/batch', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        agendaId,
                        votes: voteData,
                        groupName
                    })
                });

                const result = await response.json();
                if (result.success) {
                    showNotification('Votes and comments recorded successfully');
                    
                    // Update counts in UI
                    if (result.counts) {
                        const sCount = document.getElementById(`count-support-${agendaId}`);
                        const aCount = document.getElementById(`count-against-${agendaId}`);
                        const abCount = document.getElementById(`count-abstain-${agendaId}`);
                        if (sCount) sCount.textContent = result.counts.support;
                        if (aCount) aCount.textContent = result.counts.against;
                        if (abCount) abCount.textContent = result.counts.abstain;
                    }

                    // Refresh to show new comments below description
                    setTimeout(() => location.reload(), 1000);
                } else {
                    showNotification(result.message || 'Error recording votes', 'error');
                }
            } catch (error) {
                console.error('Error submitting votes:', error);
                showNotification('Network error recording votes', 'error');
            }
        }

        // Minutes
        async function createMinute() {
            if (!currentMeetingId) {
                showNotification('Please select a meeting first', 'error');
                return;
            }

            const data = {
                meetingId: currentMeetingId,
                groupName: groupName,
                title: document.getElementById('minuteTitle').value,
                content: document.getElementById('minuteContent').value
            };

            if (!data.title || !data.content) {
                showNotification('Please fill in required fields', 'error');
                return;
            }

            try {
                const response = await fetch('/proceedings/api/minutes', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                if (response.ok) {
                    showNotification('Minute added');
                    setTimeout(() => window.location.reload(), 800);
                }
            } catch (error) {
                showNotification('Error creating minute', 'error');
            }
        }

        async function updateMinuteStatus(minuteId, status) {
            try {
                const response = await fetch('/proceedings/api/minutes/' + minuteId, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ status })
                });
                if (response.ok) {
                    showNotification('Minute ' + status);
                    setTimeout(() => window.location.reload(), 800);
                }
            } catch (error) {
                showNotification('Error updating minute', 'error');
            }
        }

        // Final tab
        async function saveChairpersonNote() {
            if (!currentMeetingId) return;
            
            const note = document.getElementById('chairpersonNote').value;
            try {
                const response = await fetch('/proceedings/api/meetings/' + currentMeetingId, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ chairpersonNote: note })
                });
                if (response.ok) {
                    showNotification('Comments saved');
                }
            } catch (error) {
                showNotification('Error saving comments', 'error');
            }
        }

        async function saveAdjournment() {
            if (!currentMeetingId) return;
            
            const note = document.getElementById('adjournmentNote').value;
            try {
                const response = await fetch('/proceedings/api/meetings/' + currentMeetingId, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ adjournmentNote: note, status: 'adjourned' })
                });
                if (response.ok) {
                    showNotification('Meeting adjourned');
                    setTimeout(() => window.location.reload(), 1000);
                }
            } catch (error) {
                showNotification('Error saving adjournment', 'error');
            }
        }

        // Project
        async function createProject() {
            const data = {
                groupName: groupName,
                title: document.getElementById('projectTitle').value,
                objective: document.getElementById('projectObjective').value,
                budget: document.getElementById('projectBudget').value,
                targetDate: document.getElementById('projectTargetDate').value
            };

            if (!data.title) {
                showNotification('Please enter project title', 'error');
                return;
            }

            try {
                const response = await fetch('/proceedings/api/projects', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                
                if (response.ok) {
                    showNotification('Project created!');
                    closeModal('projectModal');
                    setTimeout(() => window.location.reload(), 1000);
                }
            } catch (error) {
                showNotification('Error creating project', 'error');
            }
        }

        async function updateMeetingStatus(meetingId, status) {
            try {
                const response = await fetch('/proceedings/api/meetings/' + meetingId, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ status })
                });
                
                if (response.ok) {
                    showNotification('Meeting status: ' + status);
                    setTimeout(() => window.location.reload(), 1000);
                }
            } catch (error) {
                showNotification('Error updating status', 'error');
            }
        }

        // Collapse toggle
        function toggleCollapse(id) {
            const body = document.getElementById(id);
            const arrow = document.getElementById('arrow_' + id);
            
            if (body.style.display === 'none') {
                body.style.display = 'block';
                arrow.classList.add('open');
            } else {
                body.style.display = 'none';
                arrow.classList.remove('open');
            }
        }

        function confirmDeleteMeeting() {
            if (!currentMeetingId) return;
            
            const meetingTitle = document.querySelector('#meetingSelect option:checked').text;
            document.getElementById('deleteMeetingMsg').innerHTML = `Are you sure you want to permanently delete <strong>"${meetingTitle}"</strong>?`;
            
            // Set the onclick for the confirmation button
            const confirmBtn = document.getElementById('confirmDeleteBtn');
            confirmBtn.onclick = async () => {
                confirmBtn.disabled = true;
                confirmBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Deleting...';
                
                try {
                    const response = await fetch(`/proceedings/api/meetings/${currentMeetingId}`, {
                        method: 'DELETE'
                    });
                    
                    const result = await response.json();
                    if (result.success) {
                        showNotification('Meeting deleted successfully');
                        setTimeout(() => {
                            window.location.href = `/proceedings/${encodeURIComponent(groupName)}`;
                        }, 1000);
                    } else {
                        showNotification(result.error || 'Error deleting meeting', 'error');
                        confirmBtn.disabled = false;
                        confirmBtn.innerHTML = 'Delete';
                    }
                } catch (error) {
                    console.error('Error deleting meeting:', error);
                    showNotification('Network error deleting meeting', 'error');
                    confirmBtn.disabled = false;
                    confirmBtn.innerHTML = 'Delete';
                }
            };
            
            document.getElementById('deleteMeetingModal').classList.add('active');
        }

        // Quick actions
        // Check for tab parameter on load
        window.addEventListener('load', () => {
            const urlParams = new URLSearchParams(window.location.search);
            const tabParam = urlParams.get('tab');
            if (tabParam) {
                setTimeout(() => openTab(tabParam), 100);
            }
        });

        // Notifications
        function showNotification(message, type = 'success') {
            const existing = document.querySelector('.notification');
            if (existing) existing.remove();

            const notification = document.createElement('div');
            notification.className = `notification ${type}`;
            notification.innerHTML = `
                <span>${type === 'error' ? '❌' : '✅'}</span>
                <span>${message}</span>
            `;
            document.body.appendChild(notification);

            setTimeout(() => notification.classList.add('show'), 100);
            setTimeout(() => {
                notification.classList.remove('show');
                setTimeout(() => notification.remove(), 300);
            }, 3000);
        }

        // Counter helper
        function updateCounter(inputId, counterId) {
            const input = document.getElementById(inputId);
            const counter = document.getElementById(counterId);
            if (input && counter) {
                counter.textContent = `${input.value.length}/${input.maxLength}`;
            }
        }

        // Prevent double-tap zoom on buttons
        let lastTouchEnd = 0;
        document.addEventListener('touchend', function(event) {
            const now = Date.now();
            if (now - lastTouchEnd <= 300) {
                event.preventDefault();
            }
            lastTouchEnd = now;
        }, false);
    </script>
</body>
