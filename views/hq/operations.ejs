<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Operations Dashboard</title>
  
  <!-- Icons & Fonts -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  <style>
    /* =========================
       VARIABLES & RESET
    ========================= */
    :root {
      --primary: #4f46e5;
      --primary-hover: #4338ca;
      --primary-light: #e0e7ff;
      --secondary: #64748b;
      --success: #10b981;
      --success-bg: #d1fae5;
      --success-border: #34d399;
      --danger: #ef4444;
      --danger-bg: #fee2e2;
      --danger-border: #f87171;
      --bg-body: #f3f4f6;
      --bg-surface: #ffffff;
      --text-main: #1f2937;
      --text-light: #6b7280;
      --shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
      --shadow-hover: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
      --radius: 12px;
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      padding: 30px 20px;
      font-family: 'Inter', sans-serif;
      background: var(--bg-body);
      background-image: radial-gradient(#e5e7eb 1px, transparent 1px);
      background-size: 24px 24px;
      color: var(--text-main);
      min-height: 100vh;
    }

    h1 {
      margin-bottom: 40px;
      text-align: center;
      font-size: 32px;
      font-weight: 800;
      color: var(--text-main);
      letter-spacing: -0.5px;
    }
    
    h1 i { color: var(--primary); margin-right: 10px; }

    /* =========================
       LAYOUT & CARDS
    ========================= */
    .wrap {
      max-width: 1200px;
      margin: auto;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 25px;
      animation: fadeIn 0.5s ease;
    }

    .sec {
      background: var(--bg-surface);
      border-radius: var(--radius);
      padding: 30px;
      box-shadow: var(--shadow);
      transition: transform 0.3s ease, box-shadow 0.3s ease;
      border: 1px solid rgba(255,255,255,0.5);
    }

    .sec:hover {
      transform: translateY(-5px);
      box-shadow: var(--shadow-hover);
      border-color: #e5e7eb;
    }

    /* =========================
       HEADERS
    ========================= */
    .ttl {
      margin: 0 0 20px 0;
      font-size: 18px;
      font-weight: 700;
      color: var(--text-main);
      display: flex;
      align-items: center;
      gap: 12px;
      padding-bottom: 15px;
      border-bottom: 1px solid #f3f4f6;
    }

    .ttl i {
      color: var(--primary);
      background: var(--primary-light);
      width: 32px;
      height: 32px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 8px;
      font-size: 14px;
    }

    /* Specific Icon Colors per Section */
    #sec-system .ttl i { color: #3b82f6; background: #dbeafe; }
    #sec-access .ttl i { color: #8b5cf6; background: #f3e8ff; }
    #sec-users .ttl i { color: #f59e0b; background: #fef3c7; }
    #sec-groups .ttl i { color: #10b981; background: #d1fae5; }
    #sec-docs .ttl i { color: #64748b; background: #f1f5f9; }

    /* =========================
       BUTTONS
    ========================= */
    .btns {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .btn {
      appearance: none;
      border: 1px solid transparent;
      background: white;
      color: var(--text-main);
      padding: 12px 16px;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 500;
      cursor: pointer;
      text-align: left;
      transition: all 0.2s ease;
      display: flex;
      align-items: center;
      justify-content: space-between;
      box-shadow: 0 1px 2px rgba(0,0,0,0.05);
      border: 1px solid #e5e7eb;
    }

    .btn:hover {
      border-color: var(--primary);
      color: var(--primary);
      background: #f9fafb;
      transform: translateX(2px);
    }
    
    .btn i { color: #9ca3af; font-size: 12px; transition: color 0.2s; }
    .btn:hover i { color: var(--primary); }

    /* Primary/Action Buttons (Inside Forms) */
    .btn-action {
      width: 100%;
      justify-content: center;
      gap: 8px;
      background: var(--primary);
      color: white;
      font-weight: 600;
    }
    
    .btn-action:hover { background: var(--primary-hover); color: white; }

    .btn:disabled { opacity: 0.6; cursor: not-allowed; }

    .btn.danger {
      background: var(--danger-bg);
      color: var(--danger);
      border-color: var(--danger-border);
      justify-content: center;
    }
    .btn.danger:hover { background: var(--danger); color: white; }

    /* =========================
       FORMS
    ========================= */
    .form-card {
      max-width: 500px;
      margin: 40px auto;
      background: white;
      padding: 40px;
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      text-align: center;
      border-top: 4px solid var(--primary);
    }

    label {
      display: block;
      text-align: left;
      font-size: 13px;
      font-weight: 600;
      margin-bottom: 6px;
      color: var(--text-light);
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    input, select {
      width: 100%;
      padding: 12px;
      border-radius: 8px;
      border: 1px solid #d1d5db;
      font-size: 15px;
      margin-bottom: 16px;
      background: #f9fafb;
      transition: all 0.2s;
    }

    input:focus, select:focus {
      outline: none;
      border-color: var(--primary);
      background: white;
      box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.1);
    }

    /* =========================
       VERIFIED BOX STYLING
    ========================= */
    .verified-box-wrapper {
      margin-top: 25px;
      padding: 20px;
      background: var(--success-bg);
      border: 1px solid var(--success-border);
      border-radius: var(--radius);
      text-align: center;
    }

    #verified-admin-name {
      font-size: 18px;
      font-weight: 700;
      color: #064e3b;
      margin: 0 0 15px 0;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
    }

    #phone-result {
      min-height: 24px;
      font-size: 14px;
      margin-bottom: 10px;
      font-weight: 500;
    }

    /* =========================
       UTILS
    ========================= */
    .hidden { display: none !important; }
    
    @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

    @media (max-width: 600px) {
      h1 { font-size: 24px; }
      .wrap { grid-template-columns: 1fr; }
      .form-card { padding: 25px; width: 100%; }
    }
  </style>
</head>

<body>

  <h1><i class="fa-solid fa-gauge-high"></i> Operational Dashboard</h1>

  <!-- ================= MAIN DASHBOARD ================= -->
  <div class="wrap" id="main-wrap">

    <section class="sec" id="sec-system">
      <div class="ttl"><i class="fa-solid fa-server"></i> System Status</div>
      <div class="btns">
        <button class="btn"><span>System Online / Offline</span> <i class="fa-solid fa-chevron-right"></i></button>
        <button class="btn"><span>Operational Mode</span> <i class="fa-solid fa-chevron-right"></i></button>
        <button class="btn"><span>Last Restart</span> <i class="fa-solid fa-chevron-right"></i></button>
      </div>
    </section>

    <section class="sec" id="sec-access">
      <div class="ttl"><i class="fa-solid fa-shield-halved"></i> Access & Security</div>
      <div class="btns">
        <button class="btn"><span>User Role</span> <i class="fa-solid fa-chevron-right"></i></button>
        <button class="btn"><span>Session Status</span> <i class="fa-solid fa-chevron-right"></i></button>
        <button class="btn"><span>Access Rules</span> <i class="fa-solid fa-chevron-right"></i></button>
        <button id="btn-create-admin" class="btn" style="color: var(--primary); font-weight:600; border-color: var(--primary-light); background: #eef2ff;">
          <span>Create Admin Account</span> <i class="fa-solid fa-plus"></i>
        </button>
      </div>
    </section>

    <section class="sec" id="sec-users">
      <div class="ttl"><i class="fa-solid fa-users"></i> User Management</div>
      <div class="btns">
        <button class="btn"><span>Total Users</span> <i class="fa-solid fa-chevron-right"></i></button>
        <button class="btn"><span>Active Users</span> <i class="fa-solid fa-chevron-right"></i></button>
        <button class="btn"><span>Role Assignment</span> <i class="fa-solid fa-chevron-right"></i></button>
      </div>
    </section>

    <section class="sec" id="sec-groups">
      <div class="ttl"><i class="fa-solid fa-users-gear"></i> Group Settings</div>
      <div class="btns">
        <button class="btn"><span>Total Groups</span> <i class="fa-solid fa-chevron-right"></i></button>
        <button class="btn"><span>Member Limit</span> <i class="fa-solid fa-chevron-right"></i></button>
        <button class="btn"><span>Group Registration</span> <i class="fa-solid fa-chevron-right"></i></button>
        <button class="btn"><span>Approval Required</span> <i class="fa-solid fa-chevron-right"></i></button>
      </div>
    </section>

    <section class="sec" id="sec-docs">
      <div class="ttl"><i class="fa-solid fa-file-contract"></i> Documents</div>
      <div class="btns">
        <button class="btn"><span>Total Files</span> <i class="fa-solid fa-chevron-right"></i></button>
        <button class="btn"><span>Public Files</span> <i class="fa-solid fa-chevron-right"></i></button>
        <button class="btn"><span>Restricted Files</span> <i class="fa-solid fa-chevron-right"></i></button>
      </div>
    </section>

  </div>

  <!-- ================= CREATE ADMIN ACTIONS ================= -->
  <div id="create-admin-form" class="form-card hidden">
    <h2 class="ttl" style="justify-content: center; border: none;"><i class="fa-solid fa-user-shield"></i> Admin Actions</h2>
    <div class="btns">
      <button id="btn-activate-admin" class="btn btn-action"><i class="fa-solid fa-check-circle"></i> Activate Admin</button>
      <button id="btn-register-admin" class="btn btn-action"><i class="fa-solid fa-user-plus"></i> Register Admin</button>
      <button class="btn btn-action" style="background: #fee2e2; color: #b91c1c;"><i class="fa-solid fa-ban"></i> Block Admin</button>
    </div>
    <br>
    <button id="back-dashboard-create" class="btn danger">Back to Dashboard</button>
  </div>

  <!-- ================= PHONE VERIFICATION & REGISTRATION ================= -->
  <div id="pending-activation" class="form-card hidden">
    <h2 class="ttl" style="justify-content: center; border: none;"><i class="fa-solid fa-mobile-screen"></i> Verify & Register Admin</h2>

    <!-- Step 1: Phone Check -->
    <form id="phone-check-form">
      <label>Phone Number</label>
      <input type="text" id="phone-input" placeholder="e.g. 0711155510">
      <button type="submit" class="btn btn-action">Verify</button>
    </form>

    <div id="phone-result"></div>

    <!-- Step 2: Verified Actions (Includes Geo-Location Dropdowns) -->
    <div id="verified-actions" class="verified-box-wrapper hidden">
      <h3 id="verified-admin-name">
        <i class="fa-solid fa-circle-check" style="font-size: 20px;"></i>
        <span id="name-text"></span>
      </h3>

      <form id="verified-register-form">
        
        <!-- GEO LOCATION SECTION START -->
        <label style="color: var(--primary); border-top: 1px solid #a7f3d0; padding-top:10px; margin-top:10px;">Region Assignment</label>
        
        <select id="reg-county">
          <option value="">Select County</option>
        </select>

        <select id="reg-constituency" disabled>
          <option value="">Select Constituency</option>
        </select>

        <select id="reg-ward" disabled>
          <option value="">Select Ward</option>
        </select>
        <!-- GEO LOCATION SECTION END -->

        <label>Department</label>
        <select id="verified-docet">
          <option value="">-- Select Department --</option>
          <option>IT</option>
          <option>Operation</option>
          <option>Finance</option>
          <option>Human Resource</option>
          <option>Relation</option>
          <option>Compliance</option>
        </select>

        <button type="submit" class="btn btn-action" style="background: var(--success); margin-top:10px;">Complete Registration</button>
      </form>
    </div>

    <button id="back-dashboard-pending" class="btn danger">Back</button>
  </div>

  <!-- ================= REGISTER ADMIN (LEGACY) ================= -->
  <div id="register" class="form-card hidden">
    <h2 class="ttl" style="justify-content: center; border: none;"><i class="fa-solid fa-file-pen"></i> Register Admin</h2>

    <form>
      <label>Phone Number</label>
      <input type="text" placeholder="e.g. 0711155510">

      <label>Department</label>
      <select>
        <option value="">-- Select Department --</option>
        <option>IT</option>
        <option>Operation</option>
        <option>Finance</option>
        <option>Human Resource</option>
        <option>Relation</option>
        <option>Compliance</option>
      </select>

      <button class="btn btn-action">Register</button>
    </form>

    <button id="back-dashboard-register" class="btn danger">Back</button>
  </div>

