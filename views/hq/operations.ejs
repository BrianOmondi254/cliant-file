const nameText = document.getElementById("name-text"); 
const verifiedForm = document.getElementById("verified-register-form");
const verifiedDocet = document.getElementById("verified-docet");

/* GEO DROPDOWNS */
const countySelect = document.getElementById("reg-county");
const constituencySelect = document.getElementById("reg-constituency");
const wardSelect = document.getElementById("reg-ward");


/* =========================
   VIEW CONTROLLER
========================= */
function hideAllViews() {
  Object.values(views).forEach(v => v && v.classList.add("hidden"));
}

function showView(name) {
  hideAllViews();
  views[name].classList.remove("hidden");
  views[name].scrollIntoView({ behavior: "smooth" });
}

/* =========================
   GEO DROPDOWN LOGIC
========================= */
// Populate Counties
Object.keys(kenyaGeoData).sort().forEach(county => {
  const option = document.createElement("option");
  option.value = county;
  option.textContent = county;
  countySelect.appendChild(option);
});

// County Change Event
countySelect.addEventListener("change", () => {
  const selectedCounty = countySelect.value;
  
  // Reset Constituency and Ward
  constituencySelect.innerHTML = '<option value="">Select Constituency</option>';
  wardSelect.innerHTML = '<option value="">Select Ward</option>';
  
  if (selectedCounty && kenyaGeoData[selectedCounty]) {
    constituencySelect.disabled = false;
    const constituencies = Object.keys(kenyaGeoData[selectedCounty]).sort();
    
    constituencies.forEach(constituency => {
      const option = document.createElement("option");
      option.value = constituency;
      option.textContent = constituency;
      constituencySelect.appendChild(option);
    });
  } else {
    constituencySelect.disabled = true;
    wardSelect.disabled = true;
  }
});

// Constituency Change Event
constituencySelect.addEventListener("change", () => {
  const selectedCounty = countySelect.value;
  const selectedConstituency = constituencySelect.value;
  
  // Reset Ward
  wardSelect.innerHTML = '<option value="">Select Ward</option>';
  
  if (selectedCounty && selectedConstituency && kenyaGeoData[selectedCounty][selectedConstituency]) {
    wardSelect.disabled = false;
    const wards = kenyaGeoData[selectedCounty][selectedConstituency].sort();
    
    wards.forEach(ward => {
      const option = document.createElement("option");
      option.value = ward;
      option.textContent = ward;
      wardSelect.appendChild(option);
    });
  } else {
    wardSelect.disabled = true;
  }
});


/* =========================
   RESET VERIFICATION STATE
========================= */
function resetVerification() {
  phoneInput.value = "";
  phoneResult.innerHTML = "";

  if (verifiedBox) verifiedBox.classList.add("hidden");
  if (nameText) nameText.textContent = "";
  if (verifiedDocet) verifiedDocet.value = "";
  
  // Reset Geo Selects
  countySelect.value = "";
  constituencySelect.innerHTML = '<option value="">Select Constituency</option>';
  constituencySelect.disabled = true;
  wardSelect.innerHTML = '<option value="">Select Ward</option>';
  wardSelect.disabled = true;

  // show phone input again
  if (phoneForm) phoneForm.classList.remove("hidden");
}

/* =========================
   NAVIGATION EVENTS
========================= */
btnCreateAdmin.onclick = () => showView("createAdmin");

btnActivateAdmin.onclick = () => {
  resetVerification();
  showView("verifyAdmin");
};

btnRegisterAdmin.onclick = () => showView("registerAdmin");

btnBackCreate.onclick =
btnBackVerify.onclick =
btnBackRegister.onclick = () => {
  resetVerification();
  showView("dashboard");
};

/* =========================
   PHONE VERIFICATION LOGIC
========================= */
if (phoneForm) {
  phoneForm.addEventListener("submit", async (e) => {
    e.preventDefault();

    const phone = phoneInput.value.trim();
    if (!phone) {
      phoneResult.textContent = "Please enter phone number";
      phoneResult.style.color = "var(--danger)";
      return;
    }

    phoneResult.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Verifying...';
    phoneResult.style.color = "var(--secondary)";

    try {
      const res = await fetch(`/hq/check-admin/${phone}`);
      if (!res.ok) throw new Error();

      const admin = await res.json();

      /* SUCCESS: SHOW NAME + DISPLAY VERIFIED REGISTER FORM */
      phoneForm.classList.add("hidden"); 
      phoneResult.innerHTML = "";        

      nameText.textContent = admin.name;
      verifiedBox.classList.remove("hidden"); 

    } catch {
      phoneResult.textContent = "Admin not found";
      phoneResult.style.color = "var(--danger)";
    }
  });
}

/* =========================
   REGISTER VERIFIED ADMIN
========================= */
if (verifiedForm) {
  verifiedForm.addEventListener("submit", async (e) => {
    e.preventDefault();

    const docet = verifiedDocet.value;
    const name = nameText.textContent;
    
    // Get Geo Data
    const county = countySelect.value;
    const constituency = constituencySelect.value;
    const ward = wardSelect.value;

    if (!docet) {
      alert("Please select a department");
      return;
    }
    
    if (!county || !constituency || !ward) {
      alert("Please select a County, Constituency, and Ward");
      return;
    }

    try {
     const res = await fetch("/hq/register-verified-admin", {
       method: "POST",
       headers: { "Content-Type": "application/json" },
       body: JSON.stringify({ name, docet, county, constituency, ward })
     });

     const data = await res.json();

     if (!res.ok) {
       alert(data.message || "Failed to register admin");
       return;
     }

     alert(data.message); 
     resetVerification();
     showView("dashboard");

    } catch (err) {
      console.error(err);
      alert("Failed to register admin");
    }
  });
}

/* =========================
   INITIAL STATE
========================= */
showView("dashboard");
</script>

</body>
</html>