      async function fetchRecentEvents(type) {
        const listId = `${type}EventsList`;
        const listElement = document.getElementById(listId);
        listElement.innerHTML = '<p style="text-align: center; color: var(--secondary); font-size: 0.8rem; padding: 20px;"><i class="fa-solid fa-spinner fa-spin"></i> Loading events...</p>';

        try {
          const res = await fetch('/hq/compliance/get-events');
          const data = await res.json();

          const filteredEvents = data.events.filter(e => {
            if (type === 'agent') return e.agentPhone;
            if (type === 'dealer') return e.dealerPhone && !e.agentPhone;
            return false;
          });

          if (filteredEvents.length === 0) {
            listElement.innerHTML = '<p style="text-align: center; color: var(--secondary); font-size: 0.8rem; padding: 20px;">No recent activity found.</p>';
            return;
          }

          listElement.innerHTML = filteredEvents.map(e => `
            <div class="event-item" style="display: flex; justify-content: space-between; align-items: center; padding: 10px; border-bottom: 1px solid #f1f5f9; font-size: 0.8rem;">
              <div>
                <div style="font-weight: 600; color: var(--primary);">
                  ${type === 'agent' ? 'Agent Created' : 'Dealer Created'}
                </div>
                <div style="color: var(--secondary); margin-top: 2px;">
                  ${type === 'agent' ? `A: ${e.agentPhone} | D: ${e.dealerPhone}` : `D: ${e.dealerPhone} | HQ: ${e.hqPhone}`}
                </div>
                <div style="font-size: 0.7rem; color: #94a3b8; margin-top: 2px;">
                  ${new Date(e.createdAt).toLocaleString()}
                </div>
              </div>
              <button class="btn btn-danger btn-sm" onclick="blockNumber('${type === 'agent' ? e.agentPhone : e.dealerPhone}')" style="font-size: 0.65rem; padding: 4px 8px;">
                <i class="fa-solid fa-ban"></i> Block
              </button>
            </div>
          `).join('');

        } catch (err) {
          listElement.innerHTML = '<p style="text-align: center; color: var(--danger); font-size: 0.8rem; padding: 20px;">Failed to load events.</p>';
        }
      }

      async function blockNumber(phone) {
        if (!confirm(`Are you sure you want to block ${phone}? This will restrict their account access.`)) return;

        try {
          const res = await fetch('/hq/compliance/block-number', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ phoneNumber: phone, reason: 'Dashboard Blocking' })
          });
          const result = await res.json();
          if (result.success) {
            showToast(result.message);
          } else {
            showToast(result.message, true);
          }
        } catch (err) {
          showToast('Blocking failed', true);
        }
      }

      // Set-up
      document.addEventListener('DOMContentLoaded', () => {
        initAgentCounties();
        initDealerCounties();
        setupForm('regForm', 'registration', 'Registration Standards Saved');
        setupForm('memForm', 'membership', 'Membership Rules Saved');
        setupForm('periodForm', 'periods', 'Period Configuration Saved');

        // Initial load of events
        fetchRecentEvents('agent');
        fetchRecentEvents('dealer');
        // Update compliance status badges on load
        updateComplianceStatus();
        // Apply any accepted messages (disable edited accounts)
        applyAcceptedMessagesOnLoad();
      });

      // Open compliance messages (default messages route)
      function openComplianceMessages() {
        window.location.href = '/hq/messages';
      }
    </script>
  </body>
