    <div id="toast-container"></div>

    <script>
      // UI Navigation
      function openSubAccount(id) {
        document.getElementById('mainDashboard').style.display = 'none';
        document.querySelectorAll('.single-view').forEach(v => v.style.display = 'none');
        const view = document.getElementById(id);
        view.style.display = 'block';
        view.style.animation = 'none';
        void view.offsetHeight;
        view.style.animation = 'slideUp 0.4s ease-out';
        if (id === 'pa') loadPersonalClients();
      }

      function backToDashboard() {
        document.querySelectorAll('.single-view').forEach(v => v.style.display = 'none');
        document.getElementById('mainDashboard').style.display = 'grid';
      }

      function openPanel(panelId) {
        const main = document.getElementById('groupMainView');
        const panel = document.getElementById(panelId);
        if (main && panel) {
          main.style.display = 'none';
          panel.style.display = 'block';
          // When opening registration standards, check tbank.json status
          if (panelId === 'panel-reg-standards' || panelId === 'panel-mem-standards' || panelId === 'panel-periods') {
            checkComplianceSection(panelId);
          }
        }
      }

      function closePanel(panelId) {
        const main = document.getElementById('groupMainView');
        const panel = document.getElementById(panelId);
        if (main && panel) {
          panel.style.display = 'none';
          main.style.display = 'block';
        }
      }

      function triggerAction(msg, isError = false) {
        showToast(msg, isError);
      }

      function showToast(msg, isError = false) {
        const container = document.getElementById('toast-container');
        const toast = document.createElement('div');
        toast.className = `toast ${isError ? 'error' : 'success'}`;
        const icon = isError ? '<i class="fa-solid fa-triangle-exclamation"></i>' : '<i class="fa-solid fa-circle-check"></i>';
        toast.innerHTML = `${icon} <span>${msg}</span>`;
        container.appendChild(toast);
        requestAnimationFrame(() => toast.classList.add('show'));
        setTimeout(() => {
          toast.classList.remove('show');
          setTimeout(() => toast.remove(), 400);
        }, 3000);
      }

      // ----- Client-side message helpers (localStorage prototype) -----
      function getHqMessages() { try { return JSON.parse(localStorage.getItem('hq_messages')||'[]'); } catch(e){ return []; } }
      function saveHqMessages(list) { localStorage.setItem('hq_messages', JSON.stringify(list)); }
      function addHqMessage(m){ const list = getHqMessages(); list.unshift(m); saveHqMessages(list); }

      // Compliance view message UI (badge + overlay)
      function renderCompMessagesList(){
        const list = getHqMessages();
        const container = document.getElementById('comp-messages-list');
        if(!container) return;
        container.innerHTML = '';
        if(!list.length){ container.innerHTML = '<div style="color:var(--secondary);padding:10px">No messages</div>'; return; }
        list.forEach(m=>{
          const wrap = document.createElement('div'); wrap.style.cssText='border-bottom:1px solid rgba(0,0,0,0.06);padding:10px;';
          const meta = document.createElement('div'); meta.style.cssText='display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;font-weight:700;';
          meta.innerHTML = `<div>${m.docketName} <small style="color:var(--secondary);">(${m.code})</small></div><div style="font-size:0.8rem;color:var(--secondary);">${new Date(m.date).toLocaleString()}</div>`;
          const details = document.createElement('div'); details.style.cssText='color:var(--text-muted);font-size:0.9rem;margin-bottom:8px;';
          details.textContent = `From: ${m.senderDetails}${m.processorPhone? ' / ' + m.processorPhone: ''} — Account: ${m.accountToAdjust} — Option: ${m.optionClicked || ''}`;
          wrap.appendChild(meta); wrap.appendChild(details);
          const controls = document.createElement('div');
          if(m.status === 'pending'){
            const a = document.createElement('button'); a.textContent='Accept'; a.style.cssText='background:var(--primary);color:white;border:none;padding:6px 10px;border-radius:6px;margin-right:8px;cursor:pointer;';
            a.onclick = ()=>{ acceptCompMessage(m.id); };
            const d = document.createElement('button'); d.textContent='Cancel'; d.style.cssText='background:#444;color:white;border:none;padding:6px 10px;border-radius:6px;cursor:pointer;';
            d.onclick = ()=>{ declineCompMessage(m.id); };
            controls.appendChild(a); controls.appendChild(d);
          } else {
            const state = document.createElement('span'); state.textContent = m.status.toUpperCase(); state.style.cssText='color:var(--secondary);font-weight:600;'; controls.appendChild(state);
          }
          wrap.appendChild(controls);
          container.appendChild(wrap);
        });
      }

      function refreshCompBadge(){ const list = getHqMessages(); const pending = list.filter(m=>m.status==='pending').length; const el = document.getElementById('comp-msg-count'); const el2 = document.getElementById('comp-msg-count-below'); if (el){ if (pending>0){ el.style.display='inline-block'; el.textContent = pending; } else el.style.display='none'; } if (el2){ if (pending>0){ el2.style.display='inline-block'; el2.textContent = pending; } else el2.style.display='none'; } }

      function openComplianceMessages(){ renderCompMessagesList(); document.getElementById('comp-messages-overlay').style.display='block'; }
      function closeComplianceMessages(){ document.getElementById('comp-messages-overlay').style.display='none'; }

      function acceptCompMessage(id){ const list = getHqMessages(); const m = list.find(x=>x.id===id); if(!m) return; m.status='accepted'; m.acceptedAt=new Date().toISOString(); saveHqMessages(list); renderCompMessagesList(); refreshCompBadge(); showToast && showToast('Accepted'); }
      function declineCompMessage(id){ const list = getHqMessages(); const m = list.find(x=>x.id===id); if(!m) return; m.status='cancelled'; m.cancelledAt=new Date().toISOString(); saveHqMessages(list); renderCompMessagesList(); refreshCompBadge(); showToast && showToast('Cancelled'); }

      function sendUpdateMessage(targetId, accountLabel, docketName, optionClicked){
        const code = Math.floor(10000 + Math.random()*90000).toString();
        const processorName = '<%= (typeof user !== "undefined" && user && user.name) ? user.name : "Processor" %>';
        const processorPhone = '<%= (typeof user !== "undefined" && user && user.phone) ? user.phone : "" %>';
        const msg = {
          id: Date.now() + '-' + Math.random().toString(36).slice(2,8),
          code,
          docketName: docketName || 'Update',
          senderDetails: processorName,
          processorPhone: processorPhone,
          processorLogin: processorName,
          accountToAdjust: accountLabel || '',
          targetId: targetId || '',
          optionClicked: optionClicked || '',
          date: new Date().toISOString(),
          status: 'pending'
        };
        addHqMessage(msg);
        console.log('sendUpdateMessage ->', msg);
        showToast('Message created (code: ' + code + ')');
      }

      // When compliance page loads, disable accepted message targets
      function applyAcceptedMessagesOnLoad(){
        const msgs = getHqMessages();
        msgs.forEach(m=>{
          // Pending messages block editing until processed
          if (m.status === 'pending' && m.targetId){
            const el = document.getElementById(m.targetId);
            if (el){
              const inputs = el.querySelectorAll('input, select, textarea, button');
              inputs.forEach(i=>{ i.disabled = true; i.classList && i.classList.add('disabled-by-message'); });
            }
          }
          // Accepted messages should open the panel and enable editing
          if (m.status === 'accepted'){
            handleAcceptedMessage(m);
          }
        });
      }

      // Fetch compliance data as JSON so forms can be populated
      async function fetchComplianceData(){
        try{
          const res = await fetch('/hq/compliance/data');
          if (!res.ok) return {};
          const json = await res.json();
          return json.data || {};
        } catch(e){ console.error('fetchComplianceData', e); return {}; }
      }

      function enableFormForEditing(formId){
        const form = document.getElementById(formId);
        if (!form) return;
        const inputs = form.querySelectorAll('input, select, textarea, button');
        inputs.forEach(i=>{ i.disabled = false; i.classList && i.classList.remove('disabled-by-message'); });
      }

      function populateMembershipForm(mem){
        const form = document.getElementById('memForm');
        if (!form) return;
        // Radio groups: trustees, officials, members, maxMembers
        ['trustees','officials','members','maxMembers'].forEach(name=>{
          const val = mem[name];
          if (!val) return;
          const input = form.querySelector(`input[name="${name}"][value="${val}"]`);
          if (input) input.checked = true;
        });
      }

      function populatePeriodsForm(period){
        const form = document.getElementById('periodForm');
        if (!form) return;
        ['interval','season'].forEach(name=>{
          const val = period[name];
          if (!val) return;
          const input = form.querySelector(`input[name="${name}"][value="${val}"]`);
          if (input) input.checked = true;
        });
      }

      // Handle a single accepted message: open panel, populate and enable form for editing
      async function handleAcceptedMessage(m){
        try{
          const opt = (m.optionClicked || '').toLowerCase();
          const docket = (m.docketName || '').toLowerCase();
          if (opt.includes('membership') || docket.includes('membership')){
            openPanel('panel-mem-standards');
            const data = await fetchComplianceData();
            populateMembershipForm(data.membership || {});
            enableFormForEditing('memForm');
          } else if (opt.includes('period') || docket.includes('period')){
            openPanel('panel-periods');
            const data = await fetchComplianceData();
            populatePeriodsForm(data.periods || {});
            enableFormForEditing('periodForm');
          } else {
            // Fallback: try to open main group view or focus target element
            if (m.targetId) {
              const el = document.getElementById(m.targetId);
              if (el) {
                el.classList && el.classList.remove('disabled-by-message');
              }
            }
          }
        } catch(e){ console.error('handleAcceptedMessage', e); }
      }

      // Listen for cross-tab changes to messages and act on accepted ones
      window.addEventListener('storage', function(e){
        if (e.key !== 'hq_messages') return;
        try{
          const newList = JSON.parse(e.newValue || '[]');
          // Refresh compliance badge
          refreshCompBadge();
          newList.forEach(m=>{
            if (m && m.status === 'accepted'){
              handleAcceptedMessage(m);
            }
          });
          // If overlay is open, refresh its contents
          if (document.getElementById('comp-messages-overlay') && document.getElementById('comp-messages-overlay').style.display === 'block') renderCompMessagesList();
        } catch(err){ console.error('storage parse', err); }
      });

      // Initialize compliance badge on load
      document.addEventListener('DOMContentLoaded', ()=>{ try{ refreshCompBadge(); } catch(e){} });

      // AJAX Form Handler
      function setupForm(formId, endpoint, successMsg) {
        const form = document.getElementById(formId);
        if (!form) return;

        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          const btn = form.querySelector('button[type="submit"]');
          const original = btn.innerHTML;

          btn.disabled = true;
          btn.innerHTML = '<span class="spinner"></span> Saving...';

          const formData = new FormData(form);
          const data = Object.fromEntries(formData);

          try {
            const res = await fetch(`/hq/compliance/${endpoint}`, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(data)
            });
            const result = await res.json();

            if (result.success) {
              showToast(successMsg);
              // Refresh compliance status badges after a successful save
              updateComplianceStatus();
              if (endpoint === 'registration') { closePanel('panel-reg-standards'); }
              else if (endpoint === 'membership') {
                closePanel('panel-mem-standards');
                // send message only if the 'Send update message to IT' checkbox is checked
                const memForm = document.getElementById('memForm');
                if (memForm && memForm.querySelector('input[name="sendUpdateMessage"]') && memForm.querySelector('input[name="sendUpdateMessage"]').checked) {
                  sendUpdateMessage('ga','Group Account', successMsg, 'Save Membership');
                }
              }
              else if (endpoint === 'periods') {
                closePanel('panel-periods');
                const periodForm = document.getElementById('periodForm');
                if (periodForm && periodForm.querySelector('input[name="sendUpdateMessage"]') && periodForm.querySelector('input[name="sendUpdateMessage"]').checked) {
                  sendUpdateMessage('ga','Group Account', successMsg, 'Save Periods');
                }
              }
            } else {
              showToast(result.message || 'Save failed', true);
            }
          } catch (err) {
            showToast('Network error', true);
            console.error(err);
          } finally {
            btn.disabled = false;
            btn.innerHTML = original;
          }
        });
      }

      // Initialize Agent Panels
      function openAgentPanel(id) {
        document.getElementById('agentMainView').style.display = 'none';
        document.getElementById(id).style.display = 'block';
      }

      function closeAgentPanel(id) {
        document.getElementById(id).style.display = 'none';
        document.getElementById('agentMainView').style.display = 'block';
      }

      // Agent/Dealer regional loaders use API endpoints (locations.json served by /api/locations)

      function initAgentCounties() {
        const countySelect = document.getElementById("agentCounty");
        if (!countySelect) return;
        countySelect.innerHTML = '<option value="">-- Select County --</option>';
        fetch('/api/locations/counties')
          .then(r => r.json())
          .then(list => list.forEach(county => {
            const option = document.createElement('option');
            option.value = county;
            option.textContent = county;
            countySelect.appendChild(option);
          })).catch(err => console.error('Failed to load agent counties', err));
      }

      function loadAgentConstituencies() {
        const countySelect = document.getElementById("agentCounty");
        const constituencySelect = document.getElementById("agentConstituency");
        const wardSelect = document.getElementById("agentWard");
        const selectedCounty = countySelect.value;

        constituencySelect.innerHTML = '<option value="">-- Select Constituency --</option>';
        wardSelect.innerHTML = '<option value="">-- Select Ward --</option>';
        if (!selectedCounty) return;
        return fetch(`/api/locations/${encodeURIComponent(selectedCounty)}/constituencies`)
          .then(r => r.json())
          .then(list => list.forEach(c => {
            const opt = document.createElement('option');
            opt.value = c;
            opt.textContent = c;
            constituencySelect.appendChild(opt);
          })).catch(err => {
            console.error('Failed to load agent constituencies', err);
            return [];
          });
      }

      function loadAgentWards() {
        const countySelect = document.getElementById("agentCounty");
        const constituencySelect = document.getElementById("agentConstituency");
        const wardSelect = document.getElementById("agentWard");
        const selectedCounty = countySelect.value;
        const selectedConstituency = constituencySelect.value;

        wardSelect.innerHTML = '<option value="">-- Select Ward --</option>';
        if (!selectedCounty || !selectedConstituency) return;
        return fetch(`/api/locations/${encodeURIComponent(selectedCounty)}/${encodeURIComponent(selectedConstituency)}/wards`)
          .then(r => r.json())
          .then(list => {
            if (!Array.isArray(list) || list.length === 0) {
              const option = document.createElement('option');
              option.value = '';
              option.textContent = '(No Wards Listed)';
              option.disabled = true;
              wardSelect.appendChild(option);
              return [];
            }
            list.sort().forEach(w => {
              const opt = document.createElement('option');
              opt.value = w;
              opt.textContent = w;
              wardSelect.appendChild(opt);
            });
            return list;
          }).catch(err => {
            console.error('Failed to load agent wards', err);
            return [];
          });
      }

      // Manual ward entry removed — no-op placeholder removed

      let verifiedData = null;

      async function verifyRelations() {
        const agentPhone = document.getElementById('agentPhone').value;
        const dealerPhone = document.getElementById('dealerPhone').value;
        const statusDiv = document.getElementById('relationStatus');
        const locationSection = document.getElementById('locationSection');
        const saveBtn = document.getElementById('saveAgentBtn');

        if (!agentPhone || !dealerPhone) {
          showToast('Both phone numbers are required', true);
          return;
        }

        statusDiv.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Verifying...';
        statusDiv.style.color = 'var(--secondary)';

        try {
          const res = await fetch('/hq/compliance/verify-relations', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ agentPhone, dealerPhone })
          });
          const result = await res.json();

          if (result.success) {
            verifiedData = result.data;
            statusDiv.innerHTML = `
              <div style="background: rgba(16, 185, 129, 0.1); padding: 10px; border-radius: 8px; margin-top: 5px;">
                <div style="color: var(--success); font-weight: 600; margin-bottom: 4px;">
                  <i class="fa-solid fa-circle-check"></i> Relations Verified
                </div>
                <div style="font-size: 0.8rem; color: var(--secondary);">
                  <strong>Agent:</strong> ${result.data.agentName}<br>
                  <strong>Dealer:</strong> ${result.data.dealerName}<br>
                  <strong>Region:</strong> ${result.data.county}, ${result.data.constituency}
                </div>
              </div>
            `;

            // Enable location section
            locationSection.style.opacity = '1';
            locationSection.style.pointerEvents = 'auto';

            // Auto-select County and Constituency if they match verified data
            const countySelect = document.getElementById('agentCounty');
            countySelect.value = result.data.county;
            await loadAgentConstituencies();

            const constituencySelect = document.getElementById('agentConstituency');
            constituencySelect.value = result.data.county ? result.data.constituency : ""; // Safety check
            await loadAgentWards();

            // Auto-select Ward — wait for wards to load then ensure the verified ward is present
            if (result.data.ward) {
              const wardSelect = document.getElementById('agentWard');
              await loadAgentWards();
              let found = false;
              for (let i = 0; i < wardSelect.options.length; i++) {
                if (wardSelect.options[i].value === result.data.ward) {
                  wardSelect.value = result.data.ward;
                  found = true;
                  break;
                }
              }
              if (!found && result.data.ward) {
                const opt = document.createElement('option');
                opt.value = result.data.ward;
                opt.textContent = result.data.ward + ' (Verified)';
                wardSelect.appendChild(opt);
                wardSelect.value = result.data.ward;
              }
            }

            saveBtn.disabled = false;
          } else {
            verifiedData = null;
            statusDiv.innerHTML = `<i class="fa-solid fa-circle-xmark"></i> ${result.message}`;
            statusDiv.style.color = 'var(--danger)';
            locationSection.style.opacity = '0.5';
            locationSection.style.pointerEvents = 'none';
            saveBtn.disabled = true;
          }
        } catch (err) {
          statusDiv.innerHTML = '<i class="fa-solid fa-triangle-exclamation"></i> Verification failed';
          statusDiv.style.color = 'var(--danger)';
        }
      }

      // Dealer Management Logic
      function openDealerPanel(id) {
        document.getElementById('dealerMainView').style.display = 'none';
        document.getElementById(id).style.display = 'block';
      }

      function closeDealerPanel(id) {
        document.getElementById(id).style.display = 'none';
