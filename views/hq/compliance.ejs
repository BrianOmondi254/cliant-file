      // Update status badges for registration/membership/periods based on tbank.json
      async function updateComplianceStatus() {
        try {
          const res = await fetch('/tbank-summary');
          const data = await res.json();
          const comp = data.compliance || {};

          const regs = {
            registration: !!comp.registration,
            membership: !!comp.membership,
            periods: !!comp.periods
          };

          const map = [
            { id: 'btn-reg-standards', ok: regs.registration },
            { id: 'btn-mem-standards', ok: regs.membership },
            { id: 'btn-periods', ok: regs.periods }
          ];

          map.forEach(item => {
            const el = document.getElementById(item.id);
            if (!el) return;
            // remove existing badge
            const existing = el.querySelector('.status-badge');
            if (existing) existing.remove();
            const span = document.createElement('span');
            span.className = 'status-badge ' + (item.ok ? 'updated' : 'unupdated');
            span.textContent = item.ok ? 'Updated' : 'Unupdated';
            // append so it appears on the far right of the button
            el.appendChild(span);
          });
        } catch (err) {
          console.error('Failed to update compliance status', err);
        }
      }

      let verifiedDealerData = null;

      async function verifyDealerRelations() {
        const dealerPhone = document.getElementById('dealerPhoneInput').value;
        const hqPhone = document.getElementById('hqPhoneInput').value;
        const statusDiv = document.getElementById('dealerRelationStatus');
        const locationSection = document.getElementById('dealerLocationSection');
        const saveBtn = document.getElementById('saveDealerBtn');

        if (!dealerPhone || !hqPhone) {
          showToast('Both Dealer and HQ phone numbers are required', true);
          return;
        }

        statusDiv.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Verifying...';
        statusDiv.style.color = 'var(--secondary)';

        try {
          const res = await fetch('/hq/compliance/verify-dealer-relations', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ dealerPhone, hqPhone })
          });
          const result = await res.json();

          if (result.success) {
            verifiedDealerData = result.data;
            statusDiv.innerHTML = `
              <div style="background: rgba(16, 185, 129, 0.1); padding: 10px; border-radius: 8px; margin-top: 5px;">
                <div style="color: var(--success); font-weight: 600; margin-bottom: 4px;">
                  <i class="fa-solid fa-circle-check"></i> Relations Verified
                </div>
                <div style="font-size: 0.8rem; color: var(--secondary);">
                  <strong>Dealer:</strong> ${result.data.dealerName}<br>
                  <strong>HQ Processor:</strong> ${result.data.hqName}<br>
                  <strong>Region:</strong> ${result.data.county}, ${result.data.constituency}
                </div>
              </div>
            `;

            // Enable location section
            locationSection.style.opacity = '1';
            locationSection.style.pointerEvents = 'auto';

            // Auto-select County and Constituency
            const countySelect = document.getElementById('dealerCounty');
            countySelect.value = result.data.county;
            loadDealerConstituencies();

            const constituencySelect = document.getElementById('dealerConstituency');
            constituencySelect.value = result.data.constituency;
            loadDealerWards();

            // Auto-select Ward
            if (result.data.ward) {
              const wardSelect = document.getElementById('dealerWard');
              let found = false;
              for (let i = 0; i < wardSelect.options.length; i++) {
                if (wardSelect.options[i].value === result.data.ward) {
                  wardSelect.value = result.data.ward;
                  found = true;
                  break;
                }
              }
              if (!found && result.data.ward) {
                // Ward not in list — append and select it (no manual-entry flow)
                const opt = document.createElement('option');
                opt.value = result.data.ward;
                opt.textContent = result.data.ward;
                wardSelect.appendChild(opt);
                wardSelect.value = result.data.ward;
              }
            }

            saveBtn.disabled = false;
          } else {
            verifiedDealerData = null;
            statusDiv.innerHTML = `<i class="fa-solid fa-circle-xmark"></i> ${result.message}`;
            statusDiv.style.color = 'var(--danger)';
            locationSection.style.opacity = '0.5';
            locationSection.style.pointerEvents = 'none';
            saveBtn.disabled = true;
          }
        } catch (err) {
          statusDiv.innerHTML = '<i class="fa-solid fa-triangle-exclamation"></i> Verification failed';
          statusDiv.style.color = 'var(--danger)';
        }
      }

      async function handleDealerSubmit(e) {
        e.preventDefault();
        if (!verifiedDealerData) return;

        const form = document.getElementById('dealerForm');
        const formData = new FormData(form);
        const data = Object.fromEntries(formData);

        // Manual ward entry removed; wards must be selected or appended from verified data

        if (data.county !== verifiedDealerData.county || data.constituency !== verifiedDealerData.constituency) {
          showToast('Selected location must match verified registration details', true);
          return;
        }

        if (!data.ward) {
          showToast('Please select a ward', true);
          return;
        }

        const btn = document.getElementById('saveDealerBtn');
        const original = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner"></span> Saving...';

        try {
          const res = await fetch('/hq/compliance/save-dealer', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
          });
          const result = await res.json();

          if (result.success) {
            showToast('Dealer Account Successfully Created');
            closeDealerPanel('panel-create-dealer');
            form.reset();
            document.getElementById('dealerRelationStatus').innerHTML = '';
            document.getElementById('dealerLocationSection').style.opacity = '0.5';
            document.getElementById('dealerLocationSection').style.pointerEvents = 'none';
            btn.disabled = true;
          } else {
            showToast(result.message || 'Save failed', true);
          }
        } catch (err) {
          showToast('Network error', true);
        } finally {
          btn.innerHTML = original;
        }
      }

      async function handleAgentSubmit(e) {
        e.preventDefault();
        if (!verifiedData) return;

        const form = document.getElementById('agentForm');
        const formData = new FormData(form);
        const data = Object.fromEntries(formData);

        // Manual ward entry removed; wards must be selected or appended from verified data

        // Final validation: Ensure selected location matches verified data
        if (data.county !== verifiedData.county || data.constituency !== verifiedData.constituency) {
          showToast('Selected location must match verified registration details', true);
