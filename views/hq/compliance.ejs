      // Clients Account options toggle
      function toggleGcOptions(e) {
        if (e && e.stopPropagation) e.stopPropagation();
        const el = document.getElementById('gcOptions');
        if (!el) return;
        el.classList.toggle('hidden');
      }

      function hideGcOptions() {
        const el = document.getElementById('gcOptions');
        if (!el) return;
        el.classList.add('hidden');
      }

      // Hide when clicking outside
      document.addEventListener('click', () => hideGcOptions());

      function initDealerCounties() {
        const countySelect = document.getElementById("dealerCounty");
        if (!countySelect) return;
        countySelect.innerHTML = '<option value="">-- Select County --</option>';
        fetch('/api/locations/counties')
          .then(r => r.json())
          .then(list => list.forEach(county => {
            const option = document.createElement('option');
            option.value = county;
            option.textContent = county;
            countySelect.appendChild(option);
          })).catch(err => console.error('Failed to load dealer counties', err));
      }

      function loadDealerConstituencies() {
        const countySelect = document.getElementById("dealerCounty");
        const constituencySelect = document.getElementById("dealerConstituency");
        const wardSelect = document.getElementById("dealerWard");
        const selectedCounty = countySelect.value;

        constituencySelect.innerHTML = '<option value="">-- Select Constituency --</option>';
        wardSelect.innerHTML = '<option value="">-- Select Ward --</option>';

        if (!selectedCounty) return;
        fetch(`/api/locations/${encodeURIComponent(selectedCounty)}/constituencies`)
          .then(r => r.json())
          .then(list => list.forEach(c => {
            const opt = document.createElement('option');
            opt.value = c;
            opt.textContent = c;
            constituencySelect.appendChild(opt);
          })).catch(err => console.error('Failed to load dealer constituencies', err));
      }

      function loadDealerWards() {
        const countySelect = document.getElementById("dealerCounty");
        const constituencySelect = document.getElementById("dealerConstituency");
        const wardSelect = document.getElementById("dealerWard");
        const selectedCounty = countySelect.value;
        const selectedConstituency = constituencySelect.value;

        wardSelect.innerHTML = '<option value="">-- Select Ward --</option>';
        if (!selectedCounty || !selectedConstituency) return;
        fetch(`/api/locations/${encodeURIComponent(selectedCounty)}/${encodeURIComponent(selectedConstituency)}/wards`)
          .then(r => r.json())
          .then(list => {
            if (!Array.isArray(list) || list.length === 0) {
              const option = document.createElement('option');
              option.value = '';
              option.textContent = '(No Wards Listed)';
              option.disabled = true;
              wardSelect.appendChild(option);
              return;
            }
            list.sort().forEach(w => {
              const opt = document.createElement('option');
              opt.value = w;
              opt.textContent = w;
              wardSelect.appendChild(opt);
            });
          }).catch(err => console.error('Failed to load dealer wards', err));
      }

