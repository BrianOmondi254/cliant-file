<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>T-BANK INVESTMENT — Groups' Members Registration Form</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&family=Playfair+Display:wght@700;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <script src="https://html2canvas.hertzen.com/dist/html2canvas.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <style>
        :root {
            --bg: #f0ece4;
            --fg: #1a1a1a;
            --muted: #6b6560;
            --accent: #0b6e4f;
            --accent-light: #e8f5ee;
            --card: #ffffff;
            --border: #c8c2b8;
            --danger: #b91c1c;
            --danger-bg: #fef2f2;
            --danger-border: #fca5a5;
            --shadow: 0 4px 24px rgba(0,0,0,0.08);
            --shadow-lg: 0 12px 48px rgba(0,0,0,0.12);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg);
            color: var(--fg);
            min-height: 100vh;
        }

        /* --- Top toolbar --- */
        .toolbar {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            z-index: 100;
            background: rgba(255,255,255,0.85);
            backdrop-filter: blur(16px);
            border-top: 1px solid var(--border);
            padding: 12px 32px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }
        .toolbar-brand {
            display: flex;
            align-items: center;
            gap: 10px;
            font-weight: 700;
            font-size: 15px;
            color: var(--accent);
        }
        .toolbar-brand i { font-size: 20px; }
        .toolbar-actions { display: flex; gap: 10px; flex-wrap: wrap; }

        .btn {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 10px 20px;
            border: none;
            border-radius: 8px;
            font-family: inherit;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
        }
        .btn-primary {
            background: var(--accent);
            color: #fff;
        }
        .btn-primary:hover { background: #095c42; transform: translateY(-1px); box-shadow: 0 4px 12px rgba(11,110,79,0.3); }
        .btn-secondary {
            background: var(--card);
            color: var(--fg);
            border: 1px solid var(--border);
        }
        .btn-secondary:hover { background: #f5f3ef; }
        .btn-danger {
            background: var(--danger);
            color: #fff;
        }
        .btn-danger:hover { background: #991b1b; }

        /* --- Toast notification --- */
        .toast-container {
            position: fixed;
            top: 80px;
            right: 24px;
            z-index: 999;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }
        .toast {
            background: var(--card);
            border: 1px solid var(--border);
            border-left: 4px solid var(--accent);
            padding: 14px 20px;
            border-radius: 8px;
            box-shadow: var(--shadow-lg);
            font-size: 13px;
            display: flex;
            align-items: center;
            gap: 10px;
            animation: toastIn 0.35s ease-out;
            max-width: 360px;
        }
        .toast.error { border-left-color: var(--danger); }
        .toast i { font-size: 16px; color: var(--accent); }
        .toast.error i { color: var(--danger); }
        .toast-fade-out { animation: toastOut 0.3s ease-in forwards; }
        @keyframes toastIn { from { opacity:0; transform:translateX(40px); } to { opacity:1; transform:translateX(0); } }
        @keyframes toastOut { from { opacity:1; transform:translateX(0); } to { opacity:0; transform:translateX(40px); } }

        /* --- Form page (A4 simulation) --- */
        .page-wrapper {
            display: flex;
            justify-content: center;
            padding: 40px 20px 80px;
        }
        .form-page {
            width: 210mm;
            min-height: 297mm;
            background: var(--card);
            box-shadow: var(--shadow-lg);
            border-radius: 4px;
            padding: 40px 50px;
            position: relative;
            overflow: hidden;
        }
        .form-page::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 6px;
            background: linear-gradient(90deg, var(--accent), #2dd4bf, var(--accent));
        }

        /* Watermark */
        .watermark {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%) rotate(-35deg);
            font-family: 'Playfair Display', serif;
            font-size: 80px;
            font-weight: 900;
            color: rgba(11,110,79,0.08);
            pointer-events: none;
            white-space: nowrap;
            letter-spacing: 8px;
            user-select: none;
        }
        .watermark-middle {
            top: 20% !important;
            transform: translate(-50%, -50%) rotate(-35deg) !important;
        }
        .watermark-bottom {
            top: 80% !important;
            transform: translate(-50%, -50%) rotate(-35deg) !important;
        }

        /* Header */
        .header {
            text-align: center;
            margin-bottom: 28px;
            position: relative;
        }
        .header-logo {
            width: 56px;
            height: 56px;
            background: var(--accent);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 12px;
            color: #fff;
            font-size: 24px;
            box-shadow: 0 4px 16px rgba(11,110,79,0.25);
        }
        .header h1 {
            font-family: 'Playfair Display', serif;
            font-size: 22px;
            font-weight: 900;
            color: var(--fg);
            letter-spacing: 2px;
        }
        .header h2 {
            font-size: 15px;
            font-weight: 500;
            color: var(--muted);
            margin-top: 4px;
            letter-spacing: 1px;
        }
        .header-line {
            width: 80px;
            height: 3px;
            background: var(--accent);
            margin: 14px auto 0;
            border-radius: 2px;
        }

        /* Section titles */
        .section-title {
            font-weight: 700;
            font-size: 13px;
            margin-top: 22px;
            margin-bottom: 10px;
            border-bottom: 2px solid var(--fg);
            padding-bottom: 4px;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .section-title .num {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 22px;
            height: 22px;
            background: var(--accent);
            color: #fff;
            border-radius: 50%;
            font-size: 11px;
            font-weight: 700;
        }

        /* Info grid */
        .info-grid {
            display: grid;
            grid-template-columns: 160px 1fr;
            gap: 6px 16px;
            margin-bottom: 16px;
        }
        .info-label {
            font-weight: 600;
            font-size: 12px;
            color: var(--muted);
        }
        .info-value {
            font-size: 12px;
            color: var(--fg);
            padding-bottom: 2px;
            border-bottom: 1px dotted var(--border);
            min-height: 20px;
        }
        .info-value.input-mode {
            border-bottom: 1px solid var(--border);
            background: #fafaf7;
            padding: 2px 6px;
            border-radius: 3px;
            cursor: text;
            transition: all 0.2s;
        }
        .info-value.input-mode:hover { border-color: var(--accent); }
        .info-value.input-mode:focus {
            outline: none;
            border-color: var(--accent);
            background: var(--accent-light);
            box-shadow: 0 0 0 3px rgba(11,110,79,0.1);
        }

        /* Tables */
        table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 16px;
        }
        th, td {
            border: 1px solid #d1cdc5;
            padding: 0;
            text-align: left;
            font-size: 12px;
        }
        th {
            background: #eae6de;
            text-align: center;
            font-weight: 700;
            font-size: 10px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: var(--muted);
            padding: 8px 6px;
        }
        th:first-child { width: 38px; }
        td:first-child {
            text-align: center;
            font-weight: 600;
            color: var(--muted);
            padding: 0;
            background: #f9f7f4;
        }
        td:first-child .cell-num {
            display: flex;
            align-items: center;
            justify-content: center;
            height: 32px;
            font-size: 11px;
        }
        td .cell-input {
            width: 100%;
            height: 32px;
            border: none;
            padding: 0 6px;
            font-family: inherit;
            font-size: 12px;
            background: transparent;
            color: var(--fg);
            transition: background 0.15s;
        }
        td .cell-input:focus {
            outline: none;
            background: var(--accent-light);
            box-shadow: inset 0 0 0 1px var(--accent);
        }
        /* Removed title-cell specific styling to keep it uniform for manual writing */
        td .cell-input::placeholder {
            color: #ccc;
            font-style: italic;
        }

        /* Signatures */
        .signatures { margin-top: 32px; }
        .sig-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 14px 24px;
            margin-bottom: 14px;
        }
        .sig-field-label {
            font-weight: 600;
            font-size: 11px;
            color: var(--muted);
            margin-bottom: 4px;
        }
        .sig-line {
            border-bottom: 1px solid var(--border);
            height: 28px;
            width: 100%;
            transition: border-color 0.2s;
        }
        .sig-line:hover { border-color: var(--accent); }

        /* Signature pad */
        .sig-pad-wrapper {
            position: relative;
            border: 1px dashed var(--border);
            border-radius: 6px;
            height: 60px;
            background: #fdfcfa;
            overflow: hidden;
            margin-bottom: 20px;
            transition: border-color 0.2s;
        }
        .sig-pad-wrapper:hover { border-color: var(--accent); }
        .sig-pad-wrapper canvas {
            width: 100%;
            height: 100%;
            cursor: crosshair;
            display: block;
        }
        .sig-pad-wrapper .clear-sig {
            position: absolute;
            top: 4px;
            right: 4px;
            background: rgba(255,255,255,0.9);
            border: 1px solid var(--border);
            border-radius: 4px;
            padding: 2px 8px;
            font-size: 10px;
            cursor: pointer;
            font-family: inherit;
            color: var(--muted);
            opacity: 0;
            transition: opacity 0.2s;
        }
        .sig-pad-wrapper:hover .clear-sig { opacity: 1; }
        .sig-pad-wrapper .clear-sig:hover { color: var(--danger); border-color: var(--danger); }
        .sig-placeholder {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            color: #ccc;
            font-size: 11px;
            pointer-events: none;
            font-style: italic;
        }

        /* Instructions */
        .instructions {
            margin-top: 32px;
            padding: 16px 18px;
            border: 2px solid var(--danger-border);
            background: var(--danger-bg);
            border-radius: 8px;
        }
        .instructions h3 {
            margin: 0 0 10px 0;
            color: var(--danger);
            font-size: 12px;
            display: flex;
            align-items: center;
            gap: 6px;
        }
        .instructions ul { margin: 0; padding-left: 18px; }
        .instructions li {
            margin-bottom: 6px;
            font-size: 11px;
            line-height: 1.5;
            color: #44403c;
        }
        .instructions li strong { color: var(--danger); }

        .terms-conditions .term-item {
            margin-bottom: 12px;
            padding-bottom: 12px;
            border-bottom: 1px solid var(--border);
        }
        .terms-conditions .term-item:last-child {
            border-bottom: none;
            margin-bottom: 0;
        }

        .signatures.reveal, .signatures.reveal + section {
            margin-top: 8px;
        }
        .signatures.reveal .section-title, section .section-title {
            margin-top: 8px;
            margin-bottom: 6px;
        }
        .signatures .sig-grid {
            margin-bottom: 6px;
        }
        .signatures .sig-pad-wrapper {
            margin-bottom: 8px;
        }
        .signatures .sig-field-label {
            margin-bottom: 2px;
        }

        /* Footer of the page */
        .page-footer {
            margin-top: 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 10px;
            color: #bbb;
            border-top: 1px solid #eee;
            padding-top: 10px;
        }

        /* Progress bar */
        .progress-bar {
            position: fixed;
            bottom: 60px;
            left: 0;
            right: 0;
            height: 4px;
            background: #e8e4dc;
            z-index: 100;
        }
        .progress-fill {
            height: 100%;
            background: linear-gradient(90deg, var(--accent), #2dd4bf);
            width: 0%;
            transition: width 0.4s ease;
            border-radius: 0 2px 2px 0;
        }

        /* ============= PRINT PREVIEW OVERLAY ============= */
        .print-preview-overlay {
            position: fixed;
            inset: 0;
            z-index: 500;
            background: #3a3632;
            display: flex;
            flex-direction: column;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.35s ease;
        }
        .print-preview-overlay.active {
            opacity: 1;
            pointer-events: all;
        }

        .preview-toolbar {
            flex-shrink: 0;
            background: #2a2724;
            padding: 12px 28px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            border-bottom: 1px solid rgba(255,255,255,0.08);
        }
        .preview-toolbar-left {
            display: flex;
            align-items: center;
            gap: 14px;
        }
        .preview-toolbar-left .preview-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: rgba(255,255,255,0.08);
            color: #e2dfda;
            font-size: 12px;
            font-weight: 600;
            padding: 6px 14px;
            border-radius: 6px;
            letter-spacing: 0.5px;
        }
        .preview-toolbar-left .preview-badge i { color: var(--accent); }
        .preview-toolbar-right {
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .preview-toolbar-right .btn { font-size: 12px; padding: 8px 18px; }
        .btn-print-confirm { background: var(--accent); color: #fff; }
        .btn-print-confirm:hover { background: #095c42; }
        .btn-preview-close {
            background: rgba(255,255,255,0.06);
            color: #bbb;
            border: 1px solid rgba(255,255,255,0.1);
        }
        .btn-preview-close:hover { background: rgba(255,255,255,0.12); color: #fff; }

        .preview-content {
            flex: 1;
            overflow: auto;
            display: flex;
            justify-content: center;
            padding: 40px 20px;
            align-items: flex-start;
        }

        .preview-loading {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 16px;
            color: #bbb;
            font-size: 14px;
            align-self: center;
        }
        .preview-loading .spinner {
            width: 36px;
            height: 36px;
            border: 3px solid rgba(255,255,255,0.1);
            border-top-color: var(--accent);
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
        }
        @keyframes spin { to { transform: rotate(360deg); } }

        .page-info {
            font-size: 11px;
            color: #888;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        /* Print-specific overrides applied ONLY inside the preview overlay */
        .print-preview-overlay .form-page {
            box-shadow: 0 8px 60px rgba(0,0,0,0.4);
            border-radius: 0;
            overflow: visible;
            transform-origin: top center;
        }
        .print-preview-overlay .form-page::before {
            display: none;
        }
        .print-preview-overlay .reveal {
            opacity: 1 !important;
            transform: none !important;
            transition: none !important;
        }
        .print-preview-overlay .info-value.input-mode,
        .print-preview-overlay td .cell-input,
        .print-preview-overlay .sig-line input {
            border-color: transparent !important;
            background: transparent !important;
            box-shadow: none !important;
        }
        .print-preview-overlay .sig-pad-wrapper {
            border-color: #aaa !important;
            border-style: solid;
            background: #fff;
        }
        .print-preview-overlay .clear-sig,
        .print-preview-overlay .sig-placeholder {
            display: none !important;
        }
        .print-preview-overlay td .cell-input.title-cell {
            color: #1a1a1a;
        }
        .print-preview-overlay .sig-line:hover {
            border-color: var(--border) !important;
        }
        .print-preview-overlay .error-message {
            display: none !important;
        }
        .print-preview-overlay .watermark {
            color: rgba(11,110,79,0.08);
        }
        .print-preview-overlay .cell-input:focus {
            background: transparent !important;
            box-shadow: none !important;
        }

        /* Modal */
        .modal-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.5);
            backdrop-filter: blur(4px);
            z-index: 200;
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.25s;
        }
        .modal-overlay.active { opacity: 1; pointer-events: all; }
        .modal {
            background: var(--card);
            border-radius: 16px;
            padding: 32px;
            max-width: 420px;
            width: 90%;
            box-shadow: var(--shadow-lg);
            transform: scale(0.9);
            transition: transform 0.25s;
            text-align: center;
        }
        .modal-overlay.active .modal { transform: scale(1); }
        .modal i { font-size: 48px; color: var(--accent); margin-bottom: 16px; }
        .modal h3 { font-size: 18px; margin-bottom: 8px; }
        .modal p { font-size: 13px; color: var(--muted); margin-bottom: 24px; line-height: 1.6; }

        /* Actual print styles */
        @media print {
            body { background: #fff; }
            .toolbar, .progress-bar, .toast-container, .modal-overlay, .print-preview-overlay { display: none !important; }
            .page-wrapper { padding: 0; }
            .form-page {
                box-shadow: none;
                border-radius: 0;
                width: 100%;
                padding: 20px 30px;
                overflow: visible;
            }
            .form-page::before { display: none; }
            .reveal { opacity: 1 !important; transform: none !important; }
            .info-value.input-mode,
            td .cell-input,
            .sig-pad-wrapper { border-color: #999 !important; background: transparent !important; box-shadow: none !important; }
            .sig-pad-wrapper { border-style: solid; }
            .clear-sig, .sig-placeholder { display: none !important; }
            td .cell-input.title-cell { color: #000; }
            .error-message { display: none !important; }
        }

        /* Responsive */
        @media (max-width: 860px) {
            .form-page { width: 100%; padding: 24px 20px; }
            .info-grid { grid-template-columns: 120px 1fr; }
            .sig-grid { grid-template-columns: 1fr; }
            .toolbar { padding: 10px 16px; }
            .preview-toolbar { padding: 10px 16px; flex-wrap: wrap; gap: 8px; }
            .preview-toolbar-left { gap: 8px; }
            .preview-toolbar-right { gap: 6px; }
        }

        /* Scroll reveal animation */
        .reveal {
            opacity: 0;
            transform: translateY(16px);
            transition: opacity 0.5s ease, transform 0.5s ease;
        }
        .reveal.visible {
            opacity: 1;
            transform: translateY(0);
        }

        @media (prefers-reduced-motion: reduce) {
            .reveal { opacity: 1; transform: none; transition: none; }
            .toast { animation: none; }
            .modal, .modal-overlay, .print-preview-overlay { transition: none; }
        }
    </style>
</head>
<body>

<!-- Toolbar -->
<nav class="toolbar" role="navigation" aria-label="Form actions">
    <button class="btn btn-secondary" onclick="openPrintPreview()" aria-label="Preview before printing">
        <i class="fas fa-print"></i> Print Preview
    </button>
    <button class="btn btn-primary" onclick="simulateDownload()" aria-label="Download PDF">
        <i class="fas fa-file-pdf"></i> Download PDF
    </button>
</nav>

<!-- Toast Container -->
<div class="toast-container" id="toastContainer" aria-live="polite"></div>

<!-- PDF Modal -->
<div class="modal-overlay" id="modalOverlay" role="dialog" aria-modal="true">
    <div class="modal">
        <i class="fas fa-circle-check"></i>
        <h3>PDF Ready</h3>
        <p>In the Node.js server version, this would trigger Puppeteer to generate a pixel-perfect A4 PDF and download it directly to your device.</p>
        <button class="btn btn-primary" onclick="closeModal()">Got It</button>
    </div>
</div>

<!-- Print Preview Overlay -->
<div class="print-preview-overlay" id="printPreviewOverlay" role="dialog" aria-modal="true" aria-label="Print preview">
    <div class="preview-toolbar">
        <div class="preview-toolbar-left">
            <span class="preview-badge">
                <i class="fas fa-eye"></i> Print Preview
            </span>
            <span class="page-info">
                <i class="fas fa-file-alt"></i>
                A4 — 210 x 297 mm
            </span>
        </div>
        <div class="preview-toolbar-right">
            <button class="btn btn-preview-close" onclick="closePrintPreview()" aria-label="Close preview">
                <i class="fas fa-times"></i> Close
            </button>
            <button class="btn btn-print-confirm" onclick="confirmPrint()" aria-label="Send to printer">
                <i class="fas fa-print"></i> Print
            </button>
        </div>
    </div>
    <div class="preview-content" id="previewContent">
        <div class="preview-loading">
            <div class="spinner"></div>
            <span>Rendering print preview...</span>
        </div>
    </div>
</div>

<!-- Form Page -->
<main class="page-wrapper">
    <div class="form-page" id="formPage">
        <div class="watermark"><%= group.groupName.toUpperCase() %></div>
        <div class="watermark watermark-middle"><%= group.groupName.toUpperCase() %></div>
        <div class="watermark watermark-bottom"><%= group.groupName.toUpperCase() %></div>

        <header class="header reveal">
            <div class="header-logo">
                <i class="fas fa-landmark"></i>
            </div>
            <h1>T-BANK INVESTMENT</h1>
            <h2>GROUPS' MEMBERS REGISTRATION FORM</h2>
            <div class="header-line"></div>
        </header>

        <!-- Group Details remain pre-filled -->
        <section class="reveal">
            <div class="section-title"><span class="num">1</span> GROUP DETAILS</div>
             <div class="info-grid">
                 <div class="info-label">Group Name:</div>
                 <div class="info-value" data-field="group_name"><%= group.groupName.toUpperCase() %></div>
                 <div class="info-label">Location:</div>
