<!-- Progress Bar -->
<div class="progress-bar" role="progressbar" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100">
    <div class="progress-fill" id="progressFill"></div>
</div>

<script>
    // Load tbank configuration
    var tbank = <%- JSON.stringify(tbank) %>;

    // --- Populate tables ---
    function populateTable(tbodyId, count) {
        var tbody = document.getElementById(tbodyId);
        for (var i = 1; i <= count; i++) {
            var tr = document.createElement('tr');
            // Removed all placeholder attributes and pre-filled values
            // Inputs are now blank for manual writing
            tr.innerHTML =
                '<td><div class="cell-num">' + i + '</div></td>' +
                '<td><input class="cell-input" aria-label="Row ' + i + ' membership number"></td>' +
                '<td><input class="cell-input" aria-label="Row ' + i + ' title"></td>' +
                '<td><input class="cell-input" aria-label="Row ' + i + ' name"></td>' +
                '<td><input class="cell-input" aria-label="Row ' + i + ' phone"></td>' +
                '<td><input class="cell-input" aria-label="Row ' + i + ' ID"></td>' +
                '<td><input class="cell-input" aria-label="Row ' + i + ' signature"></td>';
            tbody.appendChild(tr);
        }
    }

    populateTable('trusteesBody', parseInt(tbank.compliance.membership.trustees));
    populateTable('officialsBody', parseInt(tbank.compliance.membership.officials));
    var regularMembers = parseInt(tbank.compliance.membership.maxMembers)
        - parseInt(tbank.compliance.membership.trustees)
        - parseInt(tbank.compliance.membership.officials);
    populateTable('membersBody', regularMembers);

    // --- Signature Pad ---
    function initSigPad(wrapperId) {
        var wrapper = document.getElementById(wrapperId);
        var canvas = wrapper.querySelector('canvas');
        var ctx = canvas.getContext('2d');
        var drawing = false;
        var hasDrawn = false;

        function resize() {
            var rect = wrapper.getBoundingClientRect();
            canvas.width = rect.width * window.devicePixelRatio;
            canvas.height = rect.height * window.devicePixelRatio;
            ctx.scale(window.devicePixelRatio, window.devicePixelRatio);
            ctx.strokeStyle = '#1a1a1a';
            ctx.lineWidth = 1.5;
            ctx.lineCap = 'round';
            ctx.lineJoin = 'round';
        }
        resize();
        window.addEventListener('resize', resize);

        function getPos(e) {
            var rect = canvas.getBoundingClientRect();
            var cx = e.touches ? e.touches[0].clientX : e.clientX;
            var cy = e.touches ? e.touches[0].clientY : e.clientY;
            return { x: cx - rect.left, y: cy - rect.top };
        }
        function startDraw(e) {
            e.preventDefault();
            drawing = true;
            var p = getPos(e);
            ctx.beginPath();
            ctx.moveTo(p.x, p.y);
            if (!hasDrawn) { hasDrawn = true; }
        }
        function draw(e) {
            if (!drawing) return;
            e.preventDefault();
            var p = getPos(e);
            ctx.lineTo(p.x, p.y);
            ctx.stroke();
        }
        function stopDraw() { drawing = false; }

        canvas.addEventListener('mousedown', startDraw);
        canvas.addEventListener('mousemove', draw);
        canvas.addEventListener('mouseup', stopDraw);
        canvas.addEventListener('mouseleave', stopDraw);
        canvas.addEventListener('touchstart', startDraw, { passive: false });
        canvas.addEventListener('touchmove', draw, { passive: false });
        canvas.addEventListener('touchend', stopDraw);

        wrapper._clear = function () {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            hasDrawn = false;
        };
    }

    initSigPad('sigPad1');
    initSigPad('sigPad2');

    function clearSigPad(id) { document.getElementById(id)._clear(); }

    // --- Progress ---
    function updateProgress() {
        var allInputs = document.querySelectorAll('#formPage .cell-input');
        var filled = 0, total = allInputs.length;
        allInputs.forEach(function (el) {
            if (el.value && el.value.trim().length > 0) filled++;
        });
        var pct = total > 0 ? Math.round((filled / total) * 100) : 0;
        document.getElementById('progressFill').style.width = pct + '%';
    }
    document.addEventListener('input', updateProgress);
    document.addEventListener('focusout', updateProgress);
    updateProgress();

    // --- Toast ---
    function showToast(message, type) {
        type = type || 'success';
        var container = document.getElementById('toastContainer');
        var toast = document.createElement('div');
        toast.className = 'toast' + (type === 'error' ? ' error' : '');
        var icon = type === 'error' ? 'fa-circle-xmark' : 'fa-circle-check';
        toast.innerHTML = '<i class="fas ' + icon + '"></i><span>' + message + '</span>';
        container.appendChild(toast);
        setTimeout(function () {
            toast.classList.add('toast-fade-out');
            setTimeout(function () { toast.remove(); }, 300);
        }, 3000);
    }

    // --- PDF Modal ---
    function closeModal() { document.getElementById('modalOverlay').classList.remove('active'); }
    document.getElementById('modalOverlay').addEventListener('click', function (e) {
        if (e.target === this) closeModal();
    });

    // ========== PRINT PREVIEW ==========
    function openPrintPreview() {
        var overlay = document.getElementById('printPreviewOverlay');
        var content = document.getElementById('previewContent');

        // Show loading
        content.innerHTML = '<div class="preview-loading"><div class="spinner"></div><span>Rendering print preview...</span></div>';
        overlay.classList.add('active');
        document.body.style.overflow = 'hidden';

        // Delay so overlay fade-in plays first
        setTimeout(function () {
            var source = document.getElementById('formPage');

            html2canvas(source, {
                scale: 2,
                useCORS: true,
                backgroundColor: '#ffffff',
                logging: false,
                onclone: function (clonedDoc) {
                    var clonedPage = clonedDoc.getElementById('formPage');
                    if (clonedPage) {
                        clonedPage.querySelectorAll('.reveal').forEach(function (el) {
                            el.style.opacity = '1';
                            el.style.transform = 'none';
                        });
                        var beforeStyle = clonedDoc.createElement('style');
                        beforeStyle.textContent = '#formPage::before { display: none !important; }';
                        clonedDoc.head.appendChild(beforeStyle);
                        clonedPage.querySelectorAll('.error-message').forEach(function (el) { el.remove(); });
                        clonedPage.querySelectorAll('.sig-placeholder').forEach(function (el) { el.remove(); });
                        clonedPage.querySelectorAll('.clear-sig').forEach(function (el) { el.remove(); });
                        var sigStyle = clonedDoc.createElement('style');
                        sigStyle.textContent = '.sig-pad-wrapper { border-style: solid !important; border-color: #aaa !important; }';
                        clonedDoc.head.appendChild(sigStyle);
                    }
                }
            }).then(function (canvas) {
                var imgData = canvas.toDataURL('image/png');
                content.innerHTML = '';

                var wrapper = document.createElement('div');
                wrapper.style.cssText = 'transform-origin: top center; display: inline-block;';

                var img = document.createElement('img');
                img.src = imgData;
                img.style.cssText = 'display: block; width: 210mm; height: auto;';
                img.alt = 'Print preview of registration form';

                wrapper.appendChild(img);
                content.appendChild(wrapper);

                scalePreviewToFit();
            }).catch(function (err) {
                content.innerHTML = '<div class="preview-loading"><i class="fas fa-exclamation-triangle" style="font-size:32px;color:#b91c1c;"></i><span style="color:#e2dfda;">Failed to render preview. Try using browser Print directly.</span></div>';
                console.error('Preview render error:', err);
            });
        }, 400);
    }

    function scalePreviewToFit() {
        var content = document.getElementById('previewContent');
        var wrapper = content.querySelector('div');
        var img = content.querySelector('img');
        if (!wrapper || !img) return;

        var containerWidth = content.clientWidth - 60;
        var pageNaturalWidth = 793;
        var scale = Math.min(1, containerWidth / pageNaturalWidth);
        wrapper.style.transform = 'scale(' + scale + ')';

        if (img.complete) {
            fixScrollHeight(wrapper, scale);
        } else {
            img.onload = function () { fixScrollHeight(wrapper, scale); };
        }
    }

    function fixScrollHeight(wrapper, scale) {
        var realHeight = wrapper.scrollHeight;
        var visualHeight = realHeight * scale;
        wrapper.style.marginBottom = (visualHeight - realHeight + 40) + 'px';
    }

    function closePrintPreview() {
        document.getElementById('printPreviewOverlay').classList.remove('active');
        document.body.style.overflow = '';
        setTimeout(function () {
            document.getElementById('previewContent').innerHTML = '';
        }, 400);
    }

    function confirmPrint() {
        // Prevent double click - block for 10 seconds
        if (isDownloading) {
            showToast('Print in progress, please wait...', 'error');
            return;
        }
        isDownloading = true;
        
        // Log download when printing
        var groupName = document.querySelector('[data-field="group_name"]').textContent.trim();
        var formRef = document.getElementById('formRefNum').textContent;
        var year = document.getElementById('formRefYear').textContent;
        var formRefFull = 'NL-GROUPS-' + year + '-' + formRef;
        var userPhone = '<%= userPhone || "" %>';
        
        formRefCounter++;
        localStorage.setItem('formRefCounter', formRefCounter);
        var nextNum = String(formRefCounter).padStart(3, '0');
        document.getElementById('formRefNum').textContent = nextNum;
        
        logFormDownload(groupName, formRefFull, parseInt(year), userPhone);
        
        closePrintPreview();
        setTimeout(function () { 
            window.print(); 
            showToast('Form sent to print!', 'success');
            setTimeout(function() {
                isDownloading = false;
            }, 10000);
        }, 500);
    }

    document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') {
            if (document.getElementById('printPreviewOverlay').classList.contains('active')) {
                closePrintPreview();
            } else {
                closeModal();
            }
        }
    });

    window.addEventListener('resize', function () {
        if (document.getElementById('printPreviewOverlay').classList.contains('active')) {
            scalePreviewToFit();
        }
    });

    // --- PDF Download ---
    var formRefCounter = parseInt('<%= formRefNumber || "001" %>') - 1;
    var isDownloading = false;
    
    function logFormDownload(groupName, formRef, year, userPhone) {
        if (!navigator.geolocation) {
            callDownloadApi(groupName, formRef, year, userPhone, null, null, null);
            return;
        }
        
        navigator.geolocation.getCurrentPosition(
            function(position) {
                callDownloadApi(groupName, formRef, year, userPhone,
                    position.coords.latitude, 
                    position.coords.longitude, 
                    null);
            },
            function(error) {
                console.log("Geolocation denied or error:", error.message);
                callDownloadApi(groupName, formRef, year, userPhone, null, null, null);
            }
        );
    }
    
    function callDownloadApi(groupName, formRef, year, userPhone, latitude, longitude, address) {
        fetch('/general/api/form-download-log', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                groupName: groupName,
                formRef: formRef,
                userPhone: userPhone,
                latitude: latitude,
                longitude: longitude,
                address: address
            })
        })
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                console.log("Download logged:", data.download);
            }
        })
        .catch(err => console.error("Error logging download:", err));
    }
    
    async function simulateDownload() {
        // Prevent double click - block for 10 seconds
        if (isDownloading) {
            showToast('Download in progress, please wait...', 'error');
            return;
        }
        isDownloading = true;
        
        var groupName = document.querySelector('[data-field="group_name"]').textContent.trim();
        var formRef = document.getElementById('formRefNum').textContent;
        var year = document.getElementById('formRefYear').textContent;
        var formRefFull = 'NL-GROUPS-' + year + '-' + formRef;
        var userPhone = '<%= userPhone || "" %>';
        
        var source = document.getElementById('formPage');
        var canvas = await html2canvas(source, {
            scale: 2,
            backgroundColor: '#ffffff',
            onclone: function (clonedDoc) {
                var clonedPage = clonedDoc.getElementById('formPage');
                if (clonedPage) {
                    clonedPage.querySelectorAll('.reveal').forEach(function (el) {
                        el.style.opacity = '1';
                        el.style.transform = 'none';
                    });
                    var s = clonedDoc.createElement('style');
                    s.textContent = '#formPage::before { display: none !important; }';
                    clonedDoc.head.appendChild(s);
                    clonedPage.querySelectorAll('.error-message').forEach(function (el) { el.remove(); });
                    clonedPage.querySelectorAll('.sig-placeholder').forEach(function (el) { el.remove(); });
                    clonedPage.querySelectorAll('.clear-sig').forEach(function (el) { el.remove(); });
                }
            }
        });
        var imgData = canvas.toDataURL('image/png');
        var jsPDF = window.jspdf.jsPDF;
        var pdf = new jsPDF('p', 'mm', 'a4');
        var imgWidth = 210;
        var pageHeight = 295;
        var imgHeight = (canvas.height * imgWidth) / canvas.width;
        var heightLeft = imgHeight;
        var position = 0;

        pdf.addImage(imgData, 'PNG', 0, position, imgWidth, imgHeight);
        heightLeft -= pageHeight;

        while (heightLeft >= 0) {
            position = heightLeft - imgHeight;
            pdf.addPage();
            pdf.addImage(imgData, 'PNG', 0, position, imgWidth, imgHeight);
            heightLeft -= pageHeight;
        }

        formRefCounter++;
        localStorage.setItem('formRefCounter', formRefCounter);
        var nextNum = String(formRefCounter).padStart(3, '0');
        document.getElementById('formRefNum').textContent = nextNum;
        
        // Log the download with group name, form ref, and location
        logFormDownload(groupName, formRefFull, parseInt(year), userPhone);
        
        pdf.save('group_registration_form.pdf');
        
        // Show success toast and unblock after 10 seconds
        showToast('Form downloaded successfully!', 'success');
        setTimeout(function() {
            isDownloading = false;
        }, 10000);
    }

    // --- Scroll Reveal ---
    var observer = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
            if (entry.isIntersecting) entry.target.classList.add('visible');
        });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
    document.querySelectorAll('.reveal').forEach(function (el) { observer.observe(el); });

    // --- Set today's date ---
    document.querySelectorAll('input[type="date"]').forEach(function (el) {
        if (!el.value) el.value = new Date().toISOString().split('T')[0];
    });

</script>
</body>
</html>