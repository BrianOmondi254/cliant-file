            html += '</div>';
            html += '<div style="color:#fbbf24;font-weight:700;font-size:14px;white-space:nowrap; margin-right:35px;">KSh ' + acc.inputAmount + '</div>';
            html += `<button onclick="app.removeAccountFromSummary(${idx}, '${encodeURIComponent(decodedGroupName)}')" style="position:absolute; right:12px; top:50%; transform:translateY(-50%); background:rgba(239, 68, 68, 0.1); border:none; color:#f87171; cursor:pointer; font-size:14px; width:28px; height:28px; border-radius:50%; display:flex; align-items:center; justify-content:center; transition:0.2s;"><i class="fa-solid fa-xmark"></i></button>`;
            html += '</div>';
        });
        
        html += '<div style="display:flex;justify-content:space-between;align-items:center;padding:12px;background:rgba(251,191,36,0.2);border-radius:6px;margin-top:10px;">';
        html += '<span style="font-weight:600;font-size:14px;">TOTAL</span>';
        html += '<span style="color:#fbbf24;font-weight:700;font-size:18px;">KSh ' + total.toLocaleString() + '</span>';
