    renderGroupPlan(group) {
        const p = group.principles;
        if (!p) return '<p style="color:#94a3b8;font-style:italic;">No constitution or plan has been set for this group yet. Contact the chairperson to initialize the group principles.</p>';

        const lines = [];

        if (p.intervals) {
            const int = p.intervals;
            lines.push(`<b style="color:#0c8f44;">📅 Meeting Schedule:</b> ${(int.frequency||'N/A').charAt(0).toUpperCase()+(int.frequency||'').slice(1)} on every ${(int.period||'').toLowerCase()}. Cycle lasts ${(int.endSavingPeriod||'1 year').replace('-',' ')}.`);
        }

        if (p.otherContributions && p.otherContributions.length > 0) {
            lines.push(`<b style="color:#9333ea;">💰 Contribution Accounts:</b>`);
            p.otherContributions.forEach(c => {
                lines.push(`&nbsp;&nbsp;▸ ${c.accountName} (${c.accountNumber}): KSh ${Number(c.expectedAmount||0).toLocaleString()} expected per member.`);
            });
        }

        if (p.distribution) {
            const d = p.distribution;
            lines.push(`<b style="color:#dc2626;">📊 Profit Distribution:</b> Model: <b>${d.model||'performance'}</b>. Officials get ${d.officialPct||0}%, Performance share ${d.performancePct||0}%.`);
            if (d.targetAccountName) lines.push(`&nbsp;&nbsp;▸ Accumulates into <b>${d.targetAccountName}</b> pool.`);
        }

        if (p.balancing && p.balancing.benefitAccounts) {
            lines.push(`<b style="color:#0891b2;">⚖️ Benefits & Fines:</b> ${p.balancing.benefitAccounts.join(', ')}.`);
        }

        if (p.loans) {
            const l = p.loans;
            lines.push(`<b style="color:#f59e0b;">🏦 Loans:</b> Qualified after ${l.duration?.days||30} days. Interest: ${l.interestAndLimits?.interestRate||0}%. Max limit: x${l.interestAndLimits?.limitMultiplier||3} of savings.`);
            if (l.repayment) lines.push(`&nbsp;&nbsp;▸ Repayment: ${l.repayment.durationDays||30} days, max ${l.repayment.maxRollovers||3} rollovers via ${l.repayment.rolloverMethod||'fixed'} scale.`);
        }

        if (p.governance) {
            const g = p.governance;
            lines.push(`<b style="color:#64748b;">🛡️ Governance:</b> Fast changes need ${g.fastNotificationThreshold||60}% quorum. Major edits need ${g.editAccountThreshold||75}% consensus.`);
        }

        if (lines.length === 0) {
            return '<p style="color:#94a3b8;font-style:italic;">Constitution details are incomplete. Only basic group info available.</p>';
        }

        return `<ul style="margin:0;padding-left:18px;">${lines.map(l => `<li style="margin-bottom:6px;">${l}</li>`).join('')}</ul>`;
    },

    openGroupAccountsModal(groupName, encodedAccNum) {
        const accountNumber = encodedAccNum ? decodeURIComponent(encodedAccNum) : '';
        document.getElementById('modalOverlay').classList.add('open');
        this.updateModalContent('Loading Accounts...', '<div style="text-align:center;padding:30px;"><i class="fa-solid fa-spinner fa-spin" style="font-size:28px;color:var(--primary);"></i><p style="margin-top:10px;font-size:12px;color:#64748b;">Fetching account data...</p></div>', null, 'fa-folder-open');

        fetch('/member/group-accounts-schema', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ groupName: decodeURIComponent(groupName), accountNumber, phone: this.data.user.phoneNumber })
        })
        .then(res => {
            console.log('[Accounts fetch] status:', res.status, res.statusText);
            if (!res.ok) {
                return res.json().then(err => {
                    console.error('[Accounts fetch] server error payload:', err);
                    throw new Error((err && err.error) ? err.error : ('Server error ' + res.status));
                });
            }
            return res.json();
        })
        .then(data => {
            console.log('[Accounts fetch] data keys:', data ? Object.keys(data) : 'null/undefined', 'isMemberOnly:', data && data.isMemberOnly);
            if (!data || data.error) {
                const msg = (data && data.error) ? data.error : 'No account details found for this group.';
                console.error('[Accounts fetch] business error:', msg);
                this.updateModalContent('Accounts', `<div class="m-empty-state"><i class="fa-solid fa-folder-open"></i><p>${msg}</p></div>`, null, 'fa-folder-open');
                return;
            }

            // Store for drill-down
            this._groupAccountsData = data;
            this._groupAccountsName = groupName;

            const accSchema = data.accountSchema || {};
            const accDetails = data.accountDetails || {};
            const isMemberOnly = !!data.isMemberOnly;
            const roleRaw = data.loggedInMemberRole || (isMemberOnly ? 'member' : 'official');
            const roleLabel = roleRaw.charAt(0).toUpperCase() + roleRaw.slice(1);

            const accColors = {
                saving:       { bg: '#e8f5e9', color: '#2e7d32', icon: 'fa-piggy-bank',     grad: 'linear-gradient(135deg,#2e7d32,#66bb6a)' },
                registration: { bg: '#e3f2fd', color: '#1565c0', icon: 'fa-id-card',         grad: 'linear-gradient(135deg,#1565c0,#42a5f5)' },
                late:         { bg: '#ffebee', color: '#c62828', icon: 'fa-clock',           grad: 'linear-gradient(135deg,#c62828,#ef9a9a)' },
                welfare:      { bg: '#f3e5f5', color: '#6a1b9a', icon: 'fa-hands-holding',   grad: 'linear-gradient(135deg,#6a1b9a,#ce93d8)' },
                default:      { bg: '#e8f0fe', color: '#1a73e8', icon: 'fa-wallet',          grad: 'linear-gradient(135deg,#1a73e8,#64b5f6)' }
            };

            const getAccStyle = (name) => {
                const n = (name || '').toLowerCase();
                if (n.includes('saving'))       return accColors.saving;
                if (n.includes('registration')) return accColors.registration;
                if (n.includes('late'))         return accColors.late;
                if (n.includes('welfare'))      return accColors.welfare;
                return accColors.default;
            };

            // ── HEADER: group strip + "who am I" card ──────────────────
            let html = `
            <div style="background:linear-gradient(135deg,#0c8f44,#34d399);border-radius:12px;padding:14px 16px;margin-bottom:10px;color:white;display:flex;justify-content:space-between;align-items:center;">
                <div>
                    <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:1px;opacity:0.85;">Group</div>
                    <div style="font-size:15px;font-weight:800;margin-top:2px;">${data.groupName}</div>
                </div>
                <div style="text-align:right;">
                    <div style="font-size:11px;opacity:0.85;">${isMemberOnly ? 'Account Type' : 'Total Members'}</div>
                    <div style="font-size:${isMemberOnly ? '14px' : '22px'};font-weight:800;margin-top:${isMemberOnly ? '4px' : '0'};">${isMemberOnly ? 'Personal' : data.totalMembers}</div>
                </div>
            </div>
            <div style="background:white;border:1px solid #e2e8f0;border-radius:12px;padding:12px 14px;margin-bottom:14px;display:flex;align-items:center;gap:12px;">
