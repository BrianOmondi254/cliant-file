        html += '<select id="sourceAccount" class="form-input" onchange="app.onSourceChange(\'' + encodeURIComponent(decodedGroupName) + '\')" style="flex:1;min-width:150px;padding:10px;font-size:13px;">';
        html += '<option value="">-- Select --</option>';
        accounts.forEach((acc, index) => {
            const isAlreadyAdded = addedAccounts.some(added => added.accountNumber === acc.accountNumber);
            if (isAlreadyAdded) {
                html += '<option value="' + index + '" disabled style="color:#cbd5e1;">' + acc.accountNumber + ' - ' + acc.accountName + ' (Added)</option>';
            } else {
                html += '<option value="' + index + '">' + acc.accountNumber + ' - ' + acc.accountName + '</option>';
            }
        });
        html += '</select>';
        html += '</div>';
        html += '</div>';
        
        if (errorMsg) {
            html += '<div style="background:#fee2e2;border:1px solid #fecaca;border-radius:8px;padding:10px;margin-bottom:15px;">';
            html += '<p style="color:#dc2626;font-size:13px;margin:0;">' + errorMsg + '</p>';
            html += '</div>';
        }
        
        if (addedAccounts.length > 0) {
            html += '<div style="margin-bottom:15px;">';
            html += '<p style="font-size:12px;color:#6b7280;margin-bottom:8px;font-weight:600;">ADDED ACCOUNTS:</p>';
            addedAccounts.forEach((acc, index) => {
                html += '<div style="display:flex;align-items:center;padding:10px;background:#f8fafc;border:1px solid #e2e8f0;border-radius:8px;margin-bottom:6px;gap:10px;">';
                html += '<button onclick="app.removeAccount(' + index + ',\'' + encodeURIComponent(decodedGroupName) + '\')" style="background:#ef4444;color:white;border:none;border-radius:50%;width:24px;height:24px;cursor:pointer;font-size:14px;flex-shrink:0;display:flex;align-items:center;justify-content:center;">×</button>';
                html += '<div style="flex:1;overflow:hidden;">';
                html += '<div style="font-weight:600;color:#1e293b;font-size:13px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">' + acc.accountName + '</div>';
