    sendToMyAccount(groupName) {
        const decodedGroupName = decodeURIComponent(groupName);
        const group = this.data.userGroups.find(g => g.groupName === decodedGroupName);
        if (!group || !group.principles || !group.principles.otherContributions) {
            this.updateModalContent('Send to My Account', '<div style="text-align:center;padding:20px;"><p style="color:#6b7280;">No accounts found for this group.</p></div>', () => this.selectGroupForSend(decodedGroupName));
            return;
        }
        this.data.groupAccounts = group.principles.otherContributions;
        this.data.addedAccounts = [];
        this.data.errorMessage = '';
        this.data.sendMode = 'my';
        this.data.recipientName = 'My Account';
        this.data.isMultiMemberFlow = false;
        this.renderAccountForm(decodedGroupName);
    },
