            <div id="pinEntryFields" class="hidden" style="margin-top:12px;border-top:1px dashed #e2e8f0;padding-top:14px;">
                <div class="m-field"><label>New 4-Digit PIN</label><input type="password" id="resetNewPinCliant" autocomplete="new-password" class="form-input" maxlength="4" placeholder="••••" inputmode="numeric" style="letter-spacing:4px;font-weight:700;" oninput="app.checkResetPinMatch()"></div>
                <div class="m-field"><label>Confirm PIN</label><input type="password" id="resetConfirmPinCliant" autocomplete="new-password" class="form-input" maxlength="4" placeholder="••••" inputmode="numeric" style="letter-spacing:4px;font-weight:700;" oninput="app.checkResetPinMatch()"></div>
                <button id="finalResetBtn" class="m-submit-btn hidden" onclick="app.submitResetPinCliant()"><i class="fa-solid fa-key"></i> Reset & Login</button>
