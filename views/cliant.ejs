        <button class="m-action-btn violet" onclick="app.sendToOtherMember('${encodeURIComponent(dn)}')">
            <div class="btn-icon-box bib-violet"><i class="fa-solid fa-user-group"></i></div>
            <div class="btn-text-block"><span class="btn-label-text">Other Member A/C</span><span class="btn-hint-text">Send to another member's account</span></div>
            <i class="fa-solid fa-chevron-right btn-arrow-icon"></i>
        </button>`;
        this.updateModalContent('Send Money — ' + dn, html, () => this.openModal('Send Money'), 'fa-paper-plane');
    },

    sendToMyAccount(groupName) {
        const dn    = decodeURIComponent(groupName);
        const group = this.data.userGroups.find(g => g.groupName === dn);
        if (!group || !group.principles || !group.principles.otherContributions) {
            const html = `<div class="m-empty-state"><i class="fa-solid fa-folder-open"></i><p>No accounts found for this group.</p></div>`;
            this.updateModalContent('Send to My Account', html, () => this.selectGroupForSend(dn), 'fa-building-columns');
            return;
        }
        this.data.groupAccounts  = group.principles.otherContributions;
        this.data.addedAccounts  = [];
        this.data.errorMessage   = '';
        this.data.sendMode       = 'my';
        this.data.recipientName  = 'My Account';
        this.data.isMultiMemberFlow = false;
        this.renderAccountForm(dn);
    },

    renderAccountForm(groupName) {
        const accounts      = this.data.groupAccounts || [];
        const dn            = decodeURIComponent(groupName);
        const addedAccounts = this.data.addedAccounts || [];
        const errorMsg      = this.data.errorMessage || '';
        const sendTo        = this.data.recipientName || 'My Account';
        const icon          = this.data.sendMode === 'other' ? 'fa-user-group' : 'fa-building-columns';

        let html = '';

        if (this.data.sendMode === 'other') {
            html += `<div class="m-info-banner green"><i class="fa-solid fa-user-check"></i><span>Recipient: <b>${sendTo}</b></span></div>`;
        }

        html += `<div class="m-section-label">Source Account</div>
        <div class="m-field" style="margin-bottom:8px;">
            <label>Select Account</label>
            <select id="sourceAccount" class="form-input" onchange="app.onSourceChange('${encodeURIComponent(dn)}')" style="font-size:13px;">
                <option value="">-- Select --</option>`;
        accounts.forEach((acc, index) => {
            const isAdded = addedAccounts.some(a => a.accountNumber === acc.accountNumber);
            html += `<option value="${index}" ${isAdded ? 'disabled' : ''}>${acc.accountNumber} — ${acc.accountName}${isAdded ? ' (Added)' : ''}</option>`;
        });
        html += `</select></div>`;

        if (errorMsg) {
            html += `<div class="m-info-banner red" style="margin-bottom:10px;"><i class="fa-solid fa-triangle-exclamation"></i><span>${errorMsg}</span></div>`;
        }

        if (this.data.searchedAccount) {
            const acc = this.data.searchedAccount;
            html += `<div class="m-pay-dark">
                <div class="m-pay-dark-title">Selected Account</div>
                <div class="m-pay-row"><div><div style="font-weight:700;font-size:13.5px;">${acc.accountName}</div><div style="font-size:11px;opacity:.7;">${acc.accountNumber}</div></div><div class="m-pay-row-value" style="font-size:11px;">Expected<br><span style="font-size:14px;">KSh ${acc.expectedAmount}</span></div></div>
                <div style="display:flex;gap:8px;align-items:center;background:rgba(255,255,255,.1);padding:8px 12px;border-radius:8px;margin-top:6px;">
                    <span style="font-size:12px;opacity:.9;color:#fff;">Amount (KSh):</span>
                    <input type="number" id="accountAmount" placeholder="0" inputmode="numeric" style="flex:1;padding:8px;font-size:15px;border:none;background:transparent;color:#fbbf24;font-weight:700;text-align:right;outline:none;">
                </div>
            </div>`;
        }

        if (addedAccounts.length > 0) {
            html += `<div class="m-section-label">Added Accounts</div>`;
            addedAccounts.forEach((acc, index) => {
                html += `<div class="m-added-acc">
                    <button class="m-remove-btn" onclick="app.removeAccount(${index},'${encodeURIComponent(dn)}')"><i class="fa-solid fa-xmark"></i></button>
                    <div style="flex:1;min-width:0;"><div class="m-added-acc-name">${acc.accountName}</div><div class="m-added-acc-num">${acc.accountNumber}</div></div>
                    <div class="m-added-acc-amt">KSh ${acc.inputAmount}</div>
                </div>`;
            });
        }

        html += `<div class="m-btn-row" style="margin-top:14px;">
            <button class="m-submit-btn secondary" onclick="app.addNextAccount('${encodeURIComponent(dn)}')"><i class="fa-solid fa-plus"></i> Add</button>
            <button class="m-submit-btn" onclick="app.confirmPayment('${encodeURIComponent(dn)}')"><i class="fa-solid fa-check"></i> Confirm</button>
        </div>`;

        const title    = this.data.sendMode === 'other' ? `Send to ${sendTo}` : `Send — My Account`;
        const backFn   = this.data.sendMode === 'other' ? () => this.sendToOtherMember(dn) : () => this.selectGroupForSend(dn);
        this.updateModalContent(title, html, backFn, icon);
    },

    onSourceChange(groupName) {
        const dn    = decodeURIComponent(groupName);
        const sel   = document.getElementById('sourceAccount');
        const index = sel ? sel.value : '';
        if (index === '') { this.data.searchedAccount = null; this.renderAccountForm(dn); return; }
        const acc = this.data.groupAccounts[index];
        this.data.searchedAccount = { accountName: acc.accountName, accountNumber: acc.accountNumber, expectedAmount: acc.inputAmount || acc.estimatedAmount || "0" };
        this.renderAccountForm(dn);
    },
    addNextAccount(groupName) {
        const dn = decodeURIComponent(groupName);
        if (!this.data.searchedAccount) { this.data.errorMessage = 'Please select a source account first'; this.renderAccountForm(dn); return; }
        if (!this.data.addedAccounts) this.data.addedAccounts = [];
        const amountInput = document.getElementById('accountAmount');
        this.data.addedAccounts.push({ accountName: this.data.searchedAccount.accountName, accountNumber: this.data.searchedAccount.accountNumber, inputAmount: amountInput ? amountInput.value : '0' });
        this.data.searchedAccount = null;
        this.data.errorMessage    = '';
        this.renderAccountForm(dn);
    },
    removeAccount(index, groupName) {
        const dn = decodeURIComponent(groupName);
        if (this.data.addedAccounts && this.data.addedAccounts[index]) this.data.addedAccounts.splice(index, 1);
        this.renderAccountForm(dn);
    },
    confirmPayment(groupName) {
        const dn = decodeURIComponent(groupName);
        if (this.data.searchedAccount) {
            const amountInput = document.getElementById('accountAmount');
            const amount = amountInput ? amountInput.value.trim() : '';
            if (amount !== '' && parseFloat(amount) > 0) {
                if (!this.data.addedAccounts) this.data.addedAccounts = [];
                this.data.addedAccounts.push({ accountName: this.data.searchedAccount.accountName, accountNumber: this.data.searchedAccount.accountNumber, inputAmount: amount });
                this.data.searchedAccount = null;
            }
        }
        if ((this.data.addedAccounts || []).length === 0) { this.data.errorMessage = 'Please select an account and enter an amount first'; this.renderAccountForm(dn); return; }
        this.showFinalPaymentOptions(dn);
    },

    showFinalPaymentOptions(groupName) {
        const dn       = decodeURIComponent(groupName);
        const accounts = this.data.groupAccounts || [];
        const added    = this.data.addedAccounts || [];
        const remaining = accounts.filter(acc => !added.some(a => a.accountNumber === acc.accountNumber));

        let html = `
        <div class="m-info-banner green"><i class="fa-solid fa-wallet"></i><span>Review your added accounts or add more before payment.</span></div>
        <div class="m-section-label">Add More Accounts</div>
        <button class="m-action-btn accent" onclick="app.toggleOtherAccountsCollapse()">
            <div class="btn-icon-box bib-amber"><i class="fa-solid fa-plus-circle"></i></div>
            <div class="btn-text-block"><span class="btn-label-text">Add Another Account</span><span class="btn-hint-text">Select from remaining accounts</span></div>
            <i class="fa-solid fa-chevron-down btn-arrow-icon" id="otherAccChevron" style="transition:.3s;"></i>
        </button>
        <div id="other-accounts-list" style="display:none;margin-top:8px;background:#f8fafc;padding:12px;border-radius:10px;border:1px solid #f1f5f9;">
            <div class="m-field" style="margin:0;">
                <select class="form-input" onchange="if(this.value!=='') app.selectQuickAccount('${encodeURIComponent(dn)}', this.value)" style="font-size:13px;">
                    <option value="">-- Select Account --</option>`;
        remaining.forEach(acc => {
            const gi = accounts.indexOf(acc);
            html += `<option value="${gi}">${acc.accountNumber} — ${acc.accountName}</option>`;
        });
        html += `</select></div></div>
        <div class="m-divider"></div>
        <button class="m-submit-btn" onclick="app.showFinalPaymentSummary('${encodeURIComponent(dn)}')"><i class="fa-solid fa-file-invoice-dollar"></i> Verify Payment</button>`;

        this.updateModalContent('Payment Options', html, () => this.renderAccountForm(dn), 'fa-list-check');
    },

    toggleOtherAccountsCollapse() {
        const t = document.getElementById('other-accounts-list');
        const c = document.getElementById('otherAccChevron');
        if (t) {
            const hidden = t.style.display === 'none' || !t.style.display;
            t.style.display = hidden ? 'block' : 'none';
            if (c) c.style.transform = hidden ? 'rotate(180deg)' : 'rotate(0deg)';
        }
    },
    selectQuickAccount(groupName, index) {
        const dn  = decodeURIComponent(groupName);
        const acc = this.data.groupAccounts[index];
        if (acc) { this.data.searchedAccount = { accountName: acc.accountName, accountNumber: acc.accountNumber, expectedAmount: acc.inputAmount || acc.estimatedAmount || "0" }; this.data.errorMessage = ''; this.renderAccountForm(dn); }
    },

    showFinalPaymentSummary(groupName) {
        const dn            = decodeURIComponent(groupName);
        const addedAccounts = this.data.addedAccounts || [];

        if (this.data.isMultiMemberFlow) {
            const currentIdx = this.data.selectedMemberIndex;
            if (!this.data.settledMembersData) this.data.settledMembersData = {};
            this.data.settledMembersData[currentIdx] = { name: this.data.recipientName, accounts: [...addedAccounts] };
            const allDone = this.data.verifiedMembersList.every(m => this.data.settledMembersData[m.index]);
            if (!allDone) {
                const html = `<div style="text-align:center;padding:20px;">
                    <div style="width:56px;height:56px;background:#f0fdf4;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 12px;"><i class="fa-solid fa-check" style="color:#10b981;font-size:26px;"></i></div>
                    <h3 style="color:#1e293b;margin-bottom:8px;font-size:15px;">Details Saved</h3>
                    <p style="color:#64748b;font-size:13px;margin-bottom:18px;">Accounts for <b>${this.data.recipientName}</b> saved.</p>
                    <button class="m-submit-btn" onclick="app.showSeveralMembersSummary('${encodeURIComponent(dn)}', app.data.verifiedMembersList)">Select Next Member</button>
                </div>`;
                this.updateModalContent('Details Saved', html, null, 'fa-check-circle');
                return;
            }
            this.renderFinalBulkSummary(dn);
            return;
        }

        let total = 0;
        addedAccounts.forEach(acc => total += parseFloat(acc.inputAmount) || 0);
        const sendTo    = this.data.recipientName || 'My Account';
        const memberIdx = this.data.selectedMemberIndex;

        let html = `<div class="m-pay-dark">
            <div class="m-pay-dark-title">Payment Details</div>
            <div class="m-pay-row"><span class="m-pay-row-label">Recipient</span><span class="m-pay-row-value">${sendTo}</span></div>`;
        if (this.data.sendMode === 'other' && memberIdx) {
            html += `<div class="m-pay-row"><span class="m-pay-row-label">Member A/C No.</span><span class="m-pay-row-value">${memberIdx}</span></div>`;
        }
        addedAccounts.forEach((acc, idx) => {
            html += `<div class="m-pay-row" style="position:relative;">
                <div><div style="font-weight:700;font-size:13px;">${acc.accountName}</div><div style="font-size:10px;opacity:.7;">${acc.accountNumber}</div></div>
                <div style="display:flex;align-items:center;gap:8px;">
                    <span class="m-pay-row-value">KSh ${acc.inputAmount}</span>
                    <button onclick="app.removeAccountFromSummary(${idx},'${encodeURIComponent(dn)}')" style="background:rgba(239,68,68,.15);border:none;color:#f87171;cursor:pointer;font-size:13px;width:26px;height:26px;border-radius:50%;display:flex;align-items:center;justify-content:center;"><i class="fa-solid fa-xmark"></i></button>
                </div>
            </div>`;
        });
        html += `<div class="m-pay-total"><span class="m-pay-total-label">TOTAL</span><span class="m-pay-total-value">KSh ${total.toLocaleString()}</span></div></div>`;

        html += `<div class="m-section-label">Pay Via</div>
        <div class="m-btn-row">
            <button class="m-submit-btn" style="background:linear-gradient(135deg,#10b981,#34d399);" onclick="app.processPayment('tbank')"><i class="fa-solid fa-university"></i> tBank</button>
            <button class="m-submit-btn" style="background:linear-gradient(135deg,#22c55e,#4ade80);" onclick="app.processPayment('mpesa')"><i class="fa-solid fa-mobile"></i> M-Pesa</button>
        </div>`;

        const backFn = this.data.sendMode === 'my' ? () => this.renderAccountForm(dn) : () => this.showFinalPaymentOptions(dn);
        this.updateModalContent('Verify Payment', html, backFn, 'fa-file-invoice-dollar');
    },

    renderFinalBulkSummary(groupName) {
        const dn   = decodeURIComponent(groupName);
        const data = this.data.settledMembersData;
        let totalSum = 0;
        let html = '';
        for (const idx in data) {
            const m = data[idx]; let memberTotal = 0;
            m.accounts.forEach(a => memberTotal += parseFloat(a.inputAmount) || 0);
            totalSum += memberTotal;
            html += `<div style="margin-bottom:14px;border-bottom:1px dashed #e2e8f0;padding-bottom:12px;">
                <div style="display:flex;justify-content:space-between;align-items:center;cursor:pointer;position:relative;" onclick="app.toggleMemberCollapse('${idx}')">
                    <div><div style="font-weight:700;color:var(--primary);font-size:14px;margin-bottom:2px;">${m.name}</div><div style="font-size:10px;color:#64748b;font-weight:600;">A/C: ${idx}</div></div>
                    <div style="display:flex;align-items:center;gap:10px;">
                        <div style="text-align:right;"><div style="font-weight:700;color:#10b981;font-size:14px;">KSh ${memberTotal.toLocaleString()}</div><div style="font-size:9px;color:#94a3b8;">${m.accounts.length} Account(s)</div></div>
                        <button onclick="event.stopPropagation(); app.removeFullMemberFromSummary('${idx}','${encodeURIComponent(dn)}')" style="background:rgba(239,68,68,.1);border:none;color:#ef4444;width:30px;height:30px;border-radius:50%;display:flex;align-items:center;justify-content:center;cursor:pointer;"><i class="fa-solid fa-trash-can" style="font-size:12px;"></i></button>
                    </div>
                </div>
                <div id="collapse-${idx}" style="display:none;padding-top:10px;">`;
            m.accounts.forEach((a, accIdx) => {
                html += `<div class="m-added-acc">
                    <button class="m-remove-btn" onclick="app.removeBulkAccountFromSummary('${idx}',${accIdx},'${encodeURIComponent(dn)}')"><i class="fa-solid fa-xmark"></i></button>
                    <div style="flex:1;min-width:0;"><div class="m-added-acc-name">${a.accountName}</div><div class="m-added-acc-num">KSh ${parseFloat(a.inputAmount).toLocaleString()}</div></div>
                </div>`;
            });
            html += `</div></div>`;
        }
        html += `<div class="m-pay-dark"><div class="m-pay-dark-title">Grand Total</div><div style="text-align:center;font-size:24px;font-weight:800;color:#fbbf24;">KSh ${totalSum.toLocaleString()}</div></div>
        <div class="m-btn-row" style="margin-top:14px;">
            <button class="m-submit-btn" style="background:linear-gradient(135deg,#10b981,#34d399);" onclick="app.processPayment('tbank')"><i class="fa-solid fa-university"></i> tBank</button>
            <button class="m-submit-btn" style="background:linear-gradient(135deg,#22c55e,#4ade80);" onclick="app.processPayment('mpesa')"><i class="fa-solid fa-mobile"></i> M-Pesa</button>
        </div>`;
        this.updateModalContent('Payment Summary', html, () => this.showSeveralMembersSummary(dn, this.data.verifiedMembersList), 'fa-receipt');
    },

    processPayment(method) {
        const name = method === 'tbank' ? 'tBank' : 'M-Pesa';
        const html = `<div style="text-align:center;padding:36px 20px;">
            <div style="width:64px;height:64px;background:#f0fdf4;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 16px;">
                <i class="fa-solid fa-hard-hat" style="font-size:28px;color:var(--primary);"></i>
            </div>
            <h3 style="color:#1e293b;margin-bottom:8px;font-size:16px;">Under Construction</h3>
            <p style="color:#6b7280;font-size:13px;margin-bottom:20px;">Payment via ${name} is currently being developed.</p>
            <button class="m-submit-btn secondary" onclick="app.closeModal()">Close</button>
        </div>`;
        this.updateModalContent('Coming Soon', html, null, 'fa-wrench');
    },

    sendToOtherMember(groupName) {
        const dn   = decodeURIComponent(groupName);
        const html = `
        <div class="m-info-banner blue"><i class="fa-solid fa-circle-info"></i><span>Choose how you want to send to another member.</span></div>
        <div class="m-section-label">Options</div>
        <button class="m-action-btn" onclick="app.showSingleMemberSearch('${encodeURIComponent(dn)}')">
            <div class="btn-icon-box bib-blue"><i class="fa-solid fa-user"></i></div>
            <div class="btn-text-block"><span class="btn-label-text">A Single Member</span><span class="btn-hint-text">Verify by group A/C number</span></div>
            <i class="fa-solid fa-chevron-right btn-arrow-icon"></i>
        </button>
        <button class="m-action-btn violet" onclick="app.showAddSeveralMembers('${encodeURIComponent(dn)}')">
            <div class="btn-icon-box bib-violet"><i class="fa-solid fa-users-viewfinder"></i></div>
            <div class="btn-text-block"><span class="btn-label-text">Several Members</span><span class="btn-hint-text">Batch send to multiple members</span></div>
            <i class="fa-solid fa-chevron-right btn-arrow-icon"></i>
        </button>`;
        this.updateModalContent('Other Member Options', html, () => this.selectGroupForSend(dn), 'fa-user-group');
    },

    showSingleMemberSearch(groupName) {
        const dn   = decodeURIComponent(groupName);
        const html = `
        <div class="m-info-banner blue"><i class="fa-solid fa-circle-info"></i><span>Enter the member's group A/C number to verify.</span></div>
        <div class="m-field"><label>Member Group A/C Number</label><input type="text" id="memberIndexInput" class="form-input" placeholder="e.g. 7" inputmode="numeric"></div>
        <div id="memberVerifyError" class="hidden m-info-banner red" style="margin-bottom:10px;"><i class="fa-solid fa-triangle-exclamation"></i><span id="memberVerifyErrorText"></span></div>
        <button class="m-submit-btn" onclick="app.verifyMemberIndex('${encodeURIComponent(dn)}')"><i class="fa-solid fa-magnifying-glass"></i> Verify A/C Number</button>`;
        this.updateModalContent('Verify Member A/C', html, () => this.sendToOtherMember(dn), 'fa-id-card');
    },

    showAddSeveralMembers(groupName) {
        const dn    = decodeURIComponent(groupName);
        const group = this.data.userGroups.find(g => g.groupName === dn);
        if (!group) return;
        let totalGroupMembers = 0;
        for (const key in group) { if (key.startsWith('trustee_') || key.startsWith('official_') || key.startsWith('member_')) totalGroupMembers++; }
        const html = `
        <div class="m-info-banner blue"><i class="fa-solid fa-circle-info"></i><span>Group has <b>${totalGroupMembers}</b> members. Enter how many you want to include.</span></div>
        <div class="m-field"><label>Number of Members</label><input type="number" id="severalCountInput" class="form-input" min="1" max="${totalGroupMembers}" placeholder="e.g. 5"></div>
        <div id="severalError" class="hidden m-info-banner red"><i class="fa-solid fa-triangle-exclamation"></i><span id="severalErrorText"></span></div>
        <button class="m-submit-btn" onclick="app.renderSeveralMemberInputs('${encodeURIComponent(dn)}', ${totalGroupMembers})"><i class="fa-solid fa-arrow-right"></i> Continue</button>`;
        this.updateModalContent('Add Several Members', html, () => this.sendToOtherMember(dn), 'fa-users');
    },

    renderSeveralMemberInputs(groupName, max) {
        const dn    = decodeURIComponent(groupName);
        const input = document.getElementById('severalCountInput');
        const count = parseInt(input ? input.value : 0);
        if (isNaN(count) || count < 1 || count > max) {
            const errDiv = document.getElementById('severalError');
            const errTxt = document.getElementById('severalErrorText');
            if (errDiv) errDiv.classList.remove('hidden');
            if (errTxt) errTxt.textContent = `Please enter a valid number between 1 and ${max}.`;
            return;
        }
        let html = `<div class="m-info-banner green"><i class="fa-solid fa-circle-info"></i><span>Enter A/C numbers for each of the ${count} members.</span></div>`;
        for (let i = 1; i <= count; i++) {
            html += `<div class="m-field" style="margin-bottom:10px;"><label>Member ${i} A/C Number</label><input type="text" class="form-input several-member-input" data-index="${i}" placeholder="e.g. 7" inputmode="numeric"></div>`;
        }
        html += `<div id="severalVerifyError" class="hidden m-info-banner red" style="margin-bottom:10px;"><i class="fa-solid fa-triangle-exclamation"></i><span id="severalVerifyErrorText"></span></div>
        <button class="m-submit-btn" onclick="app.verifySeveralMembers('${encodeURIComponent(dn)}')"><i class="fa-solid fa-user-check"></i> Verify All Members</button>`;
        this.updateModalContent(`Enter ${count} Member Details`, html, () => this.showAddSeveralMembers(dn), 'fa-users');
    },

    verifySeveralMembers(groupName) {
        const dn      = decodeURIComponent(groupName);
        const inputs  = document.querySelectorAll('.several-member-input');
        const indices = Array.from(inputs).map(i => i.value.trim()).filter(v => v !== '');
        const errDiv  = document.getElementById('severalVerifyError');
        const errTxt  = document.getElementById('severalVerifyErrorText');
        if (indices.length < inputs.length) { if (errDiv) errDiv.classList.remove('hidden'); if (errTxt) errTxt.textContent = "Please fill in all account numbers."; return; }
        if (new Set(indices).size !== indices.length) { if (errDiv) errDiv.classList.remove('hidden'); if (errTxt) errTxt.textContent = "Each member account number must be unique."; return; }
        const group = this.data.userGroups.find(g => g.groupName === dn);
        if (!group) return;
        let verified = [], errors = [];
        indices.forEach((index, idx) => {
            let found = null;
            for (const key in group) { if ((key.startsWith('trustee_') || key.startsWith('official_') || key.startsWith('member_')) && key.endsWith('_' + index)) { found = group[key].name || "Member " + index; break; } }
            if (found) verified.push({ name: found, index }); else errors.push(`A/C ${index} (Field ${idx + 1}) not found.`);
        });
        if (errors.length > 0) { if (errDiv) errDiv.classList.remove('hidden'); if (errTxt) errTxt.textContent = errors[0]; return; }
        this.data.isMultiMemberFlow   = true;
        this.data.verifiedMembersList = verified;
        this.data.settledMembersData  = {};
        this.showSeveralMembersSummary(dn, verified);
    },

    showSeveralMembersSummary(groupName, members) {
        const dn           = decodeURIComponent(groupName);
        const settledCount = Object.keys(this.data.settledMembersData || {}).length;
        const totalCount   = members.length;
        if (settledCount === totalCount) { this.renderFinalBulkSummary(dn); return; }

        let html = `<div class="m-info-banner green"><i class="fa-solid fa-circle-info"></i><span>Settle accounts for each member — <b>${settledCount}/${totalCount}</b> done.</span></div>
        <div class="m-section-label">Members</div>`;
        members.forEach(m => {
            const isSettled = this.data.settledMembersData && this.data.settledMembersData[m.index];
            html += `<button class="m-action-btn ${isSettled ? '' : 'accent'}" onclick="app.selectOneMemberFromList('${encodeURIComponent(dn)}','${encodeURIComponent(m.name)}','${m.index}')">
                <div class="btn-icon-box ${isSettled ? 'bib-green' : 'bib-amber'}"><i class="fa-solid ${isSettled ? 'fa-circle-check' : 'fa-user-clock'}"></i></div>
                <div class="btn-text-block"><span class="btn-label-text">${m.name}</span><span class="btn-hint-text">Member A/C: ${m.index}</span></div>
                <i class="fa-solid fa-chevron-right btn-arrow-icon"></i>
            </button>`;
        });
        this.updateModalContent('Select Recipient', html, () => this.showAddSeveralMembers(dn), 'fa-users');
    },

    selectOneMemberFromList(groupName, memberName, memberIndex) {
        const dn  = decodeURIComponent(groupName);
        const dmn = decodeURIComponent(memberName);
        this.data.recipientName      = dmn;
        this.data.selectedMemberIndex = memberIndex;
        this.data.sendMode           = 'other';
        const group    = this.data.userGroups.find(g => g.groupName === dn);
        const accounts = (group.principles && group.principles.otherContributions) ? group.principles.otherContributions : [];
        this.data.groupAccounts  = accounts;
        this.data.addedAccounts  = [];
        this.data.errorMessage   = '';
        this.renderAccountForm(dn);
    },

    toggleMemberCollapse(idx) {
        const target = document.getElementById(`collapse-${idx}`);
        if (target) target.style.display = target.style.display === 'none' ? 'block' : 'none';
    },
    removeAccountFromSummary(idx, groupName) {
        if (this.data.addedAccounts) {
            this.data.addedAccounts.splice(idx, 1);
            if (this.data.addedAccounts.length === 0) this.renderAccountForm(decodeURIComponent(groupName));
            else this.showFinalPaymentSummary(decodeURIComponent(groupName));
        }
    },
    removeBulkAccountFromSummary(memberIdx, accIdx, groupName) {
        if (this.data.settledMembersData && this.data.settledMembersData[memberIdx]) {
            this.data.settledMembersData[memberIdx].accounts.splice(accIdx, 1);
            if (this.data.settledMembersData[memberIdx].accounts.length === 0) delete this.data.settledMembersData[memberIdx];
            if (Object.keys(this.data.settledMembersData).length === 0) this.showSeveralMembersSummary(decodeURIComponent(groupName), this.data.verifiedMembersList);
            else this.renderFinalBulkSummary(decodeURIComponent(groupName));
        }
    },
    removeFullMemberFromSummary(memberIdx, groupName) {
        if (this.data.settledMembersData && this.data.settledMembersData[memberIdx]) {
            delete this.data.settledMembersData[memberIdx];
            if (Object.keys(this.data.settledMembersData).length === 0) this.showSeveralMembersSummary(decodeURIComponent(groupName), this.data.verifiedMembersList);
            else this.renderFinalBulkSummary(decodeURIComponent(groupName));
        }
    },
    verifyMemberIndex(groupName) {
        const dn      = decodeURIComponent(groupName);
        const input   = document.getElementById('memberIndexInput');
        const index   = input ? input.value.trim() : '';
        const errDiv  = document.getElementById('memberVerifyError');
        const errTxt  = document.getElementById('memberVerifyErrorText');
        if (errDiv) errDiv.classList.add('hidden');
        if (!index) { if (errDiv) errDiv.classList.remove('hidden'); if (errTxt) errTxt.textContent = "Please enter an account number"; return; }
        const group = this.data.userGroups.find(g => g.groupName === dn);
        if (!group) return;
        let found = null;
        for (const key in group) { if ((key.startsWith('trustee_') || key.startsWith('official_') || key.startsWith('member_')) && key.endsWith('_' + index)) { found = group[key].name || "Member " + index; break; } }
        if (found) {
            this.data.recipientName      = found;
            this.data.selectedMemberIndex = index;
            this.data.sendMode           = 'other';
            this.data.isMultiMemberFlow  = false;
            const g = this.data.userGroups.find(g => g.groupName === dn);
            const accounts = (g.principles && g.principles.otherContributions) ? g.principles.otherContributions : [];
            this.data.groupAccounts  = accounts;
            this.data.addedAccounts  = [];
            this.data.errorMessage   = '';
            this.renderAccountForm(dn);
        } else { if (errDiv) errDiv.classList.remove('hidden'); if (errTxt) errTxt.textContent = "Account number " + index + " not found."; }
    },

    /* ─── UTILITIES ─── */
    showToast(msg, type) {
        const toast = document.createElement('div');
        toast.className = 'toast ' + type;
        toast.innerHTML = `<i class="fa-solid fa-${type === 'success' ? 'check-circle' : 'triangle-exclamation'}"></i> <span>${msg}</span>`;
        document.getElementById('toast-container').appendChild(toast);
        setTimeout(() => toast.remove(), 3000);
    },
    switchRole(r) { this.data.role = r; this.render(); },
    updateNav() {
        const activeRole  = this.data.role;
        const activeIndex = this.data.navLinks.indexOf(activeRole);
        const total       = this.data.navLinks.length;
        if (activeIndex > -1) this.moveIndicator(activeIndex, total);
    },
    moveIndicator(index, total) {
        const indicator = document.getElementById('navIndicator');
        if (!indicator) return;
        const buttons = document.querySelectorAll('.top-nav .nav-btn');
        buttons.forEach(btn => btn.classList.remove('active'));
        if (buttons[index]) buttons[index].classList.add('active');
        indicator.style.left = `${index * (100 / total)}%`;
    },

    /**
     * updateModalContent
     * @param {string} title
     * @param {string} html
     * @param {function|null} backAction
     * @param {string} [iconClass]  - FA icon class e.g. 'fa-wallet'
     * @param {string} [hdrStyle]   - Optional inline style override for header gradient
     */
    updateModalContent(title, html, backAction, iconClass, hdrStyle) {
        document.getElementById('modalTitle').innerText = title;
        document.getElementById('modalBody').innerHTML  = html;

        // icon
        const iconEl = document.getElementById('modalHdrIcon');
        if (iconEl) {
            iconEl.innerHTML = `<i class="fa-solid ${iconClass || 'fa-circle-info'}"></i>`;
        }

        // back button
        const backBtn = document.getElementById('modalBackBtn');
        if (backAction) { this.data.modalBackAction = backAction; if (backBtn) backBtn.classList.remove('hidden'); }
        else            { this.data.modalBackAction = null;        if (backBtn) backBtn.classList.add('hidden'); }

        // optional header colour override
        const hdr = document.getElementById('modalHdr');
        if (hdr && hdrStyle) hdr.style.background = hdrStyle;
        else if (hdr) hdr.style.background = '';
    },

    onModalBack() {
        if (typeof this.data.modalBackAction === 'function') this.data.modalBackAction();
        else if (typeof this.data.modalBackAction === 'string') new Function(this.data.modalBackAction).call(this);
    }
};

function moveIndicator(idx, total) {
    const ind = document.getElementById('navIndicator');
    if (ind) ind.style.left = (idx * (100 / total)) + '%';
    document.querySelectorAll('.nav-btn').forEach((b, i) => b.classList.toggle('active', i === idx));
}

document.addEventListener('DOMContentLoaded', () => app.init());
</script>
</body>
</html>