    async processGroupPayLoan(groupName) {
        const amtInput = document.getElementById('payLoanAmount').value;
        const pin = document.getElementById('payLoanPin').value;
        const errDiv = document.getElementById('payLoanError');
        const errTxt = document.getElementById('payLoanErrorText');
        
        if (!amtInput) { errDiv.classList.remove('hidden'); errTxt.textContent = 'Please enter repayment amount.'; return; }
        const amt = parseFloat(amtInput);
        if (isNaN(amt) || amt <= 0) { errDiv.classList.remove('hidden'); errTxt.textContent = 'Please enter a valid positive amount.'; return; }
        if (amt > parseFloat(this.data.balance)) { errDiv.classList.remove('hidden'); errTxt.textContent = 'Insufficient wallet balance.'; return; }
        if (!pin || pin.length < 4) { errDiv.classList.remove('hidden'); errTxt.textContent = 'Please enter your 4-digit PIN.'; return; }
        
        try {
            const res = await fetch('/personal/verify-pin', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ pin })
            });
            const verifyResult = await res.json();
            if (!verifyResult.success) {
                errDiv.classList.remove('hidden');
                errTxt.textContent = verifyResult.message || 'Incorrect PIN.';
                return;
            }
        } catch (e) {
            console.error('Error verifying PIN:', e);
            errDiv.classList.remove('hidden');
            errTxt.textContent = 'Server communication error.';
            return;
        }
        
        // PIN & Balance verified successfully! Let's process repayment.
        this.data.balance = parseFloat(this.data.balance) - amt;
        
        const userName = `${this.data.user.FirstName} ${this.data.user.LastName}`;
        const phone = this.data.user.phoneNumber;
        
        // Add transaction entry
        this.data.transactions.unshift({
            date: new Date().toISOString().split('T')[0],
            type: 'debit',
            acc: 'Group Loan Repayment',
            amt: amt,
            desc: `Repaid KSh ${amt.toLocaleString()} to ${groupName}`
        });
        
        const html = `
        <div style="text-align:center;padding:20px 10px;">
            <div style="width:56px;height:56px;background:#e8f5e9;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 16px;box-shadow: 0 4px 10px rgba(16,185,129,0.2);">
                <i class="fa-solid fa-circle-check" style="font-size:26px;color:#10b981;"></i>
            </div>
            <h3 style="color:#1e293b;margin-bottom:8px;font-size:16px;">Repayment Successful</h3>
            <p style="color:#6b7280;font-size:13px;margin-bottom:20px;">KSh ${amt.toLocaleString()} has been paid to <b>${groupName}</b> from the wallet of <b>${userName}</b> (${phone}).</p>
            
            <div style="background:#f8fafc;border-radius:12px;border:1px solid #e2e8f0;padding:12px 14px;margin-bottom:20px;text-align:left;">
                <div style="display:flex;justify-content:space-between;margin-bottom:8px;font-size:12px;">
                    <span style="color:#64748b;">Transaction Type:</span>
                    <span style="font-weight:700;color:var(--text-dark);">Loan Repayment</span>
                </div>
                <div style="display:flex;justify-content:space-between;margin-bottom:8px;font-size:12px;">
                    <span style="color:#64748b;">Ref Number:</span>
                    <span style="font-weight:700;color:var(--text-dark);font-family:monospace;text-transform:uppercase;">TXN${Math.random().toString(36).substring(2, 9)}</span>
                </div>
                <div style="display:flex;justify-content:space-between;font-size:12px;">
                    <span style="color:#64748b;">Updated Wallet:</span>
                    <span style="font-weight:800;color:#10b981;">KSh ${this.data.balance.toLocaleString()}</span>
                </div>
            </div>
            
            <button class="m-submit-btn" onclick="app.closeModal()">Finish</button>
        </div>`;
        
        this.updateModalContent('Transaction Status', html, null, 'fa-circle-check', 'linear-gradient(135deg, #10b981, #059669)');
        this.render();
    },

