        this.data.isMultiMemberFlow  = false;
        this.data.settledMembersData = {};
        this.data.errorMessage       = '';

        if (typeof arg1 === 'string' && typeof arg2 === 'string') {
            this.updateModalContent(arg1, arg2, arg3);
            return;
        }

        const action = arg1;

        /* ── Send Money ── */
        if (action === 'Send Money') {
            const groups = this.data.userGroups || [];
