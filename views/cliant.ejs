    // ── DRILL-DOWN: show all members for a specific account type ─────────
    openGroupAccountMembersView(accId) {
        const data = this._groupAccountsData;
        if (!data) return;

        const accDetails = data.accountDetails || {};
        const detail = accDetails[accId];
        if (!detail) return;

        const groupName = this._groupAccountsName || data.groupName;
        const isMemberOnly = data.isMemberOnly;
        const loggedInMemberName = data.loggedInMemberName || '';
        const loggedInMemberId = data.loggedInMemberId || null;

        const accColors = {
            saving:       { bg: '#e8f5e9', color: '#2e7d32', icon: 'fa-piggy-bank',   grad: 'linear-gradient(135deg,#2e7d32,#66bb6a)' },
            registration: { bg: '#e3f2fd', color: '#1565c0', icon: 'fa-id-card',       grad: 'linear-gradient(135deg,#1565c0,#42a5f5)' },
            late:         { bg: '#ffebee', color: '#c62828', icon: 'fa-clock',         grad: 'linear-gradient(135deg,#c62828,#ef9a9a)' },
            welfare:      { bg: '#f3e5f5', color: '#6a1b9a', icon: 'fa-hands-holding', grad: 'linear-gradient(135deg,#6a1b9a,#ce93d8)' },
            default:      { bg: '#e8f0fe', color: '#1a73e8', icon: 'fa-wallet',        grad: 'linear-gradient(135deg,#1a73e8,#64b5f6)' }
        };
        const getAccStyle = (name) => {
            const n = (name || '').toLowerCase();
            if (n.includes('saving'))       return accColors.saving;
            if (n.includes('registration')) return accColors.registration;
            if (n.includes('late'))         return accColors.late;
            if (n.includes('welfare'))      return accColors.welfare;
            return accColors.default;
        };
        const style = getAccStyle(detail.accountName);

        const members = detail.members || [];

        // ── summary strip ─────────────────────────────────────────────
        let html = `
        <div style="background:${style.grad};border-radius:12px;padding:14px 16px;margin-bottom:14px;color:white;">
            <div style="display:flex;align-items:center;gap:10px;margin-bottom:10px;">
                <span style="width:38px;height:38px;border-radius:9px;background:rgba(255,255,255,0.2);display:flex;align-items:center;justify-content:center;font-size:15px;">
