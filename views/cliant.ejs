            renderDealerView(container) {
                if (this.data.dealerIsVerified) {
                    container.innerHTML = '<h1>Dealer Dashboard</h1><div class="box-wrapper"><p>Dealer Dashboard Loading...</p></div>';
                } else {
                    container.innerHTML = '<h1>Dealer Dashboard</h1><div class="box-wrapper"><p class="text-muted">Please verify your PIN.</p></div>';
                    this.showToast('Authentication required for Dealer role.', 'error');
                }
            },
            handleDealerClick() {
                if (!this.data.isDealer) { this.showToast('You are not registered as a dealer.', 'error'); return; }
                this.switchRole('Dealer');
            },
            openModal(action) {
                const modal = document.getElementById('modalOverlay');
                modal.classList.add('open');
                const title = document.getElementById('modalTitle');
                const body = document.getElementById('modalBody');
                if (action === 'Send Money') { title.innerText = 'My Account'; body.innerHTML = '<button class="modal-list-btn" onclick="app.flowMyAccount()">My Account</button><button class="modal-list-btn" onclick="app.flowOtherAccount()">Other Account</button>'; }
                else if (action === 'Withdraw') { title.innerText = 'Withdraw Money'; body.innerHTML = '<button class="modal-list-btn" onclick="app.flowWithdrawMpesa()">To M-Pesa</button>'; }
                else if (action === 'Balance') { title.innerText = 'Account Balance'; body.innerHTML = '<div class="form-group"><label class="form-label">Enter PIN</label><input type="password" id="checkPin" class="form-input" maxlength="4" placeholder="****"></div><button class="btn btn-primary" onclick="app.processCheckBalance()">Check Balance</button>'; }
                else if (action === 'Change PIN') { title.innerText = 'Change PIN'; body.innerHTML = '<button class="modal-list-btn" onclick="app.flowNewPin()">New PIN</button>'; }
                else if (action === 'Statement') { title.innerText = 'Account Statement'; body.innerHTML = '<button class="modal-list-btn" onclick="app.flowMiniStatement()">Mini Statement</button>'; }
            },
            flowMyAccount() {
                if (this.data.userGroups && this.data.userGroups.length > 0) {
                    let groupsHtml = '<p style="text-align:center; color:var(--text-muted); margin-bottom:1rem; font-size:0.9rem;">Select a group linked to your number</p>';
                    this.data.userGroups.forEach((group, index) => {
                        groupsHtml += '<button class="modal-list-btn" onclick="app.selectGroupForSendMoney(' + index + ')" style="display:flex; justify-content:space-between; align-items:center;"><span style="font-weight:600;">' + (group.groupName || '').replace(/</g, '&lt;').replace(/>/g, '&gt;') + '</span><i class="fa-solid fa-chevron-right" style="color:var(--text-muted); font-size:0.85rem;"></i></button>';
                    });
                    groupsHtml += '<button class="modal-list-btn btn-secondary" onclick="app.openModal(\'Send Money\')" style="margin-top:0.5rem; border:1px solid var(--border);">Back</button>';
                    this.updateModalContent('My Account', groupsHtml);
                } else {
                    this.updateModalContent('My Account', '<p style="text-align:center; color:var(--text-muted); margin-bottom:1rem;">No group account is linked to your phone number.</p><button class="modal-list-btn" onclick="app.openModal(\'Send Money\')">Back</button>');
                }
            },
            selectGroupForSendMoney(index) {
                const group = this.data.userGroups && this.data.userGroups[index];
                if (!group) { this.showToast("Group not found", "error"); return; }
                this.data.lastGroupName = group.groupName;
                this.data.lastGroupIndex = index;
                this.data.sendMoneyAccounts = [];
                this.showAccountChoiceForSendMoney();
            },
            getGroupAccountsFromPrinciples(group) {
                const list = [];
                if (!group || !group.principles) return list;
                const p = group.principles;
                if (p.otherContributions && Array.isArray(p.otherContributions)) {
                    p.otherContributions.forEach(function(c) {
                        if (c.accountNumber != null || c.accountName) list.push({ num: String(c.accountNumber || ''), name: String(c.accountName || '') });
                    });
                }
                if (p.distribution && p.distribution.targetAccountNumber) {
                    list.push({ num: String(p.distribution.targetAccountNumber), name: String(p.distribution.targetAccountName || '') });
                }
                return list;
            },
            showAccountChoiceForSendMoney() {
                let html = '<p style="text-align:center; color:var(--text-muted); margin-bottom:1rem; font-size:0.9rem;">Select an option</p>';
                html += '<button class="modal-list-btn" onclick="app.showSelectAccountList()">Select account</button>';
                html += '<button class="modal-list-btn" onclick="app.showEnterAccountForm()">Enter account number</button>';
                html += '<button class="modal-list-btn btn-secondary" onclick="app.flowMyAccount()" style="margin-top:0.5rem; border:1px solid var(--border);">Back</button>';
                this.updateModalContent('Select Option', html);
            },
            showSelectAccountList() {
                const group = this.data.userGroups && this.data.userGroups[this.data.lastGroupIndex];
                if (!group) { this.showToast("Group not found", "error"); return; }
                const accounts = this.getGroupAccountsFromPrinciples(group);
                if (accounts.length > 0) {
                    this.data.groupAccountsList = accounts;
                    this.data.currentAccIndex = 0;
                    this.data.sendMoneyAccounts = [];
                    this.loadAccountFormForIndex();
                } else {
                    let html = '<p style="text-align:center; color:var(--text-muted); margin-bottom:1rem;">No accounts found.</p>';
                    html += '<button class="modal-list-btn btn-secondary" onclick="app.showAccountChoiceForSendMoney()" style="margin-top:0.5rem; border:1px solid var(--border);">Back</button>';
                    this.updateModalContent('Transaction Details', html);
                }
            },
            loadAccountFormForIndex() {
                const a = this.data.groupAccountsList[this.data.currentAccIndex];
                this.data.currentSendAcc = {acc: a.num, name: a.name, amt: ''};
                this.showGroupAccountsTransactionForm();
            },
            showEnterAccountForm() {
                let html = '<div class="form-group"><label class="form-label">Enter account number</label><input type="text" id="enterAccNum" class="form-input" placeholder="e.g. 002"></div><button class="btn btn-primary" onclick="app.verifyEnteredAccountNum()" style="margin-bottom:0.5rem; width:100%;">Verify</button>';
                html += '<button class="modal-list-btn btn-secondary" onclick="app.showAccountChoiceForSendMoney()" style="margin-top:0.5rem; border:1px solid var(--border);">Back</button>';
                this.updateModalContent('Enter account number', html);
            },
            selectAccountForSendMoney(accNum, accName) {
                if (!this.data.sendMoneyAccounts) this.data.sendMoneyAccounts = [];
                // Find if exists to pre-fill amount, otherwise create new
                let existing = this.data.sendMoneyAccounts.find(a => a.acc === accNum);
                this.data.currentSendAcc = existing ? {...existing} : {acc: accNum, name: accName, amt: ''};
                
                // For entered accounts, we won't show 'Add Account' to cycle since they aren't part of groupAccountsList iteration.
                // We fake the index to be the end to hide 'Add Account'
                this.data.currentAccIndex = 999;
                
                this.showGroupAccountsTransactionForm();
            },
            verifyEnteredAccountNum() {
                const entered = (document.getElementById('enterAccNum') && document.getElementById('enterAccNum').value) ? document.getElementById('enterAccNum').value.trim() : '';
                if (!entered) { this.showToast('Enter account number', 'error'); return; }
                const group = this.data.userGroups && this.data.userGroups[this.data.lastGroupIndex];
                const accounts = this.getGroupAccountsFromPrinciples(group || {});
                const found = accounts.find(function(a) { return a.num === entered; });
                if (found) {
                    this.selectAccountForSendMoney(found.num, found.name);
                } else {
                    this.selectAccountForSendMoney(entered, 'Unknown Account');
                }
            },
            showGroupAccountsTransactionForm() {
                const item = this.data.currentSendAcc;
                let html = '<div style="display:flex; gap:8px; margin-bottom:1rem; align-items:center; background:#f8fafc; padding:8px; border-radius:8px; border:1px solid var(--border);">';
                html += '<div style="flex:1;"><div style="font-size:0.7rem; color:var(--text-muted); margin-bottom:2px;">Account</div><input type="text" class="form-input" value="' + item.acc + '" readonly style="background:#e2e8f0; padding:0.5rem; font-size:0.85rem;"></div>';
                html += '<div style="flex:1.5;"><div style="font-size:0.7rem; color:var(--text-muted); margin-bottom:2px;">Name</div><input type="text" class="form-input" value="' + item.name + '" readonly style="background:#e2e8f0; padding:0.5rem; font-size:0.85rem;"></div>';
                html += '<div style="flex:1;"><div style="font-size:0.7rem; color:var(--text-muted); margin-bottom:2px;">Amount</div><input type="number" id="currentSendAmt" class="form-input" placeholder="0.00" value="' + item.amt + '" min="0" step="0.01" style="padding:0.5rem; font-size:0.85rem;"></div>';
                html += '</div>';
                
                html += '<div style="display:flex; gap:10px; margin-bottom:1rem;">';
                
                // Only show Add Account if there's a next account in the list to iterate to
                if (this.data.groupAccountsList && this.data.currentAccIndex < this.data.groupAccountsList.length - 1) {
                    html += '<button class="btn btn-secondary" onclick="app.addCurrentAndGoNext()" style="flex:1; border:1px dashed var(--primary); color:var(--primary); background:#eff6ff;"><i class="fa-solid fa-plus"></i> Add Account</button>';
                }
                
                html += '<button class="btn btn-primary" onclick="app.addCurrentAndReview()" style="flex:1;">Submit</button>';
                html += '</div>';
                
                html += '<button class="modal-list-btn btn-secondary" onclick="app.showAccountChoiceForSendMoney()" style="margin-top:0.5rem; border:1px solid var(--border);">Back</button>';
                this.updateModalContent('Transaction Details', html);
            },
            addCurrent() {
                const amtInput = document.getElementById('currentSendAmt').value;
                this.data.currentSendAcc.amt = amtInput || 0;
                if (!this.data.sendMoneyAccounts) this.data.sendMoneyAccounts = [];
                const existing = this.data.sendMoneyAccounts.find(a => a.acc === this.data.currentSendAcc.acc);
                if (existing) {
                    existing.amt = this.data.currentSendAcc.amt;
                } else {
                    this.data.sendMoneyAccounts.push({...this.data.currentSendAcc});
                }
            },
            addCurrentAndGoNext() {
                this.addCurrent();
                this.data.currentAccIndex++;
                this.loadAccountFormForIndex();
            },
            addCurrentAndReview() {
                this.addCurrent();
                this.showSendMoneyConfirmation();
            },
            showSendMoneyConfirmation() {
                let html = '<div style="max-height: 250px; overflow-y: auto; margin-bottom: 1rem; padding-right: 5px;">';
                let totalAmt = 0;
                if (this.data.sendMoneyAccounts && this.data.sendMoneyAccounts.length > 0) {
                    this.data.sendMoneyAccounts.forEach((item, i) => {
                        const amt = parseFloat(item.amt) || 0;
                        totalAmt += amt;
                        html += '<div style="display:flex; justify-content:space-between; align-items:center; background:#f8fafc; padding:10px; border-radius:8px; border:1px solid var(--border); margin-bottom:0.5rem;">';
                        html += '<div><div style="font-weight:600; font-size:0.9rem;">' + item.name + '</div><div style="font-size:0.75rem; color:var(--text-muted);">' + item.acc + '</div></div>';
                        html += '<div style="font-weight:700;">Ksh ' + amt.toFixed(2) + '</div>';
                        html += '</div>';
                    });
                }
                html += '</div>';
                
                html += '<div style="text-align:right; font-size:1.1rem; font-weight:700; margin-bottom:1rem; padding-top:1rem; border-top:1px solid var(--border);">';
                html += 'Total: Ksh ' + totalAmt.toFixed(2);
                html += '</div>';
                
                html += '<button class="btn btn-primary" onclick="app.showPaymentOptions()" style="margin-bottom:0.5rem;"><i class="fa-solid fa-paper-plane"></i> Send</button>';
                html += '<button class="modal-list-btn btn-secondary" onclick="app.showGroupAccountsTransactionForm()" style="margin-top:0.5rem; border:1px solid var(--border);">Back</button>';
                
                this.updateModalContent('Confirm Transfer', html);
            },
            processMultiGroupTransaction() {
                let totalAmt = 0;
                let validAccounts = [];
                for (let i = 0; i < this.data.sendMoneyAccounts.length; i++) {
                    const item = this.data.sendMoneyAccounts[i];
                    const amt = parseFloat(item.amt) || 0;
                    if (amt < 0) return this.showToast('Invalid amount', 'error');
                    totalAmt += amt;
                    if (amt > 0 || this.data.sendMoneyAccounts.length === 1) { // Include if amount>0 or it's the only one
                        validAccounts.push({acc: item.acc, name: item.name, amt: amt});
                    }
                }

                if(totalAmt > this.data.balance) return this.showToast('Insufficient Balance', 'error');
                
                this.data.balance -= totalAmt;
                validAccounts.forEach(item => {
                    this.addTransaction(item.acc + ' (' + item.name + ')', 'Group Transfer', item.amt, 'Success'); 
                });
                
                this.showToast('Transfer(s) Successful', 'success'); 
                this.data.sendMoneyAccounts = [];
                this.render(); 
                this.closeModal(); 
            },
            showPaymentOptions() {
                let html = '<button class="modal-list-btn" onclick="app.confirmTbankPayment()">tbank</button><button class="modal-list-btn" onclick="app.showMpesaOptions()">mpesa</button>';
                this.updateModalContent('Select Payment Method', html);
            },
            confirmTbankPayment() {
                let totalAmt = 0;
                if (this.data.sendMoneyAccounts && this.data.sendMoneyAccounts.length > 0) {
                    this.data.sendMoneyAccounts.forEach((item, i) => {
                        const amt = parseFloat(item.amt) || 0;
                        totalAmt += amt;
                    });
                }
                const group = this.data.userGroups[this.data.lastGroupIndex];
                const groupName = group ? group.groupName : 'N/A';
                const groupNumber = group ? group.accountNumber : 'N/A';

                let html = '<div style="text-align:left; margin-bottom:1rem; padding-bottom:1rem; border-bottom:1px solid var(--border);">';
                html += '<p style="font-weight: 600; font-size: 1rem; color: var(--text-main);">Group Name: ' + groupName + '</p>';
                html += '<p style="font-weight: 600; font-size: 1rem; color: var(--text-main);">Group Number: ' + groupNumber + '</p>';
                html += '</div>';

                html += '<div style="text-align:right; font-size:1.1rem; font-weight:700; margin-bottom:1rem;">';
                html += 'Total: Ksh ' + totalAmt.toFixed(2);
                html += '</div>';
                html += '<div class="form-group"><label class="form-label">Enter PIN to Confirm</label><input type="password" id="tranPin" class="form-input" maxlength="4" placeholder="****"></div>';
                html += '<button class="btn btn-primary" onclick="app.showUnderConstruction()" style="margin-bottom:0.5rem;"><i class="fa-solid fa-paper-plane"></i> Submit</button>';
                this.updateModalContent('Confirm Tbank Payment', html);
            },
            showUnderConstruction() {
                this.updateModalContent('Under Construction', '<p>This feature is under construction.</p>');
            },
            flowOtherAccount() { this.flowTransactionForm('Other', 'Other Account'); },
            flowTransactionForm(type, label) {
                this.updateModalContent(label, '<div class="form-group"><label class="form-label">Account</label><input type="number" id="tranAcc" class="form-input" placeholder="1234"></div><div class="form-group"><label class="form-label">Amount</label><input type="number" id="tranAmt" class="form-input" placeholder="0.00"></div><div class="form-group"><label class="form-label">PIN</label><input type="password" id="tranPin" class="form-input" maxlength="4"></div><button class="btn btn-primary" onclick="app.processSingleTransaction(\''+type+'\')">Submit</button>');
            },
            processSingleTransaction(type) {
                const acc = document.getElementById('tranAcc').value;
                const amt = parseFloat(document.getElementById('tranAmt').value);
                const pin = document.getElementById('tranPin').value;
                let error = '';
                if(acc !== this.data.ACCOUNT_NUM) error = 'Invalid Account';
                else if(pin !== this.data.PIN) error = 'Wrong PIN';
                else if(amt > this.data.balance) error = 'Insufficient Balance';
                if(error) { this.showToast(error, 'error'); this.addTransaction(acc, type, amt, 'Failed', error); this.closeModal(); }
                else { this.data.balance -= amt; this.addTransaction(acc, type, amt, 'Success'); this.showToast('Success', 'success'); this.render(); this.closeModal(); }
            },
            flowNewPin() { this.updateModalContent('Change PIN', '<div class="form-group"><label class="form-label">Current PIN</label><input type="password" id="currPin" class="form-input" maxlength="4"></div><div class="form-group"><label class="form-label">New PIN</label><input type="password" id="newPin" class="form-input" maxlength="4"></div><button class="btn btn-primary" onclick="app.processNewPin()">Update</button>'); },
            processNewPin() {
                const curr = document.getElementById('currPin').value;
                const newP = document.getElementById('newPin').value;
                if(curr !== this.data.PIN) return this.showToast('Incorrect Current PIN', 'error');
                this.data.PIN = newP;
                this.addTransaction('System', 'PIN Change', 0, 'Success', 'PIN updated');
                this.showToast('PIN Updated', 'success');
                this.closeModal();
            },
            flowWithdrawMpesa() { this.updateModalContent('Withdraw to M-Pesa', '<div class="form-group"><label class="form-label">M-Pesa Number</label><input type="text" class="form-input" value="1234" readonly style="background:#e2e8f0;"></div><div class="form-group"><label class="form-label">Amount</label><input type="number" id="mpesaAmt" class="form-input"></div><div class="form-group"><label class="form-label">PIN</label><input type="password" id="mpesaPin" class="form-input" maxlength="4"></div><button class="btn btn-primary" onclick="app.processWithdrawMpesa()">Submit</button>'); },
            processWithdrawMpesa() {
                const amt = parseFloat(document.getElementById('mpesaAmt').value);
                const pin = document.getElementById('mpesaPin').value;
                if(pin !== this.data.PIN) return this.showToast('Wrong PIN', 'error');
                if(amt > this.data.balance) return this.showToast('Insufficient Balance', 'error');
                this.data.balance -= amt;
                this.addTransaction('M-Pesa', 'Withdrawal', amt, 'Success', 'To 1234');
                this.render();
                this.showResultModal('Withdrawal Success', 'Success', 'Withdrew Ksh ' + amt);
            },
            processCheckBalance() {
                const pin = document.getElementById('checkPin').value;
                if(pin !== this.data.PIN) return this.showToast('Wrong PIN', 'error');
                this.addTransaction('Self', 'Balance Inquiry', 0, 'Success');
                this.updateModalContent('Account Balance', '<div style="text-align:center;"><h4>Current Balance</h4><p style="font-size:1.5rem; font-weight:700; color:var(--success); margin-top:1rem;">Ksh ' + this.data.balance.toFixed(2) + '</p></div>');
            },
            flowMiniStatement() { this.updateModalContent('Mini Statement', '<div class="form-group"><label class="form-label">Enter PIN</label><input type="password" id="stmtPin" class="form-input" maxlength="4" placeholder="****"></div><button class="btn btn-primary" onclick="app.processMiniStatement()">View</button>'); },
            processMiniStatement() {
                const pin = document.getElementById('stmtPin').value;
                if(pin !== this.data.PIN) return this.showToast('Wrong PIN', 'error');
                const recent = this.data.transactions.slice(-4);
                let rows = '';
                recent.forEach(t => { rows += '<tr><td>' + t.date + '</td><td>' + t.acc + '</td><td>Ksh ' + (t.amt || 0) + '</td><td>Ksh ' + t.balance + '</td></tr>'; });
                this.updateModalContent('Mini Statement', '<div style="overflow-x:auto;"><table style="width:100%; border-collapse:collapse; font-size:0.85rem;"><thead><tr style="background:#f1f5f9;"><th style="text-align:left; padding:8px;">Date</th><th style="text-align:left; padding:8px;">Account</th><th style="text-align:left; padding:8px;">Amount</th><th style="text-align:left; padding:8px;">Balance</th></tr></thead><tbody>' + rows + '</tbody></table></div>');
                this.showToast('Mini Statement Generated', 'success');
            },
            addTransaction(target, acc, amt, status, reason = null) {
                this.data.transactions.push({ type: acc==='Deposit'?'deposit':(acc==='Withdrawal'?'withdraw':'transfer'), target, acc, amt, status, reason, date: new Date().toLocaleTimeString(), balance: this.data.balance });
                if(status === 'Success') { this.data.unread++; this.updateBadge(); }
            },
            updateModalContent(title, html) { document.getElementById('modalTitle').innerText = title; document.getElementById('modalBody').innerHTML = html; },
            showResultModal(mainTitle, status, msg) { this.updateModalContent(mainTitle, '<div style="padding:1rem; border-radius:0.5rem; margin-bottom:1rem; text-align:left; border:1px solid ' + (status === 'Success' ? '#86efac' : '#fca5a5') + '; background:' + (status === 'Success' ? '#f0fdf4' : '#fef2f2') + ';"><h4 style="color:' + (status === 'Success' ? '#15803d' : '#b91c1c') + '; margin-bottom:0.5rem;">' + status + '</h4><p>' + msg + '</p><div style="display:flex; justify-content:space-between; font-size:0.85rem; margin-top:0.5rem; color:var(--text-muted);"><span>Balance:</span> <span style="font-weight:600;">Ksh ' + this.data.balance.toFixed(2) + '</span></div></div>'); },
            showToast(msg, type) {
                const toast = document.createElement('div');
                toast.className = 'toast ' + type;
                toast.innerHTML = '<i class="fa-solid fa-' + (type==='success'?'check-circle':'triangle-exclamation') + '"></i> <span>' + msg + '</span>';
                document.getElementById('toast-container').appendChild(toast);
                setTimeout(() => toast.remove(), 3000);
            },
            switchRole(r) { this.data.role = r; this.render(); if (r === 'Agent') { setTimeout(() => { window.location.href = '/agent'; }, 400); } }
        };
        document.addEventListener('DOMContentLoaded', () => app.init());
    </script>
</body>
</html>
