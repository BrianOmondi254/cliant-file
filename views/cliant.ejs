                            </div>
                            <div style="background:#f0fdf4;border:1px solid #dcfce7;border-radius:7px;padding:7px 9px;">
                                <div style="font-size:8.5px;font-weight:700;color:#15803d;text-transform:uppercase;letter-spacing:.5px;">Amount In</div>
                                <div style="font-size:12px;font-weight:800;color:#15803d;margin-top:2px;">+KSh ${amtIn.toLocaleString()}</div>
                            </div>
                            <div style="background:#fef2f2;border:1px solid #fee2e2;border-radius:7px;padding:7px 9px;">
                                <div style="font-size:8.5px;font-weight:700;color:#b91c1c;text-transform:uppercase;letter-spacing:.5px;">Amount Out</div>
                                <div style="font-size:12px;font-weight:800;color:#b91c1c;margin-top:2px;">-KSh ${amtOut.toLocaleString()}</div>
                            </div>
                            <div style="background:#eff6ff;border:1px solid #bfdbfe;border-radius:7px;padding:7px 9px;">
                                <div style="font-size:8.5px;font-weight:700;color:#1d4ed8;text-transform:uppercase;letter-spacing:.5px;">Closing Bal</div>
                                <div style="font-size:12px;font-weight:800;color:#1d4ed8;margin-top:2px;">KSh ${closingBal.toLocaleString()}</div>
                            </div>
                        </div>
                    </div>`;
                });
