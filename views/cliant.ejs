            if (result.success) { this.showToast("PIN set successfully!", "success"); this.data.hasPersonalPin = true; this.render(); }
            else { this.showToast(result.message || "Failed to set PIN", "error"); }
        } catch(e) { this.showToast("Server error occurred", "error"); }
