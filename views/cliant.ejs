    renderCreatePinView(container) {
        container.innerHTML = `<div class="box-wrapper" style="background:#fff;padding:2.5rem;border-radius:12px;text-align:center;max-width:450px;margin:0 auto;"><h2 style="margin-bottom:1rem;">Set Personal PIN</h2><p style="color:#6b7280;margin-bottom:1rem;">You need to set a 4-digit PIN to access your personal wallet.</p><div class="form-group"><label class="form-label">New PIN</label><input type="password" id="newPersonalPin" class="form-input" maxlength="4" placeholder="****" inputmode="numeric"></div><div class="form-group"><label class="form-label">Confirm PIN</label><input type="password" id="confirmPersonalPin" class="form-input" maxlength="4" placeholder="****" inputmode="numeric"></div><button class="btn btn-primary" onclick="app.createPersonalPin()">Create PIN</button></div>`;
    },
    async createPersonalPin() {
        const pin = document.getElementById('newPersonalPin').value;
        const confirm = document.getElementById('confirmPersonalPin').value;
        if (!pin || pin.length < 4) { this.showToast("PIN must be 4 digits", "error"); return; }
        if (pin !== confirm) { this.showToast("PINs do not match", "error"); return; }
        try {
            const res = await fetch('/personal/set-pin', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ pin }) });
            const result = await res.json();
            if (result.success) { this.showToast("PIN set successfully!", "success"); this.data.hasPersonalPin = true; this.render(); }
            else { this.showToast(result.message || "Failed to set PIN", "error"); }
        } catch (e) { console.error(e); this.showToast("Server error occurred", "error"); }
    },
