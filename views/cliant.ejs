    revealResetPinFields() {
        const key = document.getElementById('startKeyCliant')?.value || '';
        const fields = document.getElementById('pinEntryFields');
        if (fields) {
            if (key.length >= 4) fields.classList.remove('hidden');
            else fields.classList.add('hidden');
        }
    },
    checkResetPinMatch() {
        const pin1 = document.getElementById('resetNewPinCliant')?.value || '';
        const pin2 = document.getElementById('resetConfirmPinCliant')?.value || '';
        const btn = document.getElementById('finalResetBtn');
        if (btn) {
            if (pin1.length === 4 && pin1 === pin2) {
                btn.classList.remove('hidden');
            } else {
                btn.classList.add('hidden');
            }
        }
    },
    async submitResetPinCliant() {
        const startKey = document.getElementById('startKeyCliant')?.value;
        const newPin = document.getElementById('resetNewPinCliant')?.value;
        const confirmPin = document.getElementById('resetConfirmPinCliant')?.value;
        const msg = document.getElementById('resetPinMsgCliant');
        
        if (!startKey || startKey.length < 4) {
            if (msg) { msg.textContent = 'Please enter the start key from SMS'; msg.style.color = 'red'; }
            return;
        }
        if (!newPin || newPin.length < 4) {
            if (msg) { msg.textContent = 'New PIN must be 4 digits'; msg.style.color = 'red'; }
            return;
        }
        if (newPin !== confirmPin) {
            if (msg) { msg.textContent = 'PINs do not match'; msg.style.color = 'red'; }
            return;
        }
        
        // TODO: Verify start key with backend and reset PIN
        if (msg) {
            msg.textContent = 'Start key verification integration pending.';
            msg.style.color = '#f59e0b';
        }
    },
    async changePersonalPin() {
        const oldPin = document.getElementById('oldPersonalPin').value;
        const newPin = document.getElementById('newChangePin').value;
        const confirmPin = document.getElementById('confirmChangePin').value;
        
        if (!oldPin || oldPin.length < 4) { this.showToast("Please enter your current PIN", "error"); return; }
        if (!newPin || newPin.length < 4) { this.showToast("New PIN must be 4 digits", "error"); return; }
        if (newPin !== confirmPin) { this.showToast("New PINs do not match", "error"); return; }
        if (oldPin === newPin) { this.showToast("New PIN must be different from current PIN", "error"); return; }
        
        try {
            const res = await fetch('/personal/change-pin', { 
                method: 'POST', 
                headers: { 'Content-Type': 'application/json' }, 
                body: JSON.stringify({ oldPin, newPin }) 
            });
            const result = await res.json();
            if (result.success) { 
                this.showToast("PIN changed successfully!", "success"); 
                this.render(); 
            } else { 
                this.showToast(result.message || "Failed to change PIN", "error"); 
            }
        } catch (e) { 
            console.error(e); 
            this.showToast("Server error occurred", "error"); 
        }
    },
    toggleLongStatementOptions() {
        const target = document.getElementById('longStatementOptions');
        const chevron = document.getElementById('longStatementChevron');
        if (target) {
            const isHidden = target.classList.contains('hidden');
            if (isHidden) {
                target.classList.remove('hidden');
                if (chevron) chevron.style.transform = 'rotate(180deg)';
            } else {
                target.classList.add('hidden');
                if (chevron) chevron.style.transform = 'rotate(0deg)';
            }
        }
    },
