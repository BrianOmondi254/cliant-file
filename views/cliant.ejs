                `;

                filtered.forEach(g => {
                    const phase = parseInt(g.phase) || 1;
                    const roleColor = g.role === 'trustee' ? '#7c3aed' : '#0891b2';
                    const roleIcon = g.role === 'trustee' ? 'fa-user-tie' : (g.role === 'official' ? 'fa-user-gear' : 'fa-user');
                    const displayRole = (phase >= 2 && g.roleTitle) ? g.roleTitle : (g.role || 'Member');

                    // Date Snippets
                    const createdShort = g.createdAt ? new Date(g.createdAt).toLocaleDateString([], { month: 'short', day: 'numeric' }) : 'N/A';
                    let pendingDateInfo = '';
                    if (phase === 2 && g.totalProposedMembers > 0) { // Using member count as a proxy for update
                        pendingDateInfo = `<span style="font-size: 0.65rem; color: #94a3b8; font-weight: 500; margin-left: 5px;">(C: ${createdShort})</span>`;
                    }

                    html += `
                        <div class="menu-item" onclick="window.location.href='/personal/group/${encodeURIComponent(g.groupName)}'" style="background: #f8fafc; padding: 16px; border-radius: 14px; margin-bottom: 12px; border: 1px solid #e2e8f0; display: flex; justify-content: space-between; align-items: start; transition: transform 0.2s;">
                            <div style="flex: 1;">
                                <div style="display: flex; align-items: center; gap: 8px; flex-wrap: wrap; margin-bottom: 6px;">
                                    <span style="font-weight: 700; color: #1e293b; font-size: 1.05rem; letter-spacing: -0.2px;">${g.groupName}</span>
                                    ${pendingDateInfo}
                                    <span style="font-size: 0.65rem; color: ${roleColor}; font-weight: 700; background: ${roleColor}10; padding: 2px 8px; border-radius: 6px; display: flex; align-items: center; gap: 4px; border: 1px solid ${roleColor}20;">
                                        <i class="fas ${roleIcon}"></i> ${displayRole.toUpperCase()}
                                    </span>
                                </div>
                                <div style="display:flex; align-items:center; gap:10px; color:#64748b; font-size:11px; font-weight:500;">
                                    <i class="fa-solid fa-location-dot" style="font-size:9px;"></i>
                                    <span>${g.county || 'N/A'} • ${g.ward || 'N/A'}</span>
                                    <span style="margin-left:auto; font-size:10px;"><i class="far fa-calendar-alt"></i> ${createdShort}</span>
                                </div>
                            </div>
                            <div style="display:flex; align-items:center; gap:10px; margin-left: 10px;">
                                <span style="font-size:9px; font-weight:800; text-transform:uppercase; color:${config.color}; background:${config.bg}; padding:3px 8px; border-radius:6px; border:1px solid ${config.color}20; white-space: nowrap;">${config.title}</span>
                                <span class="arrow" style="color:${config.color}; font-size:16px;">›</span>
                            </div>
                        </div>
                    `;
                });

                html += `
                        </div>
                    </div>
                `;
            }
        });

        html += `
            <div style="margin-top:10px; padding:0 2px;">
                <button class="btn btn-primary" style="background:#0f9d58; height:56px; border-radius:16px; box-shadow:0 12px 24px rgba(15,157,88,0.25); border:1px solid rgba(255,255,255,0.1); font-size:16px;" onclick="app.openModal('Create Group')">
                    <i class="fa-solid fa-plus-circle"></i> Create New Request
                </button>
            </div>
        `;

        html += '</div>';
        container.innerHTML = html;
    },
