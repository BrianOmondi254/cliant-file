    /* ─── GROUP / LOCATION HELPERS ─── */
    async goToRegions() {
        const name     = document.getElementById('newGroupName').value.trim();
        const phone    = document.getElementById('newChairPhone').value.trim();
        const fullName = document.getElementById('newFullNameInput').value.trim();
        const nextBtn  = document.getElementById('newGroupNextBtn');
        const isValidP = p => /^\+?254[0-9]{9}$/.test(p) || /^0[17][0-9]{8}$/.test(p);
        if (!name)                      { this.showToast('Please enter a group name.', 'error'); return; }
        if (!phone || !isValidP(phone)) { this.showToast('Invalid phone. Use +254XXXXXXXXX or 07/01XXXXXXXX.', 'error'); return; }
        if (fullName.split(/\s+/).length < 3) { document.getElementById('newNameError').style.display = 'block'; return; }
        document.getElementById('newNameError').style.display = 'none';

        const original = nextBtn ? nextBtn.innerHTML : '';
        if (nextBtn) {
            nextBtn.disabled = true;
            nextBtn.style.opacity = '0.65';
            nextBtn.innerHTML = '<i class="fa-solid fa-circle-notch fa-spin"></i> Verifying...';
        }

        try {
            const nameOk = await this.verifyNewGroupName();
            if (!nameOk) return;
            document.getElementById('cAccountStep').classList.add('hidden');
            document.getElementById('gRegionsStep').classList.remove('hidden');
            this.initNewCounties(); // Re-init counties each time step 2 becomes visible
        } finally {
            if (nextBtn) {
                nextBtn.disabled = false;
                nextBtn.style.opacity = '';
                nextBtn.innerHTML = original || 'Next <i class="fa-solid fa-arrow-right"></i>';
            }
        }
    },
    async verifyNewGroupName() {
        const name  = document.getElementById('newGroupName').value.trim();
        const error = document.getElementById('newGroupNameError');
        if (!name) {
            error.textContent = 'Please enter a group name.';
            error.style.display = 'block';
            return false;
        }

        error.textContent = 'Verifying group name...';
        error.style.display = 'block';

        try {
            const res = await fetch(`/general/verify-group-name?groupName=${encodeURIComponent(name)}`, {
                headers: { 'Accept': 'application/json' },
                cache: 'no-store'
            });
            const result = await res.json();
            const exists = Boolean(result.exists);

            if (result.unavailable) {
                error.textContent = result.message || 'MongoDB verification is not available.';
                error.style.display = 'block';
                return false;
            }

            if (exists) {
                error.textContent = 'Group name exists. Please choose a different group name.';
                error.style.display = 'block';
                return false;
            }
            error.textContent = '';
            error.style.display = 'none';
            return true;
        } catch (e) {
            error.textContent = 'Could not verify group name. Please try again.';
            error.style.display = 'block';
            return false;
        }
    },
    clearNewGroupNameError() {
        const error = document.getElementById('newGroupNameError');
        if (error) {
            error.textContent = '';
            error.style.display = 'none';
        }
    },
    backToGroupForm() {
        document.getElementById('gRegionsStep').classList.add('hidden');
        document.getElementById('cAccountStep').classList.remove('hidden');
    },
    parseNewFullName() {
        const parts = document.getElementById('newFullNameInput').value.trim().split(/\s+/);
        document.getElementById('newFirstName').value  = parts[0] || '';
        document.getElementById('newSecondName').value = parts[1] || '';
        document.getElementById('newLastName').value   = parts.slice(2).join(' ') || '';
    },
    initNewCounties() {
        const sel = document.getElementById('newCountySelect');
        if (!sel) return;
        sel.innerHTML = '<option value="">⏳ Loading counties...</option>';
        fetch('/general/locations/counties')
            .then(r => { if (!r.ok) throw new Error('HTTP ' + r.status); return r.json(); })
            .then(list => {
                // Re-query inside callback to avoid stale reference if DOM was rebuilt
                const freshSel = document.getElementById('newCountySelect');
                if (!freshSel) return;
                freshSel.innerHTML = '<option value="">-- Select County --</option>';
                if (!Array.isArray(list) || list.length === 0) {
                    this.showToast('No counties found', 'error'); return;
                }
                list.forEach(county => {
                    const o = document.createElement('option');
                    o.value = county; o.textContent = county;
                    freshSel.appendChild(o);
                });
            })
            .catch(err => {
                const freshSel = document.getElementById('newCountySelect');
                if (freshSel) freshSel.innerHTML = '<option value="">-- Select County --</option>';
                this.showToast('Failed to load counties. Please try again.', 'error');
                console.error('[initNewCounties]', err);
            });
    },
    loadNewConstituencies() {
        const county = document.getElementById('newCountySelect').value;
        const cSel   = document.getElementById('newConstituencySelect');
        const wSel   = document.getElementById('newWardSelect');
        cSel.innerHTML = '<option value="">⏳ Loading...</option>';
        wSel.innerHTML = '<option value="">-- Select Ward --</option>';
        if (!county) { cSel.innerHTML = '<option value="">-- Select Constituency --</option>'; return; }
        fetch(`/general/locations/constituencies?county=${encodeURIComponent(county)}`)
            .then(r => { if (!r.ok) throw new Error('HTTP ' + r.status); return r.json(); })
            .then(list => {
                // Re-query inside callback to avoid stale reference
                const freshCSel = document.getElementById('newConstituencySelect');
                if (!freshCSel) return;
                freshCSel.innerHTML = '<option value="">-- Select Constituency --</option>';
                if (!Array.isArray(list) || list.length === 0) {
                    freshCSel.innerHTML += '<option disabled>No constituencies found</option>'; return;
                }
                list.forEach(c => {
                    const o = document.createElement('option');
                    o.value = c; o.textContent = c;
                    freshCSel.appendChild(o);
                });
            })
            .catch(err => {
                const freshCSel = document.getElementById('newConstituencySelect');
                if (freshCSel) freshCSel.innerHTML = '<option value="">-- Select Constituency --</option>';
                this.showToast('Failed to load constituencies.', 'error');
                console.error('[loadNewConstituencies]', err);
            });
    },
    loadNewWards() {
        const county       = document.getElementById('newCountySelect').value;
        const constituency = document.getElementById('newConstituencySelect').value;
        const wSel         = document.getElementById('newWardSelect');
        wSel.innerHTML = '<option value="">⏳ Loading...</option>';
        if (!county || !constituency) { wSel.innerHTML = '<option value="">-- Select Ward --</option>'; return; }
        fetch(`/general/locations/wards?county=${encodeURIComponent(county)}&constituency=${encodeURIComponent(constituency)}`)
            .then(r => { if (!r.ok) throw new Error('HTTP ' + r.status); return r.json(); })
            .then(list => {
                // Re-query inside callback to avoid stale reference
                const freshWSel = document.getElementById('newWardSelect');
                if (!freshWSel) return;
                freshWSel.innerHTML = '<option value="">-- Select Ward --</option>';
                if (!Array.isArray(list) || list.length === 0) {
                    const o = document.createElement('option');
                    o.value = ''; o.textContent = '(No Wards Listed)'; o.disabled = true;
                    freshWSel.appendChild(o); return;
                }
                list.sort().forEach(ward => {
                    const o = document.createElement('option');
                    o.value = ward; o.textContent = ward;
                    freshWSel.appendChild(o);
                });
            })
            .catch(err => {
                const freshWSel = document.getElementById('newWardSelect');
                if (freshWSel) freshWSel.innerHTML = '<option value="">-- Select Ward --</option>';
                this.showToast('Failed to load wards.', 'error');
                console.error('[loadNewWards]', err);
            });
    },
    async handleCreateGroupSubmit(event) {
        event.preventDefault();
        
        this.parseNewFullName();

        const wardSelect = document.getElementById('newWardSelect');
        if (wardSelect && wardSelect.value === 'OTHER') {
            const mw = prompt('Please enter your ward name:');
            if (!mw || !mw.trim()) { this.showToast('Please enter your ward name', 'error'); return false; }
            const o = document.createElement('option'); o.value = mw.trim(); o.text = mw.trim(); wardSelect.appendChild(o); wardSelect.value = mw.trim();
        }

        // ── Pin the submit button until MongoDB responds ──
        const submitBtn = document.getElementById('createGroupSubmitBtn');
        const originalHTML = submitBtn ? submitBtn.innerHTML : '';
        if (submitBtn) {
            submitBtn.disabled = true;
            submitBtn.style.opacity = '0.7';
            submitBtn.style.cursor = 'not-allowed';
            submitBtn.innerHTML = '<i class="fa-solid fa-circle-notch fa-spin"></i> Saving to database...';
        }

        const unlock = () => {
            if (submitBtn) {
                submitBtn.disabled = false;
                submitBtn.style.opacity = '';
                submitBtn.style.cursor = '';
                submitBtn.innerHTML = originalHTML || '<i class="fa-solid fa-check-circle"></i> Submit';
            }
        };

        const data = Object.fromEntries(new FormData(event.target).entries());
        try {
            const res    = await fetch('/general', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
            const result = await res.json();
            if (result.success) {
                // Keep button locked — navigating away
                if (submitBtn) {
                    submitBtn.innerHTML = '<i class="fa-solid fa-circle-check"></i> Saved!';
                    submitBtn.style.background = '#16a34a';
                }
                this.showToast('Group created successfully!', 'success');
                setTimeout(() => {
                    this.closeModal();
                    if (result.redirect) window.location.href = result.redirect;
                }, 900);
            } else {
                // Unlock so user can retry or correct input
                unlock();
                this.showToast(result.message || 'Failed to create group. Please try again.', 'error');
            }
        } catch (e) {
            unlock();
            this.showToast('Network error. Please check your connection and try again.', 'error');
            console.error('[handleCreateGroupSubmit]', e);
        }
        return false;
    },
    handleDealerClick() { if (!this.data.isDealer) { this.showToast('You are not registered as a dealer.', 'error'); return; } this.switchRole('Dealer'); },
    handleGeneralClick() { window.location.href = '/general'; },

