    openGroupLoanBalanceModal(groupName) {
        document.getElementById('modalOverlay').classList.add('open');
        this.updateModalContent('Loading Loan Details...', '<div style="text-align:center;padding:20px;"><i class="fa-solid fa-spinner fa-spin" style="font-size:24px;color:var(--primary);"></i></div>', null, 'fa-sack-dollar');
        
        fetch('/member/group-by-name', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ groupName })
        })
        .then(res => res.json())
        .then(group => {
            let closingBalance = 3500; // Premium fallback
            
            const normalize = (p) => {
                let s = String(p).trim().replace(/\D/g, '');
                if (s.startsWith('254')) s = '0' + s.substring(3);
                return s;
            };
            
            const loggedPhone = normalize(this.data.user.phoneNumber);
            if (group && group.members) {
                for (const phoneKey in group.members) {
                    if (normalize(phoneKey) === loggedPhone) {
                        const mData = group.members[phoneKey];
                        // Try to find a loan account (e.g. ID "003" or account containing "loan" or "latenes")
                        if (mData.accounts) {
                            for (const accId in mData.accounts) {
                                const accName = String(mData.accounts[accId].accountName).toLowerCase();
                                if (accName.includes('loan') || accName.includes('late')) {
                                    closingBalance = mData.accounts[accId].financials?.closingBalance || 0;
                                    break;
                                }
                            }
                        }
                        break;
                    }
                }
            }
            
            let html = `
