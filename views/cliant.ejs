    renderGeneralView(container) {
        const headerRole = document.getElementById('headerRole');
        if (headerRole) headerRole.innerHTML = '<i class="fas fa-piggy-bank"></i> My Saving Groups';

        const groups = this.data.userGroups || [];
        
        const phaseConfig = {
            1: { title: 'New Request', color: '#3b82f6', icon: 'fa-plus-circle', bg: '#eff6ff' },
            2: { title: 'Pending', color: '#f59e0b', icon: 'fa-clock', bg: '#fff7ed' },
            3: { title: 'Active', color: '#10b981', icon: 'fa-check-circle', bg: '#f0fdf4' }
        };

        if (groups.length === 0) {
            container.innerHTML = `
                <div style="text-align:center; padding:40px 20px; background:white; border-radius:20px; box-shadow:0 15px 35px rgba(0,0,0,0.1);">
                    <div style="width:70px; height:70px; background:#f1f5f9; color:#94a3b8; border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 20px; font-size:28px;">
