    onSourceChange(groupName) {
        const decodedGroupName = decodeURIComponent(groupName);
        const select = document.getElementById('sourceAccount');
        const index = select ? select.value : '';
        
        if (index !== '') {
            const accounts = this.data.groupAccounts || [];
            const acc = accounts[parseInt(index)];
            if (acc) {
                this.data.searchedAccount = acc;
                this.data.errorMessage = '';
            }
        } else {
            this.data.searchedAccount = null;
        }
        this.renderAccountForm(decodedGroupName);
    },
    addNextAccount(groupName) {
        const decodedGroupName = decodeURIComponent(groupName);
        const searchedAccount = this.data.searchedAccount;
        
        if (!searchedAccount) {
            this.data.errorMessage = 'Please select an account first';
            this.renderAccountForm(decodedGroupName);
            return;
        }
        
        if (!this.data.addedAccounts) this.data.addedAccounts = [];
        
        const amountInput = document.getElementById('accountAmount');
        const amount = amountInput ? amountInput.value : '0';
        
        this.data.addedAccounts.push({
            accountName: searchedAccount.accountName,
            accountNumber: searchedAccount.accountNumber,
            inputAmount: amount
        });
        
        this.data.searchedAccount = null;
        this.data.errorMessage = '';
        this.renderAccountForm(decodedGroupName);
    },
    removeAccount(index, groupName) {
        const decodedGroupName = decodeURIComponent(groupName);
        if (this.data.addedAccounts && this.data.addedAccounts[index]) {
            this.data.addedAccounts.splice(index, 1);
        }
        this.renderAccountForm(decodedGroupName);
    },
    confirmPayment(groupName) {
        const decodedGroupName = decodeURIComponent(groupName);
        const addedAccounts = this.data.addedAccounts || [];
        
        if (addedAccounts.length === 0) {
            this.data.errorMessage = 'Please add at least one account';
            this.renderAccountForm(decodedGroupName);
            return;
        }
        
        // Calculate total
        let total = 0;
        addedAccounts.forEach(acc => {
            total += parseFloat(acc.inputAmount) || 0;
        });
        
        let html = '<div style="text-align:left;">';
        
        // Payment details - inline display
        html += '<div style="background:linear-gradient(135deg,#1e293b,#334155);padding:15px;border-radius:12px;margin-bottom:15px;color:white;">';
        html += '<h3 style="margin:0 0 12px 0;color:white;font-size:14px;text-align:center;">PAYMENT DETAILS</h3>';
        
        // Show all added accounts - inline: number | name | amount
        addedAccounts.forEach(acc => {
            html += '<div style="display:flex;align-items:center;padding:10px;background:rgba(255,255,255,0.1);border-radius:8px;margin-bottom:8px;gap:10px;">';
            html += '<div style="flex:1;overflow:hidden;">';
            html += '<div style="font-weight:600;font-size:13px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">' + acc.accountName + '</div>';
            html += '<div style="font-size:11px;opacity:0.8;">' + acc.accountNumber + '</div>';
            html += '</div>';
            html += '<div style="color:#fbbf24;font-weight:600;font-size:13px;white-space:nowrap;">KSh ' + acc.inputAmount + '</div>';
            html += '</div>';
        });
        
        // Total inline
        html += '<div style="display:flex;justify-content:space-between;align-items:center;padding:12px;background:rgba(251,191,36,0.2);border-radius:6px;margin-top:10px;">';
        html += '<span style="font-weight:600;font-size:14px;">TOTAL</span>';
        html += '<span style="color:#fbbf24;font-weight:700;font-size:18px;">KSh ' + total.toLocaleString() + '</span>';
        html += '</div>';
        html += '</div>';
        
        // Payment buttons inline: tBank | M-Pesa
        html += '<div style="display:flex;gap:10px;margin-top:15px;">';
        html += '<button class="btn btn-primary" onclick="app.processPayment(\'tbank\')" style="flex:1;padding:12px;background-color:#10b981;"><i class="fa-solid fa-university"></i> tBank</button>';
        html += '<button class="btn btn-primary" onclick="app.processPayment(\'mpesa\')" style="flex:1;padding:12px;background-color:#22c55e;"><i class="fa-solid fa-mobile"></i> M-Pesa</button>';
        html += '</div>';
        
        if (this.data.sendMode === 'my') {
            html += '<button class="modal-list-btn" onclick="app.renderAccountForm(\'' + encodeURIComponent(decodedGroupName) + '\')" style="margin-top:10px;">Back</button></div>';
        } else {
            html += '<button class="modal-list-btn" onclick="app.showFinalPaymentOptions(\'' + encodeURIComponent(decodedGroupName) + '\')" style="margin-top:10px;">Back</button></div>';
        }
        
        this.updateModalContent('Verify Final Payment', html);
    },
    processPayment(method) {
        const methodName = method === 'tbank' ? 'tBank' : 'M-Pesa';
        this.updateModalContent('Under Construction',
            '<div style="text-align:center;padding:40px 20px;">' +
            '<i class="fa-solid fa-hard-hat" style="font-size:48px;color:var(--primary);margin-bottom:20px;"></i>' +
            '<h3 style="color:#1e293b;margin-bottom:10px;">Under Construction</h3>' +
