        // Trustees/Officials see group totals; members see only their own balance
        if (!isMemberOnly) {
            html += `
            <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;text-align:center;">
                <div style="background:rgba(255,255,255,0.15);border-radius:8px;padding:8px 4px;">
                    <div style="font-size:9px;opacity:0.8;font-weight:700;text-transform:uppercase;letter-spacing:.5px;">Total In</div>
                    <div style="font-size:13px;font-weight:800;margin-top:3px;">KSh ${Number(detail.totalIn).toLocaleString()}</div>
                </div>
                <div style="background:rgba(255,255,255,0.15);border-radius:8px;padding:8px 4px;">
