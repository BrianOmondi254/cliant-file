            html += '<span style="font-size:12px;opacity:0.9;white-space:nowrap;">Amount:</span>';
            html += '<input type="number" id="accountAmount" class="form-input" placeholder="0" inputmode="numeric" style="flex:1;padding:8px;font-size:14px;border:none;background:transparent;color:white;font-weight:600;text-align:right;">';
