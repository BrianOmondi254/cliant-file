                <div style="font-size:12px; opacity:0.8; text-transform:uppercase; letter-spacing:1px; margin-bottom:5px;">Grand Total</div>
                <div style="font-size:24px; font-weight:800; color:#fbbf24;">KSh ${totalSum.toLocaleString()}</div>
