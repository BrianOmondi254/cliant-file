                </div>
            `;
            return;
        }

        let html = '<div style="display:flex; flex-direction:column; gap:24px; padding-bottom:20px;">';

        [1, 2, 3].forEach(phase => {
            const filtered = groups.filter(g => {
                let p = parseInt(g.phase) || 0;
                const memberCount = parseInt(g.totalProposedMembers) || 0;
                
                // FORCE: If no members are populated, it is Phase 1 (New Request)
                if (memberCount === 0) p = 1;
                // FALLBACK: If phase is 0 or missing, it's Phase 1
                if (p === 0) p = 1; 
                
                return Number(p) === Number(phase);
            });
            if (filtered.length > 0) {
                const config = phaseConfig[phase];
                html += `
                    <div>
                        <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:12px; padding:0 5px;">
                            <h5 style="font-size:11.5px; color:${config.color}; text-transform:uppercase; letter-spacing:1.5px; font-weight:800; display:flex; align-items:center; gap:8px;">
