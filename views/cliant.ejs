            </div>
        `;
        this.updateModalContent('Verify Member A/C Number', html, () => this.sendToOtherMember(decodedGroupName));
    },
    showAddSeveralMembers(groupName) {
        const decodedGroupName = decodeURIComponent(groupName);
        const group = this.data.userGroups.find(g => g.groupName === decodedGroupName);
        if (!group) return;
        
        let totalGroupMembers = 0;
        for (const key in group) {
            if (key.startsWith('trustee_') || key.startsWith('official_') || key.startsWith('member_')) {
                totalGroupMembers++;
            }
        }

        let html = `
            <div style="text-align:left;">
                <p style="font-size:13px;color:#6b7280;margin-bottom:15px;">How many members do you wish to add? (Group Size: ${totalGroupMembers})</p>
                <div class="form-group">
                    <label class="form-label">Total Number of Members</label>
                    <input type="number" id="severalCountInput" class="form-input" min="1" max="${totalGroupMembers}" placeholder="e.g. 5">
                </div>
                <div id="severalError" style="color:#ef4444; font-size:12px; margin-bottom:10px;" class="hidden"></div>
                <button class="btn btn-primary" onclick="app.renderSeveralMemberInputs('${encodeURIComponent(decodedGroupName)}', ${totalGroupMembers})">Continue</button>
            </div>
        `;
        this.updateModalContent('Add Several Members', html, () => this.sendToOtherMember(decodedGroupName));
    },
    renderSeveralMemberInputs(groupName, max) {
        const decodedGroupName = decodeURIComponent(groupName);
        const input = document.getElementById('severalCountInput');
        const count = parseInt(input ? input.value : 0);
        const errorDiv = document.getElementById('severalError');
        
        if (isNaN(count) || count < 1 || count > max) {
            if (errorDiv) {
                errorDiv.innerText = `Please enter a valid number between 1 and ${max}.`;
                errorDiv.classList.remove('hidden');
            }
            return;
        }

        let html = '<div style="text-align:left; max-height:60vh; overflow-y:auto; padding-right:5px;">';
        html += `<p style="font-size:13px;color:#6b7280;margin-bottom:15px;">Enter A/C numbers for ${count} members:</p>`;
        
        for (let i = 1; i <= count; i++) {
            html += `
                <div class="form-group" style="margin-bottom:12px;">
                    <label class="form-label">Member ${i} A/C Number</label>
                    <input type="text" class="form-input several-member-input" data-index="${i}" placeholder="e.g. 7" inputmode="numeric">
                </div>
            `;
        }
        
        html += `
            <div id="severalVerifyError" style="color:#ef4444; font-size:12px; margin-bottom:10px;" class="hidden"></div>
            <button class="btn btn-primary" onclick="app.verifySeveralMembers('${encodeURIComponent(decodedGroupName)}')">Verify All Members</button>
        </div>`;
        this.updateModalContent(`Enter Details for ${count} Members`, html, () => this.showAddSeveralMembers(decodedGroupName));
    },
    verifySeveralMembers(groupName) {
        const decodedGroupName = decodeURIComponent(groupName);
        const inputs = document.querySelectorAll('.several-member-input');
        const indices = Array.from(inputs).map(i => i.value.trim()).filter(v => v !== '');
        const errorDiv = document.getElementById('severalVerifyError');
        
        if (indices.length < inputs.length) {
            if (errorDiv) { errorDiv.innerText = "Please fill in all account numbers."; errorDiv.classList.remove('hidden'); }
            return;
        }

        const uniqueIndices = new Set(indices);
        if (uniqueIndices.size !== indices.length) {
            if (errorDiv) { 
                errorDiv.innerText = "Each member account number must be unique."; 
                errorDiv.classList.remove('hidden'); 
            }
            return;
        }

        const group = this.data.userGroups.find(g => g.groupName === decodedGroupName);
        if (!group) return;

        let verifiedMembers = [];
        let errors = [];

        indices.forEach((index, idx) => {
            let foundName = null;
            for (const key in group) {
                if ((key.startsWith('trustee_') || key.startsWith('official_') || key.startsWith('member_')) && key.endsWith('_' + index)) {
                    foundName = group[key].name || "Member " + index;
                    break;
                }
            }
            if (foundName) verifiedMembers.push({ name: foundName, index: index });
            else errors.push(`A/C ${index} (Field ${idx + 1}) not found.`);
        });

        if (errors.length > 0) {
            if (errorDiv) { errorDiv.innerText = errors[0]; errorDiv.classList.remove('hidden'); }
            return;
        }

        this.data.isMultiMemberFlow = true;
        this.data.verifiedMembersList = verifiedMembers;
        this.data.settledMembersData = {}; 

        this.showSeveralMembersSummary(decodedGroupName, verifiedMembers);
    },
    showSeveralMembersSummary(groupName, members) {
        const decodedGroupName = decodeURIComponent(groupName);
        const settledCount = Object.keys(this.data.settledMembersData || {}).length;
        const totalCount = members.length;

        let html = '<div style="text-align:left;">';
        
        if (settledCount === totalCount) {
             this.renderFinalBulkSummary(decodedGroupName);
             return;
        }

        html += `<p style="font-size:13px;color:#6b7280;margin-bottom:15px;">Settle accounts for each member (${settledCount}/${totalCount} verified):</p>`;
        html += '<div style="display:flex; flex-direction:column; gap:8px; max-height:50vh; overflow-y:auto; padding-right:5px;">';
        
        members.forEach(m => {
            const isSettled = this.data.settledMembersData && this.data.settledMembersData[m.index];
            html += `
                <button class="modal-list-btn" onclick="app.selectOneMemberFromList('${encodeURIComponent(decodedGroupName)}', '${encodeURIComponent(m.name)}', '${m.index}')" 
                        style="text-align:left; padding:15px; display:flex; justify-content:space-between; align-items:center; background:${isSettled ? '#f0fdf4' : '#f8fafc'}; border:1px solid ${isSettled ? '#bcf0da' : '#e2e8f0'}; border-radius:12px; margin-bottom:0;">
                    <div>
                        <div style="font-weight:600; font-size:14px; color:${isSettled ? '#065f46' : '#1e293b'}; margin-bottom:2px;">${m.name}</div>
                        <div style="font-size:11px; color:#64748b;">Member A/C: ${m.index}</div>
                    </div>
                    <i class="fa-solid ${isSettled ? 'fa-circle-check' : 'fa-chevron-right'}" style="color:${isSettled ? '#10b981' : 'var(--primary)'}; font-size:12px;"></i>
                </button>
            `;
        });
        
        html += '</div></div>';
        this.updateModalContent('Select Recipient', html, () => this.showAddSeveralMembers(decodedGroupName));
    },
    selectOneMemberFromList(groupName, memberName, memberIndex) {
        const decodedGroupName = decodeURIComponent(groupName);
        const decodedMemberName = decodeURIComponent(memberName);
        this.data.recipientName = decodedMemberName;
        this.data.selectedMemberIndex = memberIndex;
        this.data.sendMode = 'other';
        const group = this.data.userGroups.find(g => g.groupName === decodedGroupName);
        const accounts = (group.principles && group.principles.otherContributions) ? group.principles.otherContributions : [];
        this.data.groupAccounts = accounts;
        this.data.addedAccounts = [];
        this.data.errorMessage = '';
        this.renderAccountForm(decodedGroupName);
    },
    toggleMemberCollapse(idx) {
        const target = document.getElementById(`collapse-${idx}`);
        const icon = document.getElementById(`chevron-${idx}`);
        if (target) {
            const isHidden = target.style.display === 'none';
            target.style.display = isHidden ? 'block' : 'none';
            if (icon) {
                icon.style.transform = isHidden ? 'rotate(180deg)' : 'rotate(0deg)';
                icon.style.color = isHidden ? 'var(--primary)' : '#cbd5e1';
            }
        }
    },
    removeAccountFromSummary(idx, groupName) {
        if (this.data.addedAccounts) {
            this.data.addedAccounts.splice(idx, 1);
            if (this.data.addedAccounts.length === 0) {
                this.renderAccountForm(decodeURIComponent(groupName));
            } else {
                this.showFinalPaymentSummary(decodeURIComponent(groupName));
            }
        }
    },
    removeBulkAccountFromSummary(memberIdx, accIdx, groupName) {
        if (this.data.settledMembersData && this.data.settledMembersData[memberIdx]) {
            this.data.settledMembersData[memberIdx].accounts.splice(accIdx, 1);
            if (this.data.settledMembersData[memberIdx].accounts.length === 0) {
                 delete this.data.settledMembersData[memberIdx];
            }
            if (Object.keys(this.data.settledMembersData).length === 0) {
                 this.showSeveralMembersSummary(decodeURIComponent(groupName), this.data.verifiedMembersList);
            } else {
                 this.renderFinalBulkSummary(decodeURIComponent(groupName));
            }
        }
    },
    removeFullMemberFromSummary(memberIdx, groupName) {
        if (this.data.settledMembersData && this.data.settledMembersData[memberIdx]) {
            delete this.data.settledMembersData[memberIdx];
            if (Object.keys(this.data.settledMembersData).length === 0) {
                 this.showSeveralMembersSummary(decodeURIComponent(groupName), this.data.verifiedMembersList);
            } else {
                 this.renderFinalBulkSummary(decodeURIComponent(groupName));
            }
        }
    },
    verifyMemberIndex(groupName) {
        const decodedGroupName = decodeURIComponent(groupName);
        const input = document.getElementById('memberIndexInput');
        const index = input ? input.value.trim() : '';
        const errorDiv = document.getElementById('memberVerifyError');
        if (errorDiv) errorDiv.classList.add('hidden');
        if (!index) {
            if (errorDiv) { errorDiv.innerText = "Please enter an account number"; errorDiv.classList.remove('hidden'); }
            return;
        }
        const group = this.data.userGroups.find(g => g.groupName === decodedGroupName);
        if (!group) return;
        let foundMemberName = null;
        for (const key in group) {
            if ((key.startsWith('trustee_') || key.startsWith('official_') || key.startsWith('member_')) && key.endsWith('_' + index)) {
                foundMemberName = group[key].name || "Member " + index;
                break;
            }
        }
        if (foundMemberName) {
            this.data.recipientName = foundMemberName;
            this.data.selectedMemberIndex = index;
            this.data.sendMode = 'other';
            this.data.isMultiMemberFlow = false;
            const accounts = (group.principles && group.principles.otherContributions) ? group.principles.otherContributions : [];
            this.data.groupAccounts = accounts;
            this.data.addedAccounts = [];
            this.data.errorMessage = '';
            this.renderAccountForm(decodedGroupName);
        } else {
            if (errorDiv) { errorDiv.innerText = "Account number " + index + " not found."; errorDiv.classList.remove('hidden'); }
        }
    },
    showToast(msg, type) {
        const toast = document.createElement('div');
        toast.className = 'toast ' + type;
        toast.innerHTML = '<i class="fa-solid fa-' + (type==='success'?'check-circle':'triangle-exclamation') + '"></i> <span>' + msg + '</span>';
        document.getElementById('toast-container').appendChild(toast);
        setTimeout(() => toast.remove(), 3000);
    },
    switchRole(r) {
        this.data.role = r;
        this.render();
    },
    updateNav() {
        const activeRole = this.data.role;
        const activeIndex = this.data.navLinks.indexOf(activeRole);
        const total = this.data.navLinks.length;
        if (activeIndex > -1) {
            this.moveIndicator(activeIndex, total);
        }
    },
    moveIndicator(index, total) {
        const indicator = document.getElementById('navIndicator');
        if (!indicator) return;
        const buttons = document.querySelectorAll('.top-nav .nav-btn');
        buttons.forEach(btn => btn.classList.remove('active'));
        if (buttons[index]) {
            buttons[index].classList.add('active');
        }
        const percentage = index * (100 / total);
        indicator.style.left = `${percentage}%`;
    },
    updateModalContent(title, html, backAction) { 
        document.getElementById('modalTitle').innerText = title; 
        document.getElementById('modalBody').innerHTML = html; 
        const backBtn = document.getElementById('modalBackBtn');
        if (backAction) {
            this.data.modalBackAction = backAction;
            if (backBtn) backBtn.classList.remove('hidden');
        } else {
            this.data.modalBackAction = null;
            if (backBtn) backBtn.classList.add('hidden');
        }
    },
    onModalBack() {
        if (this.data.modalBackAction) {
            if (typeof this.data.modalBackAction === 'function') {
                this.data.modalBackAction();
            } else if (typeof this.data.modalBackAction === 'string') {
                new Function(this.data.modalBackAction).call(this);
            }
        }
    }
};
document.addEventListener('DOMContentLoaded', () => app.init());
</script>
</body>
</html>
