                    <div style="text-align:right;flex-shrink:0;">
                        <div style="font-weight:800;font-size:14px;color:${style.color};">KSh ${Number(detail.totalBalance).toLocaleString()}</div>
                        ${showMemberStats ? `<div style="font-size:10px;color:#94a3b8;margin-top:2px;">${(detail.members||[]).length} member${(detail.members||[]).length!==1?'s':''}</div>` : `<div style="font-size:10px;color:#15803d;margin-top:2px;font-weight:600;">My Account</div>`}
