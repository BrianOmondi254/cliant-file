            { type: 'deposit',  acc: 'M-Pesa Deposit',   amt: 1200, date: '10:00 AM' },
            { type: 'withdraw', acc: 'Send Money',        amt: 350,  date: '09:30 AM' },
            { type: 'deposit',  acc: 'Receive Payment',  amt: 800,  date: '09:00 AM' },
            { type: 'withdraw', acc: 'Withdrawal',       amt: 500,  date: '08:45 AM' }
        ];
    },

    render() {
        const container = document.getElementById('mainContainer');
        const role = this.data.role;
        if      (role === 'Personal') this.renderPersonalView(container);
        else if (role === 'General')  this.renderGeneralView(container);
        else if (role === 'Dealer')   window.location.href = '/dealer';
        else if (role === 'Agent')    window.location.href = '/agent';
        this.updateNav();
        this.updateBadge();
    },

    /* ─── PERSONAL VIEW ─── */
    renderPersonalView(container) {
        const u = this.data.user;
        const hasPin = !!this.data.hasPersonalPin;
        const balanceAmount = Number(this.data.balance).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        const groups = this.data.userGroups || [];
        const activeCount = groups.filter(g => parseInt(g.phase) === 3).length;
        const pendingCount = groups.length - activeCount;

        let html = '';

        if (u && u.groupNotifications && u.groupNotifications.length > 0) {
            html += '<div class="group-notif" style="margin-top:14px;">';
            u.groupNotifications.forEach(n => {
                const bg = n.type === 'registration' ? '#dcfce7' : '#fef3c7';
                const border = n.type === 'registration' ? '#22c55e' : '#f59e0b';
                const icon   = n.type === 'registration' ? 'fa-check-circle' : 'fa-info-circle';
                html += `<div style="background:${bg};padding:12px 14px;border-radius:10px;margin-bottom:10px;border:1px solid ${border};border-left:4px solid ${border};">
                    <h4 style="color:#065f46;margin-bottom:6px;font-size:13px;font-weight:700;"><i class="fas ${icon}" style="color:${border};margin-right:6px;"></i>${n.groupName}</h4>
                    <div style="font-size:12px;color:#1e293b;line-height:1.5;">${n.message}</div>
                    <div style="font-size:10px;color:#64748b;margin-top:4px;">Role: ${n.role} | Index: ${n.index}</div>
                </div>`;
            });
            html += '</div>';
        }

        html += `<div style="background:white;border-radius:12px;box-shadow:var(--shadow-sm);border:1px solid #e2e8f0;overflow:hidden;margin-bottom:16px;">
            <div style="display:flex;align-items:center;justify-content:space-between;padding:14px 16px;">
                <div style="display:flex;align-items:center;gap:12px;">
                    <span style="font-size:16px;background:#efebe9;color:#5d4037;width:38px;height:38px;border-radius:50%;display:flex;align-items:center;justify-content:center;"><i class="fa-solid fa-wallet"></i></span>
                    <div style="text-align:left;">
                        <span style="display:block;font-size:13.5px;font-weight:700;color:var(--text-dark);">My Wallet</span>
                        <span style="display:block;font-size:10.5px;color:#64748b;margin-top:1px;">Available balance: <strong id="walletBalanceText" style="color:var(--primary);">KSh ${balanceAmount}</strong></span>
                    </div>
                </div>
                <span onclick="app.toggleHeaderBalance()" style="font-size: 13px; font-weight: 700; color: var(--primary); display: inline-flex; align-items: center; gap: 6px; cursor: pointer; background: white; padding: 4px 8px; border-radius: 20px; border: 1px solid #e2e8f0;">
                    <span id="headerBalanceValue" style="display: none;"></span>
                    <i id="headerBalanceEye" class="fa-solid fa-eye-slash" style="font-size: 12px; color: var(--text-light); padding: 2px;"></i>
                </span>
