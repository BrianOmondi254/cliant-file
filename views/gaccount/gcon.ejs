<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Group Account - <%= group ? group.groupName : 'Group' %></title>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    :root {
      --bg:        #f1f5f9;
      --surface:   #ffffff;
      --card:      #f8fafc;
      --border:    #e2e8f0;
      --primary:   #0f9d58;
      --primary-dk:#0b7d46;
      --accent:    #f59e0b;
      --text:      #1e293b;
      --muted:     #64748b;
      --faint:     #94a3b8;
      --radius:    14px;
      --radius-sm: 8px;
      --shadow:    0 4px 20px rgba(0,0,0,0.1);
      --focus-ring:rgba(15,157,88,0.15);
      --danger:    #ef4444;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'DM Sans', sans-serif;
      background: linear-gradient(160deg, #0f2027, #203a43, #2c5364);
      min-height: 100vh;
      font-size: 15px;
      display: flex;
      justify-content: center;
      align-items: flex-start;
      padding: 2px;
      color: var(--text);
    }

    .page-wrapper {
      width: calc(100% - 4px);
      max-width: 640px;
      background: var(--surface);
      border-radius: 5px;
      box-shadow: 0 25px 60px rgba(0,0,0,0.35);
      overflow: hidden;
      animation: slideUp .5s ease-out;
      min-height: calc(100vh - 4px);
      display: flex;
      flex-direction: column;
    }
    @keyframes slideUp {
      from { opacity: 0; transform: translateY(30px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .header {
      background: linear-gradient(135deg, #0f9d58, #34d399);
      padding: 16px 20px;
      display: flex;
      align-items: center;
      gap: 14px;
      position: sticky;
      top: 0;
      z-index: 200;
      overflow: hidden;
    }
    .header::before {
      content: '';
      position: absolute;
      top: -50%; right: -20%;
      width: 200px; height: 200px;
      background: rgba(255,255,255,.08);
      border-radius: 50%;
      pointer-events: none;
    }
    .header-back {
      width: 36px; height: 36px;
      border-radius: 50%;
      background: rgba(255,255,255,.18);
      border: 1px solid rgba(255,255,255,.3);
      display: flex; align-items: center; justify-content: center;
      color: #fff;
      text-decoration: none;
      font-size: 14px;
      flex-shrink: 0;
      transition: background .2s;
      position: relative;
    }
    .header-back:hover { background: rgba(255,255,255,.28); }
    .header-title {
      font-family: 'Syne', sans-serif;
      font-size: 17px;
      font-weight: 700;
      color: #fff;
      letter-spacing: -0.3px;
      position: relative;
    }
    .header-subtitle {
      font-size: 12px;
      color: rgba(255,255,255,.85);
      font-weight: 500;
      margin-top: 1px;
      position: relative;
    }
    .header-badge {
      margin-left: auto;
      background: rgba(255,255,255,.2);
      border: 1px solid rgba(255,255,255,.35);
      color: #fff;
      border-radius: 20px;
      padding: 4px 10px;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: .3px;
      position: relative;
      white-space: nowrap;
    }

    .content { padding: 20px; flex: 1; background: var(--bg); }

    .section-label {
      font-size: 10px;
      font-weight: 700;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 10px;
      margin-top: 22px;
    }

    .stats-grid {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 10px;
      margin-bottom: 18px;
    }
    .stat-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      padding: 12px;
      text-align: center;
    }
    .stat-label {
      font-size: 9px;
      font-weight: 600;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: .5px;
      margin-bottom: 4px;
    }
    .stat-value {
      font-family: 'Syne', sans-serif;
      font-size: 16px;
      font-weight: 700;
      color: var(--text);
    }
    .stat-value.green { color: var(--primary); }
    .stat-value.amber { color: var(--accent); }
    .stat-value.red { color: var(--danger); }

    .info-card {
      background: linear-gradient(135deg, #f0fdf4, #eff6ff);
      border-radius: var(--radius);
      padding: 16px;
      margin-bottom: 18px;
      position: relative;
      overflow: hidden;
      box-shadow: var(--shadow);
      border: 1px solid #bbf7d0;
    }
    .info-card::before {
      content: '';
      position: absolute;
      top: -30px; right: -30px;
      width: 120px; height: 120px;
      border-radius: 50%;
      background: rgba(15,157,88,.08);
      pointer-events: none;
    }
    .info-row {
      display: flex;
      justify-content: space-between;
      padding: 8px 0;
      border-bottom: 1px solid #e2e8f0;
      position: relative;
      z-index: 1;
    }
    .info-row:last-child { border-bottom: none; }
    .info-label {
      font-size: 12px;
      color: var(--muted);
      font-weight: 500;
    }
    .info-value {
      font-size: 12px;
      font-weight: 600;
      color: var(--text);
    }

    .contribution-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 14px;
      margin-bottom: 12px;
      display: flex;
      align-items: center;
      gap: 12px;
      cursor: pointer;
      transition: background .2s, border-color .2s, box-shadow .2s;
    }
    .contribution-card:hover {
      background: #f0fdf4;
      border-color: var(--primary);
      box-shadow: 0 2px 8px rgba(15,157,88,.12);
    }
    .contrib-icon {
      width: 40px; height: 40px;
      border-radius: var(--radius-sm);
      display: flex; align-items: center; justify-content: center;
      font-size: 16px;
      flex-shrink: 0;
    }
    .contrib-icon.savings { background: #dcfce7; color: #15803d; }
    .contrib-icon.shares { background: #dbeafe; color: #1d4ed8; }
    .contrib-icon.loan { background: #fee2e2; color: #b91c1c; }
    .contrib-icon.fines { background: #fef3c7; color: #b45309; }
    .contrib-details { flex: 1; min-width: 0; }
    .contrib-name {
      font-size: 14px;
      font-weight: 600;
      color: var(--text);
    }
    .contrib-amount {
      font-size: 12px;
      color: var(--muted);
      margin-top: 2px;
    }
    .contrib-status {
      font-size: 11px;
      font-weight: 700;
      padding: 3px 8px;
      border-radius: 20px;
      white-space: nowrap;
    }
    .status-active { background: #dcfce7; color: #15803d; }
    .status-pending { background: #fef9c3; color: #a16207; }

    .review-form {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 16px;
      margin-bottom: 16px;
    }
    .form-title {
      font-family: 'Syne', sans-serif;
      font-size: 14px;
      font-weight: 700;
      color: var(--text);
      margin-bottom: 14px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .form-title i { color: var(--primary); }

    .rating-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 10px 0;
      border-bottom: 1px solid #f1f5f9;
    }
    .rating-row:last-child { border-bottom: none; }
    .rating-label {
      font-size: 13px;
      color: var(--text);
      font-weight: 500;
    }
    .rating-stars {
      display: flex;
      gap: 4px;
    }
    .star {
      font-size: 16px;
      color: #e2e8f0;
      cursor: pointer;
      transition: color .15s;
    }
    .star.active { color: #f59e0b; }
    .star:hover { color: #f59e0b; }

    .textarea-field {
      width: 100%;
      padding: 12px 14px;
      background: var(--bg);
      border: 1.5px solid var(--border);
      border-radius: var(--radius-sm);
      color: var(--text);
      font-family: 'DM Sans', sans-serif;
      font-size: 13px;
      outline: none;
      transition: border-color .2s, box-shadow .2s;
      resize: none;
      margin-bottom: 12px;
    }
    .textarea-field:focus {
      border-color: var(--primary);
      box-shadow: 0 0 0 4px var(--focus-ring);
    }
    ::placeholder { color: var(--faint); }

    .submit-btn {
      width: 100%;
      padding: 13px;
      background: linear-gradient(135deg, #0f9d58, #34d399);
      color: #fff;
      border: none;
      border-radius: var(--radius-sm);
      font-family: 'Syne', sans-serif;
      font-size: 14px;
      font-weight: 700;
      cursor: pointer;
      transition: opacity .2s, transform .1s;
      letter-spacing: .3px;
    }
    .submit-btn:hover { opacity: .9; }
    .submit-btn:active { transform: scale(.98); }

    .tab-nav {
      display: flex;
      background: #f8fafc;
      border-bottom: 1px solid var(--border);
      margin-bottom: 16px;
    }
    .tab-btn {
      flex: 1;
      padding: 12px 8px;
      background: none;
      border: none;
      font-size: 12px;
      font-weight: 600;
      color: var(--muted);
      cursor: pointer;
      position: relative;
      transition: color .2s;
    }
    .tab-btn.active {
      color: var(--primary);
    }
    .tab-btn.active::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      width: 100%;
      height: 3px;
      background: var(--primary);
      border-radius: 3px 3px 0 0;
    }

    .tab-content {
      display: none;
    }
    .tab-content.active {
      display: block;
    }

    .member-select {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      padding: 12px;
      margin-bottom: 14px;
      cursor: pointer;
      transition: border-color .2s;
    }
    .member-select:hover {
      border-color: var(--primary);
    }
    .member-row {
      display: flex;
      justify-content: space-between;
      font-size: 13px;
    }
    .member-name {
      font-weight: 600;
      color: var(--text);
    }
    .member-index {
      color: var(--muted);
    }

    .empty-state {
      text-align: center;
      padding: 30px 20px;
      color: var(--faint);
    }
    .empty-state i {
      font-size: 32px;
      margin-bottom: 10px;
      display: block;
      color: #cbd5e1;
    }
    .empty-state p { font-size: 13px; }

    @media (max-width: 380px) {
      .stats-grid { grid-template-columns: 1fr 1fr; }
    }
  </style>
</head>
<body>
<div class="page-wrapper">
  
  <div class="header">
    <a href="/general/group/<%= encodeURIComponent(group ? group.groupName : '') %>" class="header-back">
      <i class="fas fa-arrow-left"></i>
    </a>
    <div>
      <div class="header-title">Group Account</div>
      <div class="header-subtitle"><%= group ? group.groupName : 'Group' %></div>
    </div>
    <div class="header-badge">
      <i class="fas fa-circle" style="font-size:7px; margin-right:4px;"></i>Active
    </div>
  </div>

  <div class="content">

    <div class="section-label">Group Overview</div>
    
    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-label">Members</div>
        <div class="stat-value" id="totalMembers"><%= membersCount || 0 %></div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Active Round</div>
        <div class="stat-value green">R-<%= activeRound || 1 %></div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Meetings</div>
        <div class="stat-value amber"><%= meetingsHeld || 0 %></div>
      </div>
    </div>

    <div class="section-label">Group Account Contributions</div>
    
    <div class="contribution-card" onclick="showContributionDetails('savings')">
      <div class="contrib-icon savings"><i class="fas fa-piggy-bank"></i></div>
      <div class="contrib-details">
        <div class="contrib-name">Group Savings</div>
        <div class="contrib-amount">KES <%= totalSavings ? totalSavings.toLocaleString() : '0' %></div>
      </div>
      <span class="contrib-status status-active">Active</span>
    </div>

    <div class="contribution-card" onclick="showContributionDetails('shares')">
      <div class="contrib-icon shares"><i class="fas fa-handshake"></i></div>
      <div class="contrib-details">
        <div class="contrib-name">Shares Capital</div>
        <div class="contrib-amount">KES <%= totalShares ? totalShares.toLocaleString() : '0' %></div>
      </div>
      <span class="contrib-status status-active">Active</span>
    </div>

    <div class="contribution-card" onclick="showContributionDetails('loan')">
      <div class="contrib-icon loan"><i class="fas fa-money-bill-wave"></i></div>
      <div class="contrib-details">
        <div class="contrib-name">Loan Disbursed</div>
        <div class="contrib-amount">KES <%= totalLoans ? totalLoans.toLocaleString() : '0' %></div>
      </div>
      <span class="contrib-status status-pending">Active</span>
    </div>

    <div class="contribution-card" onclick="showContributionDetails('fines')">
      <div class="contrib-icon fines"><i class="fas fa-gavel"></i></div>
      <div class="contrib-details">
        <div class="contrib-name">Fines & Penalties</div>
        <div class="contrib-amount">KES <%= totalFines ? totalFines.toLocaleString() : '0' %></div>
      </div>
      <span class="contrib-status status-pending">Pending</span>
    </div>

    <div class="section-label">Performance Review</div>

    <div class="tab-nav">
      <button class="tab-btn active" onclick="switchTab('member-review')">
        <i class="fas fa-user" style="margin-right:4px;"></i>Member
      </button>
      <button class="tab-btn" onclick="switchTab('group-review')">
        <i class="fas fa-users" style="margin-right:4px;"></i>Group
      </button>
    </div>

    <div id="member-review" class="tab-content active">
      <div class="review-form">
        <div class="form-title">
          <i class="fas fa-user-circle"></i>Member Performance Review
        </div>
        
        <div class="member-select" onclick="showMemberPicker()">
          <div class="member-row">
            <span class="member-name" id="selectedMemberName">Select Member</span>
            <span class="member-index" id="selectedMemberIndex">#—</span>
          </div>
        </div>

        <div class="rating-row">
          <span class="rating-label">Contribution Consistency</span>
          <div class="rating-stars" data-field="contributionRating">
            <i class="fas fa-star star" data-value="1" onclick="setRating(this, 1)"></i>
            <i class="fas fa-star star" data-value="2" onclick="setRating(this, 2)"></i>
            <i class="fas fa-star star" data-value="3" onclick="setRating(this, 3)"></i>
            <i class="fas fa-star star" data-value="4" onclick="setRating(this, 4)"></i>
            <i class="fas fa-star star" data-value="5" onclick="setRating(this, 5)"></i>
          </div>
        </div>

        <div class="rating-row">
          <span class="rating-label">Loan Repayment</span>
          <div class="rating-stars" data-field="loanRating">
            <i class="fas fa-star star" data-value="1" onclick="setRating(this, 1)"></i>
            <i class="fas fa-star star" data-value="2" onclick="setRating(this, 2)"></i>
            <i class="fas fa-star star" data-value="3" onclick="setRating(this, 3)"></i>
            <i class="fas fa-star star" data-value="4" onclick="setRating(this, 4)"></i>
            <i class="fas fa-star star" data-value="5" onclick="setRating(this, 5)"></i>
          </div>
        </div>

        <div class="rating-row">
          <span class="rating-label">Meeting Attendance</span>
          <div class="rating-stars" data-field="attendanceRating">
            <i class="fas fa-star star" data-value="1" onclick="setRating(this, 1)"></i>
            <i class="fas fa-star star" data-value="2" onclick="setRating(this, 2)"></i>
            <i class="fas fa-star star" data-value="3" onclick="setRating(this, 3)"></i>
            <i class="fas fa-star star" data-value="4" onclick="setRating(this, 4)"></i>
            <i class="fas fa-star star" data-value="5" onclick="setRating(this, 5)"></i>
          </div>
        </div>

        <div class="rating-row">
          <span class="rating-label">General Participation</span>
          <div class="rating-stars" data-field="participationRating">
            <i class="fas fa-star star" data-value="1" onclick="setRating(this, 1)"></i>
            <i class="fas fa-star star" data-value="2" onclick="setRating(this, 2)"></i>
            <i class="fas fa-star star" data-value="3" onclick="setRating(this, 3)"></i>
            <i class="fas fa-star star" data-value="4" onclick="setRating(this, 4)"></i>
            <i class="fas fa-star star" data-value="5" onclick="setRating(this, 5)"></i>
          </div>
        </div>

        <textarea class="textarea-field" id="memberReviewNotes" rows="3" placeholder="Additional comments or notes..."></textarea>

        <button class="submit-btn" onclick="submitMemberReview()">
          <i class="fas fa-check-circle" style="margin-right:6px;"></i>Submit Member Review
        </button>
      </div>
    </div>

    <div id="group-review" class="tab-content">
      <div class="review-form">
        <div class="form-title">
          <i class="fas fa-users"></i>Group Performance Review
        </div>

        <div class="rating-row">
          <span class="rating-label">Overall Contribution</span>
          <div class="rating-stars" data-field="groupContributionRating">
            <i class="fas fa-star star" data-value="1" onclick="setRating(this, 1)"></i>
            <i class="fas fa-star star" data-value="2" onclick="setRating(this, 2)"></i>
            <i class="fas fa-star star" data-value="3" onclick="setRating(this, 3)"></i>
            <i class="fas fa-star star" data-value="4" onclick="setRating(this, 4)"></i>
            <i class="fas fa-star star" data-value="5" onclick="setRating(this, 5)"></i>
          </div>
        </div>

        <div class="rating-row">
          <span class="rating-label">Loan Portfolio Quality</span>
          <div class="rating-stars" data-field="groupLoanRating">
            <i class="fas fa-star star" data-value="1" onclick="setRating(this, 1)"></i>
            <i class="fas fa-star star" data-value="2" onclick="setRating(this, 2)"></i>
            <i class="fas fa-star star" data-value="3" onclick="setRating(this, 3)"></i>
            <i class="fas fa-star star" data-value="4" onclick="setRating(this, 4)"></i>
            <i class="fas fa-star star" data-value="5" onclick="setRating(this, 5)"></i>
          </div>
        </div>

        <div class="rating-row">
          <span class="rating-label">Meeting Participation</span>
          <div class="rating-stars" data-field="groupMeetingRating">
            <i class="fas fa-star star" data-value="1" onclick="setRating(this, 1)"></i>
            <i class="fas fa-star star" data-value="2" onclick="setRating(this, 2)"></i>
            <i class="fas fa-star star" data-value="3" onclick="setRating(this, 3)"></i>
            <i class="fas fa-star star" data-value="4" onclick="setRating(this, 4)"></i>
            <i class="fas fa-star star" data-value="5" onclick="setRating(this, 5)"></i>
          </div>
        </div>

        <div class="rating-row">
          <span class="rating-label">Governance Compliance</span>
          <div class="rating-stars" data-field="groupGovernanceRating">
            <i class="fas fa-star star" data-value="1" onclick="setRating(this, 1)"></i>
            <i class="fas fa-star star" data-value="2" onclick="setRating(this, 2)"></i>
            <i class="fas fa-star star" data-value="3" onclick="setRating(this, 3)"></i>
            <i class="fas fa-star star" data-value="4" onclick="setRating(this, 4)"></i>
            <i class="fas fa-star star" data-value="5" onclick="setRating(this, 5)"></i>
          </div>
        </div>

        <textarea class="textarea-field" id="groupReviewNotes" rows="3" placeholder="Group observations and recommendations..."></textarea>

        <button class="submit-btn" onclick="submitGroupReview()">
          <i class="fas fa-check-circle" style="margin-right:6px;"></i>Submit Group Review
        </button>
      </div>
    </div>

  </div>

  <script>
    const groupName = '<%= group ? group.groupName : "" %>';
    let selectedMemberPhone = null;

    function switchTab(tabId) {
      document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
      document.querySelectorAll('.tab-content').forEach(content => content.classList.remove('active'));
      
      const btn = document.querySelector(`.tab-btn[onclick="switchTab('${tabId}')"]`);
      if (btn) btn.classList.add('active');
      document.getElementById(tabId).classList.add('active');
    }

    function setRating(starEl, value) {
      const container = starEl.parentElement;
      const field = container.dataset.field;
      const stars = container.querySelectorAll('.star');
      
      stars.forEach((star, idx) => {
        star.classList.toggle('active', idx < value);
      });
    }

    function getRating(field) {
      const container = document.querySelector(`.rating-stars[data-field="${field}"]`);
      if (!container) return 0;
      const activeStars = container.querySelectorAll('.star.active');
      return activeStars.length;
    }

    function showMemberPicker() {
      fetch('/member/group-by-name', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ groupName })
      })
      .then(res => res.json())
      .then(data => {
        if (!data || !data.members) {
          alert('No members found');
          return;
        }
        const members = Object.entries(data.members);
        if (members.length === 0) {
          alert('No members available');
          return;
        }
        
        let options = members.map(([phone, m], idx) => {
          const name = m.name || phone;
          const memberNum = m.memberNumber || (idx + 1);
          return `${memberNum}. ${name}`;
        }).join('\n');
        
        const choice = prompt('Select member number:\n' + options);
        if (choice) {
          const idx = parseInt(choice.split('.')[0]) - 1;
          if (idx >= 0 && idx < members.length) {
            selectedMemberPhone = members[idx][0];
            const member = members[idx][1];
            document.getElementById('selectedMemberName').textContent = member.name || member.memberId || selectedMemberPhone;
            document.getElementById('selectedMemberIndex').textContent = '#' + (member.memberNumber || (idx + 1));
          }
        }
      })
      .catch(err => {
        console.error(err);
        alert('Error loading members');
      });
    }

    function showContributionDetails(type) {
      const names = {
        savings: 'Group Savings Account',
        shares: 'Shares Capital Account',
        loan: 'Loan Portfolio',
        fines: 'Fines & Penalties'
      };
      alert('Viewing ' + names[type] + ' details');
    }

    function submitMemberReview() {
      if (!selectedMemberPhone) {
        alert('Please select a member first');
        return;
      }

      const review = {
        memberPhone: selectedMemberPhone,
        groupName: groupName,
        contributionRating: getRating('contributionRating'),
        loanRating: getRating('loanRating'),
        attendanceRating: getRating('attendanceRating'),
        participationRating: getRating('participationNote'),
        notes: document.getElementById('memberReviewNotes').value.trim()
      };

      console.log('Submitting member review:', review);
      alert('Member review submitted successfully!\n\nRatings:\n- Contribution: ' + review.contributionRating + '/5\n- Loan: ' + review.loanRating + '/5\n- Attendance: ' + review.attendanceRating + '/5');
    }

    function submitGroupReview() {
      const review = {
        groupName: groupName,
        groupContributionRating: getRating('groupContributionRating'),
        groupLoanRating: getRating('groupLoanRating'),
        groupMeetingRating: getRating('groupMeetingRating'),
        groupGovernanceRating: getRating('groupGovernanceRating'),
        notes: document.getElementById('groupReviewNotes').value.trim()
      };

      console.log('Submitting group review:', review);
      alert('Group review submitted successfully!\n\nRatings:\n- Overall Contribution: ' + review.groupContributionRating + '/5\n- Loan Portfolio: ' + review.groupLoanRating + '/5\n- Meetings: ' + review.groupMeetingRating + '/5\n- Governance: ' + review.groupGovernanceRating + '/5');
    }
  </script>
</div>
</body>
</html>