<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Membership - <%= group ? group.groupName : 'Group' %></title>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    :root {
      --bg:        #f1f5f9;
      --surface:   #ffffff;
      --card:      #f8fafc;
      --border:    #e2e8f0;
      --primary:   #0f9d58;
      --primary-dk:#0b7d46;
      --accent:    #f59e0b;
      --text:      #1e293b;
      --muted:     #64748b;
      --faint:     #94a3b8;
      --radius:    14px;
      --radius-sm: 8px;
      --shadow:    0 4px 20px rgba(0,0,0,0.1);
      --focus-ring:rgba(15,157,88,0.15);
      --danger:    #ef4444;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'DM Sans', sans-serif;
      background: linear-gradient(160deg, #0f2027, #203a43, #2c5364);
      min-height: 100vh;
      font-size: 15px;
      display: flex;
      justify-content: center;
      align-items: flex-start;
      padding: 2px;
      color: var(--text);
    }

    .page-wrapper {
      width: calc(100% - 4px);
      max-width: 640px;
      background: var(--surface);
      border-radius: 5px;
      box-shadow: 0 25px 60px rgba(0,0,0,0.35);
      overflow: hidden;
      animation: slideUp .5s ease-out;
      min-height: calc(100vh - 4px);
      display: flex;
      flex-direction: column;
    }
    @keyframes slideUp {
      from { opacity: 0; transform: translateY(30px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .header {
      background: linear-gradient(135deg, #0f9d58, #34d399);
      padding: 16px 20px;
      display: flex;
      align-items: center;
      gap: 14px;
      position: sticky;
      top: 0;
      z-index: 200;
      overflow: hidden;
    }
    .header::before {
      content: '';
      position: absolute;
      top: -50%; right: -20%;
      width: 200px; height: 200px;
      background: rgba(255,255,255,.08);
      border-radius: 50%;
      pointer-events: none;
    }
    .header-back {
      width: 36px; height: 36px;
      border-radius: 50%;
      background: rgba(255,255,255,.18);
      border: 1px solid rgba(255,255,255,.3);
      display: flex; align-items: center; justify-content: center;
      color: #fff;
      text-decoration: none;
      font-size: 14px;
      flex-shrink: 0;
      transition: background .2s;
      position: relative;
    }
    .header-back:hover { background: rgba(255,255,255,.28); }
    .header-title {
      font-family: 'Syne', sans-serif;
      font-size: 17px;
      font-weight: 700;
      color: #fff;
      letter-spacing: -0.3px;
      position: relative;
    }
    .header-subtitle {
      font-size: 12px;
      color: rgba(255,255,255,.85);
      font-weight: 500;
      margin-top: 1px;
      position: relative;
    }
    .header-badge {
      margin-left: auto;
      background: rgba(255,255,255,.2);
      border: 1px solid rgba(255,255,255,.35);
      color: #fff;
      border-radius: 20px;
      padding: 4px 10px;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: .3px;
      position: relative;
      white-space: nowrap;
    }

    .content { padding: 20px; flex: 1; background: var(--bg); }

    .stats-grid {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 10px;
      margin-bottom: 20px;
    }
    .stat-card {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      padding: 14px 12px;
      text-align: center;
    }
    .stat-value {
      font-family: 'Syne', sans-serif;
      font-size: 20px;
      font-weight: 800;
      color: var(--primary);
    }
    .stat-label {
      font-size: 10px;
      font-weight: 600;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: .5px;
      margin-top: 4px;
    }

    .section-label {
      font-size: 10px;
      font-weight: 700;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 10px;
    }

    .member-card {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 14px;
      background: #fff;
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      margin-bottom: 10px;
      transition: border-color .2s, background .2s;
      cursor: pointer;
    }
    .member-card:hover { background: #f0fdf4; border-color: #86efac; }
    .member-avatar {
      width: 44px; height: 44px;
      border-radius: 50%;
      background: linear-gradient(135deg, #0f9d58, #34d399);
      display: flex; align-items: center; justify-content: center;
      font-family: 'Syne', sans-serif;
      font-size: 16px;
      font-weight: 800;
      color: #fff;
      flex-shrink: 0;
    }
    .member-info { flex: 1; min-width: 0; }
    .member-name {
      font-size: 14px;
      font-weight: 700;
      color: var(--text);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .member-phone {
      font-size: 12px;
      color: var(--muted);
      margin-top: 2px;
    }
    .role-chip {
      font-size: 10px;
      font-weight: 700;
      padding: 4px 10px;
      border-radius: 20px;
      letter-spacing: .3px;
      white-space: nowrap;
    }
    .chip-green  { background: #dcfce7; color: #15803d;  border: 1px solid #86efac; }
    .chip-blue   { background: #dbeafe; color: #1d4ed8;  border: 1px solid #93c5fd; }
    .chip-amber  { background: #fef3c7; color: #b45309;  border: 1px solid #fcd34d; }
    .chip-violet { background: #ede9fe; color: #6d28d9;  border: 1px solid #c4b5fd; }
    .chip-gray   { background: #f1f5f9; color: #64748b;  border: 1px solid #e2e8f0; }

    .action-btn {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 14px 16px;
      background: #fff;
      border: 1.5px solid var(--border);
      border-radius: var(--radius);
      color: var(--text);
      cursor: pointer;
      text-align: left;
      transition: background .2s, border-color .2s;
      font-family: 'DM Sans', sans-serif;
      font-size: 13px;
      font-weight: 600;
      text-decoration: none;
      width: 100%;
    }
    .action-btn:hover {
      background: #f0fdf4;
      border-color: var(--primary);
    }
    .btn-icon {
      width: 34px; height: 34px;
      border-radius: var(--radius-sm);
      display: flex; align-items: center; justify-content: center;
      font-size: 14px;
      flex-shrink: 0;
    }
    .btn-icon.green  { background: #dcfce7; color: #15803d; }
    .btn-icon.blue   { background: #dbeafe; color: #1d4ed8; }
    .btn-icon.amber  { background: #fef3c7; color: #b45309; }
    .btn-icon.violet { background: #ede9fe; color: #6d28d9; }
    .btn-text { flex: 1; }
    .btn-label { display: block; font-weight: 600; }
    .btn-hint  { display: block; font-size: 11px; font-weight: 400; color: var(--muted); margin-top: 2px; }
    .btn-arrow { color: var(--faint); font-size: 12px; }

    .empty-state {
      text-align: center;
      padding: 40px 20px;
      color: var(--faint);
    }
    .empty-state i { font-size: 40px; margin-bottom: 12px; display: block; color: #cbd5e1; }
    .empty-state p { font-size: 14px; }

    /* Overlay Modal */
    .overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,.55);
      z-index: 1000;
      overflow-y: auto;
      padding: 20px;
      backdrop-filter: blur(3px);
    }
    .overlay.open { display: flex; align-items: center; justify-content: center; }

    .modal {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 12px;
      width: 100%;
      max-width: 460px;
      box-shadow: 0 20px 60px rgba(0,0,0,.25);
      animation: slideUp .25s ease;
    }
    @keyframes slideUp {
      from { opacity: 0; transform: translateY(24px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .modal-header {
      background: linear-gradient(135deg, #0f9d58, #34d399);
      padding: 14px 18px;
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .modal-header-icon {
      width: 30px; height: 30px;
      border-radius: var(--radius-sm);
      display: flex; align-items: center; justify-content: center;
      font-size: 13px;
      background: rgba(255,255,255,.2);
      color: #fff;
    }
    .modal-title {
      font-family: 'Syne', sans-serif;
      font-size: 15px;
      font-weight: 700;
      flex: 1;
      color: #fff;
    }
    .modal-close {
      background: rgba(255,255,255,.2);
      border: none;
      color: #fff;
      width: 28px; height: 28px;
      border-radius: 50%;
      cursor: pointer;
      font-size: 15px;
      display: flex; align-items: center; justify-content: center;
    }

    .modal-body { padding: 18px; max-height: 70vh; overflow-y: auto; }

    .field { margin-bottom: 14px; }
    .field label {
      display: block;
      font-size: 11px;
      font-weight: 700;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: .5px;
      margin-bottom: 6px;
    }
    .field input,
    .field select {
      width: 100%;
      padding: 12px 14px;
      background: #fff;
      border: 1.5px solid var(--border);
      border-radius: var(--radius-sm);
      color: var(--text);
      font-family: 'DM Sans', sans-serif;
      font-size: 14px;
      outline: none;
    }
    .field input:focus,
    .field select:focus {
      border-color: var(--primary);
      box-shadow: 0 0 0 4px var(--focus-ring);
    }

    .submit-btn {
      width: 100%;
      padding: 13px;
      background: linear-gradient(135deg, #0f9d58, #34d399);
      color: #fff;
      border: none;
      border-radius: var(--radius-sm);
      font-family: 'Syne', sans-serif;
      font-size: 14px;
      font-weight: 700;
      cursor: pointer;
      letter-spacing: .3px;
    }
    .submit-btn:hover { opacity: .9; }

    @media (max-width: 380px) {
      .stats-grid { grid-template-columns: 1fr 1fr; }
    }
  </style>
</head>
<body>
<div class="page-wrapper">
  
  <div class="header">
    <a href="/member/gcon?groupName=<%= encodeURIComponent(group.groupName) %>" class="header-back">
      <i class="fas fa-arrow-left"></i>
    </a>
    <div>
      <div class="header-title">Group Members</div>
      <div class="header-subtitle"><%= group.groupName %></div>
    </div>
    <div class="header-badge"><i class="fas fa-circle" style="font-size:7px; margin-right:4px;"></i><%= members.length %></div>
  </div>
    
  <div class="content">
    
    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-value"><%= members.length %></div>
        <div class="stat-label">Members</div>
      </div>
      <div class="stat-card">
        <div class="stat-value"><%= members.filter(m => m.role === 'official').length %></div>
        <div class="stat-label">Officials</div>
      </div>
      <div class="stat-card">
        <div class="stat-value"><%= members.filter(m => m.role === 'trustee').length %></div>
        <div class="stat-label">Trustees</div>
      </div>
    </div>

    <div class="section-label">Quick Actions</div>
    <button class="action-btn" onclick="showPendingRequestsModal()" style="margin-bottom: 14px;">
      <div class="btn-icon amber"><i class="fas fa-clock"></i></div>
      <div class="btn-text">
        <span class="btn-label">Approve Membership Requests</span>
        <span class="btn-hint">Review and approve member join requests</span>
      </div>
      <i class="fas fa-chevron-right btn-arrow"></i>
    </button>

    <button class="action-btn" onclick="showViewMembersModal()" style="margin-bottom: 14px;">
      <div class="btn-icon blue"><i class="fas fa-users"></i></div>
      <div class="btn-text">
        <span class="btn-label">View All Members</span>
        <span class="btn-hint">Browse full member list</span>
      </div>
      <i class="fas fa-chevron-right btn-arrow"></i>
    </button>

    <button class="action-btn" onclick="showPendingRequestsModal()" style="margin-bottom: 14px;">
      <div class="btn-icon amber"><i class="fas fa-clock"></i></div>
      <div class="btn-text">
        <span class="btn-label">Approve Membership Requests</span>
        <span class="btn-hint">Review and approve member join requests</span>
      </div>
      <i class="fas fa-chevron-right btn-arrow"></i>
    </button>

    <button class="action-btn" onclick="showRoleChangeModal()">
      <div class="btn-icon violet"><i class="fas fa-user-tie"></i></div>
      <div class="btn-text">
        <span class="btn-label">Appoint Official/Trustee</span>
        <span class="btn-hint">Promote member to official or trustee</span>
      </div>
      <i class="fas fa-chevron-right btn-arrow"></i>
    </button>

    <div style="margin-top: 20px;">
      <div class="section-label">Recent Members</div>
      <% if (members && members.length > 0) { %>
        <% members.slice(0, 5).forEach((member, idx) => { %>
          <% 
            const roleClass = member.role === 'official' ? 'chip-blue' : (member.role === 'trustee' ? 'chip-green' : (member.role === 'secretary' ? 'chip-violet' : 'chip-gray'));
            const initials = member.name ? member.name.split(' ').map(n => n[0]).join('').substring(0,2).toUpperCase() : '?';
          %>
          <div class="member-card" onclick="viewMemberDetails('<%= member.phone %>')">
            <div class="member-avatar"><%= initials %></div>
            <div class="member-info">
              <div class="member-name"><%= member.name %></div>
              <div class="member-phone"><%= member.phone %></div>
            </div>
            <span class="role-chip <%= roleClass %>"><%= member.role %></span>
          </div>
        <% }); %>
      <% } else { %>
        <div class="empty-state">
          <i class="fas fa-users"></i>
          <p>No members found</p>
        </div>
      <% } %>
    </div>

   </div>

   <!-- VIEW MEMBERS MODAL -->
  <div id="viewMembersOverlay" class="overlay">
    <div class="modal">
      <div class="modal-header">
        <div class="modal-header-icon btn-icon blue"><i class="fas fa-users"></i></div>
        <div class="modal-title">All Members</div>
        <button class="modal-close" onclick="closeModal('viewMembersOverlay')">
          <i class="fas fa-times"></i>
        </button>
      </div>
      <div class="modal-body" id="membersListContainer">
        <!-- Populated by JS -->
      </div>
    </div>
  </div>

</div>

<script>
  const groupName = <%- JSON.stringify(group.groupName) %>;
  const members = <%- JSON.stringify(members) %>;

  function closeModal(id) {
    const el = document.getElementById(id);
    if (el) el.classList.remove('open');
  }

  document.querySelectorAll('.overlay').forEach(el => {
    el.addEventListener('click', e => { if (e.target === el) el.classList.remove('open'); });
  });

  function getRoleClass(role) {
    if (role === 'official') return 'chip-blue';
    if (role === 'trustee') return 'chip-green';
    if (role === 'secretary') return 'chip-violet';
    return 'chip-gray';
  }

  function getInitials(name) {
    if (!name) return '?';
    return name.split(' ').map(n => n[0]).join('').substring(0, 2).toUpperCase();
  }

  function showViewMembersModal() {
    const container = document.getElementById('membersListContainer');
    if (members.length === 0) {
      container.innerHTML = '<div class="empty-state"><i class="fas fa-users"></i><p>No members found</p></div>';
    } else {
      container.innerHTML = members.map((m, i) => {
        const roleClass = getRoleClass(m.role);
        const initials = getInitials(m.name);
        return '<div class="member-card" style="cursor:pointer;" onclick="viewMemberDetails(\'' + m.phone + '\')">' +
          '<div class="member-avatar">' + initials + '</div>' +
          '<div class="member-info">' +
            '<div class="member-name">' + m.name + '</div>' +
            '<div class="member-phone">' + m.phone + '</div>' +
          '</div>' +
          '<span class="role-chip ' + roleClass + '">' + m.role + '</span>' +
        '</div>';
      }).join('');
    }
     document.getElementById('viewMembersOverlay').classList.add('open');
   }

   function viewMemberDetails(phone) {
    window.location.href = '/member/membership?groupName=' + encodeURIComponent(groupName) + '&memberPhone=' + encodeURIComponent(phone);
  }

  // PENDING REQUESTS MODAL
  async function showPendingRequestsModal() {
    document.getElementById('pendingRequestsOverlay').classList.add('open');
    loadPendingRequests();
  }

  async function loadPendingRequests() {
    const container = document.getElementById('pendingRequestsList');
    container.innerHTML = '<div class="empty-state"><i class="fas fa-spinner fa-spin"></i><p>Loading requests...</p></div>';
    
    try {
      const res = await fetch('/member/member-requests?groupName=' + encodeURIComponent(groupName));
      const data = await res.json();
      
      if (!data.success) {
        container.innerHTML = '<div class="empty-state"><i class="fas fa-exclamation-circle"></i><p>' + (data.error || 'No requests found') + '</p></div>';
        return;
      }
      
      const addRequests = data.requests.addMember || [];
      const roleRequests = data.requests.roleChange || [];
      
      if (addRequests.length === 0 && roleRequests.length === 0) {
        container.innerHTML = '<div class="empty-state"><i class="fas fa-check-circle"></i><p>No pending requests</p></div>';
        return;
      }
      
      let html = '';
      
      // Add Member Requests
      if (addRequests.length > 0) {
        html += '<div style="font-size:11px; font-weight:700; color:#0f9d58; text-transform:uppercase; margin-bottom:10px; padding-bottom:6px; border-bottom:1px solid #e2e8f0;">Add Member Requests</div>';
        html += addRequests.map(req => {
          const initials = getInitials(req.newMemberName);
          const date = new Date(req.createdAt).toLocaleDateString();
          return '<div class="member-card" style="flex-direction:column; align-items:flex-start; gap:8px; margin-bottom:12px;">' +
            '<div style="display:flex; align-items:center; gap:10px; width:100%;">' +
              '<div class="member-avatar" style="width:38px; height:38px; font-size:14px;">' + initials + '</div>' +
              '<div class="member-info" style="flex:1;">' +
                '<div class="member-name">' + req.newMemberName + '</div>' +
                '<div class="member-phone">' + req.newMemberPhone + '</div>' +
                '<div style="font-size:10px; color:#64748b; margin-top:2px;">Requested: ' + date + '</div>' +
              '</div>' +
            '</div>' +
            '<div style="font-size:12px; color:#334155; background:#eff6ff; padding:8px; border-radius:6px; width:100%;">' +
              '<div><strong>Requester:</strong> ' + (req.requesterName || 'Unknown') + '</div>' +
              '<div><strong>Requester Phone:</strong> ' + (req.requesterPhone || '—') + '</div>' +
              '<div><strong>Requester Index:</strong> ' + (req.requesterMemberIndex || '—') + '</div>' +
              '<div><strong>Requester Member No:</strong> ' + (req.requesterMemberNumber || '—') + '</div>' +
            '</div>' +
            (req.reason ? '<div style="font-size:12px; color:#64748b; background:#f8fafc; padding:8px; border-radius:6px; width:100%;"><i class="fas fa-comment" style="margin-right:6px;"></i>' + req.reason + '</div>' : '') +
            '<div style="display:flex; gap:8px; width:100%; margin-top:4px;">' +
              '<button class="submit-btn" style="flex:1; background:#0f9d58;" onclick="approveRequest(\'' + req.id + '\')"><i class="fas fa-check"></i> Approve</button>' +
              '<button class="submit-btn" style="flex:1; background:#ef4444;" onclick="rejectRequest(\'' + req.id + '\')"><i class="fas fa-times"></i> Reject</button>' +
            '</div>' +
          '</div>';
        }).join('');
      }
      
      // Role Change Requests
      if (roleRequests.length > 0) {
        html += '<div style="font-size:11px; font-weight:700; color:#7c3aed; text-transform:uppercase; margin:16px 0 10px 0; padding-bottom:6px; border-bottom:1px solid #e2e8f0;">Official/Trustee Requests</div>';
        html += roleRequests.map(req => {
          const initials = getInitials(req.targetMemberName);
          const date = new Date(req.createdAt).toLocaleDateString();
          return '<div class="member-card" style="flex-direction:column; align-items:flex-start; gap:8px; margin-bottom:12px;">' +
            '<div style="display:flex; align-items:center; gap:10px; width:100%;">' +
              '<div class="member-avatar" style="width:38px; height:38px; font-size:14px; background:linear-gradient(135deg, #7c3aed, #a78bfa);">' + initials + '</div>' +
              '<div class="member-info" style="flex:1;">' +
                '<div class="member-name">' + req.targetMemberName + '</div>' +
                '<div class="member-phone">' + req.targetMemberPhone + '</div>' +
                '<div style="font-size:11px; margin-top:4px;"><span class="chip-gray" style="padding:2px 8px; border-radius:10px; font-size:10px; background:#e2e8f0; color:#64748b;">' + req.currentRole + '</span> <i class="fas fa-arrow-right" style="font-size:9px; margin:0 4px;"></i> <span class="chip-violet" style="padding:2px 8px; border-radius:10px; font-size:10px; background:#ede9fe; color:#6d28d9;">' + req.newRole + '</span></div>' +
                '<div style="font-size:10px; color:#64748b; margin-top:2px;">Requested: ' + date + '</div>' +
              '</div>' +
            '</div>' +
            (req.reason ? '<div style="font-size:12px; color:#64748b; background:#f8fafc; padding:8px; border-radius:6px; width:100%;"><i class="fas fa-comment" style="margin-right:6px;"></i>' + req.reason + '</div>' : '') +
            '<div style="display:flex; gap:8px; width:100%; margin-top:4px;">' +
              '<button class="submit-btn" style="flex:1; background:#0f9d58;" onclick="approveRoleRequest(\'' + req.id + '\')"><i class="fas fa-check"></i> Approve</button>' +
              '<button class="submit-btn" style="flex:1; background:#ef4444;" onclick="rejectRoleRequest(\'' + req.id + '\')"><i class="fas fa-times"></i> Reject</button>' +
            '</div>' +
          '</div>';
        }).join('');
      }
      
      container.innerHTML = html;
      
    } catch (err) {
      container.innerHTML = '<div class="empty-state"><i class="fas fa-exclamation-circle"></i><p>Error loading requests</p></div>';
    }
  }

  async function approveRequest(requestId) {
    if (!confirm('Are you sure you want to approve this member request?')) return;
    
    try {
      const res = await fetch('/member/approve-member-request', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ groupName, requestId, action: 'approve' })
      });
      const data = await res.json();
      if (data.success) {
        alert('Member request approved successfully!');
        loadPendingRequests();
        window.location.reload();
      } else {
        alert('Error: ' + (data.error || 'Failed to approve request'));
      }
    } catch (err) {
      alert('Error: ' + err.message);
    }
  }

  async function rejectRequest(requestId) {
    if (!confirm('Are you sure you want to reject this member request?')) return;
    
    try {
      const res = await fetch('/member/approve-member-request', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ groupName, requestId, action: 'reject' })
      });
      const data = await res.json();
      if (data.success) {
        alert('Member request rejected.');
        loadPendingRequests();
      } else {
        alert('Error: ' + (data.error || 'Failed to reject request'));
      }
    } catch (err) {
      alert('Error: ' + err.message);
    }
  }

  // ROLE CHANGE MODAL
  async function showRoleChangeModal() {
    document.getElementById('roleChangeOverlay').classList.add('open');
  }

  async function submitRoleChangeRequest() {
    const targetPhone = document.getElementById('roleChangeMember').value;
    const newRole = document.getElementById('newRoleSelect').value;
    const reason = document.getElementById('roleChangeReason').value.trim();
    
    if (!targetPhone) { alert('Please select a member'); return; }
    if (!newRole) { alert('Please select a role'); return; }
    
    try {
      const res = await fetch('/member/request-role-change', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ 
          groupName, 
          targetMemberPhone: targetPhone, 
          newRole: newRole, 
          reason: reason 
        })
      });
      const data = await res.json();
      if (data.success) {
        alert('Request submitted! The official/trustee appointment will be reviewed for approval.');
        closeModal('roleChangeOverlay');
        document.getElementById('roleChangeMember').value = '';
        document.getElementById('newRoleSelect').value = '';
        document.getElementById('roleChangeReason').value = '';
      } else {
        alert('Error: ' + (data.error || 'Failed to submit request'));
      }
    } catch (err) {
      alert('Error: ' + err.message);
    }
  }

  async function approveRoleRequest(requestId) {
    if (!confirm('Are you sure you want to approve this role change?')) return;
    
    try {
      const res = await fetch('/member/approve-role-change', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ groupName, requestId, action: 'approve' })
      });
      const data = await res.json();
      if (data.success) {
        alert('Role change approved successfully!');
        loadPendingRequests();
        window.location.reload();
      } else {
        alert('Error: ' + (data.error || 'Failed to approve request'));
      }
    } catch (err) {
      alert('Error: ' + err.message);
    }
  }

  async function rejectRoleRequest(requestId) {
    if (!confirm('Are you sure you want to reject this role change?')) return;
    
    try {
      const res = await fetch('/member/approve-role-change', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ groupName, requestId, action: 'reject' })
      });
      const data = await res.json();
      if (data.success) {
        alert('Role change rejected.');
        loadPendingRequests();
      } else {
        alert('Error: ' + (data.error || 'Failed to reject request'));
      }
    } catch (err) {
      alert('Error: ' + err.message);
    }
  }
</script>

<!-- PENDING REQUESTS MODAL -->
<div id="pendingRequestsOverlay" class="overlay">
  <div class="modal">
    <div class="modal-header" style="background: linear-gradient(135deg, #f59e0b, #fbbf24);">
      <div class="modal-header-icon btn-icon amber"><i class="fas fa-clock"></i></div>
      <div class="modal-title">Pending Requests</div>
      <button class="modal-close" onclick="closeModal('pendingRequestsOverlay')">
        <i class="fas fa-times"></i>
      </button>
    </div>
    <div class="modal-body" id="pendingRequestsList">
      <div class="empty-state"><i class="fas fa-spinner fa-spin"></i><p>Loading...</p></div>
    </div>
  </div>
</div>

<!-- ROLE CHANGE MODAL -->
<div id="roleChangeOverlay" class="overlay">
  <div class="modal">
    <div class="modal-header" style="background: linear-gradient(135deg, #7c3aed, #a78bfa);">
      <div class="modal-header-icon btn-icon violet"><i class="fas fa-user-tie"></i></div>
      <div class="modal-title">Appoint Official/Trustee</div>
      <button class="modal-close" onclick="closeModal('roleChangeOverlay')">
        <i class="fas fa-times"></i>
      </button>
    </div>
    <div class="modal-body">
      <div class="field">
        <label>Select Member</label>
        <select id="roleChangeMember">
          <option value="">-- Select Member --</option>
          <% members.forEach(m => { %>
            <option value="<%= m.phone %>"><%= m.name %> (<%= m.role %>)</option>
          <% }); %>
        </select>
      </div>
      <div class="field">
        <label>New Role</label>
        <select id="newRoleSelect">
          <option value="">-- Select Role --</option>
          <option value="official">Official</option>
          <option value="trustee">Trustee</option>
          <option value="secretary">Secretary</option>
          <option value="member">Member (Remove Role)</option>
        </select>
      </div>
      <div class="field">
        <label>Reason (Optional)</label>
        <input type="text" id="roleChangeReason" placeholder="Enter reason for role change">
      </div>
      <button class="submit-btn" style="background: linear-gradient(135deg, #7c3aed, #a78bfa);" onclick="submitRoleChangeRequest()">
        <i class="fas fa-paper-plane" style="margin-right:8px;"></i>Submit Request
      </button>
    </div>
  </div>
</div>
</body>
</html>